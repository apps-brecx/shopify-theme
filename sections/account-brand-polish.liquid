  html body .sdash .pill-status.transit{ background:#FCE2A0 !important; color:#39220f !important; border:1.5px solid #39220f !important; }
  html body .sdash .pill-status.processing{ background:#B8DCEB !important; color:#1F5A85 !important; border:1.5px solid #1F5A85 !important; }

  /* === KILL BOXY FOCUS SHADOW ON SETTINGS INPUTS === */
  html body .sdash .field input,
  html body .sdash .field input:focus,
  html body .sdash .field input:focus-visible,
  html body .sdash .field input:focus-within{
    box-shadow: none !important;
    outline: 0 !important;
    outline-color: transparent !important;
    outline-style: none !important;
    outline-width: 0 !important;
  }
  html body .sdash .field input:focus,
  html body .sdash .field input:focus-visible{
    border-color: #c58548 !important;
  }

  html body .sdash .sect-head h2{ display:inline-block !important; transform-origin:left center; transform:scale(var(--gr, 1)); transition:transform .35s cubic-bezier(.16,.84,.34,1); will-change:transform; }
  html body .sdash .dash-hello h1{ transform-origin:left center; transform:scale(var(--gr-hello, .94)); transition:transform .5s cubic-bezier(.16,.84,.34,1); will-change:transform; }

  html body .sdash .card, html body .sdash .ov-tile, html body .sdash .order, html body .sdash .fav, html body .sdash .addr, html body .sdash .vperk, html body .sdash .vip-hero{ opacity:0; transform:translateY(14px); transition:opacity .55s ease, transform .55s cubic-bezier(.16,.84,.34,1); }
  html body .sdash.is-ready .card, html body .sdash.is-ready .ov-tile, html body .sdash.is-ready .order, html body .sdash.is-ready .fav, html body .sdash.is-ready .addr, html body .sdash.is-ready .vperk, html body .sdash.is-ready .vip-hero{ opacity:1; transform:translateY(0); }
  html body .sdash.is-ready .ov-tile:nth-child(1){ transition-delay:.05s; }
  html body .sdash.is-ready .ov-tile:nth-child(2){ transition-delay:.15s; }
  html body .sdash.is-ready .ov-tile:nth-child(3){ transition-delay:.25s; }
  html body .sdash.is-ready .vperk:nth-child(1){ transition-delay:.05s; }
  html body .sdash.is-ready .vperk:nth-child(2){ transition-delay:.12s; }
  html body .sdash.is-ready .vperk:nth-child(3){ transition-delay:.19s; }
  html body .sdash.is-ready .vperk:nth-child(4){ transition-delay:.26s; }

  html body .sdash .ov-sticky-wrap{ display: grid !important; grid-template-columns: repeat(3, 1fr) !important; gap: 16px !important; }
  html body .sdash .ov-sticky-wrap > .card.card-pad{ grid-column: 1 / -1 !important; }

  @media (max-width: 1000px){
    html body .sdash .dash-grid{ grid-template-columns: 1fr !important; }
    html body .sdash .dash-nav{ display: grid !important; grid-template-columns: 1fr 1fr !important; gap: 8px !important; padding: 14px !important; flex-direction: initial !important; flex-wrap: initial !important; }
    html body .sdash .dnav-user{ grid-column: 1 / -1 !important; justify-content: flex-start !important; width: 100% !important; padding-bottom: 14px !important; margin-bottom: 4px !important; border-bottom: 1.5px solid #39220f !important; }
    html body .sdash .dnav-item{ width: 100% !important; justify-content: flex-start !important; padding: 12px 10px !important; font-size: 12px !important; }
    html body .sdash .dnav-sep{ display: none !important; }
  }
  @media (max-width: 920px){
    html body .sdash .dash-wrap{ padding: 20px 16px 60px !important; }
    html body .sdash .crumbs{ justify-content: center !important; }
    html body .sdash .dash-hero{ flex-direction: column !important; text-align: center !important; align-items: center !important; padding: 24px 20px !important; }
    html body .sdash .dash-hello{ width: 100% !important; }
    html body .sdash .dash-hello h1{ text-align: center !important; margin-left: auto !important; margin-right: auto !important; transform-origin: center center !important; }
