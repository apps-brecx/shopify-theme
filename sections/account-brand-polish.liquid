    html body .sdash .sect-head > div{ text-align: center !important; }
    html body .sdash .sect-head h2{ text-align: center !important; transform-origin: center center !important; }
    html body .sdash .ov-tile{ align-items: center !important; text-align: center !important; }
    html body .sdash .ov-tile .ic{ margin-left: auto !important; margin-right: auto !important; }
    html body .sdash .empty-state{ text-align: center !important; }
    html body .sdash .ov-sticky-wrap{ grid-template-columns: 1fr !important; gap: 14px !important; }
    html body .sdash .ov-sticky-wrap > .ov-tile, html body .sdash .ov-sticky-wrap > .card.card-pad{ position: sticky !important; margin: 0 !important; }
    html body .sdash .ov-sticky-wrap > .ov-tile:nth-child(1){ top: 90px !important; z-index: 1 !important; }
    html body .sdash .ov-sticky-wrap > .ov-tile:nth-child(2){ top: 110px !important; z-index: 2 !important; }
    html body .sdash .ov-sticky-wrap > .ov-tile:nth-child(3){ top: 130px !important; z-index: 3 !important; }
    html body .sdash .ov-sticky-wrap > .card.card-pad{ top: 150px !important; z-index: 4 !important; }
  }
  @media (max-width: 540px){ html body .sdash .dash-nav{ grid-template-columns: 1fr 1fr !important; } }

  @media (prefers-reduced-motion: reduce){
    html body .sdash .card, html body .sdash .ov-tile, html body .sdash .order, html body .sdash .fav, html body .sdash .addr, html body .sdash .vperk, html body .sdash .vip-hero, html body .sdash .sect-head h2, html body .sdash .dash-hello h1{ transform: none !important; opacity: 1 !important; transition: none !important; }
    html body .sdash .ov-sticky-wrap > .ov-tile, html body .sdash .ov-sticky-wrap > .card.card-pad{ position: static !important; }
  }
</style>

<script>
(function(){
  function init(){
    var root = document.querySelector('.sdash');
    if (!root) return;
    var reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function dedupeTier(){
      var nodes = root.querySelectorAll('.vip-track-top, .tt-top');
      nodes.forEach(function(n){
        var html = n.innerHTML;
        var fixed = html.replace(/(<b>[^<]*tier)<\/b>(\s+)tier\b/gi, '$1</b>');
        fixed = fixed.replace(/(\bnext\s+tier)\s+tier\b/gi, '$1');
        if (html !== fixed) n.innerHTML = fixed;
      });
    }
    dedupeTier();

    var ovPanel = root.querySelector('.dpanel[data-panel="overview"]');
    if (ovPanel && !ovPanel.querySelector('.ov-sticky-wrap')){
      var ovTiles = ovPanel.querySelector('.ov-tiles');
      var vipCard = null;
      var children = ovPanel.children;
      for (var i = 0; i < children.length; i++){
        if (children[i].classList && children[i].classList.contains('card') && children[i].classList.contains('card-pad')){
          vipCard = children[i]; break;
        }
      }
      if (ovTiles){
        var wrap = document.createElement('div');
        wrap.className = 'ov-sticky-wrap';
        ovTiles.parentNode.insertBefore(wrap, ovTiles);
        [].slice.call(ovTiles.querySelectorAll('.ov-tile')).forEach(function(t){ wrap.appendChild(t); });
        ovTiles.remove();
        if (vipCard) wrap.appendChild(vipCard);
      }
    }

    requestAnimationFrame(function(){ requestAnimationFrame(function(){ root.classList.add('is-ready'); }); });
    if (reduced) return;

    var hello = root.querySelector('.dash-hello h1');
    var heads = [].slice.call(root.querySelectorAll('.sect-head h2'));
    var ticking = false;
    function update(){
      var vh = window.innerHeight || document.documentElement.clientHeight;
      if (vh < 1) { ticking = false; return; }
      if (hello){
        var r = hello.getBoundingClientRect();
        var p = (vh - r.top) / vh; if (p < 0) p = 0; if (p > 1) p = 1;
        var s = 0.94 + p * 0.06;
        hello.style.setProperty('--gr-hello', s.toFixed(3));
      }
      heads.forEach(function(h){
        var r = h.getBoundingClientRect();
        if (r.top > vh + 80 || r.bottom < -80){ return; }
        var center = r.top + r.height/2;
        var dist = Math.abs(center - vh*0.55) / (vh*0.5);
        if (dist > 1) dist = 1;
        var gr = 1 + (1 - dist) * 0.08;
        h.style.setProperty('--gr', gr.toFixed(3));
      });
      ticking = false;
    }
    function onScroll(){ if (!ticking){ ticking = true; window.requestAnimationFrame(update); } }
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll);
    update();
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>

