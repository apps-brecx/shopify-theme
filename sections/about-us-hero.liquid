<style>
  .about-us-hero__wrapper{
      position: relative;
      background: #f0e3d8;
  }
  .about-us-hero__content{
      padding: 180px 0;
      width: 47.29%;
  }
  .about-us-hero__image{
      position: absolute;
      width: 52.71%;
      right: 0;
      top: 0;
      bottom: 0;
  }

  .about-us-hero__image img{
      width: 100%;
      height: 100%;
      display: block;
      object-fit: cover;
  }
  .about-us-hero__title{
      margin-bottom: 20px;
  }
  .about-us-hero__title h2{
      font-size: 55px;
      line-height: normal;
      color: #3c2005;
      margin: 0;
  }
  .about-us-hero__description p{
      margin: 0;
      line-height: normal;
      font-size: 26px;
      color: #3c2005;
  }

  @media(max-width: 991px){
    .about-us-hero__wrapper{
        padding: 50px 0 60px;
    }
      .about-us-hero__title h2{
        font-weight: 700;
    }
      .about-us-hero__image{
      position: unset;
      width: 100%;
      padding: 0 15px;
  }
   .about-us-hero__image img{
         border-radius: 20px;
  }
    .about-us-hero__content{
        text-align: center;
      padding: 0 0 50px;
      width: 100%;
  }

  }
   @media(max-width: 768px){
     .about-us-hero__wrapper{
        padding: 40px 0;
    }
      .about-us-hero__title h2{
        font-size: 40px;
    }
      .about-us-hero__description p{
        font-size: 20px;
    }

}
</style>
<div class="about-us-hero__inner">
  <div class="about-us-hero__wrapper">
    <div class="page-width">
      <div class="about-us-hero__content">
        <div class="about-us-hero__title">
          {{ section.settings.title }}
        </div>
        <div class="about-us-hero__description">
          {{ section.settings.description }}
        </div>
      </div>
    </div>

    <div class="about-us-hero__image">
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: section.settings.title }}
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "About Us Hero",
  "settings": [
    {
      "type": "richtext",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    }
  ],
  "presets": [
    {
      "name": "About Us Hero"
    }
  ]
}
{% endschema %}
