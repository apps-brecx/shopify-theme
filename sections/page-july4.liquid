{%- comment -%} July 4th landing — Syruvia brand design, animated stars, countdown, sticky-stack flavors. {%- endcomment -%}
{%- assign s = section.settings -%}
{%- assign h1 = s.product_1 | default: 'sugar-free-dirty-soda-pack' -%}
{%- assign h2 = s.product_2 | default: 'dirty-soda-pack' -%}
{%- assign j4_handles = h1 | append: ',' | append: h2 | split: ',' -%}
{%- assign pA = all_products[h1] -%}
{%- assign pB = all_products[h2] -%}
<style id="j4-{{ section.id }}-css">
  #j4-{{ section.id }}{
    --red:#B22234;--red-dk:#8d1a29;--navy:#0A3161;--navy-2:#061f3f;--blue:#1d4ed8;
    --cream:#FFFBF4;--ink:#1a1a1a;--ink-2:#39220f;--gold:#FCE2A0;--white:#fff;
    --fh:'Archivo Black','Arial Black',sans-serif;--fb:'Josefin Sans','Josefin',sans-serif;
    background:var(--cream);color:var(--ink);font-family:var(--fb);position:relative;
  }
  #j4-{{ section.id }} *{box-sizing:border-box;}
  #j4-{{ section.id }} .j4-wrap{max-width:1180px;margin:0 auto;padding:0 24px;position:relative;z-index:2;}
  #j4-{{ section.id }} .j4-eyebrow{display:inline-flex;align-items:center;gap:8px;background:var(--gold);color:var(--ink);border:2px solid var(--ink);border-radius:999px;box-shadow:3px 3px 0 var(--ink);font-family:var(--fh);font-weight:400;font-size:11px;letter-spacing:.16em;text-transform:uppercase;padding:8px 18px;line-height:1;}
  #j4-{{ section.id }} .j4-rev,#j4-{{ section.id }} .j4-rev-l,#j4-{{ section.id }} .j4-rev-r{opacity:0;transition:opacity .65s ease,transform .65s cubic-bezier(.16,.84,.34,1);}
  #j4-{{ section.id }} .j4-rev{transform:translateY(26px);}
  #j4-{{ section.id }} .j4-rev-l{transform:translateX(-34px);}
  #j4-{{ section.id }} .j4-rev-r{transform:translateX(34px);}
  #j4-{{ section.id }} .j4-rev.in,#j4-{{ section.id }} .j4-rev-l.in,#j4-{{ section.id }} .j4-rev-r.in{opacity:1;transform:none;}
  #j4-{{ section.id }} .j4-h2{font-family:var(--fh);font-weight:400;font-size:clamp(28px,4vw,46px);line-height:1.03;letter-spacing:-.01em;text-transform:uppercase;margin:16px auto 0;max-width:20ch;}
  #j4-{{ section.id }} .j4-h2 em{font-family:var(--fb);font-style:italic;font-weight:300;color:var(--red);text-transform:none;}
  #j4-{{ section.id }} .j4-btn{display:inline-flex;align-items:center;gap:8px;border-radius:999px;font-family:var(--fh);font-weight:400;font-size:12.5px;letter-spacing:.08em;text-transform:uppercase;text-decoration:none;padding:15px 26px;border:2.5px solid var(--ink);cursor:pointer;transition:transform .16s ease, box-shadow .16s ease;}
  #j4-{{ section.id }} .j4-btn--gold{background:var(--gold);color:var(--ink);box-shadow:4px 4px 0 var(--red);}
  #j4-{{ section.id }} .j4-btn--gold:hover{transform:translate(-2px,-2px);box-shadow:6px 6px 0 var(--red);}
  #j4-{{ section.id }} .j4-btn--red{background:var(--red);color:#fff;box-shadow:4px 4px 0 var(--ink);}
  #j4-{{ section.id }} .j4-btn--red:hover{transform:translate(-2px,-2px);box-shadow:6px 6px 0 var(--ink);}
  #j4-{{ section.id }} .j4-btn--ghost{background:transparent;color:var(--cream);border-color:var(--cream);box-shadow:4px 4px 0 rgba(0,0,0,.35);}
  #j4-{{ section.id }} .j4-btn--ghost:hover{transform:translate(-2px,-2px);background:rgba(255,255,255,.1);}
  #j4-{{ section.id }} .j4-btnrow{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;margin-top:28px;}
  #j4-{{ section.id }} .j4-hero{position:relative;text-align:center;padding:80px 0 70px;background:linear-gradient(180deg, var(--navy) 0%, var(--navy-2) 100%);color:var(--cream);overflow:hidden;}
  #j4-{{ section.id }} .j4-stars{position:absolute;inset:0;z-index:0;pointer-events:none;overflow:hidden;}
  #j4-{{ section.id }} .j4-stars svg{position:absolute;color:#fff;animation-name:j4star;animation-timing-function:ease-in-out;animation-iteration-count:infinite;will-change:transform,opacity;}
  @keyframes j4star{0%,100%{opacity:.14;transform:translateY(0) scale(.9) rotate(0);}50%{opacity:.62;transform:translateY(-8px) scale(1.18) rotate(12deg);}}
  #j4-{{ section.id }} .j4-hero .j4-wrap{z-index:2;}
  #j4-{{ section.id }} .j4-hero .j4-eyebrow{background:var(--red);color:var(--white);border-color:var(--white);box-shadow:3px 3px 0 rgba(0,0,0,.4);}
  #j4-{{ section.id }} .j4-hero h1{font-family:var(--fh);font-weight:400;font-size:clamp(46px,9.5vw,108px);line-height:.88;letter-spacing:-.03em;text-transform:uppercase;margin:20px 0 0;color:var(--white);text-shadow:5px 5px 0 var(--red);}
  #j4-{{ section.id }} .j4-hero h1 em{font-style:normal;color:var(--gold);text-shadow:5px 5px 0 var(--red-dk);}
  #j4-{{ section.id }} .j4-hero .j4-sub{font-size:clamp(16px,2vw,21px);color:rgba(255,251,244,.94);font-weight:500;margin:18px auto 0;max-width:34ch;line-height:1.5;}
  #j4-{{ section.id }} .j4-off{position:relative;display:inline-flex;align-items:center;gap:14px;margin:26px 0 0;background:var(--red);color:var(--white);border:3px solid var(--white);border-radius:16px;box-shadow:6px 6px 0 rgba(0,0,0,.45);padding:13px 26px;font-family:var(--fh);font-weight:400;font-size:clamp(22px,4vw,38px);letter-spacing:-.01em;text-transform:uppercase;transform:rotate(-2deg);animation:j4pulse 2.6s ease-in-out infinite;}
  @keyframes j4pulse{0%,100%{transform:rotate(-2deg) scale(1);}50%{transform:rotate(-2deg) scale(1.035);}}
  #j4-{{ section.id }} .j4-off svg{color:var(--gold);flex:0 0 auto;}
  #j4-{{ section.id }} .j4-hero-cta{display:inline-flex;align-items:center;gap:9px;margin:26px auto 0;background:var(--gold);color:var(--ink);border:2.5px solid var(--ink);border-radius:999px;box-shadow:5px 5px 0 var(--red);padding:16px 32px;font-family:var(--fh);font-weight:400;font-size:13px;letter-spacing:.1em;text-transform:uppercase;text-decoration:none;transition:transform .18s ease, box-shadow .18s ease;}
  #j4-{{ section.id }} .j4-hero-cta:hover{transform:translate(-3px,-3px);box-shadow:8px 8px 0 var(--red);}
  #j4-{{ section.id }} .j4-countdown{position:relative;z-index:2;display:flex;flex-direction:column;align-items:center;gap:12px;margin:28px 0 0;}
  #j4-{{ section.id }} .j4-count-top{font-family:'Archivo',sans-serif;font-weight:700;font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);display:inline-flex;align-items:center;gap:9px;}
  #j4-{{ section.id }} .j4-count-top svg{color:var(--gold);}
  #j4-{{ section.id }} .j4-count{display:flex;gap:10px;}
  #j4-{{ section.id }} .j4-count-box{background:#fff;border:2.5px solid var(--ink);border-radius:14px;box-shadow:4px 4px 0 var(--red);min-width:76px;padding:12px 8px 10px;text-align:center;}
  #j4-{{ section.id }} .j4-count-num{font-family:var(--fh);font-weight:400;font-size:clamp(26px,5vw,36px);line-height:1;color:var(--navy);font-variant-numeric:tabular-nums;}
  #j4-{{ section.id }} .j4-count-lbl{font-family:'Archivo',sans-serif;font-weight:700;font-size:9.5px;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-2);margin-top:7px;}
  #j4-{{ section.id }} .j4-flagstripes{height:48px;width:100%;background:repeating-linear-gradient(180deg, var(--red) 0 8px, #fff 8px 16px);border-top:3px solid var(--ink);border-bottom:3px solid var(--ink);}
  #j4-{{ section.id }} .j4-marquee{background:var(--navy);color:var(--white);border-bottom:3px solid var(--ink);overflow:hidden;white-space:nowrap;padding:13px 0;}
  #j4-{{ section.id }} .j4-track{display:inline-block;white-space:nowrap;animation:j4mar 24s linear infinite;}
  #j4-{{ section.id }} .j4-track span{font-family:var(--fh);font-size:14px;letter-spacing:.14em;text-transform:uppercase;margin:0 10px;}
  #j4-{{ section.id }} .j4-track span::after{content:'★';color:var(--gold);margin-left:20px;}
  @keyframes j4mar{from{transform:translateX(0)}to{transform:translateX(-50%)}}
  #j4-{{ section.id }} .j4-offer{padding:74px 0 30px;text-align:center;}
  #j4-{{ section.id }} .j4-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:26px;margin-top:50px;text-align:left;}
  #j4-{{ section.id }} .j4-card{position:relative;background:var(--white);border:3px solid var(--ink);border-radius:24px;box-shadow:8px 8px 0 var(--ink);overflow:hidden;display:flex;flex-direction:column;transition:transform .25s ease, box-shadow .25s ease, opacity .65s ease;}
  #j4-{{ section.id }} .j4-card::before{content:'';position:absolute;top:0;left:0;right:0;height:8px;z-index:4;background:linear-gradient(90deg, var(--red) 0 33.33%, #fff 33.33% 66.66%, var(--navy) 66.66% 100%);}
  #j4-{{ section.id }} .j4-card:hover{transform:translate(-3px,-3px);box-shadow:11px 11px 0 var(--ink);}
  #j4-{{ section.id }} .j4-card-top{position:relative;background:var(--cream);border-bottom:3px solid var(--ink);padding:30px 26px 26px;display:flex;align-items:center;justify-content:center;min-height:300px;}
  #j4-{{ section.id }} .j4-card-top::before{content:'';position:absolute;inset:0;background:repeating-linear-gradient(180deg, rgba(178,34,52,.07) 0 16px, transparent 16px 32px);pointer-events:none;}
  #j4-{{ section.id }} .j4-card-top img{position:relative;max-width:100%;max-height:300px;width:auto;height:auto;object-fit:contain;mix-blend-mode:multiply;transition:transform .4s ease;}
  #j4-{{ section.id }} .j4-card:hover .j4-card-top img{transform:scale(1.05) rotate(-1deg);}
  #j4-{{ section.id }} .j4-badge{position:absolute;top:18px;left:16px;z-index:3;background:var(--red);color:var(--white);border:2.5px solid var(--white);border-radius:12px;box-shadow:3px 3px 0 var(--ink);font-family:var(--fh);font-weight:400;font-size:14px;letter-spacing:.02em;text-transform:uppercase;padding:8px 12px;transform:rotate(-4deg);}
  #j4-{{ section.id }} .j4-flag{position:absolute;top:18px;right:16px;z-index:3;background:var(--navy);color:#fff;border:2px solid #fff;border-radius:999px;font-family:var(--fh);font-size:9.5px;letter-spacing:.12em;text-transform:uppercase;padding:6px 11px;display:inline-flex;align-items:center;gap:5px;box-shadow:2px 2px 0 var(--ink);}
  #j4-{{ section.id }} .j4-flag svg{color:var(--gold);}
  #j4-{{ section.id }} .j4-card-body{padding:24px 24px 26px;display:flex;flex-direction:column;gap:14px;flex:1;}
  #j4-{{ section.id }} .j4-card-kicker{font-family:var(--fh);font-size:10.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--navy);}
  #j4-{{ section.id }} .j4-card-name{font-family:var(--fh);font-weight:400;font-size:23px;line-height:1.05;text-transform:uppercase;letter-spacing:-.01em;}
  #j4-{{ section.id }} .j4-price{display:flex;align-items:baseline;gap:12px;flex-wrap:wrap;}
  #j4-{{ section.id }} .j4-price .now{font-family:var(--fh);font-weight:400;font-size:32px;color:var(--red);letter-spacing:-.02em;}
  #j4-{{ section.id }} .j4-price .was{font-family:'Archivo',sans-serif;font-weight:700;font-size:18px;color:#9a8b78;text-decoration:line-through;}
  #j4-{{ section.id }} .j4-price .save{font-family:var(--fh);font-size:10.5px;letter-spacing:.06em;text-transform:uppercase;background:var(--gold);color:var(--ink);border:1.5px solid var(--ink);border-radius:999px;padding:4px 9px;}
  #j4-{{ section.id }} .j4-card-desc{font-size:14.5px;line-height:1.6;color:var(--ink-2);font-weight:500;margin:0;}
  #j4-{{ section.id }} .j4-atc{margin-top:auto;display:inline-flex;align-items:center;justify-content:center;gap:9px;width:100%;background:var(--navy);color:#fff;border:2.5px solid var(--ink);border-radius:999px;box-shadow:4px 4px 0 var(--red);padding:16px 22px;font-family:var(--fh);font-weight:400;font-size:13px;letter-spacing:.07em;text-transform:uppercase;cursor:pointer;transition:transform .16s ease, box-shadow .16s ease, background .2s ease;}
  #j4-{{ section.id }} .j4-atc:hover{transform:translate(-2px,-2px);box-shadow:6px 6px 0 var(--red);background:var(--blue);}
  #j4-{{ section.id }} .j4-view{display:block;text-align:center;margin-top:10px;font-family:'Archivo',sans-serif;font-weight:700;font-size:11.5px;letter-spacing:.04em;text-transform:uppercase;color:var(--ink-2);text-decoration:underline;}
  #j4-{{ section.id }} .j4-flavors{padding:64px 0 40px;text-align:center;}
  #j4-{{ section.id }} .j4-flav-stack{max-width:660px;margin:44px auto 0;}
  #j4-{{ section.id }} .j4-flav-card{position:sticky;display:flex;align-items:center;gap:24px;text-align:left;background:var(--white);border:2.5px solid var(--ink);border-radius:22px;box-shadow:7px 7px 0 var(--ink);padding:28px 32px;margin-bottom:34px;}
  #j4-{{ section.id }} .j4-flav-card:nth-child(1){top:96px;}
  #j4-{{ section.id }} .j4-flav-card:nth-child(2){top:120px;}
  #j4-{{ section.id }} .j4-flav-card:nth-child(3){top:144px;margin-bottom:0;}
  #j4-{{ section.id }} .j4-flav-card .sw{flex:0 0 auto;width:74px;height:74px;border-radius:50%;border:2.5px solid var(--ink);box-shadow:3px 3px 0 var(--ink);animation:j4swatch 5s ease-in-out infinite;}
  #j4-{{ section.id }} .j4-flav-card:nth-child(2) .sw{animation-delay:.8s;}
  #j4-{{ section.id }} .j4-flav-card:nth-child(3) .sw{animation-delay:1.6s;}
  @keyframes j4swatch{0%,100%{transform:translateY(0) rotate(-6deg);}50%{transform:translateY(-5px) rotate(8deg);}}
  #j4-{{ section.id }} .j4-flav-card.red .sw{background:radial-gradient(circle at 34% 28%, #e8657a, var(--red));}
  #j4-{{ section.id }} .j4-flav-card.white .sw{background:radial-gradient(circle at 34% 28%, #ffffff, #e6d6bf);}
  #j4-{{ section.id }} .j4-flav-card.blue .sw{background:radial-gradient(circle at 34% 28%, #5b86f0, var(--navy));}
  #j4-{{ section.id }} .j4-flav-card .ft{display:flex;flex-direction:column;gap:7px;}
  #j4-{{ section.id }} .j4-flav-card .fn{font-family:var(--fh);font-weight:400;font-size:20px;text-transform:uppercase;letter-spacing:-.005em;}
  #j4-{{ section.id }} .j4-flav-card .fd{font-size:14.5px;line-height:1.55;color:var(--ink-2);font-weight:500;}
  #j4-{{ section.id }} .j4-home{padding:46px 0 60px;}
  #j4-{{ section.id }} .j4-home-card{position:relative;background:linear-gradient(180deg,var(--navy),var(--navy-2));color:var(--cream);border:3px solid var(--ink);border-radius:30px;box-shadow:8px 8px 0 var(--ink);padding:52px clamp(26px,5vw,64px);text-align:center;overflow:hidden;}
  #j4-{{ section.id }} .j4-home-card::before{content:'';position:absolute;inset:0;background-image:radial-gradient(rgba(255,255,255,.5) 1.2px, transparent 1.4px);background-size:28px 28px;opacity:.14;pointer-events:none;}
  #j4-{{ section.id }} .j4-home .j4-eyebrow{background:var(--red);color:#fff;border-color:#fff;}
  #j4-{{ section.id }} .j4-home .j4-h2{color:#fff;position:relative;}
  #j4-{{ section.id }} .j4-home .j4-h2 em{color:var(--gold);}
  #j4-{{ section.id }} .j4-home p{position:relative;color:rgba(255,251,244,.92);font-size:16px;line-height:1.7;font-weight:500;max-width:60ch;margin:18px auto 0;}
  #j4-{{ section.id }} .j4-home-stats{position:relative;display:flex;justify-content:center;gap:16px;flex-wrap:wrap;margin-top:30px;}
  #j4-{{ section.id }} .j4-home-stat{background:rgba(255,255,255,.08);border:2px solid rgba(255,255,255,.45);border-radius:16px;padding:18px 24px;min-width:150px;}
  #j4-{{ section.id }} .j4-home-stat .n{font-family:var(--fh);font-weight:400;font-size:28px;color:var(--gold);line-height:1;}
  #j4-{{ section.id }} .j4-home-stat .l{font-size:12px;letter-spacing:.04em;text-transform:uppercase;color:rgba(255,251,244,.8);margin-top:8px;font-family:'Archivo',sans-serif;font-weight:700;}
  #j4-{{ section.id }} .j4-trust{padding:42px 0 30px;}
  #j4-{{ section.id }} .j4-trust-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;}
  #j4-{{ section.id }} .j4-trust-card{background:var(--white);border:2.5px solid var(--ink);border-radius:18px;box-shadow:4px 4px 0 var(--ink);padding:22px 16px;text-align:center;display:flex;flex-direction:column;align-items:center;gap:10px;}
  #j4-{{ section.id }} .j4-trust-card:nth-child(2){transition-delay:.08s;}
  #j4-{{ section.id }} .j4-trust-card:nth-child(3){transition-delay:.16s;}
  #j4-{{ section.id }} .j4-trust-card:nth-child(4){transition-delay:.24s;}
  #j4-{{ section.id }} .j4-trust-card:nth-child(1) .ic{background:#fbe3e6;}
  #j4-{{ section.id }} .j4-trust-card:nth-child(2) .ic{background:#e3ebf7;}
  #j4-{{ section.id }} .j4-trust-card:nth-child(3) .ic{background:var(--cream);}
  #j4-{{ section.id }} .j4-trust-card:nth-child(4) .ic{background:#fbe3e6;}
  #j4-{{ section.id }} .j4-trust-card .ic{width:46px;height:46px;border-radius:50%;border:2px solid var(--ink);display:flex;align-items:center;justify-content:center;box-shadow:2px 2px 0 var(--ink);}
  #j4-{{ section.id }} .j4-trust-card .ic svg{width:24px;height:24px;color:var(--navy);}
  #j4-{{ section.id }} .j4-trust-card .t{font-family:var(--fh);font-size:12px;text-transform:uppercase;letter-spacing:.02em;line-height:1.15;}
  #j4-{{ section.id }} .j4-trust-card .d{font-size:12px;color:var(--ink-2);line-height:1.4;}
  #j4-{{ section.id }} .j4-final{padding:20px 0 84px;}
  #j4-{{ section.id }} .j4-final-card{position:relative;background:linear-gradient(135deg,var(--red),var(--red-dk));color:#fff;border:3px solid var(--ink);border-radius:30px;box-shadow:8px 8px 0 var(--ink);padding:54px clamp(26px,5vw,60px);text-align:center;overflow:hidden;}
  #j4-{{ section.id }} .j4-final-card::before{content:'';position:absolute;inset:0;background-image:radial-gradient(rgba(255,255,255,.6) 1.2px, transparent 1.4px);background-size:26px 26px;opacity:.16;pointer-events:none;}
  #j4-{{ section.id }} .j4-final .j4-eyebrow{background:var(--gold);color:var(--ink);border-color:var(--ink);}
  #j4-{{ section.id }} .j4-final .j4-h2{color:#fff;position:relative;}
  #j4-{{ section.id }} .j4-final .j4-h2 em{color:var(--gold);}
  #j4-{{ section.id }} .j4-final p{position:relative;color:rgba(255,255,255,.92);font-size:15px;margin:14px auto 0;max-width:46ch;line-height:1.5;}
  @media (max-width:820px){
    #j4-{{ section.id }} .j4-grid{grid-template-columns:1fr;gap:20px;}
    #j4-{{ section.id }} .j4-trust-grid{grid-template-columns:repeat(2,1fr);}
    #j4-{{ section.id }} .j4-flagstripes{height:34px;background:repeating-linear-gradient(180deg, var(--red) 0 5.6px, #fff 5.6px 11.3px);}
    #j4-{{ section.id }} .j4-flav-card{gap:16px;padding:22px 20px;}
    #j4-{{ section.id }} .j4-flav-card .sw{width:58px;height:58px;}
    #j4-{{ section.id }} .j4-count-box{min-width:64px;padding:10px 6px 8px;}
  }
  @media (prefers-reduced-motion: reduce){
    #j4-{{ section.id }} .j4-rev,#j4-{{ section.id }} .j4-rev-l,#j4-{{ section.id }} .j4-rev-r{opacity:1;transform:none;}
    #j4-{{ section.id }} .j4-stars svg,#j4-{{ section.id }} .j4-off,#j4-{{ section.id }} .j4-flav-card .sw,#j4-{{ section.id }} .j4-track{animation:none;}
    #j4-{{ section.id }} .j4-stars svg{opacity:.22;}
  }
</style>

<section id="j4-{{ section.id }}">

  <div class="j4-hero">
    <div class="j4-stars" aria-hidden="true">
      {%- assign sx = '6,16,27,40,52,63,74,86,93,12,35,58,80,46' | split: ',' -%}
      {%- assign sy = '18,62,30,75,22,55,16,68,38,88,12,86,46,90' | split: ',' -%}
      {%- assign ss = '26,16,20,14,30,18,22,15,24,17,19,21,14,16' | split: ',' -%}
      {%- assign sd = '4,5.5,6,4.5,7,5,6.5,4.2,5.8,6.2,4.8,7.2,5.2,6' | split: ',' -%}
      {%- assign sl = '0,.6,1.2,.3,.9,1.5,.4,1.1,.7,.2,1.3,.5,1,.8' | split: ',' -%}
      {%- for i in (0..13) -%}
        <svg style="left:{{ sx[i] }}%;top:{{ sy[i] }}%;width:{{ ss[i] }}px;height:{{ ss[i] }}px;animation-duration:{{ sd[i] }}s;animation-delay:{{ sl[i] }}s;" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.9 6.3 6.8.8-5 4.6 1.3 6.7L12 17.8 5.9 20.4 7.2 13.7l-5-4.6 6.8-.8z"></path></svg>
      {%- endfor -%}
    </div>
    <div class="j4-wrap">
      <span class="j4-eyebrow">{{ s.hero_eyebrow | default: 'Limited Time · Stars & Stripes' }}</span>
      <h1>{{ s.hero_title | default: '4th of July <em>Blowout</em>' }}</h1>
      <p class="j4-sub">{{ s.hero_sub | default: 'Celebrate red, white & delicious. Our USA Dirty Soda Packs are half price for the holiday.' }}</p>
      <div class="j4-off"><svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true"><path d="M12 2l2.9 6.3 6.8.8-5 4.6 1.3 6.7L12 17.8 5.9 20.4 7.2 13.7l-5-4.6 6.8-.8z"></path></svg>{{ s.hero_offer | default: '50% Off · This Week Only' }}<svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true"><path d="M12 2l2.9 6.3 6.8.8-5 4.6 1.3 6.7L12 17.8 5.9 20.4 7.2 13.7l-5-4.6 6.8-.8z"></path></svg></div>
      <div class="j4-countdown" data-count{% if s.countdown_date != blank %} data-end="{{ s.countdown_date }}"{% endif %}>
        <span class="j4-count-top"><svg viewBox="0 0 24 24" width="13" height="13" fill="currentColor"><path d="M12 2l2.9 6.3 6.8.8-5 4.6 1.3 6.7L12 17.8 5.9 20.4 7.2 13.7l-5-4.6 6.8-.8z"></path></svg>{{ s.count_label | default: 'Deal ends July 4th' }}<svg viewBox="0 0 24 24" width="13" height="13" fill="currentColor"><path d="M12 2l2.9 6.3 6.8.8-5 4.6 1.3 6.7L12 17.8 5.9 20.4 7.2 13.7l-5-4.6 6.8-.8z"></path></svg></span>
        <div class="j4-count">
          <div class="j4-count-box"><div class="j4-count-num" data-d>00</div><div class="j4-count-lbl">Days</div></div>
          <div class="j4-count-box"><div class="j4-count-num" data-h>00</div><div class="j4-count-lbl">Hrs</div></div>
          <div class="j4-count-box"><div class="j4-count-num" data-m>00</div><div class="j4-count-lbl">Min</div></div>
          <div class="j4-count-box"><div class="j4-count-num" data-s>00</div><div class="j4-count-lbl">Sec</div></div>
        </div>
      </div>
      <div><a class="j4-hero-cta" href="#j4-packs">{{ s.hero_cta | default: 'Grab the deal' }} <span>★</span></a></div>
    </div>
  </div>

  <div class="j4-flagstripes" aria-hidden="true"></div>

  <div class="j4-marquee" aria-hidden="true">
    <div class="j4-track">
      {%- assign mw = '50% Off,4th of July,Stars & Stripes,USA Dirty Soda,Limited Time,Free Shipping Over $36' | split: ',' -%}
      {%- for i in (1..2) -%}{%- for w in mw -%}<span>{{ w | strip }}</span>{%- endfor -%}{%- endfor -%}
    </div>
  </div>

  <div class="j4-offer" id="j4-packs">
    <div class="j4-wrap">
      <span class="j4-eyebrow j4-rev">{{ s.offer_eyebrow | default: 'The deal' }}</span>
      <h2 class="j4-h2 j4-rev">{{ s.offer_title | default: 'Two packs. <em>Half off</em>.' }}</h2>
      <div class="j4-grid">
        {%- assign idx = 0 -%}
        {%- for hd in j4_handles -%}
          {%- assign p = all_products[hd] -%}
          {%- if p != blank and p != empty -%}
            {%- assign idx = idx | plus: 1 -%}
            {%- assign v = p.selected_or_first_available_variant -%}
            {%- assign pct = 0 -%}
            {%- if v.compare_at_price and v.compare_at_price > v.price -%}
              {%- assign d = v.compare_at_price | minus: v.price -%}
              {%- assign pct = d | times: 100 | divided_by: v.compare_at_price -%}
            {%- endif -%}
            <div class="j4-card {% if idx == 1 %}j4-rev-l{% else %}j4-rev-r{% endif %}">
              <div class="j4-card-top">
                <span class="j4-badge">{% if pct > 0 %}{{ pct }}% Off{% else %}Deal{% endif %}</span>
                <span class="j4-flag"><svg viewBox="0 0 24 24" width="11" height="11" fill="currentColor" aria-hidden="true"><path d="M12 2l2.9 6.3 6.8.8-5 4.6 1.3 6.7L12 17.8 5.9 20.4 7.2 13.7l-5-4.6 6.8-.8z"></path></svg> USA</span>
                {%- if p.featured_image -%}<img src="{{ p.featured_image | image_url: width: 700 }}" alt="{{ p.title | escape }}" loading="lazy">{%- endif -%}
              </div>
              <div class="j4-card-body">
                <span class="j4-card-kicker">{% if p.handle contains 'sugar-free' %}Sugar-Free · Zero Sugar{% else %}Pure Cane · Full Flavor{% endif %}</span>
                <h3 class="j4-card-name">{{ p.title | replace: '(USA)', '' | strip }}</h3>
                <div class="j4-price">
                  <span class="now">{{ v.price | money }}</span>
                  {%- if v.compare_at_price and v.compare_at_price > v.price -%}<span class="was">{{ v.compare_at_price | money }}</span><span class="save">Save {{ pct }}%</span>{%- endif -%}
                </div>
                <p class="j4-card-desc">{% if p.handle contains 'sugar-free' %}Strawberry, Coconut & Blue Raspberry — zero sugar, all the fizz-worthy flavor.{% else %}Strawberry, Coconut & Blue Raspberry — pure cane sweet, made for backyard pours.{% endif %}</p>
                <form method="post" action="/cart/add" class="j4-atc-form">
                  <input type="hidden" name="id" value="{{ v.id }}">
                  <button type="submit" class="j4-atc"{% unless p.available %} disabled{% endunless %}>{% if p.available %}Add to cart · {{ v.price | money }}{% else %}Sold Out{% endif %}</button>
                </form>
                <a class="j4-view" href="{{ p.url }}">View pack details →</a>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  <div class="j4-flagstripes" aria-hidden="true"></div>

  <div class="j4-flavors">
    <div class="j4-wrap">
      <span class="j4-eyebrow j4-rev">{{ s.flav_eyebrow | default: "What's inside" }}</span>
      <h2 class="j4-h2 j4-rev">{{ s.flav_title | default: 'Red, white &amp; blue, <em>in a bottle</em>.' }}</h2>
      <div class="j4-flav-stack">
        <div class="j4-flav-card red"><span class="sw"></span><div class="ft"><span class="fn">Strawberry</span><span class="fd">The all-American red — juicy, ripe and sweet. Bright in dirty sodas, lemonades and creams.</span></div></div>
        <div class="j4-flav-card white"><span class="sw"></span><div class="ft"><span class="fn">Coconut</span><span class="fd">The creamy white — smooth and tropical. Turns any soda into a dreamy, milky dirty soda.</span></div></div>
        <div class="j4-flav-card blue"><span class="sw"></span><div class="ft"><span class="fn">Blue Raspberry</span><span class="fd">The electric blue — bold and candy-like. Fun, fizzy and a total showstopper.</span></div></div>
      </div>
      <div class="j4-btnrow">
        <a class="j4-btn j4-btn--red j4-rev" href="#j4-packs">Shop the deal ★</a>
        <a class="j4-btn j4-btn--gold j4-rev" href="/collections/variety-packs-for-coffee-and-cocktails">See all packs</a>
      </div>
    </div>
  </div>

  <div class="j4-home">
    <div class="j4-wrap">
      <div class="j4-home-card j4-rev">
        <span class="j4-eyebrow">{{ s.home_eyebrow | default: 'Your kitchen soda shop' }}</span>
        <h2 class="j4-h2">{{ s.home_title | default: 'Make your favorite drinks at home — <em>for pennies</em>.' }}</h2>
        <p>Dirty sodas, sparkling lemonades, Italian sodas, mocktails, energy-drink refreshers — just pour, mix and fizz. A soda-shop drink runs $5–$7 each. With a 750 ml bottle you get 50+ drinks, so every pour costs cents, not dollars. Three packs, endless red-white-and-blue combos all summer long.</p>
        <div class="j4-home-stats">
          <div class="j4-home-stat"><div class="n">50+</div><div class="l">Drinks per bottle</div></div>
          <div class="j4-home-stat"><div class="n">Pennies</div><div class="l">Per pour</div></div>
          <div class="j4-home-stat"><div class="n">$5–7</div><div class="l">Saved per drink</div></div>
          <div class="j4-home-stat"><div class="n">3-in-1</div><div class="l">Flavors per pack</div></div>
        </div>
        <div class="j4-btnrow">
          <a class="j4-btn j4-btn--gold" href="#j4-packs">Grab both packs · 50% off</a>
          <a class="j4-btn j4-btn--ghost" href="/blogs/blog-posts">Get recipe ideas</a>
        </div>
      </div>
    </div>
  </div>

  <div class="j4-trust">
    <div class="j4-wrap">
      <div class="j4-trust-grid">
        <div class="j4-trust-card j4-rev"><span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 4h13v8H1zM14 7h4l3 3v2h-7z"/><circle cx="5.5" cy="15" r="2"/><circle cx="17" cy="15" r="2"/></svg></span><span class="t">Free Shipping</span><span class="d">On orders over $36</span></div>
        <div class="j4-trust-card j4-rev"><span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 L14.5 8 L21 9 L16.5 13.5 L17.5 20 L12 16.5 L6.5 20 L7.5 13.5 L3 9 L9.5 8 Z"/></svg></span><span class="t">Made in the USA</span><span class="d">Small-batch, real flavor</span></div>
        <div class="j4-trust-card j4-rev"><span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12 l4 4 L19 7"/></svg></span><span class="t">Kosher &amp; GF</span><span class="d">OU certified, gluten-free</span></div>
        <div class="j4-trust-card j4-rev"><span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 10h18"/></svg></span><span class="t">50% Off</span><span class="d">Holiday pricing, limited</span></div>
      </div>
    </div>
  </div>

  <div class="j4-final">
    <div class="j4-wrap">
      <div class="j4-final-card j4-rev">
        <span class="j4-eyebrow">{{ s.final_eyebrow | default: 'Before the fireworks' }}</span>
        <h2 class="j4-h2">{{ s.final_title | default: 'Pour something <em>patriotic</em>.' }}</h2>
        <p>50% off both USA Dirty Soda Packs — only while the deal lasts. Stock up for the cookout.</p>
        <div class="j4-btnrow">
          {%- if pA != blank -%}<a class="j4-btn j4-btn--gold" href="{{ pA.url }}">Shop the sugar-free pack</a>{%- endif -%}
          {%- if pB != blank -%}<a class="j4-btn j4-btn--ghost" href="{{ pB.url }}">Shop the original pack</a>{%- endif -%}
        </div>
      </div>
    </div>
  </div>

</section>

<script>
(function(){
  var root=document.getElementById('j4-{{ section.id }}');
  if(!root) return;
  var sel='.j4-rev,.j4-rev-l,.j4-rev-r';
  if('IntersectionObserver' in window && !(window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches)){
    var io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);}});},{threshold:.12});
    root.querySelectorAll(sel).forEach(function(el){io.observe(el);});
    setTimeout(function(){root.querySelectorAll(sel).forEach(function(el){if(!el.classList.contains('in'))el.classList.add('in');});},2800);
  } else { root.querySelectorAll(sel).forEach(function(el){el.classList.add('in');}); }

  var cd=root.querySelector('[data-count]');
  if(cd){
    var dEl=cd.querySelector('[data-d]'),hEl=cd.querySelector('[data-h]'),mEl=cd.querySelector('[data-m]'),sEl=cd.querySelector('[data-s]');
    function pad(n){return (n<10?'0':'')+n;}
    function target(){
      var set=cd.getAttribute('data-end');
      if(set){ var ds=new Date(set+'T23:59:59'); if(!isNaN(ds.getTime())) return ds; }
      var now=new Date(), y=now.getFullYear();
      var t=new Date(y,6,4,23,59,59);
      if(now>t){ t=new Date(y+1,6,4,23,59,59); }
      return t;
    }
    var T=target();
    function tick(){
      var diff=T-new Date(); if(diff<0)diff=0;
      dEl.textContent=pad(Math.floor(diff/86400000));
      hEl.textContent=pad(Math.floor(diff%86400000/3600000));
      mEl.textContent=pad(Math.floor(diff%3600000/60000));
      sEl.textContent=pad(Math.floor(diff%60000/1000));
    }
    tick(); setInterval(tick,1000);
  }
})();
</script>

