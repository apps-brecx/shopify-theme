{%- comment -%} Section 6 — Video Wall (light fun brand bg, not dark) {%- endcomment -%}
<style id="syr-vid-{{ section.id }}-css">
  #syr-vid-{{ section.id }}{
    --ink:#39220f; --paper:#FFFBF4; --accent:#c58548; --butter:#FCE2A0; --peach:#FFD4B8; --mint:#C5E4D4; --sky:#B8DCEB;
    background:
      radial-gradient(60% 70% at 80% 10%, var(--butter) 0%, transparent 55%),
      radial-gradient(50% 60% at 10% 90%, var(--peach) 0%, transparent 55%),
      var(--paper);
    color:var(--ink);
    padding:84px 40px 88px;
    font-family:'Josefin Sans','Josefin',sans-serif;
  }
  #syr-vid-{{ section.id }} .syr-vid-wrap{ max-width:1320px; margin:0 auto; }
  #syr-vid-{{ section.id }} .syr-vid-head{ text-align:center; margin-bottom:40px; }
  #syr-vid-{{ section.id }} .syr-vid-eyebrow{
    display:inline-block; background:var(--mint); color:var(--ink);
    border:2px solid var(--ink); border-radius:999px;
    font-family:'Archivo Black','Archivo',sans-serif; font-weight:400;
    font-size:11px; letter-spacing:.16em; text-transform:uppercase;
    padding:7px 16px; margin-bottom:14px; box-shadow:3px 3px 0 var(--ink);
  }
  #syr-vid-{{ section.id }} h2{
    font-family:'Archivo Black','Archivo',sans-serif; font-weight:400;
    font-size:clamp(38px, 5vw, 60px); line-height:.95;
    letter-spacing:-.015em; text-transform:uppercase;
    color:var(--ink); margin:0 0 12px;
  }
  #syr-vid-{{ section.id }} .syr-vid-sub{ font-size:16px; color:rgba(57,34,15,.7); margin:0 auto; max-width:42ch; }
  #syr-vid-{{ section.id }} .syr-vid-grid{ display:grid; grid-template-columns:repeat(3, 1fr); gap:20px; margin-bottom:44px; }
  #syr-vid-{{ section.id }} .syr-vid-card{
    position:relative; aspect-ratio:9/16;
    background:#0c0907;
    border:2px solid var(--ink); border-radius:20px; overflow:hidden;
    box-shadow:5px 5px 0 var(--ink);
    cursor:pointer; text-decoration:none;
    transition:transform .22s cubic-bezier(.4,0,.2,1), box-shadow .22s cubic-bezier(.4,0,.2,1);
  }
  #syr-vid-{{ section.id }} .syr-vid-card:hover{ transform:translate(-4px,-4px) scale(1.02); box-shadow:9px 9px 0 var(--ink); }
  #syr-vid-{{ section.id }} .syr-vid-thumb{
    position:absolute; inset:0;
    background-size:cover; background-position:center;
    filter:saturate(1.05);
  }
  #syr-vid-{{ section.id }} .syr-vid-thumb::after{
    content:""; position:absolute; inset:0;
    background:linear-gradient(180deg, transparent 40%, rgba(12,9,7,.7) 100%);
  }
  #syr-vid-{{ section.id }} .syr-vid-play{
    position:absolute; top:50%; left:50%; transform:translate(-50%,-50%);
    width:60px; height:60px; border-radius:50%;
    background:var(--paper); color:var(--ink);
    display:flex; align-items:center; justify-content:center;
    border:2px solid var(--ink); box-shadow:3px 3px 0 var(--ink);
    z-index:2; transition:transform .2s ease, background .15s ease;
  }
  #syr-vid-{{ section.id }} .syr-vid-card:hover .syr-vid-play{ background:var(--butter); transform:translate(-50%,-50%) scale(1.1); }
  #syr-vid-{{ section.id }} .syr-vid-play svg{ width:18px; height:18px; margin-left:3px; }
  #syr-vid-{{ section.id }} .syr-vid-handle{
    position:absolute; top:10px; left:10px;
    background:rgba(0,0,0,.55); color:#fff;
    border:1px solid rgba(255,255,255,.2); border-radius:999px;
    font-family:'Josefin Sans','Josefin',sans-serif; font-weight:600;
    font-size:11px; padding:4px 10px; z-index:2;
  }
  #syr-vid-{{ section.id }} .syr-vid-tag{
    position:absolute; bottom:10px; left:10px; right:10px;
    background:var(--butter); color:var(--ink);
    border:1.5px solid var(--ink); border-radius:999px;
    box-shadow:2px 2px 0 var(--ink);
    font-family:'Archivo Black','Archivo',sans-serif; font-weight:400;
    font-size:10.5px; letter-spacing:.06em; text-transform:uppercase;
    padding:5px 10px; z-index:2;
    display:inline-block; max-width:fit-content;
  }

  #syr-vid-{{ section.id }} .syr-vid-cta{ text-align:center; }
  #syr-vid-{{ section.id }} .syr-vid-handle-big{
    font-family:'Archivo Black','Archivo',sans-serif; font-weight:400;
    font-size:clamp(28px, 3.8vw, 42px); color:var(--ink);
    margin:0 0 14px; letter-spacing:-.005em;
  }
  #syr-vid-{{ section.id }} .syr-vid-socials{ display:inline-flex; gap:14px; padding-top:4px; }
  #syr-vid-{{ section.id }} .syr-vid-soc{
    width:48px; height:48px; border-radius:50%;
    background:var(--paper); color:var(--ink);
    border:2px solid var(--ink); box-shadow:3px 3px 0 var(--ink);
    display:inline-flex; align-items:center; justify-content:center;
    text-decoration:none;
    transition:background .15s ease, transform .15s ease, box-shadow .15s ease;
  }
  #syr-vid-{{ section.id }} .syr-vid-soc:hover{ background:var(--butter); transform:translate(-2px,-2px); box-shadow:5px 5px 0 var(--ink); }
  #syr-vid-{{ section.id }} .syr-vid-soc svg{ width:18px; height:18px; }

  @media (max-width:760px){
    #syr-vid-{{ section.id }}{ padding:48px 16px 60px; }
    #syr-vid-{{ section.id }} .syr-vid-grid{ grid-template-columns:repeat(2, 1fr); gap:14px; margin-bottom:32px; }
    #syr-vid-{{ section.id }} .syr-vid-play{ width:46px; height:46px; }
    #syr-vid-{{ section.id }} .syr-vid-play svg{ width:14px; height:14px; }
    #syr-vid-{{ section.id }} .syr-vid-tag{ font-size:9px; padding:4px 8px; }
    #syr-vid-{{ section.id }} .syr-vid-handle{ font-size:10px; padding:3px 8px; }
    #syr-vid-{{ section.id }} .syr-vid-soc{ width:44px; height:44px; }
  }
</style>

<section id="syr-vid-{{ section.id }}">
  <div class="syr-vid-wrap">
    <div class="syr-vid-head">
      <span class="syr-vid-eyebrow" data-reveal="up">Real Sips</span>
      <h2 data-reveal="up" data-reveal-delay="80">{{ section.settings.headline }}</h2>
      <p class="syr-vid-sub" data-reveal="up" data-reveal-delay="160">{{ section.settings.sub }}</p>
    </div>
    <div class="syr-vid-grid">
      {%- assign vids = 'v1,v2,v3,v4,v5,v6' | split: ',' -%}
      {%- for v in vids -%}
        {%- assign img_k = v | append: '_thumb' -%}
        {%- assign handle_k = v | append: '_handle' -%}
        {%- assign tag_k = v | append: '_tag' -%}
        {%- assign link_k = v | append: '_link' -%}
        {%- assign img = section.settings[img_k] -%}
        <a class="syr-vid-card" href="{{ section.settings[link_k] | default: '#' }}" data-reveal="up" data-reveal-delay="{{ forloop.index0 | times: 90 }}">
          <div class="syr-vid-thumb" style="{% if img %}background-image:url('{{ img | image_url: width: 540 }}');{% else %}background:linear-gradient(160deg,#FFD4B8,#c58548);{% endif %}"></div>
          <span class="syr-vid-handle">@{{ section.settings[handle_k] }}</span>
          <div class="syr-vid-play" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg></div>
          <span class="syr-vid-tag">{{ section.settings[tag_k] }}</span>
        </a>
      {%- endfor -%}
    </div>
    <div class="syr-vid-cta" data-reveal="up">
      <p class="syr-vid-handle-big">@{{ section.settings.brand_handle }}</p>
      <div class="syr-vid-socials">
        <a class="syr-vid-soc" href="{{ section.settings.ig_link | default: 'https://instagram.com' }}" aria-label="Instagram"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg></a>
        <a class="syr-vid-soc" href="{{ section.settings.tt_link | default: 'https://tiktok.com' }}" aria-label="TikTok"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.4 6.7a5 5 0 01-3-2.7h-3v12a2.5 2.5 0 11-2.5-2.5h.5v-3l-.5-.1a5.5 5.5 0 105.5 5.6V9.7a8 8 0 003 .7v-3a5 5 0 01-.5-.7z"/></svg></a>
        <a class="syr-vid-soc" href="{{ section.settings.yt_link | default: 'https://youtube.com' }}" aria-label="YouTube"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M22 8.2a3 3 0 00-2-2C18 5.7 12 5.7 12 5.7s-6 0-8 .5a3 3 0 00-2 2C1.5 10 1.5 12 1.5 12s0 2 .5 3.8a3 3 0 002 2c2 .5 8 .5 8 .5s6 0 8-.5a3 3 0 002-2c.5-1.8.5-3.8.5-3.8s0-2-.5-3.8zM10 15.3V8.7l5.5 3.3-5.5 3.3z"/></svg></a>
      </div>
    </div>
  </div>
</section>

{% schema %}
