  "name": "Video Wall (Syr)",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "headline", "label": "Headline", "default": "Syruvia in the wild" },
    { "type": "text", "id": "sub", "label": "Subtext", "default": "Real people. Real drinks. Real obsession." },
    { "type": "text", "id": "brand_handle", "label": "Brand handle", "default": "syruviaofficial" },
    { "type": "url", "id": "ig_link", "label": "Instagram URL" },
    { "type": "url", "id": "tt_link", "label": "TikTok URL" },
    { "type": "url", "id": "yt_link", "label": "YouTube URL" },
    { "type": "header", "content": "Video 1" },
    { "type": "image_picker", "id": "v1_thumb", "label": "Thumbnail" },
    { "type": "text", "id": "v1_handle", "label": "Creator handle", "default": "lattegirl" },
    { "type": "text", "id": "v1_tag", "label": "Product tag", "default": "Vanilla Syrup" },
    { "type": "url", "id": "v1_link", "label": "Video link" },
    { "type": "header", "content": "Video 2" },
    { "type": "image_picker", "id": "v2_thumb", "label": "Thumbnail" },
    { "type": "text", "id": "v2_handle", "label": "Creator handle", "default": "sipwith.me" },
    { "type": "text", "id": "v2_tag", "label": "Product tag", "default": "Salted Caramel" },
    { "type": "url", "id": "v2_link", "label": "Video link" },
    { "type": "header", "content": "Video 3" },
    { "type": "image_picker", "id": "v3_thumb", "label": "Thumbnail" },
    { "type": "text", "id": "v3_handle", "label": "Creator handle", "default": "cafechrome" },
    { "type": "text", "id": "v3_tag", "label": "Product tag", "default": "Cotton Candy" },
    { "type": "url", "id": "v3_link", "label": "Video link" },
    { "type": "header", "content": "Video 4" },
    { "type": "image_picker", "id": "v4_thumb", "label": "Thumbnail" },
    { "type": "text", "id": "v4_handle", "label": "Creator handle", "default": "baristabella" },
    { "type": "text", "id": "v4_tag", "label": "Product tag", "default": "Hazelnut" },
    { "type": "url", "id": "v4_link", "label": "Video link" },
    { "type": "header", "content": "Video 5" },
    { "type": "image_picker", "id": "v5_thumb", "label": "Thumbnail" },
    { "type": "text", "id": "v5_handle", "label": "Creator handle", "default": "sweetspotjake" },
    { "type": "text", "id": "v5_tag", "label": "Product tag", "default": "Blueberry" },
    { "type": "url", "id": "v5_link", "label": "Video link" },
    { "type": "header", "content": "Video 6" },
    { "type": "image_picker", "id": "v6_thumb", "label": "Thumbnail" },
    { "type": "text", "id": "v6_handle", "label": "Creator handle", "default": "icedmornings" },
    { "type": "text", "id": "v6_tag", "label": "Product tag", "default": "Banana Nut" },
    { "type": "url", "id": "v6_link", "label": "Video link" }
  ],
  "presets": [ { "name": "Video Wall" } ]
}
{% endschema %}
