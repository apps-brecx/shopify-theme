{%- comment -%} Why Syruvia — SIMPLE: head scrolls normally, only cards stack {%- endcomment -%}
{%- render 'syr-type-polish' -%}
<style id="syr-pts-{{ section.id }}-css">
  #syr-pts-{{ section.id }}{
    --ink:#39220f; --paper:#FFFBF4; --bg:#F4E8CE; --accent:#c58548;
    --butter:#FCE2A0; --peach:#FFD4B8; --mint:#C5E4D4; --sky:#B8DCEB;
    --eye-scale:.55; --eye-rot:0deg;
    background:{{ section.settings.bg_color | default: '#FFFBF4' }};
    padding:60px 0 70px;
    font-family:'Josefin Sans','Josefin',sans-serif;
    color:var(--ink);
    overflow:visible;
  }
  #syr-pts-{{ section.id }} .syr-pts-wrap{ max-width:820px; margin:0 auto; padding:0 24px; overflow:visible; }

  /* HEAD — NOT sticky. Scrolls normally with the page. */
  #syr-pts-{{ section.id }} .syr-pts-head{
    text-align:center; margin:0 auto 32px; max-width:780px; padding:0 8px;
  }
  #syr-pts-{{ section.id }} .syr-pts-eyebrow{
    display:inline-block;
    background:{{ section.settings.eyebrow_bg | default: '#FCE2A0' }};
    color:{{ section.settings.eyebrow_color | default: '#39220f' }};
    border:2px solid var(--ink); border-radius:999px;
    box-shadow:3px 3px 0 var(--ink);
    font-family:'Archivo Black','Archivo Black Fallback','Arial Black',sans-serif !important;
    font-weight:400;
    font-size:12px; letter-spacing:.18em; text-transform:uppercase;
    padding:7px 16px; margin-bottom:18px;
    transform-origin:center;
    transform:scale(var(--eye-scale)) rotate(var(--eye-rot));
    transition:transform .25s cubic-bezier(.16,.84,.34,1);
    will-change:transform;
  }
  @media (prefers-reduced-motion: reduce){
    #syr-pts-{{ section.id }} .syr-pts-eyebrow{ transform:scale(1) rotate(0deg); transition:none; }
  }
  #syr-pts-{{ section.id }} h2{
    font-family:'Archivo Black','Archivo Black Fallback','Arial Black',sans-serif !important;
    font-weight:400;
    font-size:clamp(34px, 5vw, 56px); line-height:.95;
    letter-spacing:-.015em; text-transform:uppercase;
    color:var(--ink); margin:0;
  }
  #syr-pts-{{ section.id }} h2 em{
    font-family:Georgia,'Times New Roman',serif !important; font-style:italic; font-weight:400;
    color:var(--accent); font-size:.78em; letter-spacing:0;
    text-transform:none; display:inline-block; transform:translateY(2px);
  }

  /* STICKY STACK — only cards stick. Simple original behavior. */
  #syr-pts-{{ section.id }} .syr-pts-stack{
    position:relative;
    display:flex; flex-direction:column;
    gap:14px;
  }
  #syr-pts-{{ section.id }} .syr-pts-card{
    position:sticky;
    top: calc(var(--header-height, 90px) + 16px);
    border:2px solid var(--ink); border-radius:24px;
    box-shadow:5px 5px 0 var(--ink);
    padding:40px 28px 36px;
    text-align:center;
    transition:transform .2s cubic-bezier(.4,0,.2,1), box-shadow .2s cubic-bezier(.4,0,.2,1);
    margin-bottom:80px;
  }
  #syr-pts-{{ section.id }} .syr-pts-card:last-child{ margin-bottom:0; }
  #syr-pts-{{ section.id }} .syr-pts-card:hover{ transform:translate(-3px,-3px); box-shadow:8px 8px 0 var(--ink); }

  #syr-pts-{{ section.id }} .syr-pts-card:nth-child(1){ z-index:11; }
  #syr-pts-{{ section.id }} .syr-pts-card:nth-child(2){ z-index:12; }
  #syr-pts-{{ section.id }} .syr-pts-card:nth-child(3){ z-index:13; }
  #syr-pts-{{ section.id }} .syr-pts-card:nth-child(4){ z-index:14; }
  #syr-pts-{{ section.id }} .syr-pts-card:nth-child(5){ z-index:15; }
  #syr-pts-{{ section.id }} .syr-pts-card:nth-child(6){ z-index:16; }
  #syr-pts-{{ section.id }} .syr-pts-card:nth-child(7){ z-index:17; }
  #syr-pts-{{ section.id }} .syr-pts-card:nth-child(8){ z-index:18; }

  #syr-pts-{{ section.id }} .syr-pts-ic{
    width:64px; height:64px; border-radius:50%;
    border:2px solid var(--ink);
    display:flex; align-items:center; justify-content:center;
    margin:0 auto 22px;
    font-size:26px;
    box-shadow:2.5px 2.5px 0 var(--ink);
  }
  #syr-pts-{{ section.id }} .syr-pts-num{
    font-family:'Archivo Black','Archivo Black Fallback','Arial Black',sans-serif !important;
    font-weight:400;
    font-size:clamp(38px, 5vw, 56px); line-height:1;
    color:var(--ink); margin:0 0 18px;
    letter-spacing:-.015em;
  }
  #syr-pts-{{ section.id }} .syr-pts-h{
    font-family:'Archivo Black','Archivo Black Fallback','Arial Black',sans-serif !important;
    font-weight:400;
    font-size:16px; letter-spacing:.16em; text-transform:uppercase;
    color:var(--ink); margin:0 0 16px;
  }
  #syr-pts-{{ section.id }} .syr-pts-desc{
    font-family:'Josefin Sans','Josefin',sans-serif;
    font-size:16px; line-height:1.65;
    color:rgba(57,34,15,.78); margin:0 auto;
    max-width:54ch;
  }

  @media (max-width:760px){
    #syr-pts-{{ section.id }}{ padding:44px 0 52px; }
    #syr-pts-{{ section.id }} .syr-pts-wrap{ padding:0 14px; }
    #syr-pts-{{ section.id }} .syr-pts-head{ margin-bottom:24px; }
    #syr-pts-{{ section.id }} h2{ font-size:clamp(28px, 9vw, 42px); }
    #syr-pts-{{ section.id }} .syr-pts-stack{ gap:10px; }
    #syr-pts-{{ section.id }} .syr-pts-card{
      padding:32px 22px 28px;
      box-shadow:4px 4px 0 var(--ink);
      border-radius:20px;
      margin-bottom:56px;
      top: calc(var(--header-height, 72px) + 10px);
    }
    #syr-pts-{{ section.id }} .syr-pts-ic{ width:56px; height:56px; margin-bottom:18px; font-size:22px; box-shadow:1.5px 1.5px 0 var(--ink); }
    #syr-pts-{{ section.id }} .syr-pts-num{ font-size:clamp(32px, 8vw, 42px); margin-bottom:14px; }
    #syr-pts-{{ section.id }} .syr-pts-h{ font-size:14px; margin-bottom:12px; }
    #syr-pts-{{ section.id }} .syr-pts-desc{ font-size:14.5px; line-height:1.6; }
  }

  body #syr-pts-{{ section.id }},
  body #syr-pts-{{ section.id }} .syr-pts-wrap,
  body #syr-pts-{{ section.id }} .syr-pts-stack{ overflow:visible !important; }
</style>

<section id="syr-pts-{{ section.id }}">
  <div class="syr-pts-wrap">
    <div class="syr-pts-head">
      <span class="syr-pts-eyebrow">{{ section.settings.eyebrow_text | default: 'Why Syruvia' }}</span>
      <h2>{{ section.settings.headline }}</h2>
    </div>
    <div class="syr-pts-stack">
      {%- for block in section.blocks -%}
        {%- assign bg = block.settings.bg_color | default: '#FFD4B8' -%}
        {%- assign txt = block.settings.text_color | default: '#39220f' -%}
        {%- assign ic_bg = block.settings.icon_bg | default: '#FFFBF4' -%}
        {%- assign ic_color = block.settings.icon_color | default: '#39220f' -%}
        {%- assign shadow = block.settings.shadow_color | default: '#39220f' -%}
        <div class="syr-pts-card" {{ block.shopify_attributes }}
             style="background:{{ bg }}; color:{{ txt }}; box-shadow:5px 5px 0 {{ shadow }}; border-color:{{ shadow }};">
          <div class="syr-pts-ic" style="background:{{ ic_bg }}; color:{{ ic_color }}; border-color:{{ shadow }};">{{ block.settings.icon }}</div>
          {%- if block.settings.num != blank -%}<p class="syr-pts-num" style="color:{{ txt }};">{{ block.settings.num }}</p>{%- endif -%}
          {%- if block.settings.heading != blank -%}<h3 class="syr-pts-h" style="color:{{ txt }};">{{ block.settings.heading }}</h3>{%- endif -%}
          {%- if block.settings.description != blank -%}<p class="syr-pts-desc" style="color:{{ txt }}; opacity:.82;">{{ block.settings.description }}</p>{%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<script>
(function(){
  var root = document.getElementById('syr-pts-{{ section.id }}');
  if (!root) return;

  /* Scroll-grow eyebrow (head not sticky, so eyebrow grows as section enters viewport) */
  var eyebrow = root.querySelector('.syr-pts-eyebrow');
  if (eyebrow && !(window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches)){
    var ticking = false;
    function updateEye(){
      var rect = eyebrow.getBoundingClientRect();
      var vh = window.innerHeight || document.documentElement.clientHeight;
      if (vh < 1) return;
      var elementCenter = rect.top + rect.height / 2;
      var viewportCenter = vh / 2;
      var progress = (viewportCenter - elementCenter) / vh;
      if (progress < -1) progress = -1; if (progress > 1) progress = 1;
      var scale = 0.55 + (progress + 0.4) * 0.7;
      if (scale < 0.4) scale = 0.4; if (scale > 1.3) scale = 1.3;
      var rot = progress * 6;
      if (rot < -6) rot = -6; if (rot > 6) rot = 6;
      root.style.setProperty('--eye-scale', scale.toFixed(3));
      root.style.setProperty('--eye-rot', rot.toFixed(2) + 'deg');
      ticking = false;
    }
    window.addEventListener('scroll', function(){ if (!ticking){ ticking = true; window.requestAnimationFrame(updateEye); } }, { passive:true });
    window.addEventListener('resize', updateEye);
    updateEye();
  }

  /* Ensure --header-height is set so cards stick just below the main nav */
  function syncHeaderHeight(){
    if (document.documentElement.style.getPropertyValue('--header-height')) return;
    var nav = document.querySelector('#syrnav') || document.querySelector('.shopify-section-header') || document.querySelector('.section-header');
    var h = nav ? nav.offsetHeight : 0;
    if (h > 0) document.documentElement.style.setProperty('--header-height', h + 'px');
  }
  syncHeaderHeight();
  window.addEventListener('load', syncHeaderHeight);
  window.addEventListener('resize', syncHeaderHeight);
})();
</script>

{% schema %}
{
  "name": "Why Syruvia (Stack)",
  "tag": "section",
  "max_blocks": 8,
  "settings": [
    { "type": "header", "content": "Header" },
    { "type": "text", "id": "eyebrow_text", "label": "Eyebrow text", "default": "Why Syruvia" },
    { "type": "text", "id": "headline", "label": "Headline (use <em>word</em> for italic accent)", "default": "A better way to <em>pour.</em>" },
    { "type": "color", "id": "bg_color", "label": "Section background", "default": "#FFFBF4" },
    { "type": "color", "id": "eyebrow_bg", "label": "Eyebrow background", "default": "#FCE2A0" },
    { "type": "color", "id": "eyebrow_color", "label": "Eyebrow text color", "default": "#39220f" },
    { "type": "paragraph", "content": "Each card is a block below. Drag to reorder. Click a block to edit its number, heading, description and colors." }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "Card",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (emoji or text)", "default": "✨" },
        { "type": "text", "id": "num", "label": "Big number / stat (e.g. 250+, 0g, USA, 4.9★)" },
        { "type": "text", "id": "heading", "label": "Heading (under number)" },
        { "type": "textarea", "id": "description", "label": "Description (SEO copy)" },
        { "type": "color", "id": "bg_color", "label": "Card background", "default": "#FFD4B8" },
        { "type": "color", "id": "text_color", "label": "Text color", "default": "#39220f" },
        { "type": "color", "id": "icon_bg", "label": "Icon circle background", "default": "#FFFBF4" },
        { "type": "color", "id": "icon_color", "label": "Icon color", "default": "#39220f" },
        { "type": "color", "id": "shadow_color", "label": "Border + offset shadow color", "default": "#39220f" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Syruvia",
      "blocks": [
        { "type": "point", "settings": { "icon": "✨", "num": "250+", "heading": "Flavors", "description": "From classic vanilla to cotton candy, Syruvia offers over 250 craft syrup flavors.", "bg_color": "#FFD4B8" } },
        { "type": "point", "settings": { "icon": "🇺🇸", "num": "USA", "heading": "Made here", "description": "Small-batch crafted in the United States with real ingredients you can actually pronounce.", "bg_color": "#FCE2A0" } },
        { "type": "point", "settings": { "icon": "☕", "num": "0g", "heading": "Sugar-free", "description": "Every flavor available in a sugar-free version with the same rich, craft taste.", "bg_color": "#C5E4D4" } },
        { "type": "point", "settings": { "icon": "★", "num": "4.9★", "heading": "Sippers obsessed", "description": "Over 5 million happy customers and a 4.9-star average across thousands of verified reviews.", "bg_color": "#B8DCEB" } }
      ]
    }
  ]
}
{% endschema %}
