{%- comment -%}
  Syrup Pouches — launch / pre-order page (Syruvia) · v2 "full color".
  Colorful band layout (gradient hero, wavy color bands, rainbow flavor tiles) in the
  brand system — logo espresso #3c2415 + orange #e28f26 with a warm fruit palette.
  • Hero: Syrup Pouches logo lockup, VIP pre-order badge, chips, Shop now (anchors to grid).
  • VIP gating switch (signed-in / strict VIP tag / everyone) with join-free gate card.
  • "Live now" duo: two product pickers (Vanilla + Sugar-Free Vanilla) as big spotlight
    cards; falls back to the first two collection products if none picked.
  • Three full-bleed picture bands (editable image slots; hidden until an image is set).
  • Flavor grid: live products from a collection + coming-soon overlay tiles from
    editable lists; All / Regular / Sugar-Free tabs; colorful tile backgrounds.
  Mobile-first, reveal-on-scroll, fonts non-blocking, prefers-reduced-motion respected.
{%- endcomment -%}
{%- assign s = section.settings -%}
{%- assign rad = s.card_radius | default: 18 -%}
{%- assign cl = collections[s.collection_handle] -%}

{%- assign allowed = false -%}
{%- case s.access_mode -%}
  {%- when 'everyone' -%}{%- assign allowed = true -%}
  {%- when 'vip_tag' -%}{%- if customer and customer.tags contains 'VIP' -%}{%- assign allowed = true -%}{%- endif -%}
  {%- else -%}{%- if customer -%}{%- assign allowed = true -%}{%- endif -%}
{%- endcase -%}

{%- assign logo_top = 'sp-logo-syrup.svg' | asset_url -%}
{%- assign logo_main = 'sp-logo-pouches.svg' | asset_url -%}
{%- if s.logo_top != blank -%}{%- assign logo_top = s.logo_top | image_url: width: 600 -%}{%- endif -%}
{%- if s.logo_main != blank -%}{%- assign logo_main = s.logo_main | image_url: width: 1000 -%}{%- endif -%}

{%- comment -%} featured live duo: product pickers, fallback to first 2 collection products {%- endcomment -%}
{%- assign f1 = s.feat_prod_1 -%}
{%- assign f2 = s.feat_prod_2 -%}
{%- if f1 == blank and cl != blank and cl.products.size > 0 -%}{%- assign f1 = cl.products[0] -%}{%- endif -%}
{%- if f2 == blank and cl != blank and cl.products.size > 1 -%}{%- assign f2 = cl.products[1] -%}{%- endif -%}

{%- capture live_titles -%}{%- if cl != blank -%}{%- for p in cl.products limit: 50 -%}{{ p.title | downcase }}|{%- endfor -%}{%- endif -%}{%- endcapture -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" media="print" onload="this.media='all'" href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Josefin+Sans:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&display=swap">
<noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Josefin+Sans:wght@300;400;600;700&display=swap"></noscript>

<style>
  #sp-{{ section.id }}{
    --ink:{{ s.color_ink | default: '#1a1a1a' }};
    --brand:{{ s.color_brand | default: '#3c2415' }};
    --bg:{{ s.color_bg | default: '#FFFBF4' }};
    --paper:{{ s.color_paper | default: '#ffffff' }};
    --orange:{{ s.color_orange | default: '#e28f26' }};
    --pop:{{ s.color_pop | default: '#C8252B' }};
    --rule-c:{{ s.color_rule | default: '#3c2415' }};
    --soon:{{ s.coming_overlay | default: '#3c2415' }};
    --gold:#F6C14E;--peach:#FF9E7A;--pink:#F5567B;--sky:#5FB4E5;--mint:#7CC9A1;--lav:#B69AE0;
    --wrap:{{ s.wrap_max | default: 1120 }}px;
    --rad:{{ rad }}px;
    --display:'Archivo Black','Josefin Sans',system-ui,sans-serif;
    --serif:'Josefin Sans',system-ui,sans-serif;
    --rule:2px solid var(--rule-c);
    background:var(--bg);color:var(--ink);font-family:var(--serif);position:relative;overflow-x:clip;font-size:16px;line-height:1.5;scroll-behavior:smooth;
  }
  #sp-{{ section.id }} *{box-sizing:border-box;}
  #sp-{{ section.id }} .sp-wrap{max-width:var(--wrap);margin:0 auto;padding:0 18px;}
  #sp-{{ section.id }} .sp-eyebrow{font-family:var(--display);font-size:11px;letter-spacing:.16em;text-transform:uppercase;display:inline-block;padding:7px 14px;border:var(--rule);border-radius:999px;background:var(--paper);color:var(--brand);}
  #sp-{{ section.id }} .sp-h2{font-family:var(--display);font-weight:900;font-size:clamp(24px,6.4vw,44px);line-height:.98;letter-spacing:-.01em;text-transform:uppercase;margin:12px 0 0;color:var(--brand);text-wrap:balance;}
  #sp-{{ section.id }} .sp-h2 em{font-family:var(--serif);font-weight:300;font-style:italic;text-transform:none;color:var(--orange);}
  #sp-{{ section.id }} .sp-rev{opacity:0;transform:translateY(22px);transition:opacity .6s ease,transform .7s cubic-bezier(.2,.7,.2,1);}
  #sp-{{ section.id }} .sp-rev.in{opacity:1;transform:none;}
  #sp-{{ section.id }} .sp-btn{display:inline-flex;align-items:center;justify-content:center;gap:9px;font-family:var(--display);font-size:14px;letter-spacing:.08em;text-transform:uppercase;text-decoration:none;padding:16px 26px;border:var(--rule);border-radius:999px;cursor:pointer;transition:transform .14s ease,box-shadow .14s ease;background:var(--orange);color:#fff;box-shadow:4px 4px 0 var(--rule-c);}
  #sp-{{ section.id }} .sp-btn--ghost{background:var(--paper);color:var(--brand);}
  #sp-{{ section.id }} .sp-btn--pop{background:var(--pop);}
  #sp-{{ section.id }} .sp-btn:active{transform:translate(2px,2px);box-shadow:2px 2px 0 var(--rule-c);}
  @media(hover:hover){#sp-{{ section.id }} .sp-btn:hover{transform:translate(-2px,-2px);box-shadow:6px 6px 0 var(--rule-c);}}
  #sp-{{ section.id }} .sp-btnrow{display:flex;gap:12px;flex-wrap:wrap;justify-content:center;}
  @media(max-width:560px){#sp-{{ section.id }} .sp-btnrow .sp-btn{width:100%;}}
  /* wave divider */
  #sp-{{ section.id }} .sp-wave{display:block;width:100%;height:clamp(26px,5vw,56px);}

  /* ===== HERO — warm gradient + blobs ===== */
  #sp-{{ section.id }} .sp-hero{position:relative;padding:clamp(34px,7vw,64px) 0 clamp(30px,5vw,50px);text-align:center;overflow:hidden;background:linear-gradient(180deg,{{ s.hero_g1 | default: '#FFF3DC' }} 0%,{{ s.hero_g2 | default: '#FFD9A0' }} 100%);}
  #sp-{{ section.id }} .sp-blob{position:absolute;border-radius:50%;opacity:.5;pointer-events:none;filter:blur(2px);}
  #sp-{{ section.id }} .sp-blob.b1{width:26vw;height:26vw;max-width:280px;max-height:280px;background:var(--gold);top:-8%;left:-6%;}
  #sp-{{ section.id }} .sp-blob.b2{width:20vw;height:20vw;max-width:220px;max-height:220px;background:var(--peach);bottom:-10%;right:-4%;}
  #sp-{{ section.id }} .sp-blob.b3{width:12vw;height:12vw;max-width:130px;max-height:130px;background:var(--pink);top:18%;right:10%;opacity:.35;}
  #sp-{{ section.id }} .sp-hero .sp-wrap{position:relative;z-index:2;}
  #sp-{{ section.id }} .sp-vipflag{display:inline-flex;align-items:center;gap:8px;background:var(--pop);color:#fff;border:var(--rule);border-radius:999px;font-family:var(--display);font-size:11.5px;letter-spacing:.12em;text-transform:uppercase;padding:8px 16px;box-shadow:3px 3px 0 var(--rule-c);}
  #sp-{{ section.id }} .sp-vipflag .dot{width:8px;height:8px;border-radius:50%;background:#fff;animation:sppulse{{ section.id }} 1.6s infinite;}
  @keyframes sppulse{{ section.id }}{0%{box-shadow:0 0 0 0 rgba(255,255,255,.7)}70%{box-shadow:0 0 0 7px rgba(255,255,255,0)}100%{box-shadow:0 0 0 0 rgba(255,255,255,0)}}
  #sp-{{ section.id }} .sp-logo{margin:22px auto 0;max-width:min(520px,86vw);}
  #sp-{{ section.id }} .sp-logo .top{display:block;width:56%;margin:0 auto;}
  #sp-{{ section.id }} .sp-logo .main{display:block;width:100%;margin:6px auto 0;}
  #sp-{{ section.id }} .sp-logo img{width:100%;height:auto;display:block;}
  #sp-{{ section.id }} .sp-sub{font-size:clamp(16px,4vw,20px);margin:18px auto 0;max-width:44ch;color:var(--brand);}
  #sp-{{ section.id }} .sp-chips{display:flex;justify-content:center;gap:10px;flex-wrap:wrap;margin-top:16px;}
  #sp-{{ section.id }} .sp-chip{font-family:var(--display);font-size:11px;letter-spacing:.1em;text-transform:uppercase;border:var(--rule);border-radius:999px;padding:7px 14px;background:var(--paper);color:var(--brand);box-shadow:2px 2px 0 var(--rule-c);}
  #sp-{{ section.id }} .sp-chip.c1{background:var(--gold);}
  #sp-{{ section.id }} .sp-chip.c2{background:var(--sky);color:#fff;}
  #sp-{{ section.id }} .sp-chip.c3{background:var(--pink);color:#fff;}
  #sp-{{ section.id }} .sp-hero .sp-btnrow{margin-top:24px;}

  /* ===== VIP GATE ===== */
  #sp-{{ section.id }} .sp-gate{padding:26px 0;scroll-margin-top:90px;background:var(--bg);}
  #sp-{{ section.id }} .sp-gate-card{max-width:640px;margin:0 auto;background:var(--paper);border:var(--rule);border-radius:calc(var(--rad) + 8px);box-shadow:7px 7px 0 var(--rule-c);padding:26px 22px;text-align:center;}
  #sp-{{ section.id }} .sp-gate-card .lock{width:52px;height:52px;border-radius:50%;background:var(--orange);border:var(--rule);box-shadow:3px 3px 0 var(--rule-c);display:inline-flex;align-items:center;justify-content:center;font-size:22px;margin-top:-52px;}
  #sp-{{ section.id }} .sp-gate-card h2{font-family:var(--display);font-size:clamp(19px,4.8vw,26px);text-transform:uppercase;color:var(--brand);margin:12px 0 0;line-height:1.05;}
  #sp-{{ section.id }} .sp-gate-card p{font-size:14.5px;opacity:.85;margin:10px auto 0;max-width:44ch;}
  #sp-{{ section.id }} .sp-gate-card .sp-btnrow{margin-top:18px;}
  #sp-{{ section.id }} .sp-unlocked{max-width:640px;margin:0 auto;background:#C5E4D4;border:2px solid #2b6b53;color:#2b6b53;border-radius:16px;padding:13px 16px;text-align:center;font-family:var(--display);font-size:13px;letter-spacing:.06em;text-transform:uppercase;}

  /* ===== LIVE NOW duo — orange band ===== */
  #sp-{{ section.id }} .sp-live{background:var(--orange);padding:clamp(30px,6vw,56px) 0 clamp(38px,7vw,64px);}
  #sp-{{ section.id }} .sp-live .sp-head{text-align:center;margin-bottom:24px;}
  #sp-{{ section.id }} .sp-live .sp-eyebrow{background:var(--paper);}
  #sp-{{ section.id }} .sp-live .sp-h2{color:#fff;text-shadow:2px 3px 0 rgba(60,36,21,.35);}
  #sp-{{ section.id }} .sp-live .sp-h2 em{color:#FFE7B8;}
  #sp-{{ section.id }} .sp-duo{display:grid;grid-template-columns:1fr;gap:18px;max-width:880px;margin:0 auto;}
  @media(min-width:700px){#sp-{{ section.id }} .sp-duo{grid-template-columns:1fr 1fr;}}
  #sp-{{ section.id }} .sp-feat{position:relative;display:flex;flex-direction:column;background:var(--paper);border:var(--rule);border-radius:calc(var(--rad) + 8px);box-shadow:7px 7px 0 var(--rule-c);overflow:hidden;text-decoration:none;color:var(--ink);transition:transform .18s ease,box-shadow .18s ease;}
  @media(hover:hover){#sp-{{ section.id }} a.sp-feat:hover{transform:translate(-3px,-3px);box-shadow:10px 10px 0 var(--rule-c);}}
  #sp-{{ section.id }} .sp-feat .ph{aspect-ratio:1/1;display:flex;align-items:center;justify-content:center;border-bottom:var(--rule);padding:18px;}
  #sp-{{ section.id }} .sp-feat:nth-child(1) .ph{background:linear-gradient(160deg,#FFF3DC,var(--gold));}
  #sp-{{ section.id }} .sp-feat:nth-child(2) .ph{background:linear-gradient(160deg,#EAF6FF,var(--sky));}
  #sp-{{ section.id }} .sp-feat .ph img{max-width:100%;max-height:100%;object-fit:contain;filter:drop-shadow(5px 8px 0 rgba(60,36,21,.18));}
  #sp-{{ section.id }} .sp-feat .b{padding:18px 16px 20px;text-align:center;display:flex;flex-direction:column;gap:8px;flex:1;}
  #sp-{{ section.id }} .sp-feat .t{font-family:var(--display);font-size:17px;line-height:1.12;text-transform:uppercase;color:var(--brand);}
  #sp-{{ section.id }} .sp-feat .p{font-family:var(--display);font-size:19px;color:var(--brand);}
  #sp-{{ section.id }} .sp-feat .cta{margin-top:auto;font-family:var(--display);font-size:12.5px;letter-spacing:.08em;text-transform:uppercase;background:var(--brand);color:#fff;border:var(--rule);border-radius:999px;padding:13px 18px;box-shadow:3px 3px 0 rgba(0,0,0,.25);}
  #sp-{{ section.id }} .sp-livebadge{position:absolute;top:11px;left:11px;z-index:2;display:inline-flex;align-items:center;gap:6px;background:var(--pop);color:#fff;border:var(--rule);border-radius:999px;font-family:var(--display);font-size:10px;letter-spacing:.08em;text-transform:uppercase;padding:6px 11px;}
  #sp-{{ section.id }} .sp-livebadge .d{width:7px;height:7px;border-radius:50%;background:#fff;animation:sppulse{{ section.id }} 1.6s infinite;}
  #sp-{{ section.id }} .sp-sfbadge{position:absolute;top:11px;right:11px;z-index:2;background:var(--sky);color:#fff;border:var(--rule);border-radius:999px;font-family:var(--display);font-size:10px;letter-spacing:.06em;text-transform:uppercase;padding:6px 11px;}

  /* ===== FULL-BLEED PICTURE BANDS ===== */
  #sp-{{ section.id }} .sp-band{position:relative;}
  #sp-{{ section.id }} .sp-band img{display:block;width:100%;height:auto;}
  #sp-{{ section.id }} .sp-band .m{display:none;}
  @media(max-width:760px){
    #sp-{{ section.id }} .sp-band .has-m.d{display:none;}
    #sp-{{ section.id }} .sp-band .m{display:block;}
  }

  /* ===== ABOUT — espresso band ===== */
  #sp-{{ section.id }} .sp-about{background:var(--brand);color:var(--bg);padding:clamp(34px,6vw,60px) 0 clamp(26px,5vw,44px);}
  #sp-{{ section.id }} .sp-about .sp-row{display:grid;grid-template-columns:1fr;gap:18px;align-items:center;margin-bottom:30px;}
  #sp-{{ section.id }} .sp-about .sp-row:last-child{margin-bottom:0;}
  #sp-{{ section.id }} .sp-about img{width:100%;height:auto;display:block;border:2px solid var(--bg);border-radius:calc(var(--rad) + 6px);box-shadow:6px 6px 0 var(--orange);}
  #sp-{{ section.id }} .sp-about .txt h3{font-family:var(--display);font-size:clamp(20px,5vw,30px);text-transform:uppercase;color:#fff;margin:0;line-height:1.02;}
  #sp-{{ section.id }} .sp-about .txt h3 em{font-family:var(--serif);font-weight:300;font-style:italic;text-transform:none;color:var(--gold);}
  #sp-{{ section.id }} .sp-about .txt p{font-size:15.5px;opacity:.88;margin:10px 0 0;max-width:52ch;}
  @media(min-width:820px){
    #sp-{{ section.id }} .sp-about .sp-row{grid-template-columns:1fr 1fr;gap:clamp(24px,4vw,54px);}
    #sp-{{ section.id }} .sp-about .sp-row.flip .media{order:2;}
  }

  /* ===== GRID ===== */
  #sp-{{ section.id }} .sp-shop{padding:34px 0 60px;scroll-margin-top:80px;background:var(--bg);}
  #sp-{{ section.id }} .sp-head{text-align:center;margin-bottom:18px;}
  #sp-{{ section.id }} .sp-tabs{display:flex;justify-content:center;gap:8px;flex-wrap:wrap;margin:18px 0 22px;}
  #sp-{{ section.id }} .sp-tab{font-family:var(--display);font-size:12px;letter-spacing:.08em;text-transform:uppercase;border:var(--rule);border-radius:999px;padding:10px 18px;background:var(--paper);color:var(--brand);cursor:pointer;transition:transform .12s ease;box-shadow:2px 2px 0 var(--rule-c);}
  #sp-{{ section.id }} .sp-tab.on{background:var(--orange);color:#fff;}
  #sp-{{ section.id }} .sp-tab:active{transform:scale(.96);}
  #sp-{{ section.id }} .sp-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;}
  @media(min-width:640px){#sp-{{ section.id }} .sp-grid{grid-template-columns:repeat(3,1fr);}}
  @media(min-width:960px){#sp-{{ section.id }} .sp-grid{grid-template-columns:repeat(4,1fr);}}
  #sp-{{ section.id }} .sp-tile{position:relative;display:flex;flex-direction:column;background:var(--paper);border:var(--rule);border-radius:var(--rad);box-shadow:5px 5px 0 var(--rule-c);overflow:hidden;text-decoration:none;color:var(--ink);transition:transform .18s ease,box-shadow .18s ease;}
  @media(hover:hover){#sp-{{ section.id }} a.sp-tile:hover{transform:translate(-3px,-3px);box-shadow:8px 8px 0 var(--rule-c);}}
  #sp-{{ section.id }} .sp-tile .ph{aspect-ratio:1/1;display:flex;align-items:center;justify-content:center;border-bottom:var(--rule);background:var(--bg);padding:12px;}
  #sp-{{ section.id }} .sp-tile .ph img{max-width:100%;max-height:100%;object-fit:contain;}
  /* rainbow tile backgrounds */
  #sp-{{ section.id }} .sp-grid .sp-tile:nth-child(6n+1) .ph{background:#FFF3DC;}
  #sp-{{ section.id }} .sp-grid .sp-tile:nth-child(6n+2) .ph{background:#FFE9DB;}
  #sp-{{ section.id }} .sp-grid .sp-tile:nth-child(6n+3) .ph{background:#EAF6FF;}
  #sp-{{ section.id }} .sp-grid .sp-tile:nth-child(6n+4) .ph{background:#FDE7EE;}
  #sp-{{ section.id }} .sp-grid .sp-tile:nth-child(6n+5) .ph{background:#E9F7EF;}
  #sp-{{ section.id }} .sp-grid .sp-tile:nth-child(6n+6) .ph{background:#F1EBFB;}
  #sp-{{ section.id }} .sp-tile .b{padding:13px 12px 15px;text-align:center;display:flex;flex-direction:column;gap:6px;flex:1;}
  #sp-{{ section.id }} .sp-tile .t{font-family:var(--display);font-size:13px;line-height:1.15;text-transform:uppercase;letter-spacing:.02em;color:var(--brand);}
  #sp-{{ section.id }} .sp-tile .p{margin-top:auto;font-family:var(--display);font-size:15px;color:var(--brand);}
  #sp-{{ section.id }} .sp-badge{position:absolute;top:9px;left:9px;z-index:2;background:var(--pop);color:#fff;border:var(--rule);border-radius:999px;font-family:var(--display);font-size:9.5px;letter-spacing:.06em;text-transform:uppercase;padding:5px 9px;}
  #sp-{{ section.id }} .sp-badge.sf{background:var(--sky);left:auto;right:9px;}
  #sp-{{ section.id }} .sp-tile.locked .ph,#sp-{{ section.id }} .sp-tile.locked .b{filter:grayscale(.25);}
  #sp-{{ section.id }} .sp-lockov{position:absolute;inset:0;z-index:3;background:rgba(60,36,21,.45);display:flex;align-items:center;justify-content:center;}
  #sp-{{ section.id }} .sp-lockov span{font-family:var(--display);font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:#fff;background:var(--brand);border:2px solid #fff;border-radius:999px;padding:8px 14px;}
  /* coming soon — colorful name tiles */
  #sp-{{ section.id }} .sp-tile.soon .ph .fl{font-family:var(--display);font-size:clamp(15px,3.4vw,19px);line-height:1.1;text-transform:uppercase;color:var(--brand);text-align:center;padding:0 10px;}
  #sp-{{ section.id }} .sp-grid .sp-tile.soon:nth-child(6n+1) .ph{background:var(--gold);}
  #sp-{{ section.id }} .sp-grid .sp-tile.soon:nth-child(6n+2) .ph{background:var(--peach);}
  #sp-{{ section.id }} .sp-grid .sp-tile.soon:nth-child(6n+3) .ph{background:var(--sky);}
  #sp-{{ section.id }} .sp-grid .sp-tile.soon:nth-child(6n+4) .ph{background:var(--pink);}
  #sp-{{ section.id }} .sp-grid .sp-tile.soon:nth-child(6n+5) .ph{background:var(--mint);}
  #sp-{{ section.id }} .sp-grid .sp-tile.soon:nth-child(6n+6) .ph{background:var(--lav);}
  #sp-{{ section.id }} .sp-soonov{position:absolute;inset:0;z-index:3;background:color-mix(in srgb, var(--soon) 45%, transparent);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:7px;}
  @supports not (background: color-mix(in srgb, red 50%, transparent)){#sp-{{ section.id }} .sp-soonov{background:rgba(60,36,21,.5);}}
  #sp-{{ section.id }} .sp-soonov .cs{font-family:var(--display);font-size:11.5px;letter-spacing:.1em;text-transform:uppercase;color:var(--brand);background:#fff;border:var(--rule);border-radius:999px;padding:8px 14px;}
  #sp-{{ section.id }} .sp-soonov .dt{font-family:var(--display);font-size:10px;letter-spacing:.08em;text-transform:uppercase;color:#fff;}
  #sp-{{ section.id }} .sp-empty{text-align:center;border:2px dashed var(--rule-c);border-radius:var(--rad);padding:30px 18px;background:var(--paper);opacity:.85;}
  #sp-{{ section.id }} .sp-note{text-align:center;font-size:13px;opacity:.75;margin-top:18px;}

  @media (prefers-reduced-motion: reduce){
    #sp-{{ section.id }} .sp-rev{opacity:1;transform:none;}
    #sp-{{ section.id }} .sp-vipflag .dot,#sp-{{ section.id }} .sp-livebadge .d{animation:none;}
  }
</style>

<section id="sp-{{ section.id }}">

  {%- comment -%} ===== HERO ===== {%- endcomment -%}
  <div class="sp-hero">
    <span class="sp-blob b1" aria-hidden="true"></span><span class="sp-blob b2" aria-hidden="true"></span><span class="sp-blob b3" aria-hidden="true"></span>
    <div class="sp-wrap">
      {%- if s.vip_badge != blank -%}<span class="sp-vipflag sp-rev"><span class="dot"></span>{{ s.vip_badge }}</span>{%- endif -%}
      <div class="sp-logo sp-rev">
        <span class="top"><img src="{{ logo_top }}" alt="Syrup" loading="eager"></span>
        <span class="main"><img src="{{ logo_main }}" alt="Pouches" loading="eager"></span>
      </div>
      {%- if s.hero_sub != blank -%}<p class="sp-sub sp-rev">{{ s.hero_sub }}</p>{%- endif -%}
      <div class="sp-chips sp-rev">
        {%- if s.chip1 != blank -%}<span class="sp-chip c1">{{ s.chip1 }}</span>{%- endif -%}
        {%- if s.chip2 != blank -%}<span class="sp-chip c2">{{ s.chip2 }}</span>{%- endif -%}
        {%- if s.chip3 != blank -%}<span class="sp-chip c3">{{ s.chip3 }}</span>{%- endif -%}
      </div>
      <div class="sp-btnrow sp-rev">
        <a class="sp-btn sp-btn--pop" href="#sp-shop-{{ section.id }}">{{ s.shop_btn | default: 'Shop now' }}</a>
        {%- if s.collection_btn_url != blank -%}<a class="sp-btn sp-btn--ghost" href="{{ s.collection_btn_url }}">{{ s.collection_btn_text | default: 'View the collection' }}</a>{%- endif -%}
      </div>
    </div>
  </div>
  <svg class="sp-wave" viewBox="0 0 1440 60" preserveAspectRatio="none" aria-hidden="true" style="background:{{ s.hero_g2 | default: '#FFD9A0' }};"><path d="M0,32 C240,64 480,0 720,30 C960,60 1200,4 1440,32 L1440,60 L0,60 Z" fill="{{ s.color_bg | default: '#FFFBF4' }}"/></svg>

  {%- comment -%} ===== VIP GATE / UNLOCKED ===== {%- endcomment -%}
  <div class="sp-gate" id="sp-gate-{{ section.id }}">
    <div class="sp-wrap">
      {%- if allowed -%}
        {%- if s.access_mode != 'everyone' and s.unlocked_text != blank -%}
          <div class="sp-unlocked sp-rev">✓ {{ s.unlocked_text }}</div>
        {%- endif -%}
      {%- else -%}
        <div class="sp-gate-card sp-rev">
          <span class="lock" aria-hidden="true">🔒</span>
          <h2>{{ s.gate_title | default: 'Pre-order is VIP-only right now' }}</h2>
          <p>{{ s.gate_text | default: 'VIP membership is free. Create an account (or sign in) and you can pre-order every pouch flavor before everyone else. Open to all on Monday.' }}</p>
          <div class="sp-btnrow">
            <a class="sp-btn" href="{{ routes.account_register_url }}?return_url={{ request.path | url_encode }}">{{ s.gate_join | default: 'Join VIP — it’s free' }}</a>
            <a class="sp-btn sp-btn--ghost" href="{{ routes.account_login_url }}?return_url={{ request.path | url_encode }}">{{ s.gate_signin | default: 'Sign in' }}</a>
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} ===== LIVE NOW — the two live listings ===== {%- endcomment -%}
  {%- if s.show_featured and f1 != blank or s.show_featured and f2 != blank -%}
  <svg class="sp-wave" viewBox="0 0 1440 60" preserveAspectRatio="none" aria-hidden="true" style="background:{{ s.color_bg | default: '#FFFBF4' }};transform:scaleY(-1);"><path d="M0,32 C240,64 480,0 720,30 C960,60 1200,4 1440,32 L1440,60 L0,60 Z" fill="{{ s.color_orange | default: '#e28f26' }}"/></svg>
  <div class="sp-live">
    <div class="sp-wrap">
      <div class="sp-head sp-rev">
        {%- if s.feat_eyebrow != blank -%}<span class="sp-eyebrow">{{ s.feat_eyebrow }}</span>{%- endif -%}
        <h2 class="sp-h2">{{ s.feat_title | default: 'Live now — <em>pre-order today</em>' }}</h2>
      </div>
      <div class="sp-duo">
        {%- for fi in (1..2) -%}
          {%- if fi == 1 -%}{%- assign fp = f1 -%}{%- else -%}{%- assign fp = f2 -%}{%- endif -%}
          {%- if fp == blank -%}{%- continue -%}{%- endif -%}
          {%- assign tdl = fp.title | downcase -%}
          {%- assign issf = false -%}{%- if tdl contains 'sugar free' or tdl contains 'sugar-free' -%}{%- assign issf = true -%}{%- endif -%}
          {%- if allowed -%}<a class="sp-feat sp-rev" href="{{ fp.url }}">{%- else -%}<a class="sp-feat sp-rev" href="#sp-gate-{{ section.id }}">{%- endif -%}
            <span class="sp-livebadge"><span class="d"></span>{{ s.live_badge | default: 'Live now' }}</span>
            {%- if issf -%}<span class="sp-sfbadge">{{ s.sf_badge | default: '0g sugar' }}</span>{%- endif -%}
            <span class="ph">{%- if fp.featured_image -%}<img src="{{ fp.featured_image | image_url: width: 720 }}" alt="{{ fp.title | escape }}" loading="lazy">{%- endif -%}</span>
            <span class="b">
              <span class="t">{{ fp.title | replace: '(USA)', '' | strip }}</span>
              <span class="p">{{ fp.price | money }}</span>
              <span class="cta">{% if allowed %}{{ s.preorder_badge | default: 'Pre-order' }} →{% else %}🔒 {{ s.locked_label | default: 'VIP only' }}{% endif %}</span>
            </span>
          </a>
        {%- endfor -%}
      </div>
    </div>
  </div>
  <svg class="sp-wave" viewBox="0 0 1440 60" preserveAspectRatio="none" aria-hidden="true" style="background:{{ s.color_orange | default: '#e28f26' }};"><path d="M0,32 C240,64 480,0 720,30 C960,60 1200,4 1440,32 L1440,60 L0,60 Z" fill="{{ s.color_bg | default: '#FFFBF4' }}"/></svg>
  {%- endif -%}

  {%- comment -%} ===== FULL-BLEED PICTURE 1 ===== {%- endcomment -%}
  {%- if s.band1_img != blank -%}
  <div class="sp-band">
    <img class="d {% if s.band1_img_m != blank %}has-m{% endif %}" src="{{ s.band1_img | image_url: width: 2400 }}" alt="{{ s.band1_alt | default: 'Syrup Pouches' | escape }}" loading="lazy">
    {%- if s.band1_img_m != blank -%}<img class="m" src="{{ s.band1_img_m | image_url: width: 1200 }}" alt="{{ s.band1_alt | default: 'Syrup Pouches' | escape }}" loading="lazy">{%- endif -%}
  </div>
  {%- endif -%}

  {%- comment -%} ===== ABOUT — espresso band ===== {%- endcomment -%}
  {%- if s.show_about -%}
  <div class="sp-about">
    <div class="sp-wrap">
      {%- if s.row1_img != blank or s.row1_title != blank -%}
      <div class="sp-row sp-rev">
        <div class="media">{%- if s.row1_img != blank -%}<img src="{{ s.row1_img | image_url: width: 1200 }}" alt="{{ s.row1_title | escape }}" loading="lazy">{%- endif -%}</div>
        <div class="txt">{%- if s.row1_title != blank -%}<h3>{{ s.row1_title }}</h3>{%- endif -%}{%- if s.row1_text != blank -%}<p>{{ s.row1_text }}</p>{%- endif -%}</div>
      </div>
      {%- endif -%}
      {%- if s.row2_img != blank or s.row2_title != blank -%}
      <div class="sp-row flip sp-rev">
        <div class="media">{%- if s.row2_img != blank -%}<img src="{{ s.row2_img | image_url: width: 1200 }}" alt="{{ s.row2_title | escape }}" loading="lazy">{%- endif -%}</div>
        <div class="txt">{%- if s.row2_title != blank -%}<h3>{{ s.row2_title }}</h3>{%- endif -%}{%- if s.row2_text != blank -%}<p>{{ s.row2_text }}</p>{%- endif -%}</div>
      </div>
      {%- endif -%}
    </div>
  </div>
  {%- endif -%}

  {%- comment -%} ===== FULL-BLEED PICTURE 2 ===== {%- endcomment -%}
  {%- if s.band2_img != blank -%}
  <div class="sp-band"><img src="{{ s.band2_img | image_url: width: 2400 }}" alt="{{ s.band2_alt | default: 'Syrup Pouches' | escape }}" loading="lazy"></div>
  {%- endif -%}

  {%- comment -%} ===== FLAVOR GRID ===== {%- endcomment -%}
  <div class="sp-shop" id="sp-shop-{{ section.id }}">
    <div class="sp-wrap">
      <div class="sp-head sp-rev">
        {%- if s.grid_eyebrow != blank -%}<span class="sp-eyebrow">{{ s.grid_eyebrow }}</span>{%- endif -%}
        <h2 class="sp-h2">{{ s.grid_title | default: '50 flavors. <em>Pick yours.</em>' }}</h2>
      </div>
      {%- if s.show_tabs -%}
      <div class="sp-tabs sp-rev" role="tablist">
        <button class="sp-tab on" data-filter="all">{{ s.tab_all | default: 'All' }}</button>
        <button class="sp-tab" data-filter="reg">{{ s.tab_reg | default: 'Regular' }}</button>
        <button class="sp-tab" data-filter="sf">{{ s.tab_sf | default: 'Sugar-Free' }}</button>
      </div>
      {%- endif -%}
      <div class="sp-grid" data-grid>
        {%- if cl != blank and cl.products.size > 0 -%}
          {%- for pr in cl.products limit: 50 -%}
            {%- assign tdl = pr.title | downcase -%}
            {%- assign kind = 'reg' -%}
            {%- if tdl contains 'sugar free' or tdl contains 'sugar-free' -%}{%- assign kind = 'sf' -%}{%- endif -%}
            {%- if allowed -%}
            <a class="sp-tile sp-rev" data-kind="{{ kind }}" href="{{ pr.url }}">
            {%- else -%}
            <a class="sp-tile locked sp-rev" data-kind="{{ kind }}" href="#sp-gate-{{ section.id }}" aria-label="{{ pr.title | escape }} — VIP only">
              <span class="sp-lockov"><span>🔒 {{ s.locked_label | default: 'VIP only' }}</span></span>
            {%- endif -%}
              <span class="sp-badge">{{ s.preorder_badge | default: 'Pre-order' }}</span>
              {%- if kind == 'sf' -%}<span class="sp-badge sf">{{ s.sf_badge | default: '0g sugar' }}</span>{%- endif -%}
              <span class="ph">{%- if pr.featured_image -%}<img src="{{ pr.featured_image | image_url: width: 480 }}" alt="{{ pr.title | escape }}" loading="lazy">{%- endif -%}</span>
              <span class="b"><span class="t">{{ pr.title | replace: '(USA)', '' | strip }}</span><span class="p">{{ pr.price | money }}</span></span>
            </a>
          {%- endfor -%}
        {%- endif -%}
        {%- assign lists = 'reg,sf' | split: ',' -%}
        {%- for kindv in lists -%}
          {%- if kindv == 'reg' -%}{%- assign raw = s.upcoming_regular -%}{%- else -%}{%- assign raw = s.upcoming_sf -%}{%- endif -%}
          {%- if raw != blank -%}
            {%- assign lines = raw | newline_to_br | split: '<br />' -%}
            {%- for line in lines -%}
              {%- assign parts = line | strip | split: '|' -%}
              {%- assign fname = parts[0] | strip -%}
              {%- if fname == blank -%}{%- continue -%}{%- endif -%}
              {%- assign fkey = fname | downcase -%}
              {%- if kindv == 'sf' -%}{%- assign fkey = 'sugar free ' | append: fkey -%}{%- endif -%}
              {%- if live_titles contains fkey -%}{%- continue -%}{%- endif -%}
              {%- assign fdate = '' -%}{%- if parts.size > 1 -%}{%- assign fdate = parts[1] | strip -%}{%- endif -%}
              <div class="sp-tile soon sp-rev" data-kind="{{ kindv }}">
                {%- if kindv == 'sf' -%}<span class="sp-badge sf">{{ s.sf_badge | default: '0g sugar' }}</span>{%- endif -%}
                <span class="ph"><span class="fl">{{ fname }}</span></span>
                <span class="sp-soonov"><span class="cs">{{ s.coming_label | default: 'Coming soon' }}</span>{%- if fdate != blank -%}<span class="dt">{{ fdate }}</span>{%- endif -%}</span>
                <span class="b"><span class="t">{{ fname }}</span></span>
              </div>
            {%- endfor -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
      {%- if cl == blank -%}
        <div class="sp-empty" style="margin-top:14px;">Set the collection handle in the section settings (“{{ s.collection_handle }}” not found) — live pouch products will appear here automatically.</div>
      {%- endif -%}
      {%- if s.grid_note != blank -%}<p class="sp-note">{{ s.grid_note }}</p>{%- endif -%}
    </div>
  </div>

  {%- comment -%} ===== FULL-BLEED PICTURE 3 ===== {%- endcomment -%}
  {%- if s.band3_img != blank -%}
  <div class="sp-band"><img src="{{ s.band3_img | image_url: width: 2400 }}" alt="{{ s.band3_alt | default: 'Syrup Pouches' | escape }}" loading="lazy"></div>
  {%- endif -%}

</section>

<script>
(function(){
  var root=document.getElementById('sp-{{ section.id }}');
  if(!root) return;
  var reduce=window.matchMedia&&window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if('IntersectionObserver' in window && !reduce){
    var io=new IntersectionObserver(function(es){es.forEach(function(e){ if(e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target); } });},{threshold:.1});
    root.querySelectorAll('.sp-rev').forEach(function(el){io.observe(el);});
  } else { root.querySelectorAll('.sp-rev').forEach(function(el){el.classList.add('in');}); }
  var tabs=[].slice.call(root.querySelectorAll('.sp-tab'));
  var tiles=[].slice.call(root.querySelectorAll('[data-grid] .sp-tile'));
  tabs.forEach(function(tb){
    tb.addEventListener('click',function(){
      tabs.forEach(function(t){t.classList.toggle('on',t===tb);});
      var f=tb.getAttribute('data-filter');
      tiles.forEach(function(el){ el.style.display=(f==='all'||el.getAttribute('data-kind')===f)?'':'none'; });
    });
  });
})();
</script>

{% schema %}
{
  "name": "Syrup Pouches Launch",
  "tag": "section",
  "settings": [
