      { "value": "vip_tag", "label": "Strict: customers with the VIP tag only" },
      { "value": "everyone", "label": "Everyone (open pre-order)" }
    ], "info": "Flip to 'Everyone' when pre-order opens to all (Monday)." },
    { "type": "text", "id": "vip_badge", "label": "Hero badge", "default": "VIP Pre-Order · Open to all Monday" },
