    { "type": "text", "id": "locked_label", "label": "Locked tile label", "default": "VIP only" },
    { "type": "header", "content": "Hero" },
    { "type": "image_picker", "id": "logo_top", "label": "Logo — 'Syrup' (defaults to built-in SVG)" },
    { "type": "image_picker", "id": "logo_main", "label": "Logo — 'Pouches' (defaults to built-in SVG)" },
