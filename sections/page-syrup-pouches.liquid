    { "type": "color", "id": "hero_g2", "label": "Hero gradient bottom", "default": "#FFD9A0" },
    { "type": "textarea", "id": "hero_sub", "label": "Subtitle", "default": "Your favorite Syruvia flavors — now in perfectly portioned, take-anywhere pouches." },
