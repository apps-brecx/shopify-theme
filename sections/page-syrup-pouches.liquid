    { "type": "text", "id": "band1_alt", "label": "Band 1 alt text", "default": "Syrup Pouches" },
    { "type": "image_picker", "id": "band2_img", "label": "Picture band 2 (before the grid)" },
    { "type": "text", "id": "band2_alt", "label": "Band 2 alt text", "default": "Syrup Pouches" },
    { "type": "image_picker", "id": "band3_img", "label": "Picture band 3 (bottom of page)" },
    { "type": "text", "id": "band3_alt", "label": "Band 3 alt text", "default": "Syrup Pouches" },
    { "type": "header", "content": "About rows (espresso band)" },
    { "type": "checkbox", "id": "show_about", "label": "Show about rows", "default": true },
    { "type": "image_picker", "id": "row1_img", "label": "Row 1 image" },
    { "type": "text", "id": "row1_title", "label": "Row 1 title", "default": "Tear. Pour. <em>Enjoy.</em>" },
    { "type": "textarea", "id": "row1_text", "label": "Row 1 text", "default": "Every pouch is one perfect serving of café-quality syrup — no bottle, no measuring, no mess. Toss a few in your bag and flavor anything, anywhere." },
