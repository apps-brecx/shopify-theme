    { "type": "product", "id": "feat_prod_1", "label": "Featured product 1 (pick Vanilla)" },
    { "type": "product", "id": "feat_prod_2", "label": "Featured product 2 (pick Sugar-Free Vanilla)" },
    { "type": "text", "id": "feat_eyebrow", "label": "Eyebrow", "default": "First drop" },
    { "type": "text", "id": "feat_title", "label": "Heading", "default": "Live now — <em>pre-order today</em>" },
