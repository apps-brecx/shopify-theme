{% comment %} Shakable Toppings — Hero (primary/main section). Loads shared assets once. {% endcomment %}
{{ 'pdp-brand.css' | asset_url | stylesheet_tag }}
{% render 'pd-fixes' %}
{% render 'pd-tweaks' %}
{% render 'pd-rv2-affordances' %}
{% render 'pd-reviews-style' %}
{% render 'pd-color-swap' %}
{% render 'pd-page-polish-v2' %}
{% render 'pd-cat-styles' %}
{% render 'pd-cat-extras' %}

{%- comment -%} ===== Flavor color theming + copy (dynamic, from product title) ===== {%- endcomment -%}
{%- assign t_lc = product.title | downcase -%}
{%- assign st_main = '#FCE2A0' -%}
{%- assign st_accent = '#c58548' -%}
{%- assign st_glow = '#FCE2A0' -%}
{%- assign st_glow2 = '#FFD4B8' -%}
{%- assign st_band = '#FCE2A0' -%}
{%- assign flavor_name = 'topping' -%}
{%- assign flavor_short = 'topping' -%}
{%- assign sprinkle_color = '#c58548' -%}
{%- if t_lc contains 'chocolate crisp' -%}
  {%- assign st_main = '#D4A574' -%}{%- assign st_accent = '#5C3A1F' -%}{%- assign st_glow = '#E8C9A0' -%}{%- assign st_glow2 = '#D4A574' -%}{%- assign st_band = '#E8C9A0' -%}{%- assign flavor_name = 'chocolate crisp' -%}{%- assign flavor_short = 'chocolate' -%}{%- assign sprinkle_color = '#5C3A1F' -%}
{%- elsif t_lc contains 'cinnamon crisp' -%}
  {%- assign st_main = '#FFD4B8' -%}{%- assign st_accent = '#c58548' -%}{%- assign st_glow = '#FFD4B8' -%}{%- assign st_glow2 = '#FCE2A0' -%}{%- assign st_band = '#FFD4B8' -%}{%- assign flavor_name = 'cinnamon crisp' -%}{%- assign flavor_short = 'cinnamon' -%}{%- assign sprinkle_color = '#c58548' -%}
{%- elsif t_lc contains 'sweet nutmeg' or t_lc contains 'nutmeg' -%}
  {%- assign st_main = '#E8C9A0' -%}{%- assign st_accent = '#7A4F2A' -%}{%- assign st_glow = '#E8C9A0' -%}{%- assign st_glow2 = '#FFD4B8' -%}{%- assign st_band = '#E8C9A0' -%}{%- assign flavor_name = 'sweet nutmeg' -%}{%- assign flavor_short = 'nutmeg' -%}{%- assign sprinkle_color = '#7A4F2A' -%}
{%- elsif t_lc contains 'raspberry crunch' or t_lc contains 'raspberry' -%}
  {%- assign st_main = '#F5C7BE' -%}{%- assign st_accent = '#D14B3F' -%}{%- assign st_glow = '#F5C7BE' -%}{%- assign st_glow2 = '#FFD4E5' -%}{%- assign st_band = '#F5C7BE' -%}{%- assign flavor_name = 'raspberry crunch' -%}{%- assign flavor_short = 'raspberry' -%}{%- assign sprinkle_color = '#D14B3F' -%}
{%- elsif t_lc contains 'toasted coconut' or t_lc contains 'coconut' -%}
  {%- assign st_main = '#FFFBF4' -%}{%- assign st_accent = '#c58548' -%}{%- assign st_glow = '#FCE2A0' -%}{%- assign st_glow2 = '#E8C9A0' -%}{%- assign st_band = '#FCE2A0' -%}{%- assign flavor_name = 'toasted coconut' -%}{%- assign flavor_short = 'coconut' -%}{%- assign sprinkle_color = '#c58548' -%}
{%- elsif t_lc contains 'french vanilla' or t_lc contains 'vanilla' -%}
  {%- assign st_main = '#FCE2A0' -%}{%- assign st_accent = '#c58548' -%}{%- assign st_glow = '#FCE2A0' -%}{%- assign st_glow2 = '#FFD4B8' -%}{%- assign st_band = '#FCE2A0' -%}{%- assign flavor_name = 'french vanilla' -%}{%- assign flavor_short = 'vanilla' -%}{%- assign sprinkle_color = '#c58548' -%}
{%- elsif t_lc contains 'white chocolate' -%}
  {%- assign st_main = '#FFFBF4' -%}{%- assign st_accent = '#c58548' -%}{%- assign st_glow = '#FCE2A0' -%}{%- assign st_glow2 = '#FFD4B8' -%}{%- assign st_band = '#FFD4B8' -%}{%- assign flavor_name = 'white chocolate' -%}{%- assign flavor_short = 'white chocolate' -%}{%- assign sprinkle_color = '#c58548' -%}
{%- endif -%}

{% style %}
  #shopify-section-{{ section.id }} {
    --pd-text: {{ section.settings.text_primary }};
    --pd-brand: {{ section.settings.text_brand }};
    --pd-bg: {{ section.settings.bg_section }};
    --pd-hero-bg: {{ section.settings.hero_bg }};
    --pd-cta-bg: {{ section.settings.cta_color_bg }};
    --pd-cta-text: {{ section.settings.cta_color_text }};
    --pd-price-color: {{ section.settings.price_color }};
    --pd-rating-text: {{ section.settings.rating_text_color }};
    --pd-chip-text: {{ section.settings.chip_text_color }};
    --pd-sticky-bg: {{ section.settings.sticky_bg }};
    --pd-sticky-text: {{ section.settings.sticky_text_color }};
    --st-main: {{ st_main }};
    --st-accent: {{ st_accent }};
    --st-glow: {{ st_glow }};
    --st-glow2: {{ st_glow2 }};
  }

  #shopify-section-{{ section.id }} .pd { background: var(--pd-bg) !important; color: var(--pd-text) !important; }
  #shopify-section-{{ section.id }} .pd-hero { background: var(--pd-hero-bg) !important; }
  #shopify-section-{{ section.id }} .pd-h1 { color: var(--pd-brand) !important; }
  #shopify-section-{{ section.id }} .pd-price { color: var(--pd-price-color) !important; }
  #shopify-section-{{ section.id }} .pd-rating-text { color: var(--pd-rating-text) !important; }
  #shopify-section-{{ section.id }} .pd-chip { color: var(--pd-chip-text) !important; }
  #shopify-section-{{ section.id }} .pd-atc,
  #shopify-section-{{ section.id }} .pd-stickybar .pd-atc { background: var(--pd-cta-bg) !important; color: var(--pd-cta-text) !important; }
  #shopify-section-{{ section.id }} .pd-atc:hover { filter: brightness(0.92); }
  #shopify-section-{{ section.id }} .pd-stickybar { background: var(--pd-sticky-bg) !important; }
  #shopify-section-{{ section.id }} .pd-stickybar .pd-price { color: var(--pd-sticky-text) !important; }

  html body #shopify-section-{{ section.id }} .pd .pd-price-row { display:flex !important; align-items:center !important; gap:10px !important; flex-wrap:wrap !important; }

  /* Shakable Topping flavor theming */
  #shopify-section-{{ section.id }} .pd-st-hero-bg { position:absolute; inset:0; z-index:0; background:radial-gradient(ellipse at 25% 20%, var(--st-glow) 0%, transparent 55%),radial-gradient(ellipse at 80% 80%, var(--st-glow2) 0%, transparent 60%); opacity:.7; pointer-events:none; }
  #shopify-section-{{ section.id }} .pd-st-sprinkles { position:absolute; inset:0; z-index:0; pointer-events:none; opacity:.45; }
  #shopify-section-{{ section.id }} .pd-st-sprinkle { position:absolute; width:8px; height:8px; border-radius:50%; background:var(--st-accent); }
  #shopify-section-{{ section.id }} .pd-st-chip { background:var(--st-main) !important; }

  /* Thumbnail strip → arrow-only slider (every product image, ~4 visible; navigate with ‹ ›, no scrollbar) */
  #shopify-section-{{ section.id }} .pd-hero-media { min-width:0; }
  #shopify-section-{{ section.id }} .pd-thumbs-wrap { margin-top:14px; display:flex; align-items:center; gap:8px; }
  html body #shopify-section-{{ section.id }} .pd .pd-thumbs { margin-top:0 !important; display:flex !important; grid-template-columns:none !important; gap:10px !important; flex:1 1 auto; min-width:0; overflow:hidden; scroll-behavior:smooth; scroll-snap-type:x mandatory; }
  html body #shopify-section-{{ section.id }} .pd .pd-thumb { flex:0 0 calc((100% - 30px) / 4) !important; scroll-snap-align:start; }
  #shopify-section-{{ section.id }} .pd-thumbs-nav { flex:0 0 auto; width:30px; height:30px; border-radius:50%; border:2px solid var(--pd-brand); background:#FFFBF4; color:var(--pd-brand); cursor:pointer; display:flex; align-items:center; justify-content:center; font-family:'Archivo',sans-serif; font-size:18px; line-height:1; box-shadow:2px 2px 0 var(--pd-brand); transition:transform .12s ease, box-shadow .12s ease, opacity .12s ease; padding:0; }
  #shopify-section-{{ section.id }} .pd-thumbs-nav:hover { transform:translate(-1px,-1px); box-shadow:3px 3px 0 var(--pd-brand); }
  #shopify-section-{{ section.id }} .pd-thumbs-nav:disabled { opacity:.3; cursor:default; box-shadow:none; transform:none; }
  @media (max-width:760px){ #shopify-section-{{ section.id }} .pd-thumbs-wrap { display:none !important; } }

  /* Mobile-only slider */
  #shopify-section-{{ section.id }} .pd-slider-mobile { display:none; }
  #shopify-section-{{ section.id }} .pd-slider-dots { display:none; }
  @media (max-width:760px){
    #shopify-section-{{ section.id }} .pd-hero-frame { display:none !important; }
    #shopify-section-{{ section.id }} .pd-thumbs { display:none !important; }
    #shopify-section-{{ section.id }} .pd-slider-mobile { display:block !important; position:relative; background:#FFFBF4; border:2px solid var(--pd-brand); border-radius:20px; padding:0; box-shadow:4px 4px 0 var(--pd-brand); overflow:hidden; max-width:340px; margin:0 auto; }
    #shopify-section-{{ section.id }} .pd-slides { display:flex; overflow-x:auto; scroll-snap-type:x mandatory; scroll-behavior:smooth; -webkit-overflow-scrolling:touch; scrollbar-width:none; width:100%; position:relative; z-index:0; }
    #shopify-section-{{ section.id }} .pd-slides::-webkit-scrollbar { display:none; }
    #shopify-section-{{ section.id }} .pd-slide { flex:0 0 100%; scroll-snap-align:start; min-width:100%; }
    #shopify-section-{{ section.id }} .pd-slide img { width:100%; height:auto; display:block; aspect-ratio:1/1; object-fit:cover; }
    #shopify-section-{{ section.id }} .pd-slider-dots { display:flex !important; justify-content:center; gap:5px; margin-top:10px; }
  }
{% endstyle %}

{%- assign hero_img = product.featured_media.preview_image -%}
{%- assign hero_src = hero_img | image_url: width: 1400 -%}
<link rel="preload" as="image" href="{{ hero_src }}" imagesrcset="{{ hero_img | image_url: width: 600 }} 600w, {{ hero_img | image_url: width: 1000 }} 1000w, {{ hero_img | image_url: width: 1400 }} 1400w" imagesizes="(max-width: 980px) 100vw, 600px" fetchpriority="high">

{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign price = current_variant.price -%}
{%- assign display_price = price -%}
{%- assign review_count = product.metafields.reviews.rating_count.value | default: 0 -%}

<div class="pd" data-product-id="{{ product.id }}" data-base-price="{{ display_price }}">

  {%- if section.settings.show_breadcrumbs -%}
    <nav class="pd-breadcrumbs" aria-label="Breadcrumb">
      <div class="pd-wrap">
        <ol>
          <li><a href="/">{{ section.settings.breadcrumb_home }}</a></li>
          <li class="pd-bc-sep" aria-hidden="true">/</li>
          <li><a href="/collections/shakable-toppings">{{ section.settings.breadcrumb_category }}</a></li>
          <li class="pd-bc-sep" aria-hidden="true">/</li>
          <li class="pd-bc-current">{{ product.title }}</li>
        </ol>
      </div>
    </nav>
  {%- endif -%}

  <section class="pd-hero" style="position:relative;overflow:hidden">
    <div class="pd-st-hero-bg" aria-hidden="true"></div>
    <div class="pd-st-sprinkles" aria-hidden="true">
      <span class="pd-st-sprinkle" style="top:12%;left:8%;background:var(--st-accent)"></span>
      <span class="pd-st-sprinkle" style="top:22%;left:18%;width:6px;height:6px;background:var(--st-main)"></span>
      <span class="pd-st-sprinkle" style="top:8%;left:74%;background:var(--st-accent);width:10px;height:10px"></span>
      <span class="pd-st-sprinkle" style="top:34%;left:88%;background:var(--st-main)"></span>
      <span class="pd-st-sprinkle" style="top:62%;left:5%;background:var(--st-accent);width:7px;height:7px"></span>
      <span class="pd-st-sprinkle" style="top:78%;left:14%;background:var(--st-main)"></span>
      <span class="pd-st-sprinkle" style="top:80%;left:82%;background:var(--st-accent);width:9px;height:9px"></span>
      <span class="pd-st-sprinkle" style="top:55%;left:92%;background:var(--st-main);width:6px;height:6px"></span>
    </div>
    <div class="pd-wrap" style="position:relative;z-index:1">
      <div class="pd-hero-grid">
        <div class="pd-hero-media">
          <div class="pd-hero-frame">
            <img id="pdHeroImg" src="{{ hero_src }}" alt="{{ product.title | escape }}" width="1200" height="1200" fetchpriority="high">
          </div>
          {%- if product.images.size > 1 -%}
            <div class="pd-thumbs-wrap">
              {%- if product.images.size > 4 -%}<button type="button" class="pd-thumbs-nav pd-thumbs-prev" aria-label="Previous thumbnails">‹</button>{%- endif -%}
              <div class="pd-thumbs">
                {%- for img in product.images -%}
                  <button type="button" class="pd-thumb{% if forloop.first %} is-active{% endif %}" data-src="{{ img | image_url: width: 1400 }}" aria-label="View image {{ forloop.index }}"><img src="{{ img | image_url: width: 200 }}" alt="" width="200" height="200" loading="lazy"></button>
                {%- endfor -%}
              </div>
              {%- if product.images.size > 4 -%}<button type="button" class="pd-thumbs-nav pd-thumbs-next" aria-label="Next thumbnails">›</button>{%- endif -%}
            </div>
          {%- endif -%}
          <div class="pd-slider-mobile">
            <div class="pd-slides" id="pdSlides">
              {%- for img in product.images -%}
                <div class="pd-slide" data-idx="{{ forloop.index0 }}"><img src="{{ img | image_url: width: 1000 }}" alt="{{ product.title | escape }}" {% if forloop.first %}fetchpriority="high"{% else %}loading="lazy"{% endif %}></div>
              {%- endfor -%}
            </div>
          </div>
          {%- if product.images.size > 1 -%}
            <div class="pd-slider-dots" id="pdDots">
              {%- for img in product.images -%}<button type="button" class="pd-dot{% if forloop.first %} is-active{% endif %}" data-idx="{{ forloop.index0 }}" aria-label="View image {{ forloop.index }}"></button>{%- endfor -%}
            </div>
          {%- endif -%}
        </div>

        <div class="pd-hero-info">
          <a href="#reviews" class="pd-rating-row">
            <span class="pd-stars" aria-hidden="true">
              {%- for i in (1..5) -%}<svg viewBox="0 0 24 24" fill="{{ section.settings.star_color }}" stroke="{{ section.settings.star_color }}" stroke-width="1" stroke-linejoin="round"><path d="M12 2 L14.6 8.4 L21.5 9 L16.3 13.6 L17.9 20.4 L12 16.9 L6.1 20.4 L7.7 13.6 L2.5 9 L9.4 8.4 Z"/></svg>{%- endfor -%}
            </span>
            <span class="pd-rating-text">{{ review_count }} {{ section.settings.reviews_label }}</span>
          </a>
          <h1 class="pd-h1">{{ product.title | upcase }}</h1>

          <div class="pd-chips">
            <span class="pd-chip pd-st-chip" style="background:var(--st-main)!important"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><circle cx="9" cy="10" r="1" fill="currentColor"/><circle cx="15" cy="10" r="1" fill="currentColor"/><path d="M8 15 Q12 18 16 15"/></svg>{{ section.settings.chip_flavor_prefix }} {{ flavor_short | capitalize }}</span>
            <span class="pd-chip pd-chip--butter"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6 L20 6 M5 6 L7 20 H17 L19 6 M9 6 V3 H15 V6"/></svg>{{ section.settings.chip_lid }}</span>
            <span class="pd-chip pd-chip--mint"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12 l4 4 L19 7"/></svg>{{ section.settings.chip_kosher }}</span>
            <span class="pd-chip pd-chip--sky"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3 H18 L17 8 H7 Z M7 8 L8 21 H16 L17 8"/></svg>{{ section.settings.chip_cafe }}</span>
          </div>

          {%- form 'product', product, id: 'pdAtcForm', class: 'pd-form' -%}
            <input type="hidden" name="id" value="{{ current_variant.id }}">
            <div class="pd-priceqty">
              <div class="pd-priceblock">
                <div class="pd-price-row">
                  <span class="pd-price" id="pdPriceTotal">{{ display_price | money }}</span>
                  <span class="pd-price-was" id="pdPriceWas" style="display:none"></span>
                </div>
                <span class="pd-save-inline" id="pdSaveTag" style="display:none"></span>
              </div>
              <div class="pd-qty" aria-label="Quantity">
                <button type="button" data-qty="-1" aria-label="Decrease">−</button>
                <input type="number" name="quantity" value="1" min="1" inputmode="numeric">
                <button type="button" data-qty="1" aria-label="Increase">+</button>
              </div>
            </div>
            <button type="submit" class="pd-atc pd-atc--full" {% unless product.available %}disabled{% endunless %}>
              <svg class="pd-atc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 L4 6 V20 a2 2 0 0 0 2 2 H18 a2 2 0 0 0 2 -2 V6 L18 2 Z M4 6 H20 M16 10 a4 4 0 0 1 -8 0"/></svg>
              <span class="pd-atc-text" id="pdAtcText">{%- if product.available -%}{{ section.settings.atc_text_available }}{%- else -%}{{ section.settings.atc_text_soldout }}{%- endif -%}</span>
              {%- if product.available -%}<svg class="pd-atc-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12 H19 M13 6 l6 6 -6 6"/></svg>{%- endif -%}
            </button>
          {%- endform -%}

          {%- if section.settings.show_mini_bundle -%}
            <div class="pd-minibundle">
              <div class="pd-mb-head">
                <span class="pd-mb-headline">{{ section.settings.mb_headline }}</span>
                <span class="pd-mb-sub">{{ section.settings.mb_sub }}</span>
              </div>
              <div class="pd-mb-grid">
                <button type="button" class="pd-mb-cell" data-tier="2"><span class="pd-mb-num">{{ section.settings.mb_tier2_num }}</span><span class="pd-mb-label">{{ section.settings.mb_tier2_label }}</span><span class="pd-mb-save">{{ section.settings.mb_tier2_save }}</span></button>
                <button type="button" class="pd-mb-cell" data-tier="3"><span class="pd-mb-flag">{{ section.settings.mb_tier3_flag }}</span><span class="pd-mb-num">{{ section.settings.mb_tier3_num }}</span><span class="pd-mb-label">{{ section.settings.mb_tier3_label }}</span><span class="pd-mb-save">{{ section.settings.mb_tier3_save }}</span></button>
                <button type="button" class="pd-mb-cell" data-tier="4"><span class="pd-mb-num">{{ section.settings.mb_tier4_num }}</span><span class="pd-mb-label">{{ section.settings.mb_tier4_label }}</span><span class="pd-mb-save">{{ section.settings.mb_tier4_save }}</span></button>
              </div>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>

  {%- if section.settings.show_sticky_bar -%}
    <div class="pd-stickybar" id="pdStickybar">
      <span class="pd-price"><span id="pdStickyPrice">{{ display_price | money }}</span></span>
      <button type="button" class="pd-atc" {% unless product.available %}disabled{% endunless %} onclick="document.getElementById('pdAtcForm').requestSubmit()">{%- if product.available -%}{{ section.settings.atc_text_available }}{%- else -%}{{ section.settings.atc_text_soldout }}{%- endif -%}</button>
    </div>
  {%- endif -%}
</div>

{% render 'pd-mb-prices' %}

<script>
window.PD_BASE_CENTS = {{ display_price }};
window.PD_TIERS = [1, 0.95, 0.90, 0.85];
(function(){
  var currentBaseCents = window.PD_BASE_CENTS;
  const tiers = window.PD_TIERS;
  const fmt = (c)=>{const d=c/100; return '$' + d.toFixed(2);};
  function updatePrice(qty){
    qty = Math.max(1, parseInt(qty)||1);
    const tierIdx = Math.min(qty-1, tiers.length-1);
    const discount = tiers[tierIdx];
    const totalCents = Math.round(currentBaseCents * qty * discount);
    const origCents = currentBaseCents * qty;
    const priceEl = document.getElementById('pdPriceTotal');
    const wasEl = document.getElementById('pdPriceWas');
    const saveEl = document.getElementById('pdSaveTag');
    const stickyPriceEl = document.getElementById('pdStickyPrice');
    if (priceEl) priceEl.textContent = fmt(totalCents);
    if (stickyPriceEl) stickyPriceEl.textContent = fmt(totalCents);
    if (qty > 1){ if (wasEl){wasEl.textContent = fmt(origCents); wasEl.style.display='inline';} if (saveEl){saveEl.textContent = 'Save '+Math.round((1-discount)*100)+'%'; saveEl.style.display='inline-block';} }
    else { if (wasEl) wasEl.style.display='none'; if (saveEl) saveEl.style.display='none'; }
    document.querySelectorAll('.pd-mb-cell').forEach(c=>{ const t = parseInt(c.dataset.tier)||1; const match = (qty === t) || (qty >= 4 && t === 4); if (match) c.setAttribute('data-active',''); else c.removeAttribute('data-active'); });
  }
  document.querySelectorAll('.pd-qty [data-qty]').forEach(b=>{b.addEventListener('click',()=>{const inp=b.parentElement.querySelector('input'); const v=Math.max(1,(parseInt(inp.value)||1)+parseInt(b.dataset.qty)); inp.value=v; updatePrice(v);});});
  document.querySelectorAll('.pd-qty input').forEach(inp=>{inp.addEventListener('change',()=>updatePrice(parseInt(inp.value)||1)); inp.addEventListener('input',()=>updatePrice(parseInt(inp.value)||1));});
  document.querySelectorAll('.pd-mb-cell').forEach(c=>{c.addEventListener('click',()=>{const tier=parseInt(c.dataset.tier)||1; const qtyInp=document.querySelector('.pd-qty input'); if(qtyInp){qtyInp.value=tier; updatePrice(tier);}});});
  const heroImg=document.getElementById('pdHeroImg');
  document.querySelectorAll('.pd-thumb').forEach(t=>{t.addEventListener('click',()=>{document.querySelectorAll('.pd-thumb').forEach(x=>x.classList.remove('is-active'));t.classList.add('is-active');if(heroImg&&t.dataset.src)heroImg.src=t.dataset.src;});});
  /* Desktop thumbnail slider — arrow controls */
  (function(){
    var strip=document.querySelector('.pd-thumbs');
    var prev=document.querySelector('.pd-thumbs-prev');
    var next=document.querySelector('.pd-thumbs-next');
    if(!strip||!prev||!next) return;
    function upd(){ var max=strip.scrollWidth-strip.clientWidth-2; prev.disabled=strip.scrollLeft<=2; next.disabled=strip.scrollLeft>=max; }
    function step(){ return Math.max(strip.clientWidth*0.8, 120); }
    prev.addEventListener('click',function(){ strip.scrollBy({left:-step(),behavior:'smooth'}); });
    next.addEventListener('click',function(){ strip.scrollBy({left:step(),behavior:'smooth'}); });
    strip.addEventListener('scroll',upd,{passive:true});
    window.addEventListener('resize',upd);
    upd();
  })();
  const slides=document.getElementById('pdSlides'); const dots=document.querySelectorAll('.pd-dot');
  if(slides&&dots.length){let st; slides.addEventListener('scroll',()=>{clearTimeout(st);st=setTimeout(()=>{const idx=Math.round(slides.scrollLeft/slides.clientWidth);dots.forEach((d,i)=>d.classList.toggle('is-active',i===idx));},50);}); dots.forEach((d,i)=>d.addEventListener('click',()=>{slides.scrollTo({left:i*slides.clientWidth,behavior:'smooth'});}));}
  const mainAtc=document.querySelector('.pd-atc--full'); const stickyBar=document.getElementById('pdStickybar');
  if(mainAtc&&stickyBar&&'IntersectionObserver' in window){const io=new IntersectionObserver((entries)=>{entries.forEach(e=>{if(e.isIntersecting)stickyBar.classList.add('is-hidden');else stickyBar.classList.remove('is-hidden');});},{threshold:0.15}); io.observe(mainAtc);}
})();
</script>

