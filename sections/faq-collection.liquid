{% schema %}
{
  "name": "FAQ by Heading",
  "settings": [],
  "presets": [
    {
      "name": "FAQ by Heading",
      "category": "Collections"
    }
  ]
}
{% endschema %}

  <!-- FAQ Section 1 -->
  {% if collection.metafields.custom.learn_more_main_heading
  %}
    <div class="faqs-sections-cstm">
    <div class="faq-learn-section">
      <div class="top-content-more">
        <h2>{{ collection.metafields.custom.learn_more_main_heading }}</h2>
        <p>{{ collection.metafields.custom.learn_more_sub_content }}</p>
      </div>

      {% assign faq_headings = collection.metafields.custom.learn_more_heading %}
      {% assign faq_content = collection.metafields.custom.learn_more_content %}

      {% assign headings_array = faq_headings.value %}
      {% assign content_array = faq_content.value %}

      {% if headings_array and content_array %}
        <div class="faq-container">
          {% for heading in headings_array %}
            {% assign clean_heading = heading | strip %}
            <div class="faq-group">
              <h3 class="faq-group-heading">{{ clean_heading }}</h3>

              {% assign heading_index = forloop.index0 %}
              {% if content_array[heading_index] %}
                <div class="faq-item">
                  <p>{{ content_array[heading_index] | strip }}</p>
                </div>
              {% else %}
             
              {% endif %}
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  {% endif %}

  <!-- FAQ Section 2 -->
  {% if collection.metafields.custom.faq_main_heading
  %}
    <div class="faq-coll-section">
      <div class="top-content-more">
        <h2>{{ collection.metafields.custom.faq_main_heading }}</h2>
        <p>{{ collection.metafields.custom.faq_sub_heading }}</p>
      </div>

      {% assign faq_headings = collection.metafields.custom.faq_heading %}
      {% assign faq_content = collection.metafields.custom.faq_content %}

      {% assign headings_array = faq_headings.value %}
      {% assign content_array = faq_content.value %}

      {% if headings_array and content_array %}
        <div class="faq-container">
          {% for heading in headings_array %}
            {% assign clean_heading = heading | strip %}
            <div class="faq-group">
              <h3 class="faq-group-heading">{{ clean_heading }}</h3>

              {% assign heading_index = forloop.index0 %}
              {% if content_array[heading_index] %}
                <div class="faq-item">
                  <p>{{ content_array[heading_index] | strip }}</p>
                </div>
              {% else %}
              
              {% endif %}
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  {% endif %}
</div>
