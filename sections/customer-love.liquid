{%- comment -%} Customer Love — Syruvia brand style. Same block schema (product_block + media_block) so existing reviews persist. {%- endcomment -%}
{%- assign s = section.settings -%}
{%- assign initial = s.initial_count | default: 12 -%}
<style id="cl-{{ section.id }}-css">
  #cl-{{ section.id }}{--ink:#39220f;--ink-2:#5a4632;--paper:#FFFBF4;--white:#fff;--butter:#FCE2A0;--copper:#c58548;--peach:#ffd4b8;--mint:#c5e4d4;--sky:#b8dceb;--gold:#f3a712;--fh:'Archivo Black','Arial Black',sans-serif;--fb:'Josefin Sans','Josefin',sans-serif;background:var(--paper);color:var(--ink);font-family:var(--fb);}
  #cl-{{ section.id }} *{box-sizing:border-box;}
  #cl-{{ section.id }} .cl-wrap{max-width:1200px;margin:0 auto;padding:0 24px;}
  #cl-{{ section.id }} .cl-rev{opacity:0;transform:translateY(18px) scale(.96);transition:opacity .6s ease, transform .6s cubic-bezier(.2,.7,.3,1.2);}
  #cl-{{ section.id }} .cl-rev.in{opacity:1;transform:none;}
  #cl-{{ section.id }} .cl-hero{text-align:center;padding:64px 0 14px;position:relative;}
  #cl-{{ section.id }} .cl-hero::after{content:'';position:absolute;inset:0;background:radial-gradient(circle, rgba(57,34,15,.05) 1.4px, transparent 1.6px);background-size:26px 26px;opacity:.5;pointer-events:none;}
  #cl-{{ section.id }} .cl-hero .cl-wrap{position:relative;z-index:2;}
  #cl-{{ section.id }} .cl-eyebrow{display:inline-flex;align-items:center;gap:7px;background:var(--butter);color:var(--ink);border:2px solid var(--ink);border-radius:999px;box-shadow:3px 3px 0 var(--ink);font-family:var(--fh);font-weight:400;font-size:11px;letter-spacing:.16em;text-transform:uppercase;padding:8px 18px;line-height:1;}
  #cl-{{ section.id }} .cl-hero h1{font-family:var(--fh);font-weight:400;font-size:clamp(40px,7vw,82px);line-height:.92;letter-spacing:-.02em;text-transform:uppercase;margin:20px 0 0;}
  #cl-{{ section.id }} .cl-hero h1 em{font-family:var(--fb);font-style:italic;font-weight:300;color:var(--copper);text-transform:none;}
  #cl-{{ section.id }} .cl-hero .sub{font-size:clamp(15px,2vw,18px);color:var(--ink-2);font-weight:500;margin:16px auto 0;max-width:52ch;line-height:1.6;}
  #cl-{{ section.id }} .cl-trust{display:flex;gap:10px;justify-content:center;flex-wrap:wrap;margin:22px auto 0;}
  #cl-{{ section.id }} .cl-tchip{display:inline-flex;align-items:center;gap:7px;background:var(--white);border:2px solid var(--ink);border-radius:999px;box-shadow:2px 2px 0 var(--ink);font-family:'Archivo',sans-serif;font-weight:700;font-size:11px;letter-spacing:.04em;text-transform:uppercase;padding:7px 14px;}
  #cl-{{ section.id }} .cl-tchip .st{color:var(--gold);letter-spacing:1px;}
  #cl-{{ section.id }} .cl-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:22px;padding:40px 0 8px;}
  #cl-{{ section.id }} .cl-card{display:flex;flex-direction:column;background:var(--white);border:2.5px solid var(--ink);border-radius:22px;box-shadow:6px 6px 0 var(--ink);overflow:hidden;transition:transform .2s ease,box-shadow .2s ease,opacity .5s ease;}
  #cl-{{ section.id }} .cl-card:hover{transform:translate(-3px,-3px);box-shadow:9px 9px 0 var(--ink);}
  #cl-{{ section.id }} .cl-card.cl-hidden{display:none;}
  #cl-{{ section.id }} .cl-vid{position:relative;aspect-ratio:9/16;background:#1c1109;border-bottom:2.5px solid var(--ink);overflow:hidden;}
  #cl-{{ section.id }} .cl-vid video,#cl-{{ section.id }} .cl-vid img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;}
  #cl-{{ section.id }} .cl-play{position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);width:60px;height:60px;border-radius:50%;background:rgba(255,251,244,.92);border:2.5px solid var(--ink);box-shadow:3px 3px 0 var(--ink);display:flex;align-items:center;justify-content:center;cursor:pointer;transition:transform .15s ease;}
  #cl-{{ section.id }} .cl-play:hover{transform:translate(-50%,-50%) scale(1.07);}
  #cl-{{ section.id }} .cl-play svg{width:24px;height:24px;color:var(--ink);margin-left:3px;}
  #cl-{{ section.id }} .cl-card.playing .cl-play{display:none;}
  #cl-{{ section.id }} .cl-quote-ic{position:absolute;top:12px;left:12px;width:34px;height:34px;border-radius:9px;background:var(--butter);border:2px solid var(--ink);box-shadow:2px 2px 0 var(--ink);display:flex;align-items:center;justify-content:center;font-family:var(--fh);font-size:20px;line-height:1;color:var(--ink);z-index:2;}
  #cl-{{ section.id }} .cl-body{padding:16px 16px 18px;display:flex;flex-direction:column;gap:10px;flex:1;}
  #cl-{{ section.id }} .cl-stars{color:var(--gold);font-size:15px;letter-spacing:2px;line-height:1;}
  #cl-{{ section.id }} .cl-quote{font-size:14px;line-height:1.55;color:var(--ink-2);font-weight:500;flex:1;}
  #cl-{{ section.id }} .cl-prod{display:flex;align-items:center;gap:10px;border-top:1.5px dashed rgba(57,34,15,.2);padding-top:12px;text-decoration:none;color:var(--ink);}
  #cl-{{ section.id }} .cl-thumb{width:46px;height:46px;flex:0 0 46px;border:2px solid var(--ink);border-radius:10px;background:var(--peach);overflow:hidden;display:flex;align-items:center;justify-content:center;}
  #cl-{{ section.id }} .cl-thumb img{width:100%;height:100%;object-fit:contain;mix-blend-mode:multiply;}
  #cl-{{ section.id }} .cl-pn{font-family:var(--fh);font-weight:400;font-size:12px;text-transform:uppercase;line-height:1.15;}
  #cl-{{ section.id }} .cl-shop{font-family:'Archivo',sans-serif;font-weight:700;font-size:10.5px;letter-spacing:.04em;text-transform:uppercase;color:var(--copper);margin-top:2px;}
  #cl-{{ section.id }} .cl-more-wrap{text-align:center;padding:30px 0 80px;}
  #cl-{{ section.id }} .cl-btn{display:inline-flex;align-items:center;gap:9px;background:var(--copper);color:#fff;border:2.5px solid var(--ink);border-radius:999px;box-shadow:5px 5px 0 var(--ink);font-family:var(--fh);font-size:13px;letter-spacing:.06em;text-transform:uppercase;padding:16px 30px;text-decoration:none;cursor:pointer;transition:transform .16s ease,box-shadow .16s ease;}
  #cl-{{ section.id }} .cl-btn:hover{transform:translate(-2px,-2px);box-shadow:7px 7px 0 var(--ink);}
  #cl-{{ section.id }} .cl-btn--ghost{background:transparent;color:var(--ink);box-shadow:5px 5px 0 var(--copper);margin-left:12px;}
  #cl-{{ section.id }} .cl-btn--ghost:hover{background:var(--butter);box-shadow:7px 7px 0 var(--copper);}
  @media (max-width:1100px){#cl-{{ section.id }} .cl-grid{grid-template-columns:repeat(3,1fr);}}
  @media (max-width:760px){#cl-{{ section.id }} .cl-grid{grid-template-columns:repeat(2,1fr);gap:14px;} #cl-{{ section.id }} .cl-hero{padding:42px 0 8px;}}
  @media (max-width:440px){#cl-{{ section.id }} .cl-grid{grid-template-columns:1fr;}}
  @media (prefers-reduced-motion: reduce){#cl-{{ section.id }} .cl-rev{opacity:1;transform:none;}}
</style>

<section id="cl-{{ section.id }}">
  <div class="cl-hero">
    <div class="cl-wrap">
      <span class="cl-eyebrow cl-rev">{{ s.hero_eyebrow | default: 'Customer Love' }}</span>
      <h1 class="cl-rev">{{ s.hero_title | default: 'Real people, real <em>pours</em>.' }}</h1>
      <p class="sub cl-rev">{{ s.hero_sub | default: 'See how Syruvia fans are mixing, sipping and loving their favorite flavors at home — straight from their own kitchens.' }}</p>
      <div class="cl-trust cl-rev">
        <span class="cl-tchip"><span class="st">★★★★★</span> Loved by customers</span>
        <span class="cl-tchip">Real customer videos</span>
        <span class="cl-tchip">Made in the USA</span>
      </div>
    </div>
  </div>

  <div class="cl-wrap">
    <div class="cl-grid">
      {%- assign idx = 0 -%}
      {%- assign p_handle = '' -%}
      {%- assign p_text = '' -%}
      {%- assign have_p = false -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'product_block' -%}
          {%- assign p_handle = block.settings.selected_product -%}
          {%- assign p_text = block.settings.customreview_text -%}
          {%- assign have_p = true -%}
        {%- elsif block.type == 'media_block' -%}
          {%- assign vsrc = '' -%}
          {%- if block.settings.media_video and block.settings.media_video.sources.size > 0 -%}
            {%- for src in block.settings.media_video.sources -%}
              {%- if src.mime_type == 'video/mp4' or src.format == 'mp4' -%}{%- assign vsrc = src.url -%}{%- break -%}{%- endif -%}
            {%- endfor -%}
            {%- if vsrc == '' -%}{%- assign vsrc = block.settings.media_video.sources.last.url -%}{%- endif -%}
          {%- endif -%}
          {%- assign vposter = '' -%}
          {%- if block.settings.media_video.preview_image -%}{%- assign vposter = block.settings.media_video.preview_image | image_url: width: 540 -%}{%- endif -%}
          {%- assign rprod = all_products[p_handle] -%}
          <article class="cl-card cl-rev{% if idx >= initial %} cl-hidden{% endif %}" {{ block.shopify_attributes }}>
            <div class="cl-vid">
              <span class="cl-quote-ic">&#8220;</span>
              {%- if vsrc != '' -%}
                <video class="cl-video" preload="none" playsinline loop {% if vposter != '' %}poster="{{ vposter }}"{% endif %}><source src="{{ vsrc }}" type="video/mp4"></video>
                <button type="button" class="cl-play" aria-label="Play video"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"></path></svg></button>
              {%- elsif block.settings.media_image -%}
                <img src="{{ block.settings.media_image | image_url: width: 540 }}" alt="Customer review" loading="lazy">
              {%- endif -%}
            </div>
            <div class="cl-body">
              <div class="cl-stars">★★★★★</div>
              {%- if p_text != blank -%}<p class="cl-quote">{{ p_text | strip_html | strip }}</p>{%- endif -%}
              {%- if rprod -%}
                <a class="cl-prod" href="{{ rprod.url }}">
                  <span class="cl-thumb">{%- if rprod.featured_image -%}<img src="{{ rprod.featured_image | image_url: width: 120 }}" alt="{{ rprod.title | escape }}" loading="lazy">{%- endif -%}</span>
                  <span><span class="cl-pn">{{ rprod.title | remove: 'Syrup' | strip }}</span><br><span class="cl-shop">Shop now →</span></span>
                </a>
              {%- endif -%}
            </div>
          </article>
          {%- assign idx = idx | plus: 1 -%}
          {%- assign have_p = false -%}
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="cl-more-wrap">
      {%- if idx > initial -%}<button type="button" class="cl-btn cl-more">Show more reviews</button>{%- endif -%}
      <a class="cl-btn cl-btn--ghost" href="/collections/all">Shop all flavors</a>
    </div>
  </div>
</section>

<script>
(function(){
  var root=document.getElementById('cl-{{ section.id }}');
  if(!root) return;
  /* play buttons */
  root.querySelectorAll('.cl-play').forEach(function(btn){
    btn.addEventListener('click',function(){
      var card=btn.closest('.cl-card'); var v=card.querySelector('video'); if(!v) return;
      root.querySelectorAll('video').forEach(function(o){ if(o!==v){ try{o.pause();o.controls=false;}catch(e){} var c=o.closest('.cl-card'); if(c) c.classList.remove('playing'); } });
      v.controls=true; card.classList.add('playing'); var p=v.play(); if(p&&p.catch){p.catch(function(){});}
    });
  });
  /* show more */
  var more=root.querySelector('.cl-more');
  if(more){
    more.addEventListener('click',function(){
      var hidden=root.querySelectorAll('.cl-card.cl-hidden');
      for(var i=0;i<12 && i<hidden.length;i++){ hidden[i].classList.remove('cl-hidden'); }
      if(root.querySelectorAll('.cl-card.cl-hidden').length===0){ more.style.display='none'; }
    });
  }
  /* reveal */
  if('IntersectionObserver' in window && !(window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches)){
    var io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);}});},{threshold:.08});
    root.querySelectorAll('.cl-rev').forEach(function(el){io.observe(el);});
    setTimeout(function(){root.querySelectorAll('.cl-rev:not(.in)').forEach(function(el){el.classList.add('in');});},2800);
  } else { root.querySelectorAll('.cl-rev').forEach(function(el){el.classList.add('in');}); }
})();
</script>

{% schema %}
{
  "name": "Customer Love Section",
  "settings": [
    { "type": "text", "id": "hero_eyebrow", "label": "Eyebrow", "default": "Customer Love" },
    { "type": "text", "id": "hero_title", "label": "Title (use <em>)", "default": "Real people, real <em>pours</em>." },
    { "type": "textarea", "id": "hero_sub", "label": "Subtitle", "default": "See how Syruvia fans are mixing, sipping and loving their favorite flavors at home." },
    { "type": "range", "id": "initial_count", "min": 4, "max": 24, "step": 4, "label": "Reviews shown before Show more", "default": 12 }
  ],
  "blocks": [
    {
      "type": "product_block",
      "name": "Product Block",
      "settings": [
        { "type": "product", "id": "selected_product", "label": "Select a product" },
        { "type": "richtext", "id": "customreview_text", "label": "Review text" },
        { "type": "range", "id": "custom_review", "min": 1, "max": 5, "step": 1, "label": "Reviews", "default": 5 }
      ]
    },
    {
      "type": "media_block",
      "name": "Video or Image Block",
      "settings": [
        { "type": "radio", "id": "media_type", "label": "Media Type", "options": [ { "label": "Image", "value": "image" }, { "label": "Video", "value": "video" } ] },
        { "type": "image_picker", "id": "media_image", "label": "Select an image", "info": "Shown if no video is set" },
        { "type": "video", "id": "media_video", "label": "Review video" }
      ]
    }
  ],
  "presets": [ { "name": "Customer Love", "category": "Custom" } ]
}
{% endschema %}