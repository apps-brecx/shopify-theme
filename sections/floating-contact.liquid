{% comment %}
  Floating Contact Button + Modal
  - Position: bottom-right (fixed)
  - Sends to: Shopify contact email (default) OR a custom webhook URL
  - No page reload on submit
{% endcomment %}

{% liquid
  assign bb_icon_url = ''
  if section.settings.button_icon != blank
    assign bb_icon_url = section.settings.button_icon | image_url: width: 120
  else
    assign bb_icon_url = 'https://cdn.shopify.com/s/files/1/0861/1106/0252/files/Contact_us.png?v=1758809684'
  endif
%}

{%- render 'pd-collection-polish' -%}

<section id="bb-floating-contact"
  class="bb-floating-contact"
  data-send-mode="{{ section.settings.send_mode }}"
  data-webhook-url="{{ section.settings.webhook_url | escape }}"
  data-success-text="{{ section.settings.success_text | escape }}"
  data-error-text="{{ section.settings.error_text | escape }}"
  data-default-tab="{{ section.settings.default_tab | default: 'chat' }}"
  data-chat-endpoint="{{ section.settings.chat_endpoint | escape }}"
  data-customer-email="{% if customer %}{{ customer.email | escape }}{% endif %}"
  data-chat-greeting="{{ section.settings.chat_greeting | escape }}"
  data-chat-fallback="{{ section.settings.chat_fallback | escape }}"
>
  <!-- Floating button -->
  <button class="bb-float-btn"
          id="bb-float-btn"
          aria-haspopup="dialog"
          aria-controls="bb-contact-modal"
          aria-label="{{ section.settings.button_label }}">
    <img id="bb-float-icon"
         src="{{ bb_icon_url }}"
         alt="{{ section.settings.button_label | escape }}"
         width="60" height="60" loading="lazy">
  </button>

  <!-- Backdrop -->
  <div class="bb-modal-overlay" id="bb-modal-overlay" hidden></div>

  <!-- Modal container (centers the card) -->
  <div class="bb-modal" id="bb-contact-modal" role="dialog" aria-modal="true" aria-labelledby="bb-modal-title" hidden>
    <!-- Card -->
    <div class="bb-modal-card" role="document">
          <button class="bb-modal-close" id="bb-modal-close" aria-label="Close">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M6 6l12 12M18 6L6 18"
            fill="none" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

      <h3 class="bb-modal-title" id="bb-modal-title">{{ section.settings.modal_title }}</h3>
      <p class="bb-modal-sub">{{ section.settings.modal_subtext }}</p>

      {%- if section.settings.enable_chat -%}
      <div class="bb-tabs" role="tablist" aria-label="Contact options">
        <button type="button" class="bb-tab" id="bb-tab-chat" role="tab" aria-controls="bb-panel-chat" aria-selected="false">{{ section.settings.chat_tab_label | default: 'Quick help' }}</button>
        <button type="button" class="bb-tab" id="bb-tab-form" role="tab" aria-controls="bb-panel-form" aria-selected="false">{{ section.settings.form_tab_label | default: 'Send message' }}</button>
      </div>

      <div class="bb-panel" id="bb-panel-chat" role="tabpanel" aria-labelledby="bb-tab-chat" hidden>
        <div class="bb-chat-log" id="bb-chat-log" aria-live="polite"></div>
        <div class="bb-chat-pills" id="bb-chat-pills">
          {%- for block in section.blocks -%}
            {%- if block.type == 'faq' -%}
              {%- if block.settings.question != blank -%}
                <button type="button" class="bb-pill" data-faq="{{ forloop.index0 }}" {{ block.shopify_attributes }}>{{ block.settings.question | escape }}</button>
              {%- elsif request.design_mode -%}
                <button type="button" class="bb-pill bb-pill--empty" {{ block.shopify_attributes }}>Add a question…</button>
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
        {%- for block in section.blocks -%}
          {%- if block.type == 'faq' and block.settings.answer != blank -%}
            <div class="bb-faq-answer" id="bb-faq-answer-{{ forloop.index0 }}" hidden>{{ block.settings.answer }}</div>
          {%- endif -%}
        {%- endfor -%}
        <form class="bb-chat-inputrow" id="bb-chat-inputrow" novalidate>
          <input type="text" id="bb-chat-input" placeholder="{{ section.settings.chat_placeholder | default: 'Type a question…' | escape }}" autocomplete="off" maxlength="300">
          <button type="submit" class="bb-chat-send" aria-label="Send">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 12l18-8-8 18-2-8-8-2z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>
          </button>
        </form>
      </div>

      {%- endif -%}

      {%- comment -%} Chat disabled: the form renders as the whole modal, visible
          without JS (no hidden attribute, no tab roles). {%- endcomment -%}
      <div class="bb-panel" id="bb-panel-form" {% if section.settings.enable_chat %}role="tabpanel" aria-labelledby="bb-tab-form" hidden{% endif %}>
      {% if section.settings.send_mode == 'shopify' %}
        {%- form 'contact', id: 'FloatingContactForm', class: 'bb-form' -%}
          <input type="hidden" name="form_type" value="contact">
          {% if section.settings.subject_prefix != blank %}
            <input type="hidden" name="contact[tags]" value="{{ section.settings.subject_prefix }}">
          {% endif %}

          <label class="bb-field">
            <span>Name*</span>
            <input type="text" name="contact[name]" required autocomplete="name">
          </label>

          <label class="bb-field">
            <span>Email*</span>
            <input type="email" name="contact[email]" required autocomplete="email">
          </label>

          <label class="bb-field">
            <span>Phone</span>
            <input type="tel" name="contact[phone]" autocomplete="tel">
          </label>

          <label class="bb-field">
            <span>Message*</span>
            <textarea name="contact[body]" rows="5" required></textarea>
          </label>

          <button type="submit" class="bb-submit" id="bb-submit">{{ section.settings.submit_label }}</button>
          <div class="bb-status" id="bb-status" aria-live="polite"></div>
        {%- endform -%}
      {% else %}
        <!-- Custom webhook JSON POST -->
        <form id="FloatingContactWebhookForm" class="bb-form" novalidate>
          <label class="bb-field">
            <span>Name*</span>
            <input type="text" name="name" required autocomplete="name">
          </label>

          <label class="bb-field">
            <span>Email*</span>
            <input type="email" name="email" required autocomplete="email">
          </label>

          <label class="bb-field">
            <span>Phone</span>
            <input type="tel" name="phone" autocomplete="tel">
          </label>

          <label class="bb-field">
            <span>Message*</span>
            <textarea name="message" rows="5" required></textarea>
          </label>

          <button type="submit" class="bb-submit" id="bb-submit">{{ section.settings.submit_label }}</button>
          <div class="bb-status" id="bb-status" aria-live="polite"></div>
        </form>
      {% endif %}
      </div>
    </div>
  </div>

  <style>
    /* Floating Button */
    .bb-float-btn {
      position: fixed;
      bottom: 4%;
      right: 1%;
      z-index: 10002; 
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 60px;
      height: 60px;
      padding: 0;
      border-radius: 50%;
      border: 0;
      background: {{ section.settings.button_bg }};
      color: {{ section.settings.button_text }};
      box-shadow: 0 8px 20px rgba(0,0,0,.18);
      cursor: pointer;
    }
    .bb-float-btn img {
      width: 60px; height: 60px; border-radius: 50%; display: block;
    }

    /* Backdrop */
    .bb-modal-overlay {
      position: fixed; inset: 0; background: rgba(0,0,0,.5); z-index: 10000;
    }

      .bb-modal{
      position: fixed;
      inset: auto;                                    
      right: {{ section.settings.offset_right | default: 24 }}px;
      bottom: calc(24px + 72px);                       
      z-index: 10001;                                 
      width: min(92vw, 520px);
      pointer-events: none;                          
    }

    .bb-modal-card{
        position: relative;
        pointer-events: auto;
        width: 100%;
        max-width: 520px;
        max-height: calc(100vh - 130px);
        overflow-y: auto;
        background: #fff;
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 20px 50px rgba(0,0,0,.25);
        animation: bb-slide-up .18s ease-out;
        font-family: "Helvetica" !important;
    }

 

     .bb-modal-close{
  position:absolute; top:10px; right:12px;
  display:inline-flex; align-items:center; justify-content:center;
  width:32px; height:32px; border:0; border-radius:8px;
  background:transparent; color:#111;
  cursor:pointer; line-height:1;
}

.bb-modal-close svg{ width:20px; height:20px; display:block; }



    /* Form */
    .bb-field { display: grid; gap: 6px; margin-bottom: 12px;  }
    .bb-field input, .bb-field textarea {
      width: 100%; padding: 10px 12px; border-radius: 10px; border: 1px solid #ddd; font: inherit;
    }
    .bb-submit {
      width: 100%; padding: 12px 14px; border-radius: 10px; border: 0; cursor: pointer;
      font-weight: 700; background: #3C2005; color: {{ section.settings.submit_text }};
    }
    .bb-modal-title { margin: 0 0 6px; font-size: 20px; font-family: Helvetica !important ;}
    .bb-modal-sub   { margin: 0 0 16px; color: #555; font-size: 14px; font-family: Helvetica !important ; }
    .bb-status      { margin-top: 10px; min-height: 18px; font-size: 14px; }

    /* Tabs + chat */
    .bb-tabs{display:flex;gap:8px;margin:0 0 14px;border-bottom:1px solid #eee;padding-bottom:12px}
    .bb-tab{flex:1;padding:9px 10px;border:1px solid #ddd;border-radius:10px;background:#fff;color:#3C2005;font:inherit;font-weight:700;font-size:13px;cursor:pointer}
    .bb-tab.is-active{background:#3C2005;color:#fff;border-color:#3C2005}
    .bb-panel[hidden], .bb-faq-answer[hidden]{display:none!important}
    .bb-chat-log{display:flex;flex-direction:column;gap:8px;min-height:110px;max-height:250px;overflow-y:auto;padding:4px 2px;margin-bottom:10px;scrollbar-width:thin}
    .bb-msg{max-width:85%;padding:9px 12px;border-radius:12px;font-size:13.5px;line-height:1.45;overflow-wrap:break-word}
    .bb-msg--plain{white-space:pre-line}
    .bb-msg--bot{align-self:flex-start;background:#F6F1E7;color:#3C2005;border-bottom-left-radius:4px}
    .bb-msg--user{align-self:flex-end;background:#3C2005;color:#fff;border-bottom-right-radius:4px}
    .bb-msg--bot p{margin:0 0 6px}
    .bb-msg--bot p:last-child{margin:0}
    .bb-msg-link{display:inline-block;margin-top:6px;color:#3C2005;font-weight:700;text-decoration:underline;cursor:pointer;background:none;border:0;padding:0;font:inherit;font-size:13px}
    .bb-msg--product{display:flex;flex-direction:column;gap:2px}
    .bb-prod-link{color:#3C2005;font-weight:700;text-decoration:underline}
    .bb-prod-price{font-size:12.5px;color:#6b5138}
    .bb-typing{align-self:flex-start;background:#F6F1E7;color:#3C2005;border-radius:12px;padding:9px 14px;font-size:15px;letter-spacing:3px}
    .bb-chat-pills{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:10px}
    .bb-chat-pills:empty{display:none}
    .bb-pill{padding:7px 12px;border:1px solid #ddd;border-radius:999px;background:#fff;color:#333;font:inherit;font-size:12.5px;cursor:pointer}
    .bb-pill:hover{border-color:#3C2005;color:#3C2005}
    .bb-pill--empty{opacity:.5;font-style:italic}
    .bb-chat-send[disabled]{opacity:.55;cursor:default}
    .bb-chat-inputrow input[disabled]{opacity:.7}
    .bb-chat-inputrow{display:flex;gap:8px}
    .bb-chat-inputrow input{flex:1;min-width:0;padding:10px 12px;border-radius:10px;border:1px solid #ddd;font:inherit}
    .bb-chat-send{width:42px;height:42px;flex:0 0 auto;border:0;border-radius:10px;background:#3C2005;color:#fff;cursor:pointer;display:inline-flex;align-items:center;justify-content:center}
    .bb-chat-send svg{width:18px;height:18px}

    /* Hide when closed */
    .bb-modal[hidden], .bb-modal-overlay[hidden] { display: none !important; }

    @keyframes bb-zoom-in {
      from { transform: scale(.96); opacity: 0; }
      to   { transform: scale(1);   opacity: 1; }
    }
    @keyframes bb-slide-up{
  from{ transform: translateY(8px); opacity: 0; }
  to  { transform: translateY(0);    opacity: 1; }
}


    @media (max-width: 480px){
  .bb-modal{
    right: 12px;
    bottom: calc(12px + 72px);
    width: calc(100vw - 24px);
  }
  .bb-modal-card::after{ right: 24px; }
}

    @media (max-width: 768px){
    .bb-float-btn{
      bottom: 15%;
      right: 1%;
    }
}

  </style>

  <script>
    (function () {
      const root = document.getElementById('bb-floating-contact');
      if (!root) return;

      // Icons
      const DEFAULT_ICON_URL = "{{ bb_icon_url }}";
      const OPEN_ICON_URL    = "https://cdn.shopify.com/s/files/1/0861/1106/0252/files/Dropdown_4.png?v=1758809684";
      const pre = new Image(); pre.src = OPEN_ICON_URL;

      // Config
      const sendMode    = root.dataset.sendMode; // 'shopify' | 'webhook'
      const webhookUrl  = root.dataset.webhookUrl;
      const successText = root.dataset.successText || 'Thanks! We received your message.';
      const errorText   ='Thanks! We received your message';

      // Elements
      const btn      = document.getElementById('bb-float-btn');
      const btnIcon  = document.getElementById('bb-float-icon');
      const modal    = document.getElementById('bb-contact-modal');
      const overlay  = document.getElementById('bb-modal-overlay');
      const closeBtn = document.getElementById('bb-modal-close');
      const statusBox = document.getElementById('bb-status');
      const submitBtn = document.getElementById('bb-submit');
      const shopifyForm = document.getElementById('FloatingContactForm');
      const webhookForm = document.getElementById('FloatingContactWebhookForm');

      function setButtonIcon(isOpen) {
        if (btnIcon) btnIcon.src = isOpen ? OPEN_ICON_URL : DEFAULT_ICON_URL;
      }

      function openModal() {
        overlay.hidden = false;
        modal.hidden = false;
        setButtonIcon(true);
        const first = modal.querySelector('input, textarea, button');
        if (first) first.focus();
        document.body.style.overflow = 'hidden';
      }

      function closeModal() {
        overlay.hidden = true;
        modal.hidden = true;
        setButtonIcon(false);
        document.body.style.overflow = '';
        if (btn) btn.focus();
      }

      // Toggle open/close
      btn.addEventListener('click', () => (modal.hidden ? openModal() : closeModal()));
      overlay.addEventListener('click', closeModal);
      closeBtn.addEventListener('click', closeModal);
      document.addEventListener('keydown', (e) => { if (!modal.hidden && e.key === 'Escape') closeModal(); });

      // Helpers
      const validEmail = (v) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v);
      const validPhone = (v) => v.trim() === '' || /^[\d+\-\s()]{6,}$/.test(v);

      function setLoading(on) {
        if (!submitBtn) return;
        submitBtn.disabled = on;
        submitBtn.textContent = on ? 'Sending…' : '{{ section.settings.submit_label }}';
      }

      // Shopify AJAX submit
      async function handleShopifySubmit(ev) {
        ev.preventDefault();
        const fd = new FormData(shopifyForm);

        const name  = fd.get('contact[name]')  || '';
        const email = fd.get('contact[email]') || '';
        const phone = fd.get('contact[phone]') || '';
        const body  = fd.get('contact[body]')  || '';

        if (!name.trim() || !validEmail(email) || !body.trim() || !validPhone(phone)) {
          statusBox.textContent = 'Please fill required fields correctly.';
          return;
        }

        try {
          setLoading(true);
          const resp = await fetch('/contact', {
            method: 'POST',
            headers: { 'Accept': 'text/html' },
            body: fd
          });

          if (resp.ok) {
            statusBox.textContent = successText;
            shopifyForm.reset();
            setTimeout(closeModal, 1200);
          } else {
            statusBox.textContent = errorText;
          }
        } catch (e) {
          statusBox.textContent = errorText;
        } finally {
          setLoading(false);
        }
      }

      // Webhook submit
      async function handleWebhookSubmit(ev) {
        ev.preventDefault();
        const fd = new FormData(webhookForm);

        const name    = (fd.get('name')    || '').trim();
        const email   = (fd.get('email')   || '').trim();
        const phone   = (fd.get('phone')   || '').trim();
        const message = (fd.get('message') || '').trim();

        if (!name || !validEmail(email) || !message || !validPhone(phone)) {
          statusBox.textContent = 'Please fill required fields correctly.';
          return;
        }
        if (!webhookUrl) {
          statusBox.textContent = 'Missing webhook URL in section settings.';
          return;
        }

        try {
          setLoading(true);
          const resp = await fetch(webhookUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              name, email, phone, message,
              page: window.location.href,
              source: 'floating-contact'
            })
          });

          if (resp.ok) {
            statusBox.textContent = successText;
            webhookForm.reset();
            setTimeout(closeModal, 1200);
          } else {
            statusBox.textContent = errorText;
          }
        } catch (e) {
          statusBox.textContent = errorText;
        } finally {
          setLoading(false);
        }
      }

      if (shopifyForm) shopifyForm.addEventListener('submit', handleShopifySubmit);
      if (webhookForm) webhookForm.addEventListener('submit', handleWebhookSubmit);

      setButtonIcon(false);
    })();

    /* ---- Quick-help chat tab (separate from the form logic above) ---- */
    (function () {
      const root = document.getElementById('bb-floating-contact');
      if (!root) return;
      const log       = document.getElementById('bb-chat-log');
      const pills     = document.getElementById('bb-chat-pills');
      const inputRow  = document.getElementById('bb-chat-inputrow');
      const input     = document.getElementById('bb-chat-input');
      const tabChat   = document.getElementById('bb-tab-chat');
      const tabForm   = document.getElementById('bb-tab-form');
      const panelChat = document.getElementById('bb-panel-chat');
      const panelForm = document.getElementById('bb-panel-form');
      if (!log || !tabChat || !tabForm || !panelChat || !panelForm) return;

      const greeting     = root.dataset.chatGreeting || '';
      const fallbackText = root.dataset.chatFallback || "I couldn't find an instant answer for that.";
      const llmUrl       = (root.dataset.chatEndpoint || '').trim();

      function showTab(name){
        const chat = name === 'chat';
        panelChat.hidden = !chat;
        panelForm.hidden = chat;
        tabChat.classList.toggle('is-active', chat);
        tabForm.classList.toggle('is-active', !chat);
        tabChat.setAttribute('aria-selected', chat ? 'true' : 'false');
        tabForm.setAttribute('aria-selected', chat ? 'false' : 'true');
      }
      tabChat.addEventListener('click', function(){ showTab('chat'); });
      tabForm.addEventListener('click', function(){ showTab('form'); });
      showTab(root.dataset.defaultTab === 'form' ? 'form' : 'chat');

      function scrollLog(){ log.scrollTop = log.scrollHeight; }
      function addMsg(who, content, opts){
        const el = document.createElement('div');
        el.className = 'bb-msg bb-msg--' + who;
        if (opts && opts.html){ el.innerHTML = content; }
        else { el.classList.add('bb-msg--plain'); el.textContent = content; }
        log.appendChild(el);
        scrollLog();
        return el;
      }
      function addFormLink(el){
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'bb-msg-link';
        btn.textContent = 'Send us a message instead';
        btn.addEventListener('click', function(){ showTab('form'); });
        el.appendChild(document.createElement('br'));
        el.appendChild(btn);
        scrollLog();
      }
      let typingEl = null;
      function typing(on){
        if (on && !typingEl){
          typingEl = document.createElement('div');
          typingEl.className = 'bb-typing';
          typingEl.textContent = '•••';
          log.appendChild(typingEl);
          scrollLog();
        }
        if (!on && typingEl){ typingEl.remove(); typingEl = null; }
      }

      if (greeting) addMsg('bot', greeting);

      const sendBtn = inputRow ? inputRow.querySelector('.bb-chat-send') : null;
      let busy = false;
      function setBusy(on){
        busy = on;
        if (input) input.disabled = on;
        if (sendBtn) sendBtn.disabled = on;
      }
      async function ask(q, history){
        if (busy) return;
        setBusy(true);
        typing(true);
        try {
          if (llmUrl) await askLlm(q, history); else await askFaq(q);
        } catch(e){
          console.warn('[bb-chat]', e);
          addFormLink(addMsg('bot', fallbackText));
        } finally {
          typing(false);
          setBusy(false);
        }
      }

      /* Shopify Storefront MCP — same-origin, public, no auth needed.
         The FAQ tool lives on /api/mcp (sunsets 2026-08-31; failures degrade to the
         fallback + form link). Catalog search uses its successor /api/ucp/mcp.
         The abort timer covers the whole request INCLUDING the body read. */
      async function fetchJson(url, body, timeoutMs){
        const ctrl  = ('AbortController' in window) ? new AbortController() : null;
        const timer = ctrl && setTimeout(function(){ ctrl.abort(); }, timeoutMs || 12000);
        try {
          const res = await fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body),
            signal: ctrl ? ctrl.signal : undefined
          });
          if (!res.ok) throw new Error('http ' + res.status);
          return await res.json();
        } finally {
          if (timer) clearTimeout(timer);
        }
      }
      const UCP_PROFILE = 'https://shopify.dev/ucp/agent-profiles/examples/2026-04-08/valid-with-capabilities.json';
      async function mcpCall(endpoint, name, args){
        const data = await fetchJson(endpoint, { jsonrpc: '2.0', method: 'tools/call', id: 1,
          params: { name: name, arguments: args } });
        return (data && data.result && data.result.content) || [];
      }
      function parseJsonItems(items){
        const out = [];
        items.forEach(function(it){
          if (it && it.type === 'text' && typeof it.text === 'string'){
            try { out.push(JSON.parse(it.text)); } catch(e){}
          }
        });
        return out;
      }
      function money(pr){
        const mn = pr && pr.min && typeof pr.min.amount === 'number' ? pr.min.amount : null;
        if (mn === null) return '';
        const mx = pr.max && typeof pr.max.amount === 'number' ? pr.max.amount : mn;
        const cur = (pr.min && pr.min.currency) || 'USD';
        const f = function(c){ return cur === 'USD' ? '$' + (c/100).toFixed(2) : (c/100).toFixed(2) + ' ' + cur; };
        return mn === mx ? f(mn) : f(mn) + ' – ' + f(mx);
      }
      function addProductMsg(p){
        const url = String(p.url || '');
        if (!/^https?:\/\//i.test(url)) return;
        const el = document.createElement('div');
        el.className = 'bb-msg bb-msg--bot bb-msg--product';
        const a = document.createElement('a');
        a.href = url;
        a.className = 'bb-prod-link';
        a.textContent = p.title;
        el.appendChild(a);
        const priceTxt = money(p.price_range);
        if (priceTxt){
          const s = document.createElement('span');
          s.className = 'bb-prod-price';
          s.textContent = priceTxt;
          el.appendChild(s);
        }
        log.appendChild(el);
        scrollLog();
      }
      /* Order-status questions can't be answered from the storefront (needs the
         authenticated Admin API via the future AI endpoint) — route them to the
         customer's account order history instead of the generic fallback. */
      function looksLikeOrderQuery(q){
        if (/^#?\d{3,}$/.test(q.trim())) return true;
        return /(order|track|shipment|delivery|status)/i.test(q) && /#?\d{3,}/.test(q);
      }
      function addOrderHelpMsg(){
        const el = addMsg('bot', 'I can’t look up individual orders in this chat yet. You can see your order status and tracking any time in your account:');
        const a = document.createElement('a');
        a.href = '/account';
        a.className = 'bb-prod-link';
        a.textContent = 'View my orders';
        el.appendChild(document.createElement('br'));
        el.appendChild(a);
        addFormLink(el);
      }
      /* Free-text flow: store policies/FAQ first, then product catalog, then fallback. */
      async function askFaq(q){
        if (looksLikeOrderQuery(q)){ addOrderHelpMsg(); return; }
        let answers = [];
        try {
          parseJsonItems(await mcpCall('/api/mcp', 'search_shop_policies_and_faqs', { query: q }))
            .forEach(function(v){ if (Array.isArray(v)) answers = answers.concat(v); });
        } catch(e){ console.warn('[bb-chat] faq lookup failed', e); }
        answers = answers.filter(function(a){ return a && a.answer; }).slice(0, 2);
        if (answers.length){
          answers.forEach(function(a){ addMsg('bot', a.answer); });
          return;
        }
        let products = [];
        try {
          parseJsonItems(await mcpCall('/api/ucp/mcp', 'search_catalog', { meta: { 'ucp-agent': { profile: UCP_PROFILE } }, catalog: { query: q } }))
            .forEach(function(v){ if (v && Array.isArray(v.products)) products = products.concat(v.products); });
        } catch(e){ console.warn('[bb-chat] catalog lookup failed', e); }
        products = products.filter(function(p){ return p && p.title && p.url; }).slice(0, 3);
        if (products.length){
          addMsg('bot', 'Here’s what I found in our shop:');
          products.forEach(addProductMsg);
          return;
        }
        addFormLink(addMsg('bot', fallbackText));
      }

      /* Optional AI endpoint (section setting) for when the LLM Worker exists.
         Contract: POST {message, history:[{role,text}...], page} -> {reply:"..."}
         History is snapshotted BEFORE the outgoing question is painted, and UI
         affordances (the "Send us a message instead" button) are stripped. */
      function snapshotHistory(){
        return Array.prototype.slice.call(log.querySelectorAll('.bb-msg')).slice(-10).map(function(m){
          const c = m.cloneNode(true);
          Array.prototype.forEach.call(c.querySelectorAll('.bb-msg-link, br'), function(n){ n.remove(); });
          return { role: m.classList.contains('bb-msg--user') ? 'user' : 'assistant', text: (c.textContent || '').trim() };
        });
      }
      async function askLlm(q, history){
        const payload = { message: q, history: history || [], page: location.href };
        if (root.dataset.customerEmail) payload.customer_email = root.dataset.customerEmail;
        const data = await fetchJson(llmUrl, payload, 25000);
        if (data && typeof data.reply === 'string' && data.reply) addMsg('bot', data.reply);
        else throw new Error('bad reply');
      }

      if (pills) pills.addEventListener('click', function(e){
        const pill = e.target.closest('.bb-pill');
        if (!pill || typeof pill.dataset.faq === 'undefined') return;
        const q = pill.textContent.trim();
        const canned = document.getElementById('bb-faq-answer-' + pill.dataset.faq);
        if (canned){
          addMsg('user', q);
          addMsg('bot', canned.innerHTML, { html: true });
          return;
        }
        if (busy) return;
        const h = snapshotHistory();
        addMsg('user', q);
        ask(q, h);
      });
      if (inputRow) inputRow.addEventListener('submit', function(e){
        e.preventDefault();
        if (busy) return;
        const q = (input.value || '').trim();
        if (!q) return;
        const h = snapshotHistory();
        input.value = '';
        addMsg('user', q);
        ask(q, h);
      });

      /* Theme editor: selecting the section or a Quick question block opens the
         widget so merchants can see what they're editing. */
      if (window.Shopify && window.Shopify.designMode){
        const ensureOpen = function(){
          const m = document.getElementById('bb-contact-modal');
          const b = document.getElementById('bb-float-btn');
          if (m && m.hidden && b) b.click();
        };
        document.addEventListener('shopify:section:select', function(e){
          if (e.target && e.target.contains(root)) ensureOpen();
        });
        document.addEventListener('shopify:block:select', function(e){
          if (e.target && e.target.contains(root)){ ensureOpen(); showTab('chat'); }
        });
      }
    })();
  </script>
</section>

{% schema %}
{
  "name": "Floating contact button",
  "settings": [
    {
      "type": "select",
      "id": "send_mode",
      "label": "Send to",
      "default": "shopify",
      "options": [
        { "value": "shopify", "label": "Shopify Contact (emails store owner)" },
        { "value": "webhook", "label": "Custom Webhook (POST JSON)" }
      ]
    },
    { "type": "url", "id": "webhook_url", "label": "Webhook URL (when 'webhook' is selected)" },

    { "type": "text", "id": "button_label", "label": "Button label", "default": "Contact us" },
    { "type": "image_picker", "id": "button_icon", "label": "Custom button icon (optional)" },

    { "type": "text", "id": "modal_title", "label": "Modal title", "default": "Send us a message" },
    { "type": "text", "id": "modal_subtext", "label": "Subtitle", "default": "We typically reply within a business day." },
    { "type": "text", "id": "subject_prefix", "label": "Subject/Tag hint (optional)", "default": "Floating Contact" },

    { "type": "color", "id": "button_bg", "label": "Button background", "default": "#111827" },
    { "type": "color", "id": "button_text", "label": "Button text color", "default": "#ffffff" },

    { "type": "color", "id": "submit_bg", "label": "Submit button background", "default": "#111827" },
    { "type": "color", "id": "submit_text", "label": "Submit button text", "default": "#ffffff" },

    {
      "type": "range",
      "id": "offset_right",
      "label": "Right offset (px)",
      "min": 0,
      "max": 200,
      "step": 2,
      "default": 24
    },

    { "type": "text", "id": "submit_label", "label": "Submit label", "default": "Send Message" },
    { "type": "text", "id": "success_text", "label": "Success text", "default": "Thanks! We received your message." },
    { "type": "text", "id": "error_text", "label": "Error text", "default": "Something went wrong. Please try again." },

    { "type": "header", "content": "Quick-help chat" },
    {
      "type": "checkbox",
      "id": "enable_chat",
      "label": "Enable Quick-help chat",
      "default": true,
      "info": "Off: the widget shows only the contact form, exactly as before the chat existed."
    },
    {
      "type": "select",
      "id": "default_tab",
      "label": "Tab shown when the widget opens",
      "default": "chat",
      "options": [
        { "value": "chat", "label": "Quick help (chat)" },
        { "value": "form", "label": "Contact form" }
      ]
    },
    { "type": "text", "id": "chat_tab_label", "label": "Chat tab label", "default": "Quick help" },
    { "type": "text", "id": "form_tab_label", "label": "Form tab label", "default": "Send message" },
    { "type": "text", "id": "chat_greeting", "label": "Chat greeting", "default": "Hi! Pick a question below, or type your own — I’ll answer instantly." },
    { "type": "text", "id": "chat_placeholder", "label": "Input placeholder", "default": "Type a question…" },
    { "type": "text", "id": "chat_fallback", "label": "No-answer fallback text", "default": "I couldn’t find an instant answer for that." },
    { "type": "url", "id": "chat_endpoint", "label": "AI chat endpoint (optional)", "info": "Leave empty to answer typed questions from the store’s built-in policies/FAQ search. Set to your AI Worker URL later to switch to LLM replies." }
  ],
  "max_blocks": 12,
  "blocks": [
    {
      "type": "faq",
      "name": "Quick question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer (optional)",
          "info": "Leave empty to auto-answer this question from the store’s policies/FAQ search."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Floating contact button",
      "blocks": [
        { "type": "faq", "settings": { "question": "What countries do you ship to?" } },
        { "type": "faq", "settings": { "question": "How long does shipping take?" } }
      ]
    }
  ]
}
{% endschema %}
