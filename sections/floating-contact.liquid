    .bb-typing{align-self:flex-start;background:#F6F1E7;color:#3C2005;border-radius:12px;padding:9px 14px;font-size:15px;letter-spacing:3px}
    .bb-chat-pills{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:10px}
    .bb-chat-pills:empty{display:none}
    .bb-pill{padding:7px 12px;border:1px solid #ddd;border-radius:999px;background:#fff;color:#333;font:inherit;font-size:12.5px;cursor:pointer}
    .bb-pill:hover{border-color:#3C2005;color:#3C2005}
    /* Starter questions vanish once the conversation begins (Track stays). */
    .bb-chat-pills.is-used .bb-pill[data-faq]{display:none}
    /* Gentle floating bob, staggered so pills don't move in unison. */
    @keyframes bb-pill-float{0%,100%{transform:translateY(0)}50%{transform:translateY(-3px)}}
    .bb-pill{animation:bb-pill-float 3.2s ease-in-out infinite}
    .bb-chat-pills .bb-pill:nth-child(2n){animation-delay:-1.1s}
    .bb-chat-pills .bb-pill:nth-child(3n){animation-delay:-2.2s}
    @media (prefers-reduced-motion:reduce){.bb-pill{animation:none}}
    .bb-pill--empty{opacity:.5;font-style:italic}
    /* Track tab: input row + step timeline */
    .bb-track-intro{margin:0 0 12px;color:#555;font-size:13.5px}
    .bb-trackform{display:flex;gap:8px;margin-bottom:12px}
    .bb-trackform input{flex:1;min-width:0;padding:10px 12px;border-radius:10px;border:1px solid #ddd;font:inherit}
    .bb-submit.bb-track-go{width:auto;padding:10px 20px;margin:0;flex:0 0 auto}
    .bb-track-go[disabled]{opacity:.6;cursor:default}
    .bb-track-status{min-height:18px;font-size:13.5px;color:#3C2005}
    .bb-track-head{display:flex;justify-content:space-between;align-items:baseline;gap:10px;flex-wrap:wrap;margin:8px 0 2px}
    .bb-track-current{font-weight:700;font-size:16.5px;color:#3C2005}
    .bb-track-updated{font-size:12px;color:#8a7a68}
    .bb-steps{list-style:none;margin:12px 0 0;padding:0 0 0 4px}
    .bb-step{position:relative;display:flex;align-items:baseline;gap:10px;padding:0 0 22px 24px}
    .bb-step::before{content:'';position:absolute;left:7px;top:16px;bottom:-2px;width:2px;background:#E8DFC9}
    .bb-step:last-child{padding-bottom:4px}
    .bb-step:last-child::before{display:none}
    .bb-step-dot{position:absolute;left:0;top:2px;width:18px;height:18px;border-radius:50%;border:2px solid #C9BBA4;background:#fff;box-sizing:border-box;display:flex;align-items:center;justify-content:center;transition:all .25s ease}
    .bb-step.is-done::before{background:#3C2005}
    .bb-step.is-done .bb-step-dot{border-color:#3C2005;background:#3C2005}
    .bb-step.is-done .bb-step-dot::after{content:'✓';color:#FCE2A0;font-size:11px;font-weight:700;line-height:1}
    .bb-step.is-current .bb-step-dot{border-color:#3C2005;background:#FF6B5C;animation:bb-pulse 1.6s ease-in-out infinite}
    .bb-step.is-current.is-done .bb-step-dot{background:#3C2005;animation:none}
    @keyframes bb-pulse{0%,100%{box-shadow:0 0 0 0 rgba(255,107,92,.45)}50%{box-shadow:0 0 0 6px rgba(255,107,92,0)}}
    @media (prefers-reduced-motion:reduce){.bb-step.is-current .bb-step-dot{animation:none}}
    .bb-step-lbl{font-size:14px;color:#8a7a68}
    .bb-step.is-done .bb-step-lbl{color:#3C2005}
    .bb-step.is-current .bb-step-lbl{font-weight:700;color:#3C2005}
    .bb-step-at{margin-left:auto;font-size:11.5px;color:#a3907a;white-space:nowrap}
    /* Delivery-issue node */
    .bb-step.is-fail{background:#FDECEA;border-radius:12px;padding:10px 10px 10px 34px;margin:2px 0 8px;align-items:center;flex-wrap:wrap}
    .bb-step.is-fail::before{display:none}
    .bb-step.is-fail .bb-step-dot{left:10px;top:12px;border-color:#c0392b;background:#c0392b}
    .bb-step.is-fail .bb-step-dot::after{content:'!';color:#fff;font-size:11px;font-weight:700}
    .bb-step.is-fail .bb-step-lbl{color:#8a2b1d;font-weight:700;font-size:13px}
    .bb-step-fail-btn{margin-left:auto;border:1.5px solid #c0392b;border-radius:999px;background:#fff;color:#c0392b;font:inherit;font-size:12px;font-weight:700;padding:6px 12px;cursor:pointer}
    .bb-step-fail-btn:hover{background:#c0392b;color:#fff}
    .bb-track-meta{margin-top:12px;font-size:12.5px;color:#5a4632;overflow-wrap:break-word}
    .bb-chat-send[disabled]{opacity:.55;cursor:default}
    .bb-chat-inputrow input[disabled]{opacity:.7}
    .bb-chat-inputrow{display:flex;gap:8px}
    .bb-chat-inputrow input{flex:1;min-width:0;padding:10px 12px;border-radius:10px;border:1px solid #ddd;font:inherit}
    .bb-chat-send{width:42px;height:42px;flex:0 0 auto;border:0;border-radius:10px;background:#3C2005;color:#fff;cursor:pointer;display:inline-flex;align-items:center;justify-content:center}
    .bb-chat-send svg{width:18px;height:18px}

    /* Hide when closed */
    .bb-modal[hidden], .bb-modal-overlay[hidden] { display: none !important; }

    @keyframes bb-zoom-in {
      from { transform: scale(.96); opacity: 0; }
      to   { transform: scale(1);   opacity: 1; }
    }
    @keyframes bb-slide-up{
  from{ transform: translateY(8px); opacity: 0; }
  to  { transform: translateY(0);    opacity: 1; }
}


    @media (max-width: 480px){
  .bb-modal{
    right: 12px;
    bottom: calc(12px + 72px);
    width: calc(100vw - 24px);
  }
  .bb-modal-card::after{ right: 24px; }
}

    @media (max-width: 768px){
    .bb-float-btn{
      bottom: 15%;
