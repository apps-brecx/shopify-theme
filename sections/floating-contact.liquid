{% comment %}
  Floating Contact Button + Modal
  - Position: bottom-right (fixed)
  - Sends to: Shopify contact email (default) OR a custom webhook URL
  - No page reload on submit
{% endcomment %}

{% liquid
  assign bb_icon_url = ''
  if section.settings.button_icon != blank
    assign bb_icon_url = section.settings.button_icon | image_url: width: 120
  else
    assign bb_icon_url = 'https://cdn.shopify.com/s/files/1/0861/1106/0252/files/Contact_us.png?v=1758809684'
  endif
%}

{%- render 'pd-collection-polish' -%}

<section id="bb-floating-contact"
  class="bb-floating-contact"
  data-send-mode="{{ section.settings.send_mode }}"
  data-webhook-url="{{ section.settings.webhook_url | escape }}"
  data-success-text="{{ section.settings.success_text | escape }}"
  data-error-text="{{ section.settings.error_text | escape }}"
  data-default-tab="{{ section.settings.default_tab | default: 'chat' }}"
  data-chat-endpoint="{{ section.settings.chat_endpoint | escape }}"
  data-customer-email="{% if customer %}{{ customer.email | escape }}{% endif %}"
  data-chat-greeting="{{ section.settings.chat_greeting | escape }}"
  data-chat-fallback="{{ section.settings.chat_fallback | escape }}"
>
  <!-- Floating button -->
  <button class="bb-float-btn"
          id="bb-float-btn"
          aria-haspopup="dialog"
          aria-controls="bb-contact-modal"
          aria-label="{{ section.settings.button_label }}">
    <img id="bb-float-icon"
         src="{{ bb_icon_url }}"
         alt="{{ section.settings.button_label | escape }}"
         width="60" height="60" loading="lazy">
  </button>

  <!-- Backdrop -->
  <div class="bb-modal-overlay" id="bb-modal-overlay" hidden></div>

  <!-- Modal container (centers the card) -->
  <div class="bb-modal" id="bb-contact-modal" role="dialog" aria-modal="true" aria-labelledby="bb-modal-title" hidden>
    <!-- Card -->
    <div class="bb-modal-card" role="document">
          <button class="bb-modal-close" id="bb-modal-close" aria-label="Close">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M6 6l12 12M18 6L6 18"
            fill="none" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

      <h3 class="bb-modal-title" id="bb-modal-title">{{ section.settings.modal_title }}</h3>
      <p class="bb-modal-sub">{{ section.settings.modal_subtext }}</p>

      {%- if section.settings.enable_chat or section.settings.enable_claim or section.settings.enable_track -%}
      <div class="bb-tabs" role="tablist" aria-label="Contact options">
        {%- if section.settings.enable_chat -%}
        <button type="button" class="bb-tab" id="bb-tab-chat" role="tab" aria-controls="bb-panel-chat" aria-selected="false">{{ section.settings.chat_tab_label | default: 'Quick help' }}</button>
        {%- endif -%}
        <button type="button" class="bb-tab" id="bb-tab-form" role="tab" aria-controls="bb-panel-form" aria-selected="false">{{ section.settings.form_tab_label | default: 'Send message' }}</button>
        {%- if section.settings.enable_claim -%}
        <button type="button" class="bb-tab" id="bb-tab-claim" role="tab" aria-controls="bb-panel-claim" aria-selected="false">{{ section.settings.claim_tab_label | default: 'Claim' }}</button>
        {%- endif -%}
        {%- if section.settings.enable_track -%}
        <button type="button" class="bb-tab" id="bb-tab-track" role="tab" aria-controls="bb-panel-track" aria-selected="false">{{ section.settings.track_tab_label | default: 'Track package' }}</button>
        {%- endif -%}
      </div>
      {%- endif -%}

      {%- comment -%} Both panels share one grid cell, so the modal keeps the
          height of the taller (form) tab and never jumps when switching. {%- endcomment -%}
      <div class="bb-panels">
      {%- if section.settings.enable_chat -%}
      <div class="bb-panel" id="bb-panel-chat" role="tabpanel" aria-labelledby="bb-tab-chat" hidden>
        <div class="bb-chat-log" id="bb-chat-log" aria-live="polite"></div>
        <div class="bb-chat-pills" id="bb-chat-pills">
          {%- for block in section.blocks -%}
            {%- if block.type == 'faq' -%}
              {%- if block.settings.question != blank -%}
                <button type="button" class="bb-pill" data-faq="{{ forloop.index0 }}" {{ block.shopify_attributes }}>{{ block.settings.question | escape }}</button>
              {%- elsif request.design_mode -%}
                <button type="button" class="bb-pill bb-pill--empty" {{ block.shopify_attributes }}>Add a question…</button>
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
        {%- for block in section.blocks -%}
          {%- if block.type == 'faq' and block.settings.answer != blank -%}
            <div class="bb-faq-answer" id="bb-faq-answer-{{ forloop.index0 }}" hidden>{{ block.settings.answer }}</div>
          {%- endif -%}
        {%- endfor -%}
        <form class="bb-chat-inputrow" id="bb-chat-inputrow" novalidate>
          <input type="text" id="bb-chat-input" placeholder="{{ section.settings.chat_placeholder | default: 'Type a question…' | escape }}" autocomplete="off" maxlength="300">
          <button type="submit" class="bb-chat-send" aria-label="Send">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 12l18-8-8 18-2-8-8-2z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>
          </button>
        </form>
      </div>

      {%- endif -%}

      {%- comment -%} Chat and claim disabled: the form renders as the whole
          modal, visible without JS (no hidden attribute, no tab roles). {%- endcomment -%}
      <div class="bb-panel" id="bb-panel-form" {% if section.settings.enable_chat or section.settings.enable_claim or section.settings.enable_track %}role="tabpanel" aria-labelledby="bb-tab-form" hidden{% endif %}>
      {%- comment -%} bb-panels wrapper closes after this panel {%- endcomment -%}
      {% if section.settings.send_mode == 'shopify' %}
        {%- form 'contact', id: 'FloatingContactForm', class: 'bb-form' -%}
          <input type="hidden" name="form_type" value="contact">
          {% if section.settings.subject_prefix != blank %}
            <input type="hidden" name="contact[tags]" value="{{ section.settings.subject_prefix }}">
          {% endif %}

          <label class="bb-field">
            <span>Name*</span>
            <input type="text" name="contact[name]" required autocomplete="name">
          </label>

          <label class="bb-field">
            <span>Email*</span>
            <input type="email" name="contact[email]" required autocomplete="email">
          </label>

          <label class="bb-field">
            <span>Phone</span>
            <input type="tel" name="contact[phone]" autocomplete="tel">
          </label>

          <label class="bb-field">
            <span>Message*</span>
            <textarea name="contact[body]" rows="5" required></textarea>
          </label>

          <button type="submit" class="bb-submit" id="bb-submit">{{ section.settings.submit_label }}</button>
          <div class="bb-status" id="bb-status" aria-live="polite"></div>
        {%- endform -%}
      {% else %}
        <!-- Custom webhook JSON POST -->
        <form id="FloatingContactWebhookForm" class="bb-form" novalidate>
          <label class="bb-field">
            <span>Name*</span>
            <input type="text" name="name" required autocomplete="name">
          </label>

          <label class="bb-field">
            <span>Email*</span>
            <input type="email" name="email" required autocomplete="email">
          </label>

          <label class="bb-field">
            <span>Phone</span>
            <input type="tel" name="phone" autocomplete="tel">
          </label>

          <label class="bb-field">
            <span>Message*</span>
            <textarea name="message" rows="5" required></textarea>
          </label>

          <button type="submit" class="bb-submit" id="bb-submit">{{ section.settings.submit_label }}</button>
          <div class="bb-status" id="bb-status" aria-live="polite"></div>
        </form>
      {% endif %}
      </div>

      {%- if section.settings.enable_claim -%}
      {%- comment -%} Claim tab: 3-step wizard posting multipart to
          <chat_endpoint>/claim — the Worker holds the Claim API key. No email
          field: logged-in uses the account email; guests are resolved from
          the Shopify order server-side, with an inline fallback prompt only
          when that lookup can't run (needs_email). {%- endcomment -%}
      <div class="bb-panel" id="bb-panel-claim" role="tabpanel" aria-labelledby="bb-tab-claim" hidden>
        <p class="bb-claim-intro">{{ section.settings.claim_intro | default: 'Something wrong with your order? Tell us and we’ll make it right.' }}</p>
        <div class="bb-wiz-dots" id="bb-claim-dots" aria-hidden="true">
          <span class="bb-wiz-dot is-on">1</span><span class="bb-wiz-bar"></span><span class="bb-wiz-dot">2</span><span class="bb-wiz-bar"></span><span class="bb-wiz-dot">3</span>
        </div>
        <form id="bb-claim-form" novalidate>
          <div class="bb-wiz-step is-active" data-step="1">
            <label class="bb-field">
              <span>Your order number</span>
              <input type="text" id="bb-claim-order" maxlength="100" placeholder="e.g. 154008587601" autocomplete="off" inputmode="numeric" aria-label="Order number">
            </label>
            <button type="button" class="bb-submit bb-wiz-next" id="bb-claim-next1">Next</button>
          </div>
          <div class="bb-wiz-step" data-step="2">
            <div class="bb-wiz-q">What went wrong?</div>
            <div class="bb-claim-types" id="bb-claim-types">
              <button type="button" class="bb-ctype" data-type="Damaged in transit" data-photo="1"><span class="bb-ctype-ic">📦</span>Damaged in transit</button>
              <button type="button" class="bb-ctype" data-type="Wrong item" data-photo="1"><span class="bb-ctype-ic">🔄</span>Wrong item</button>
              <button type="button" class="bb-ctype" data-type="Never received"><span class="bb-ctype-ic">🕵️</span>Never received</button>
              <button type="button" class="bb-ctype" data-type="Delayed in transit"><span class="bb-ctype-ic">⏳</span>Delayed in transit</button>
              <button type="button" class="bb-ctype bb-ctype--wide" data-type="Other" data-msg="1"><span class="bb-ctype-ic">💬</span>Something else</button>
            </div>
            <div class="bb-wiz-nav">
              <button type="button" class="bb-wiz-back" data-back="1">← Back</button>
            </div>
          </div>
          <div class="bb-wiz-step" data-step="3">
            <div class="bb-claim-picked" id="bb-claim-picked"></div>
            <div class="bb-field" id="bb-claim-photo-field">
              <span>Photos <b class="bb-req-badge" id="bb-claim-photo-req" hidden>required</b></span>
              <label class="bb-claim-drop" for="bb-claim-files">📷 Add photos<input type="file" id="bb-claim-files" accept="image/*" multiple hidden></label>
            </div>
            <div class="bb-claim-filelist" id="bb-claim-filelist"></div>
            <label class="bb-field">
              <span id="bb-claim-msg-lbl">Tell us more <b class="bb-req-badge" id="bb-claim-msg-req" hidden>required</b></span>
              <textarea id="bb-claim-msg" rows="3" maxlength="8000" placeholder="Anything that helps us fix this faster…"></textarea>
            </label>
            {%- if customer -%}
              <input type="hidden" id="bb-claim-email" value="{{ customer.email | escape }}">
            {%- else -%}
              <label class="bb-field" id="bb-claim-email-field" hidden>
                <span>Your email <small class="bb-field-hint">our reply goes here</small></span>
                <input type="email" id="bb-claim-email" maxlength="200" autocomplete="email">
              </label>
            {%- endif -%}
            <div class="bb-wiz-nav">
              <button type="button" class="bb-wiz-back" data-back="2">← Back</button>
              <button type="submit" class="bb-submit bb-claim-send" id="bb-claim-submit">{{ section.settings.claim_submit_label | default: 'Submit claim' }}</button>
            </div>
            <div class="bb-status" id="bb-claim-status" aria-live="polite"></div>
          </div>
        </form>
        <div class="bb-claim-done" id="bb-claim-done" hidden>
          <div class="bb-claim-done-ic">✓</div>
          <div class="bb-claim-done-h">Claim received</div>
          <p class="bb-claim-done-p" id="bb-claim-done-text"></p>
          <button type="button" class="bb-wiz-back" id="bb-claim-again">Submit another claim</button>
        </div>
      </div>
      {%- endif -%}

      {%- if section.settings.enable_track -%}
      {%- comment -%} Track tab: order number -> <chat_endpoint>/track (FBM-backed)
          -> step timeline. Statuses/timestamps only; no personal data. {%- endcomment -%}
      <div class="bb-panel" id="bb-panel-track" role="tabpanel" aria-labelledby="bb-tab-track" hidden>
        <p class="bb-track-intro">{{ section.settings.track_intro | default: 'Enter your order number to see exactly where your package is.' }}</p>
        <form class="bb-trackform" id="bb-track-form" novalidate>
          <input type="text" id="bb-track-num" placeholder="e.g. 154008587601" maxlength="30" autocomplete="off" inputmode="numeric" aria-label="Order number">
          <button type="submit" class="bb-submit bb-track-go" id="bb-track-go">{{ section.settings.track_button_label | default: 'Track' }}</button>
        </form>
        <div class="bb-track-status" id="bb-track-status" aria-live="polite"></div>
        <div class="bb-track-result" id="bb-track-result" hidden>
          <div class="bb-track-head">
            <div class="bb-track-current" id="bb-track-current"></div>
            <div class="bb-track-updated" id="bb-track-updated"></div>
          </div>
          <ol class="bb-steps" id="bb-track-steps"></ol>
          <div class="bb-track-meta" id="bb-track-meta"></div>
        </div>
      </div>
      {%- endif -%}
      </div>
    </div>
  </div>

  <style>
    /* Floating Button */
    .bb-float-btn {
      position: fixed;
      bottom: 4%;
      right: 1%;
      z-index: 10002; 
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 60px;
      height: 60px;
      padding: 0;
      border-radius: 50%;
      border: 0;
      background: {{ section.settings.button_bg }};
      color: {{ section.settings.button_text }};
      box-shadow: 0 8px 20px rgba(0,0,0,.18);
      cursor: pointer;
    }
    .bb-float-btn img {
      width: 60px; height: 60px; border-radius: 50%; display: block;
    }

    /* Backdrop */
    .bb-modal-overlay {
      position: fixed; inset: 0; background: rgba(0,0,0,.5); z-index: 10000;
    }

      .bb-modal{
      position: fixed;
      inset: auto;                                    
      right: {{ section.settings.offset_right | default: 24 }}px;
      bottom: calc(24px + 72px);                       
      z-index: 10001;                                 
      width: min(92vw, 520px);
      pointer-events: none;                          
    }

    .bb-modal-card{
        position: relative;
        pointer-events: auto;
        width: 100%;
        max-width: 520px;
        max-height: calc(100vh - 130px);
        overflow-y: auto;
        background: #fff;
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 20px 50px rgba(0,0,0,.25);
        animation: bb-slide-up .18s ease-out;
        font-family: "Helvetica" !important;
    }

 

     .bb-modal-close{
  position:absolute; top:10px; right:12px;
  display:inline-flex; align-items:center; justify-content:center;
  width:32px; height:32px; border:0; border-radius:8px;
  background:transparent; color:#111;
  cursor:pointer; line-height:1;
}

.bb-modal-close svg{ width:20px; height:20px; display:block; }



    /* Form */
    .bb-field { display: grid; gap: 6px; margin-bottom: 12px;  }
    .bb-field input, .bb-field textarea, .bb-field select {
      width: 100%; padding: 10px 12px; border-radius: 10px; border: 1px solid #ddd; font: inherit; background:#fff;
    }
    .bb-claim-intro{margin:0 0 12px;color:#555;font-size:13.5px}
    .bb-field-hint{font-weight:400;color:#888;font-size:12px}
    .bb-claim-filelist:empty{display:none}
    .bb-claim-filelist{display:flex;flex-direction:column;gap:4px;margin:-4px 0 12px}
    .bb-claim-file{display:flex;align-items:center;gap:8px;font-size:12.5px;color:#3C2005;background:#F6F1E7;border-radius:8px;padding:5px 8px}
    .bb-claim-file span{flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .bb-claim-file button{border:0;background:none;color:#3C2005;font-weight:700;cursor:pointer;font:inherit;padding:0 2px}
    /* Claim wizard: progress dots, animated steps, issue-type cards */
    .bb-wiz-dots{display:flex;align-items:center;gap:6px;margin:0 0 16px}
    .bb-wiz-dot{width:26px;height:26px;border-radius:50%;border:2px solid #E0D5C2;background:#fff;color:#B9A78D;font-size:12px;font-weight:700;display:inline-flex;align-items:center;justify-content:center;transition:all .25s ease}
    .bb-wiz-dot.is-on{background:#3C2005;border-color:#3C2005;color:#FCE2A0}
    .bb-wiz-bar{flex:1;height:2px;background:#E8DFC9;border-radius:2px}
    .bb-wiz-step{display:none}
    .bb-wiz-step.is-active{display:block;animation:bb-wiz-in .22s ease}
    @keyframes bb-wiz-in{from{opacity:0;transform:translateX(12px)}to{opacity:1;transform:none}}
    @media (prefers-reduced-motion:reduce){.bb-wiz-step.is-active{animation:none}}
    .bb-wiz-q{font-weight:700;font-size:15px;color:#3C2005;margin:0 0 10px}
    .bb-wiz-nav{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-top:12px}
    .bb-wiz-nav .bb-submit{width:auto;flex:1;margin:0}
    .bb-wiz-back{border:0;background:none;color:#8a7a68;font:inherit;font-size:13px;font-weight:700;cursor:pointer;padding:8px 4px}
    .bb-wiz-back:hover{color:#3C2005}
    .bb-claim-types{display:grid;grid-template-columns:1fr 1fr;gap:8px}
    .bb-ctype{display:flex;flex-direction:column;align-items:flex-start;gap:6px;padding:12px;border:1.5px solid #E0D5C2;border-radius:12px;background:#fff;color:#3C2005;font:inherit;font-size:13px;font-weight:700;cursor:pointer;text-align:left;transition:transform .12s ease,box-shadow .12s ease,border-color .12s,background .12s}
    .bb-ctype:hover{border-color:#3C2005;transform:translate(-1px,-1px);box-shadow:3px 3px 0 #3C2005}
    .bb-ctype.is-picked{background:#FCE2A0;border-color:#3C2005;box-shadow:3px 3px 0 #3C2005}
    .bb-ctype--wide{grid-column:1 / -1;flex-direction:row;align-items:center}
    .bb-ctype-ic{font-size:20px;line-height:1}
    .bb-claim-picked{display:flex;align-items:center;gap:8px;margin:0 0 12px}
    .bb-claim-picked:empty{display:none}
    .bb-claim-chip{background:#3C2005;color:#FCE2A0;border-radius:999px;padding:6px 12px;font-size:12.5px;font-weight:700}
    .bb-claim-chg{border:0;background:none;color:#8a7a68;font:inherit;font-size:12px;text-decoration:underline;cursor:pointer;padding:0}
    .bb-req-badge{background:#FF6B5C;color:#fff;border-radius:999px;padding:2px 8px;font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.04em;margin-left:6px}
    .bb-claim-drop{display:flex;align-items:center;justify-content:center;gap:8px;border:1.5px dashed #C9BBA4;border-radius:12px;background:#FFFBF4;color:#3C2005;font-weight:700;font-size:13.5px;padding:16px 12px;cursor:pointer;transition:border-color .12s,background .12s}
    .bb-claim-drop:hover{border-color:#3C2005;background:#FCE2A0}
    .bb-claim-done{text-align:center;padding:18px 6px 8px;animation:bb-wiz-in .25s ease}
    .bb-claim-done-ic{width:56px;height:56px;margin:0 auto 10px;border-radius:50%;background:#3C2005;color:#FCE2A0;font-size:28px;font-weight:700;display:flex;align-items:center;justify-content:center;box-shadow:3px 3px 0 #FF6B5C}
    .bb-claim-done-h{font-size:19px;font-weight:700;color:#3C2005;margin-bottom:6px}
    .bb-claim-done-p{margin:0 0 14px;color:#5a4632;font-size:14px}
    .bb-submit {
      width: 100%; padding: 12px 14px; border-radius: 10px; border: 0; cursor: pointer;
      font-weight: 700; background: #3C2005; color: {{ section.settings.submit_text }};
    }
    .bb-modal-title { margin: 0 0 6px; font-size: 20px; font-family: Helvetica !important ;}
    .bb-modal-sub   { margin: 0 0 16px; color: #555; font-size: 14px; font-family: Helvetica !important ; }
    .bb-status      { margin-top: 10px; min-height: 18px; font-size: 14px; }

    /* Tabs + chat */
    .bb-tabs{display:flex;gap:8px;margin:0 0 14px;border-bottom:1px solid #eee;padding-bottom:12px}
    .bb-tab{flex:1;padding:9px 6px;border:1px solid #ddd;border-radius:10px;background:#fff;color:#3C2005;font:inherit;font-weight:700;font-size:12px;cursor:pointer}
    .bb-tab.is-active{background:#3C2005;color:#fff;border-color:#3C2005}
    .bb-faq-answer[hidden]{display:none!important}
    /* panel stack: both tabs occupy the same grid cell so the card holds the
       taller (form) height; the inactive one stays laid out but invisible */
    .bb-panels{display:grid}
    .bb-panels > .bb-panel{grid-area:1/1;min-width:0}
    .bb-panels > .bb-panel[hidden]{display:block!important;visibility:hidden!important;pointer-events:none!important}
    #bb-panel-chat{display:flex;flex-direction:column}
    #bb-panel-chat[hidden]{display:flex!important;visibility:hidden!important;pointer-events:none!important}
    .bb-chat-log{display:flex;flex-direction:column;gap:8px;flex:1 1 auto;min-height:110px;max-height:340px;overflow-y:auto;padding:4px 2px;margin-bottom:60px;scrollbar-width:thin}
    /* Never let the log compress its bubbles to fit max-height — scroll instead.
       (An explicit min-height on bubbles disables the content-based minimum
       that used to prevent this.) */
    .bb-chat-log > *{flex-shrink:0}
    .bb-msg{max-width:85%;padding:9px 12px;border-radius:12px;font-size:13.5px;line-height:1.45;overflow-wrap:break-word}
    .bb-msg--plain{white-space:pre-line}
    .bb-msg--bot{align-self:flex-start;background:#F6F1E7;color:#3C2005;border-bottom-left-radius:4px}
    /* AI avatar beside every bot bubble (and the typing dots). Pure CSS so
       messages restored from sessionStorage get it too. */
    .bb-msg--bot,.bb-typing{position:relative;margin-left:68px;max-width:calc(85% - 68px);min-height:60px;display:flex;flex-direction:column;justify-content:center}
    .bb-msg--bot::before,.bb-typing::before{content:'';position:absolute;left:-68px;top:0;width:60px;height:60px;border-radius:50%;background:#fff url('{{ 'chatbot.png' | asset_url }}') center/cover no-repeat;border:1px solid #E8DFC9}
    .bb-msg--user{align-self:flex-end;background:#3C2005;color:#fff;border-bottom-right-radius:4px}
    .bb-msg--bot p{margin:0 0 6px}
    .bb-msg--bot p:last-child{margin:0}
    .bb-msg-link{display:inline-block;margin-top:6px;color:#3C2005;font-weight:700;text-decoration:underline;cursor:pointer;background:none;border:0;padding:0;font:inherit;font-size:13px}
    .bb-msg--product{display:flex;flex-direction:column;gap:2px}
    .bb-prod-link{color:#3C2005;font-weight:700;text-decoration:underline}
