  </style>

  <script>
    (function () {
      const root = document.getElementById('bb-floating-contact');
      if (!root) return;

      // Icons
      const DEFAULT_ICON_URL = "{{ bb_icon_url }}";
      const OPEN_ICON_URL    = "https://cdn.shopify.com/s/files/1/0861/1106/0252/files/Dropdown_4.png?v=1758809684";
      const pre = new Image(); pre.src = OPEN_ICON_URL;

      // Config
      const sendMode    = root.dataset.sendMode; // 'shopify' | 'webhook'
      const webhookUrl  = root.dataset.webhookUrl;
      const successText = root.dataset.successText || 'Thanks! We received your message.';
      const errorText   ='Thanks! We received your message';

      // Elements
      const btn      = document.getElementById('bb-float-btn');
      const btnIcon  = document.getElementById('bb-float-icon');
      const modal    = document.getElementById('bb-contact-modal');
      const overlay  = document.getElementById('bb-modal-overlay');
      const closeBtn = document.getElementById('bb-modal-close');
      const statusBox = document.getElementById('bb-status');
      const submitBtn = document.getElementById('bb-submit');
      const shopifyForm = document.getElementById('FloatingContactForm');
      const webhookForm = document.getElementById('FloatingContactWebhookForm');

      function setButtonIcon(isOpen) {
        if (btnIcon) btnIcon.src = isOpen ? OPEN_ICON_URL : DEFAULT_ICON_URL;
      }

      function openModal() {
        overlay.hidden = false;
        modal.hidden = false;
        setButtonIcon(true);
        const first = modal.querySelector('input, textarea, button');
        if (first) first.focus();
        document.body.style.overflow = 'hidden';
      }

      function closeModal() {
        overlay.hidden = true;
        modal.hidden = true;
        setButtonIcon(false);
        document.body.style.overflow = '';
        if (btn) btn.focus();
      }

      // Toggle open/close
      btn.addEventListener('click', () => (modal.hidden ? openModal() : closeModal()));
      overlay.addEventListener('click', closeModal);
      closeBtn.addEventListener('click', closeModal);
      document.addEventListener('keydown', (e) => { if (!modal.hidden && e.key === 'Escape') closeModal(); });

      // Helpers
      const validEmail = (v) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v);
      const validPhone = (v) => v.trim() === '' || /^[\d+\-\s()]{6,}$/.test(v);

      function setLoading(on) {
        if (!submitBtn) return;
        submitBtn.disabled = on;
        submitBtn.textContent = on ? 'Sending…' : '{{ section.settings.submit_label }}';
      }

      // Shopify AJAX submit
      async function handleShopifySubmit(ev) {
        ev.preventDefault();
        const fd = new FormData(shopifyForm);

        const name  = fd.get('contact[name]')  || '';
        const email = fd.get('contact[email]') || '';
        const phone = fd.get('contact[phone]') || '';
        const body  = fd.get('contact[body]')  || '';

        if (!name.trim() || !validEmail(email) || !body.trim() || !validPhone(phone)) {
          statusBox.textContent = 'Please fill required fields correctly.';
          return;
        }

        try {
          setLoading(true);
          const resp = await fetch('/contact', {
            method: 'POST',
            headers: { 'Accept': 'text/html' },
            body: fd
          });

          if (resp.ok) {
            statusBox.textContent = successText;
            shopifyForm.reset();
            setTimeout(closeModal, 1200);
          } else {
            statusBox.textContent = errorText;
          }
        } catch (e) {
          statusBox.textContent = errorText;
        } finally {
          setLoading(false);
        }
      }

      // Webhook submit
      async function handleWebhookSubmit(ev) {
        ev.preventDefault();
        const fd = new FormData(webhookForm);

        const name    = (fd.get('name')    || '').trim();
        const email   = (fd.get('email')   || '').trim();
        const phone   = (fd.get('phone')   || '').trim();
        const message = (fd.get('message') || '').trim();

        if (!name || !validEmail(email) || !message || !validPhone(phone)) {
          statusBox.textContent = 'Please fill required fields correctly.';
          return;
        }
        if (!webhookUrl) {
          statusBox.textContent = 'Missing webhook URL in section settings.';
          return;
        }

        try {
          setLoading(true);
          const resp = await fetch(webhookUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              name, email, phone, message,
              page: window.location.href,
              source: 'floating-contact'
            })
          });

          if (resp.ok) {
            statusBox.textContent = successText;
            webhookForm.reset();
            setTimeout(closeModal, 1200);
          } else {
            statusBox.textContent = errorText;
          }
        } catch (e) {
          statusBox.textContent = errorText;
        } finally {
          setLoading(false);
        }
      }

      if (shopifyForm) shopifyForm.addEventListener('submit', handleShopifySubmit);
      if (webhookForm) webhookForm.addEventListener('submit', handleWebhookSubmit);

      setButtonIcon(false);
    })();

    /* ---- Tab controller: chat / form / claim, any combination enabled.
            Exposed as bbShowTab so the chat and claim scripts can switch. ---- */
    (function () {
      const root = document.getElementById('bb-floating-contact');
      if (!root) return;
      const tabs = [
        { name: 'chat',  tab: document.getElementById('bb-tab-chat'),  panel: document.getElementById('bb-panel-chat') },
        { name: 'form',  tab: document.getElementById('bb-tab-form'),  panel: document.getElementById('bb-panel-form') },
        { name: 'claim', tab: document.getElementById('bb-tab-claim'), panel: document.getElementById('bb-panel-claim') },
        { name: 'track', tab: document.getElementById('bb-tab-track'), panel: document.getElementById('bb-panel-track') },
      ].filter(function(t){ return t.tab && t.panel; });
      if (!tabs.length) return;
      window.bbShowTab = function(name){
        /* Unknown name (e.g. a sessionStorage-restored "Open a claim" button
           after the claim tab was disabled) must never hide every panel. */
        if (!tabs.some(function(t){ return t.name === name; })) name = 'form';
        tabs.forEach(function(t){
          const on = t.name === name;
          t.panel.hidden = !on;
          t.tab.classList.toggle('is-active', on);
          t.tab.setAttribute('aria-selected', on ? 'true' : 'false');
        });
      };
      tabs.forEach(function(t){ t.tab.addEventListener('click', function(){ window.bbShowTab(t.name); }); });
      const def = root.dataset.defaultTab === 'form' ? 'form' : 'chat';
      window.bbShowTab(tabs.some(function(t){ return t.name === def; }) ? def : tabs[0].name);
    })();

    /* ---- Quick-help chat tab (separate from the form logic above) ---- */
    (function () {
      const root = document.getElementById('bb-floating-contact');
      if (!root) return;
      const log       = document.getElementById('bb-chat-log');
      const pills     = document.getElementById('bb-chat-pills');
      const inputRow  = document.getElementById('bb-chat-inputrow');
      const input     = document.getElementById('bb-chat-input');
      const tabChat   = document.getElementById('bb-tab-chat');
      const panelChat = document.getElementById('bb-panel-chat');
      if (!log || !tabChat || !panelChat) return;

      const greeting     = root.dataset.chatGreeting || '';
      const fallbackText = root.dataset.chatFallback || "I couldn't find an instant answer for that.";
      const llmUrl       = (root.dataset.chatEndpoint || '').trim();

      function showTab(name){ if (window.bbShowTab) window.bbShowTab(name); }

      function scrollLog(){ log.scrollTop = log.scrollHeight; }

      /* Persist the conversation for the tab's lifetime so a refresh or page
         navigation doesn't wipe it. Transient UI (typing dots, the inline track
         form) is never saved; restored user text stays escaped because it was
         inserted via textContent. */
      const LOG_KEY = 'bb-chat-log-v1';
      function saveLog(){
        try {
          const c = log.cloneNode(true);
          Array.prototype.forEach.call(c.querySelectorAll('.bb-typing, .bb-track-form'), function(n){ n.remove(); });
          while (c.children.length > 40) c.removeChild(c.firstChild);
          sessionStorage.setItem(LOG_KEY, c.innerHTML);
        } catch(e){}
      }
      /* The quick-question pills are conversation starters — once the customer
         sends anything, hide them (the Track pill stays). Kept visible in the
         theme editor so merchants can always see the blocks they're editing. */
      function hideStarters(){
        if (window.Shopify && window.Shopify.designMode) return;
        if (pills) pills.classList.add('is-used');
      }
      function addMsg(who, content, opts){
        const el = document.createElement('div');
        el.className = 'bb-msg bb-msg--' + who;
        if (opts && opts.html){ el.innerHTML = content; }
        else { el.classList.add('bb-msg--plain'); el.textContent = content; }
        log.appendChild(el);
        if (who === 'user') hideStarters();
        scrollLog();
        saveLog();
        return el;
      }
      /* Delegated so the buttons still work on messages restored from sessionStorage. */
      log.addEventListener('click', function(e){
        const lnk = e.target.closest ? e.target.closest('.bb-msg-link') : null;
        if (lnk) showTab(lnk.classList.contains('bb-claim-link') ? 'claim' : 'form');
      });
      function addFormLink(el){
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'bb-msg-link';
        btn.textContent = 'Send us a message instead';
        el.appendChild(document.createElement('br'));
        el.appendChild(btn);
        scrollLog();
        saveLog();
      }
      function addClaimLink(el){
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'bb-msg-link bb-claim-link';
        btn.textContent = 'Open a claim';
        el.appendChild(document.createElement('br'));
        el.appendChild(btn);
        scrollLog();
        saveLog();
      }
      let typingEl = null;
      function typing(on){
        if (on && !typingEl){
          typingEl = document.createElement('div');
          typingEl.className = 'bb-typing';
          typingEl.textContent = '•••';
          log.appendChild(typingEl);
          scrollLog();
        }
        if (!on && typingEl){ typingEl.remove(); typingEl = null; }
      }

      let restored = false;
      try {
        const saved = (window.Shopify && window.Shopify.designMode) ? null : sessionStorage.getItem(LOG_KEY);
        if (saved){
          log.innerHTML = saved;
          Array.prototype.forEach.call(log.querySelectorAll('.bb-typing, .bb-track-form'), function(n){ n.remove(); });
          restored = log.children.length > 0;
        }
      } catch(e){}
      if (!restored && greeting) addMsg('bot', greeting);
      if (restored && log.querySelector('.bb-msg--user')) hideStarters();

      /* The log can't scroll while the modal is display:none — re-scroll when it
         becomes visible (widget opened, or chat tab re-selected). */
      const floatBtn = document.getElementById('bb-float-btn');
      if (floatBtn) floatBtn.addEventListener('click', function(){ requestAnimationFrame(scrollLog); });
      tabChat.addEventListener('click', function(){ requestAnimationFrame(scrollLog); });

      const sendBtn = inputRow ? inputRow.querySelector('.bb-chat-send') : null;
      let busy = false;
      function setBusy(on){
        busy = on;
        if (input) input.disabled = on;
        if (sendBtn) sendBtn.disabled = on;
      }
      async function ask(q, history){
        if (busy) return;
        setBusy(true);
        typing(true);
        try {
          if (llmUrl) await askLlm(q, history); else await askFaq(q);
        } catch(e){
          console.warn('[bb-chat]', e);
          addFormLink(addMsg('bot', fallbackText));
        } finally {
          typing(false);
          setBusy(false);
        }
      }

      /* Shopify Storefront MCP — same-origin, public, no auth needed.
         The FAQ tool lives on /api/mcp (sunsets 2026-08-31; failures degrade to the
         fallback + form link). Catalog search uses its successor /api/ucp/mcp.
         The abort timer covers the whole request INCLUDING the body read. */
      async function fetchJson(url, body, timeoutMs){
        const ctrl  = ('AbortController' in window) ? new AbortController() : null;
        const timer = ctrl && setTimeout(function(){ ctrl.abort(); }, timeoutMs || 12000);
        try {
          const res = await fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body),
            signal: ctrl ? ctrl.signal : undefined
          });
          if (!res.ok) throw new Error('http ' + res.status);
          return await res.json();
        } finally {
          if (timer) clearTimeout(timer);
        }
      }
      const UCP_PROFILE = 'https://shopify.dev/ucp/agent-profiles/examples/2026-04-08/valid-with-capabilities.json';
      async function mcpCall(endpoint, name, args){
        const data = await fetchJson(endpoint, { jsonrpc: '2.0', method: 'tools/call', id: 1,
          params: { name: name, arguments: args } });
        return (data && data.result && data.result.content) || [];
      }
      function parseJsonItems(items){
        const out = [];
        items.forEach(function(it){
          if (it && it.type === 'text' && typeof it.text === 'string'){
            try { out.push(JSON.parse(it.text)); } catch(e){}
          }
        });
        return out;
      }
      function money(pr){
        const mn = pr && pr.min && typeof pr.min.amount === 'number' ? pr.min.amount : null;
        if (mn === null) return '';
        const mx = pr.max && typeof pr.max.amount === 'number' ? pr.max.amount : mn;
        const cur = (pr.min && pr.min.currency) || 'USD';
        const f = function(c){ return cur === 'USD' ? '$' + (c/100).toFixed(2) : (c/100).toFixed(2) + ' ' + cur; };
        return mn === mx ? f(mn) : f(mn) + ' – ' + f(mx);
      }
      function addProductMsg(p){
        const url = String(p.url || '');
        if (!/^https?:\/\//i.test(url)) return;
        const el = document.createElement('div');
        el.className = 'bb-msg bb-msg--bot bb-msg--product';
        const a = document.createElement('a');
        a.href = url;
        a.className = 'bb-prod-link';
        a.textContent = p.title;
        el.appendChild(a);
        const priceTxt = money(p.price_range);
        if (priceTxt){
          const s = document.createElement('span');
          s.className = 'bb-prod-price';
          s.textContent = priceTxt;
          el.appendChild(s);
        }
        log.appendChild(el);
        scrollLog();
        saveLog();
      }
      /* Order-status questions can't be answered from the storefront (needs the
         authenticated Admin API via the future AI endpoint) — route them to the
         customer's account order history instead of the generic fallback. */
      function looksLikeOrderQuery(q){
        if (/^#?\d{3,}$/.test(q.trim())) return true;
        return /(order|track|shipment|delivery|status)/i.test(q) && /#?\d{3,}/.test(q);
      }
      function addOrderHelpMsg(){
        const el = addMsg('bot', 'I can’t look up individual orders in this chat yet. You can see your order status and tracking any time in your account:');
        const a = document.createElement('a');
        a.href = '/account';
        a.className = 'bb-prod-link';
        a.textContent = 'View my orders';
        el.appendChild(document.createElement('br'));
        el.appendChild(a);
        addFormLink(el);
      }
      /* Free-text flow: store policies/FAQ first, then product catalog, then fallback. */
      async function askFaq(q){
        if (looksLikeOrderQuery(q)){ addOrderHelpMsg(); return; }
        let answers = [];
        try {
          parseJsonItems(await mcpCall('/api/mcp', 'search_shop_policies_and_faqs', { query: q }))
            .forEach(function(v){ if (Array.isArray(v)) answers = answers.concat(v); });
        } catch(e){ console.warn('[bb-chat] faq lookup failed', e); }
        answers = answers.filter(function(a){ return a && a.answer; }).slice(0, 2);
        if (answers.length){
          answers.forEach(function(a){ addMsg('bot', a.answer); });
          return;
        }
        let products = [];
        try {
          parseJsonItems(await mcpCall('/api/ucp/mcp', 'search_catalog', { meta: { 'ucp-agent': { profile: UCP_PROFILE } }, catalog: { query: q } }))
            .forEach(function(v){ if (v && Array.isArray(v.products)) products = products.concat(v.products); });
        } catch(e){ console.warn('[bb-chat] catalog lookup failed', e); }
        products = products.filter(function(p){ return p && p.title && p.url; }).slice(0, 3);
        if (products.length){
          addMsg('bot', 'Here’s what I found in our shop:');
          products.forEach(addProductMsg);
          return;
        }
        addFormLink(addMsg('bot', fallbackText));
      }

      /* Optional AI endpoint (section setting) for when the LLM Worker exists.
         Contract: POST {message, history:[{role,text}...], page} -> {reply:"..."}
         History is snapshotted BEFORE the outgoing question is painted, and UI
         affordances (the "Send us a message instead" button) are stripped. */
      function snapshotHistory(){
        return Array.prototype.slice.call(log.querySelectorAll('.bb-msg')).slice(-10).map(function(m){
          const c = m.cloneNode(true);
          Array.prototype.forEach.call(c.querySelectorAll('.bb-msg-link, br'), function(n){ n.remove(); });
          return { role: m.classList.contains('bb-msg--user') ? 'user' : 'assistant', text: (c.textContent || '').trim() };
        });
      }
      /* When the AI deflects to human support it flags the reply (show_contact,
         or a [[CONTACT]] marker in the text) — render the "Send us a message"
         button under it. The phrase regex is a backstop for older Worker builds
         that don't send the flag yet. */
      const NEEDS_HUMAN_RE = /send message|send us a message|contact (us|the team)|reach (out|us|the team)|get in touch|email (us|the team)|support team|customer (service|support)/i;
      async function askLlm(q, history){
        const payload = { message: q, history: history || [], page: location.href };
        if (root.dataset.customerEmail) payload.customer_email = root.dataset.customerEmail;
        const data = await fetchJson(llmUrl, payload, 25000);
        if (!data || typeof data.reply !== 'string' || !data.reply) throw new Error('bad reply');
        let text = data.reply;
        const contactMark = text.indexOf('[[CONTACT]]') !== -1;
        const claimMark   = text.indexOf('[[CLAIM]]') !== -1;
        if (contactMark || claimMark) text = text.split('[[CONTACT]]').join(' ').split('[[CLAIM]]').join(' ').replace(/\s+/g, ' ').trim();
        const el = addMsg('bot', text || fallbackText);
        /* A claim-flagged reply must never dead-end: if the claim tab is
           disabled, degrade to the message-form button. */
        if ((data.show_claim || claimMark) && document.getElementById('bb-tab-claim')) addClaimLink(el);
        else if (data.show_claim || claimMark || data.show_contact || contactMark || NEEDS_HUMAN_RE.test(text)) addFormLink(el);
      }

      if (pills) pills.addEventListener('click', function(e){
        const pill = e.target.closest('.bb-pill');
        if (!pill || typeof pill.dataset.faq === 'undefined') return;
        const q = pill.textContent.trim();
        const canned = document.getElementById('bb-faq-answer-' + pill.dataset.faq);
        if (canned){
          addMsg('user', q);
          addMsg('bot', canned.innerHTML, { html: true });
          return;
        }
        if (busy) return;
        const h = snapshotHistory();
        addMsg('user', q);
        ask(q, h);
      });
      if (inputRow) inputRow.addEventListener('submit', function(e){
        e.preventDefault();
        if (busy) return;
        const q = (input.value || '').trim();
        if (!q) return;
        const h = snapshotHistory();
        input.value = '';
        addMsg('user', q);
        ask(q, h);
      });

      /* Tracking moved to its own tab (bb-panel-track); typed "where is my
         order" questions still go through the AI's track_package tool. */

      /* Theme editor: selecting the section or a Quick question block opens the
         widget so merchants can see what they're editing. */
      if (window.Shopify && window.Shopify.designMode){
        const ensureOpen = function(){
          const m = document.getElementById('bb-contact-modal');
          const b = document.getElementById('bb-float-btn');
          if (m && m.hidden && b) b.click();
        };
        document.addEventListener('shopify:section:select', function(e){
          if (e.target && e.target.contains(root)) ensureOpen();
        });
        document.addEventListener('shopify:block:select', function(e){
          if (e.target && e.target.contains(root)){ ensureOpen(); showTab('chat'); }
        });
      }
    })();

    /* ---- Claim tab: 3-step wizard → multipart POST to <chat_endpoint>/claim.
            Step 1 order number, step 2 issue-type cards, step 3 evidence.
            No email field: logged-in uses the hidden account email; guests are
            resolved server-side from the order, and only a needs_email reply
            reveals the inline email prompt. idempotencyKey stays stable across
            unchanged retries, rotates on any edit. ---- */
    (function () {
      const root = document.getElementById('bb-floating-contact');
      const form = document.getElementById('bb-claim-form');
      if (!root || !form) return;
      const endpoint   = (root.dataset.chatEndpoint || '').trim().replace(/\/+$/, '');
      const dots       = document.getElementById('bb-claim-dots');
      const orderIn    = document.getElementById('bb-claim-order');
      const next1      = document.getElementById('bb-claim-next1');
      const typesWrap  = document.getElementById('bb-claim-types');
      const pickedEl   = document.getElementById('bb-claim-picked');
      const photoReq   = document.getElementById('bb-claim-photo-req');
      const msgReq     = document.getElementById('bb-claim-msg-req');
      const msgIn      = document.getElementById('bb-claim-msg');
      const emailIn    = document.getElementById('bb-claim-email');
      const emailField = document.getElementById('bb-claim-email-field');
      const filesIn    = document.getElementById('bb-claim-files');
      const fileList   = document.getElementById('bb-claim-filelist');
      const submitBtn  = document.getElementById('bb-claim-submit');
      const statusEl   = document.getElementById('bb-claim-status');
      const doneEl     = document.getElementById('bb-claim-done');
      const doneText   = document.getElementById('bb-claim-done-text');
      const againBtn   = document.getElementById('bb-claim-again');
      const submitLabel = submitBtn ? submitBtn.textContent : 'Submit claim';
      const MAX_FILES = 10, MAX_FILE_BYTES = 10 * 1024 * 1024, MAX_TOTAL_BYTES = 35 * 1024 * 1024;

      function makeKey(){
        return (window.crypto && crypto.randomUUID) ? crypto.randomUUID()
          : 'ck-' + Date.now().toString(36) + '-' + Math.random().toString(36).slice(2, 12);
      }
      let idemKey = makeKey();
      let picked = [];
      let sending = false;
      let chosenType = '';
      let needPhoto = false, needMsg = false;

      function contentChanged(){ idemKey = makeKey(); }
      form.addEventListener('input', contentChanged);
      function totalPicked(){ return picked.reduce(function(s, f){ return s + f.size; }, 0); }
      function status(msg, ok){
        if (!statusEl) return;
        statusEl.textContent = msg || '';
        statusEl.style.color = ok ? '#1a7f37' : '';
      }
      function goStep(n){
        Array.prototype.forEach.call(form.querySelectorAll('.bb-wiz-step'), function(s){
          s.classList.toggle('is-active', s.getAttribute('data-step') === String(n));
        });
        if (dots) Array.prototype.forEach.call(dots.querySelectorAll('.bb-wiz-dot'), function(d, i){
          d.classList.toggle('is-on', i < n);
        });
        status('');
      }

      if (next1) next1.addEventListener('click', function(){
        if (!(orderIn.value || '').trim()){ status('Please enter your order number.'); orderIn.focus(); return; }
        goStep(2);
      });
      if (orderIn) orderIn.addEventListener('keydown', function(e){
        if (e.key === 'Enter'){ e.preventDefault(); if (next1) next1.click(); }
      });
      form.addEventListener('click', function(e){
        const b = e.target.closest ? e.target.closest('.bb-wiz-back') : null;
        if (b && b.dataset.back) goStep(parseInt(b.dataset.back, 10));
      });

      if (typesWrap) typesWrap.addEventListener('click', function(e){
        const card = e.target.closest ? e.target.closest('.bb-ctype') : null;
        if (!card) return;
        Array.prototype.forEach.call(typesWrap.querySelectorAll('.bb-ctype'), function(c){
          c.classList.toggle('is-picked', c === card);
        });
        chosenType = card.dataset.type || 'Other';
        needPhoto = card.dataset.photo === '1';
        needMsg = card.dataset.msg === '1';
        if (photoReq) photoReq.hidden = !needPhoto;
        if (msgReq) msgReq.hidden = !needMsg;
        if (pickedEl){
          pickedEl.textContent = '';
          const chip = document.createElement('span');
          chip.className = 'bb-claim-chip';
          chip.textContent = chosenType;
          const chg = document.createElement('button');
          chg.type = 'button';
          chg.className = 'bb-claim-chg';
          chg.textContent = 'change';
          chg.addEventListener('click', function(){ goStep(2); });
          pickedEl.appendChild(chip);
          pickedEl.appendChild(chg);
        }
        contentChanged();
        goStep(3);
      });

      function renderFiles(){
        if (!fileList) return;
        fileList.textContent = '';
        picked.forEach(function(f, i){
          const row = document.createElement('div');
          row.className = 'bb-claim-file';
          const nm = document.createElement('span');
          nm.textContent = f.name + ' (' + (f.size / 1048576).toFixed(1) + ' MB)';
          const rm = document.createElement('button');
          rm.type = 'button';
          rm.setAttribute('aria-label', 'Remove ' + f.name);
          rm.textContent = '✕';
          rm.addEventListener('click', function(){ picked.splice(i, 1); renderFiles(); contentChanged(); });
          row.appendChild(nm);
          row.appendChild(rm);
          fileList.appendChild(row);
        });
      }
      if (filesIn) filesIn.addEventListener('change', function(){
        status('');
        Array.prototype.forEach.call(filesIn.files, function(f){
          if (picked.length >= MAX_FILES){ status('You can attach up to ' + MAX_FILES + ' photos.'); return; }
          if (f.size > MAX_FILE_BYTES){ status('“' + f.name + '” is over 10 MB — please use a smaller photo.'); return; }
          if (totalPicked() + f.size > MAX_TOTAL_BYTES){ status('Photos can total 35 MB — “' + f.name + '” doesn’t fit. Remove one or use smaller photos.'); return; }
          const dup = picked.some(function(p){ return p.name === f.name && p.size === f.size; });
          if (!dup){ picked.push(f); contentChanged(); }
        });
        filesIn.value = '';
        renderFiles();
      });

      function setSending(on){
        sending = on;
        if (submitBtn){ submitBtn.disabled = on; submitBtn.textContent = on ? 'Submitting…' : submitLabel; }
      }
      form.addEventListener('submit', async function(e){
        e.preventDefault();
        if (sending) return;
        if (!endpoint){ status('Claims aren’t set up yet — please use the Send message tab.'); return; }
        const orderVal = (orderIn.value || '').trim();
        if (!orderVal){ goStep(1); status('Please enter your order number.'); return; }
        if (!chosenType){ goStep(2); status('Please pick what went wrong.'); return; }
        if (needPhoto && picked.length === 0){ status('Please attach at least one photo of the item — the team needs it to resolve this.'); return; }
        const msgVal = (msgIn ? msgIn.value : '').trim();
        if (needMsg && !msgVal){ status('Please tell us what happened.'); if (msgIn) msgIn.focus(); return; }
        if (totalPicked() > MAX_TOTAL_BYTES){ status('Photos can total 35 MB — please remove one or use smaller photos.'); return; }
        const emailVal = emailIn ? (emailIn.value || '').trim() : '';
        if (emailField && !emailField.hidden && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailVal)){
          status('Please enter a valid email.');
          if (emailIn) emailIn.focus();
          return;
        }

        const fd = new FormData();
        fd.set('order_id', orderVal);
        fd.set('type', chosenType);
        fd.set('message', msgVal);
        if (emailVal) fd.set('email', emailVal);
        fd.set('page_url', String(location.href).slice(0, 500));
        fd.set('idempotencyKey', idemKey);
        picked.forEach(function(f){ fd.append('files', f, f.name); });

        setSending(true);
        status('Submitting your claim — this can take a few seconds…');
        const ctrl  = ('AbortController' in window) ? new AbortController() : null;
        const timer = ctrl && setTimeout(function(){ ctrl.abort(); }, 90000);
        try {
          const res = await fetch(endpoint + '/claim', { method: 'POST', body: fd, signal: ctrl ? ctrl.signal : undefined });
          let data = null;
          try { data = await res.json(); } catch(err){}
          if (res.ok && data && data.ok && data.reference){
            form.hidden = true;
            if (dots) dots.hidden = true;
            if (doneEl){
              doneEl.hidden = false;
              if (doneText) doneText.textContent = 'Your reference is ' + data.reference + '.'
                + (emailVal ? ' We’ll email you at ' + emailVal + '.' : ' Our reply goes to the email on your order.');
            }
            status('');
          } else if (data && data.needs_email && emailField){
            emailField.hidden = false;
            status('One more thing — add your email so our reply can reach you, then submit again.');
            if (emailIn) emailIn.focus();
          } else {
            /* A not-yet-updated Worker routes /claim into its chat handler,
               whose raw errors would confuse customers — replace those. */
            const raw = (data && data.error) ? String(data.error) : '';
            const stale = /invalid json|payload too large|empty message|worker secrets|origin not allowed|^too many requests$/i.test(raw);
            status(raw && !stale ? raw : 'Claims aren’t available right now — please try again later, or use the Send message tab.');
          }
        } catch(err){
          status('Something went wrong — please try again. Resubmitting is safe, it won’t create a duplicate.');
        } finally {
          if (timer) clearTimeout(timer);
          setSending(false);
        }
      });

      if (againBtn) againBtn.addEventListener('click', function(){
        form.reset();
        picked = [];
        renderFiles();
        chosenType = '';
        needPhoto = false;
        needMsg = false;
        if (photoReq) photoReq.hidden = true;
        if (msgReq) msgReq.hidden = true;
        if (pickedEl) pickedEl.textContent = '';
        if (typesWrap) Array.prototype.forEach.call(typesWrap.querySelectorAll('.bb-ctype'), function(c){ c.classList.remove('is-picked'); });
        idemKey = makeKey();
        form.hidden = false;
        if (dots) dots.hidden = false;
        if (doneEl) doneEl.hidden = true;
        if (emailField) emailField.hidden = true;
        goStep(1);
      });
    })();

    /* ---- Track tab: order number -> <chat_endpoint>/track -> step timeline.
            The worker returns FBM statuses + timestamps; the step rank is
            derived here so display tweaks only need a theme deploy. ---- */
    (function () {
      const root = document.getElementById('bb-floating-contact');
      const form = document.getElementById('bb-track-form');
      if (!root || !form) return;
      const endpoint  = (root.dataset.chatEndpoint || '').trim().replace(/\/+$/, '');
      const numIn     = document.getElementById('bb-track-num');
      const goBtn     = document.getElementById('bb-track-go');
      const statusEl  = document.getElementById('bb-track-status');
      const resultEl  = document.getElementById('bb-track-result');
      const currentEl = document.getElementById('bb-track-current');
      const updatedEl = document.getElementById('bb-track-updated');
      const stepsEl   = document.getElementById('bb-track-steps');
      const metaEl    = document.getElementById('bb-track-meta');
      let busy = false;

      const STEPS = [
        { label: 'Order placed',                at: 'order_created_at' },
        { label: 'Accepted',                    at: 'accepted_at' },
        { label: 'Preparing shipment / Packed', at: 'prep_at' },
        { label: 'Handed over to carrier',      at: 'pallet_at' },
        { label: 'On the way',                  at: null },
        { label: 'Out for delivery',            at: null },
        { label: 'Delivered',                   at: null },
      ];
      function rankOf(d){
        if (d.shipping_status === 'delivered') return 7;
        /* FBM has no out-for-delivery signal (step 6) — it fills in only once
           delivered. in_transit maps to "On the way". */
        if (d.shipping_status === 'in_transit') return 5;
        /* awaiting_collection = packed & staged for the carrier; scans lag, so
           trust the shipping status before the warehouse scans. */
        if (d.shipping_status === 'awaiting_collection') return 4;
        if (d.scan_status === 'pallet' || d.pallet_at) return 4;
        if (d.packed_at || d.scan_status === 'packed' || d.label_printed_at) return 3;
        return 2;
      }
      function fmt(iso){
        if (!iso) return '';
        const dt = new Date(iso);
        if (isNaN(dt.getTime())) return '';
        try {
          return dt.toLocaleDateString(undefined, { month: 'short', day: 'numeric' }) + ', '
               + dt.toLocaleTimeString(undefined, { hour: 'numeric', minute: '2-digit' });
        } catch(e){ return ''; }
      }
      function render(d){
        d.prep_at = d.packed_at || d.label_printed_at;
        const rank = rankOf(d);
        const trouble = !!(d.is_returning || d.is_stuck || d.is_label_failed);
        currentEl.textContent = (d.order ? d.order + ' — ' : '') + (trouble ? 'Needs attention' : STEPS[rank - 1].label);
        const updatedTxt = fmt(d.updated_at);
        updatedEl.textContent = updatedTxt ? 'Last updated: ' + updatedTxt : '';
        stepsEl.textContent = '';
        STEPS.forEach(function(s, i){
          const n = i + 1;
          const li = document.createElement('li');
          li.className = 'bb-step'
            + (n < rank ? ' is-done' : '')
            + (n === rank ? (rank === 7 ? ' is-done is-current' : ' is-current') : '');
          const dot = document.createElement('span'); dot.className = 'bb-step-dot';
          const lbl = document.createElement('span'); lbl.className = 'bb-step-lbl'; lbl.textContent = s.label;
          li.appendChild(dot);
          li.appendChild(lbl);
          const when = (n <= rank && s.at) ? fmt(d[s.at]) : '';
          if (when){
            const t = document.createElement('span'); t.className = 'bb-step-at'; t.textContent = when;
            li.appendChild(t);
          }
          stepsEl.appendChild(li);
        });
        /* Delivery-problem branch (returning / stuck / label failed): a red
           node right after the current step, pointing at human help. */
        if (trouble){
          const li = document.createElement('li');
          li.className = 'bb-step is-fail';
          const dot = document.createElement('span'); dot.className = 'bb-step-dot';
          const lbl = document.createElement('span'); lbl.className = 'bb-step-lbl';
          lbl.textContent = 'There’s a delivery issue with this shipment';
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'bb-step-fail-btn';
          btn.textContent = 'Contact support';
          btn.addEventListener('click', function(){ if (window.bbShowTab) window.bbShowTab('form'); });
          li.appendChild(dot);
          li.appendChild(lbl);
          li.appendChild(btn);
          const after = stepsEl.children[rank];
          if (after) stepsEl.insertBefore(li, after); else stepsEl.appendChild(li);
        }
        const bits = [];
        if (d.carrier) bits.push('Carrier: ' + String(d.carrier).toUpperCase());
        if (d.tracking && d.tracking.length) bits.push('Tracking: ' + d.tracking.join(', '));
        metaEl.textContent = bits.join('  ·  ');
        resultEl.hidden = false;
      }

      form.addEventListener('submit', async function(e){
        e.preventDefault();
        if (busy) return;
        const v = (numIn.value || '').trim();
        if (!v){ numIn.focus(); return; }
        if (!endpoint){ statusEl.textContent = 'Tracking isn’t set up yet — please ask us via the Send message tab.'; return; }
        busy = true;
        if (goBtn) goBtn.disabled = true;
        resultEl.hidden = true;
        statusEl.textContent = 'Looking up your order…';
        const ctrl  = ('AbortController' in window) ? new AbortController() : null;
        const timer = ctrl && setTimeout(function(){ ctrl.abort(); }, 30000);
        try {
          const res = await fetch(endpoint + '/track', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ order_number: v }),
            signal: ctrl ? ctrl.signal : undefined
          });
          let data = null;
          try { data = await res.json(); } catch(err){}
          if (res.ok && data && data.ok){
            if (data.found){ statusEl.textContent = ''; render(data); }
            else statusEl.textContent = 'We couldn’t find a shipment for that order number. Double-check the number — brand-new orders can take a little while to appear.';
          } else {
            /* A not-yet-updated worker answers /track from the chat handler
               with raw errors — swap those (and the terse 429) for a friendly
               message that doesn't promise quick self-recovery. */
            const raw = (data && data.error) ? String(data.error) : '';
            const stale = /empty message|invalid json|payload too large|worker secrets|^too many requests$/i.test(raw);
            statusEl.textContent = raw && !stale ? raw : 'Tracking isn’t available right now — please try again later, or ask us via the Send message tab.';
          }
        } catch(err){
          statusEl.textContent = 'Tracking is temporarily unavailable — please try again in a minute.';
        } finally {
          if (timer) clearTimeout(timer);
          busy = false;
          if (goBtn) goBtn.disabled = false;
        }
      });
    })();
  </script>
</section>

{% schema %}
{
  "name": "Floating contact button",
  "settings": [
    {
      "type": "select",
      "id": "send_mode",
      "label": "Send to",
      "default": "shopify",
      "options": [
        { "value": "shopify", "label": "Shopify Contact (emails store owner)" },
        { "value": "webhook", "label": "Custom Webhook (POST JSON)" }
      ]
    },
    { "type": "url", "id": "webhook_url", "label": "Webhook URL (when 'webhook' is selected)" },

    { "type": "text", "id": "button_label", "label": "Button label", "default": "Contact us" },
    { "type": "image_picker", "id": "button_icon", "label": "Custom button icon (optional)" },

    { "type": "text", "id": "modal_title", "label": "Modal title", "default": "Send us a message" },
    { "type": "text", "id": "modal_subtext", "label": "Subtitle", "default": "We typically reply within a business day." },
    { "type": "text", "id": "subject_prefix", "label": "Subject/Tag hint (optional)", "default": "Floating Contact" },

    { "type": "color", "id": "button_bg", "label": "Button background", "default": "#111827" },
    { "type": "color", "id": "button_text", "label": "Button text color", "default": "#ffffff" },

    { "type": "color", "id": "submit_bg", "label": "Submit button background", "default": "#111827" },
    { "type": "color", "id": "submit_text", "label": "Submit button text", "default": "#ffffff" },

    {
      "type": "range",
      "id": "offset_right",
      "label": "Right offset (px)",
      "min": 0,
      "max": 200,
      "step": 2,
      "default": 24
    },

    { "type": "text", "id": "submit_label", "label": "Submit label", "default": "Send Message" },
    { "type": "text", "id": "success_text", "label": "Success text", "default": "Thanks! We received your message." },
    { "type": "text", "id": "error_text", "label": "Error text", "default": "Something went wrong. Please try again." },

    { "type": "header", "content": "Quick-help chat" },
    {
      "type": "checkbox",
      "id": "enable_chat",
      "label": "Enable Quick-help chat",
      "default": true,
      "info": "Off: the widget shows only the contact form, exactly as before the chat existed."
    },
    {
      "type": "select",
      "id": "default_tab",
      "label": "Tab shown when the widget opens",
      "default": "chat",
      "options": [
        { "value": "chat", "label": "Quick help (chat)" },
        { "value": "form", "label": "Contact form" }
      ]
    },
    { "type": "text", "id": "chat_tab_label", "label": "Chat tab label", "default": "Quick help" },
    { "type": "text", "id": "form_tab_label", "label": "Form tab label", "default": "Send message" },
    { "type": "text", "id": "chat_greeting", "label": "Chat greeting", "default": "Hi! Pick a question below, or type your own — I’ll answer instantly." },
    { "type": "text", "id": "chat_placeholder", "label": "Input placeholder", "default": "Type a question…" },
    { "type": "text", "id": "chat_fallback", "label": "No-answer fallback text", "default": "I couldn’t find an instant answer for that." },
    { "type": "header", "content": "Track-package tab" },
    {
      "type": "checkbox",
      "id": "enable_track",
      "label": "Enable Track-package tab",
      "default": true,
      "info": "Live shipment steps from the fulfillment system, via the AI chat endpoint (Worker)."
    },
    { "type": "text", "id": "track_tab_label", "label": "Track tab label", "default": "Track package" },
    { "type": "text", "id": "track_intro", "label": "Track intro text", "default": "Enter your order number to see exactly where your package is." },
    { "type": "text", "id": "track_button_label", "label": "Track button label", "default": "Track" },
    { "type": "url", "id": "chat_endpoint", "label": "AI chat endpoint (optional)", "info": "Leave empty to answer typed questions from the store’s built-in policies/FAQ search. Set to your AI Worker URL later to switch to LLM replies." },

    { "type": "header", "content": "Claim tab" },
    {
      "type": "checkbox",
      "id": "enable_claim",
      "label": "Enable Claim tab",
      "default": true,
      "info": "Claims post through the AI chat endpoint (Worker), which holds the Claim API key."
    },
    { "type": "text", "id": "claim_tab_label", "label": "Claim tab label", "default": "Claim" },
    { "type": "text", "id": "claim_intro", "label": "Claim intro text", "default": "Something wrong with your order? Tell us and we’ll make it right." },
    { "type": "text", "id": "claim_submit_label", "label": "Claim submit label", "default": "Submit claim" }
  ],
  "max_blocks": 12,
  "blocks": [
    {
      "type": "faq",
      "name": "Quick question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer (optional)",
          "info": "Leave empty to auto-answer this question from the store’s policies/FAQ search."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Floating contact button",
      "blocks": [
        { "type": "faq", "settings": { "question": "What countries do you ship to?" } },
        { "type": "faq", "settings": { "question": "How long does shipping take?" } }
      ]
    }
  ]
}
{% endschema %}
