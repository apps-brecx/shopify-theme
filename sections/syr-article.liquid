{%- comment -%} Syruvia article — brand style (blog posts + recipes). {%- endcomment -%}
{%- assign s = section.settings -%}
{%- assign shop_handle = s.shop_collection | default: 'best-sellers' -%}
<style id="sa-{{ section.id }}-css">
  #sa-{{ section.id }}{--ink:#39220f;--ink-2:#5a4632;--paper:#FFFBF4;--white:#fff;--butter:#FCE2A0;--copper:#c58548;--peach:#ffd4b8;--mint:#c5e4d4;--sky:#b8dceb;--fh:'Archivo Black','Arial Black',sans-serif;--fb:'Josefin Sans','Josefin',sans-serif;background:var(--paper);color:var(--ink);font-family:var(--fb);}
  #sa-{{ section.id }} *{box-sizing:border-box;}
  #sa-{{ section.id }} .sa-wrap{max-width:760px;margin:0 auto;padding:0 24px;}
  #sa-{{ section.id }} .sa-wide{max-width:1180px;margin:0 auto;padding:0 24px;}
  #sa-{{ section.id }} .sa-rev{opacity:0;transform:translateY(16px);transition:opacity .6s ease, transform .6s cubic-bezier(.2,.7,.3,1.2);}
  #sa-{{ section.id }} .sa-rev.in{opacity:1;transform:none;}
  #sa-{{ section.id }} .sa-head{text-align:center;padding:50px 0 8px;position:relative;}
  #sa-{{ section.id }} .sa-back{display:inline-block;font-family:'Archivo',sans-serif;font-weight:700;font-size:12px;letter-spacing:.06em;text-transform:uppercase;color:var(--copper);text-decoration:none;margin-bottom:18px;}
  #sa-{{ section.id }} .sa-back:hover{text-decoration:underline;}
  #sa-{{ section.id }} .sa-tags{display:flex;gap:8px;justify-content:center;flex-wrap:wrap;margin-bottom:14px;}
  #sa-{{ section.id }} .sa-tag{background:var(--mint);border:2px solid var(--ink);border-radius:999px;box-shadow:2px 2px 0 var(--ink);font-family:'Archivo',sans-serif;font-weight:700;font-size:10.5px;letter-spacing:.06em;text-transform:uppercase;padding:5px 12px;color:var(--ink);}
  #sa-{{ section.id }} .sa-title{font-family:var(--fh);font-weight:400;font-size:clamp(30px,5.2vw,54px);line-height:1;letter-spacing:-.02em;text-transform:uppercase;margin:0 auto;max-width:18ch;}
  #sa-{{ section.id }} .sa-meta{font-family:'Archivo',sans-serif;font-weight:700;font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-2);margin-top:16px;}
  #sa-{{ section.id }} .sa-body{padding:34px 0 6px;font-size:17.5px;line-height:1.75;color:var(--ink-2);}
  #sa-{{ section.id }} .sa-body h1,#sa-{{ section.id }} .sa-body h2,#sa-{{ section.id }} .sa-body h3,#sa-{{ section.id }} .sa-body h4{font-family:var(--fh);font-weight:400;color:var(--ink);line-height:1.12;letter-spacing:-.01em;text-transform:uppercase;margin:1.7em 0 .55em;}
  #sa-{{ section.id }} .sa-body h2{font-size:clamp(24px,3.4vw,32px);}
  #sa-{{ section.id }} .sa-body h3{font-size:clamp(20px,2.6vw,24px);}
  #sa-{{ section.id }} .sa-body h4{font-size:18px;}
  #sa-{{ section.id }} .sa-body h1:has(img),#sa-{{ section.id }} .sa-body h2:has(img),#sa-{{ section.id }} .sa-body h3:has(img){margin:0;}
  #sa-{{ section.id }} .sa-body p{margin:0 0 1.15em;}
  #sa-{{ section.id }} .sa-body a{color:var(--copper);font-weight:600;text-decoration:underline;text-underline-offset:3px;}
  #sa-{{ section.id }} .sa-body strong{color:var(--ink);font-weight:700;}
  #sa-{{ section.id }} .sa-body ul,#sa-{{ section.id }} .sa-body ol{margin:0 0 1.3em;padding-left:1.3em;}
  #sa-{{ section.id }} .sa-body li{margin:.4em 0;padding-left:.3em;}
  #sa-{{ section.id }} .sa-body ul li::marker{color:var(--copper);}
  #sa-{{ section.id }} .sa-body ol li::marker{color:var(--copper);font-family:var(--fh);}
  #sa-{{ section.id }} .sa-body img{max-width:100%;height:auto;border:2.5px solid var(--ink);border-radius:16px;box-shadow:5px 5px 0 var(--ink);margin:1.4em auto;display:block;}
  #sa-{{ section.id }} .sa-body blockquote{border-left:5px solid var(--copper);background:var(--butter);border-radius:0 14px 14px 0;margin:1.5em 0;padding:16px 22px;font-size:19px;color:var(--ink);font-style:italic;}
  #sa-{{ section.id }} .sa-body hr{border:none;border-top:2px dashed rgba(57,34,15,.25);margin:2em 0;}
  #sa-{{ section.id }} .sa-share{display:flex;align-items:center;gap:12px;justify-content:center;flex-wrap:wrap;border-top:2px dashed rgba(57,34,15,.25);margin-top:34px;padding:26px 0 6px;}
  #sa-{{ section.id }} .sa-share .lbl{font-family:var(--fh);font-size:12px;letter-spacing:.1em;text-transform:uppercase;color:var(--ink);}
  #sa-{{ section.id }} .sa-share a,#sa-{{ section.id }} .sa-share button{display:inline-flex;align-items:center;justify-content:center;width:42px;height:42px;background:var(--white);border:2.5px solid var(--ink);border-radius:12px;box-shadow:3px 3px 0 var(--ink);color:var(--ink);text-decoration:none;cursor:pointer;font-family:'Archivo',sans-serif;font-weight:700;font-size:13px;}
  #sa-{{ section.id }} .sa-share a:hover,#sa-{{ section.id }} .sa-share button:hover{transform:translate(-1px,-1px);box-shadow:4px 4px 0 var(--ink);}
  #sa-{{ section.id }} .sa-shop{margin-top:54px;padding:48px 0 50px;background:var(--butter);border-top:3px solid var(--ink);border-bottom:3px solid var(--ink);}
  #sa-{{ section.id }} .sa-shop h2{font-family:var(--fh);font-weight:400;font-size:clamp(26px,4vw,40px);text-transform:uppercase;text-align:center;letter-spacing:-.01em;margin:0 0 6px;}
  #sa-{{ section.id }} .sa-shop .sub{text-align:center;color:var(--ink-2);font-weight:500;margin:0 auto 28px;max-width:48ch;}
  #sa-{{ section.id }} .sa-pgrid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;}
  #sa-{{ section.id }} .sa-pcard{background:var(--white);border:2.5px solid var(--ink);border-radius:16px;box-shadow:5px 5px 0 var(--ink);overflow:hidden;text-decoration:none;color:var(--ink);text-align:center;transition:transform .2s ease,box-shadow .2s ease;}
  #sa-{{ section.id }} .sa-pcard:hover{transform:translate(-3px,-3px);box-shadow:8px 8px 0 var(--ink);}
  #sa-{{ section.id }} .sa-pimg{aspect-ratio:1/1;background:var(--peach);border-bottom:2.5px solid var(--ink);display:flex;align-items:center;justify-content:center;}
  #sa-{{ section.id }} .sa-pgrid .sa-pcard:nth-child(4n+2) .sa-pimg{background:var(--mint);}
  #sa-{{ section.id }} .sa-pgrid .sa-pcard:nth-child(4n+3) .sa-pimg{background:var(--sky);}
  #sa-{{ section.id }} .sa-pgrid .sa-pcard:nth-child(4n+4) .sa-pimg{background:var(--butter);}
  #sa-{{ section.id }} .sa-pimg img{width:100%;height:100%;object-fit:cover;}
  #sa-{{ section.id }} .sa-pb{padding:14px 12px 16px;display:flex;flex-direction:column;gap:8px;align-items:center;}
  #sa-{{ section.id }} .sa-pn{font-family:var(--fh);font-weight:400;font-size:13px;text-transform:uppercase;line-height:1.1;}
  #sa-{{ section.id }} .syrvip{display:flex;flex-direction:column;align-items:center;gap:5px;}
  #sa-{{ section.id }} .syrvip-now{font-family:var(--fh);font-weight:400;font-size:15px;color:var(--copper);}
  #sa-{{ section.id }} .syrvip-was{font-family:'Archivo',sans-serif;font-weight:700;font-size:12px;color:#a8967f;text-decoration:line-through;margin-top:-2px;}
  #sa-{{ section.id }} .syrvip-tag{display:inline-flex;align-items:center;gap:4px;background:#dcebf2;color:#1f5a85;border:1.5px solid #2f7bb0;border-radius:999px;font-family:var(--fh);font-weight:400;font-size:9.5px;letter-spacing:.03em;text-transform:uppercase;padding:4px 9px;line-height:1;}
  #sa-{{ section.id }} .syrvip-tag svg{width:10px;height:10px;}
  #sa-{{ section.id }} .syrvip-tag.is-vip{background:#c5e4d4;color:#2f6b4a;border-color:#2f6b4a;}
  #sa-{{ section.id }} .sa-cta{display:flex;justify-content:center;margin-top:30px;}
  #sa-{{ section.id }} .sa-btn{display:inline-block;background:var(--copper);color:#fff;border:2.5px solid var(--ink);border-radius:14px;box-shadow:5px 5px 0 var(--ink);font-family:var(--fh);font-size:14px;letter-spacing:.04em;text-transform:uppercase;padding:15px 30px;text-decoration:none;}
  #sa-{{ section.id }} .sa-btn:hover{transform:translate(-2px,-2px);box-shadow:7px 7px 0 var(--ink);}
  #sa-{{ section.id }} .sa-more{padding:52px 0 64px;}
  #sa-{{ section.id }} .sa-more h2{font-family:var(--fh);font-weight:400;font-size:clamp(24px,3.6vw,36px);text-transform:uppercase;text-align:center;margin:0 0 26px;}
  #sa-{{ section.id }} .sa-mgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}
  #sa-{{ section.id }} .sa-mcard{background:var(--white);border:2.5px solid var(--ink);border-radius:16px;box-shadow:5px 5px 0 var(--ink);overflow:hidden;text-decoration:none;color:var(--ink);transition:transform .2s ease,box-shadow .2s ease;}
  #sa-{{ section.id }} .sa-mcard:hover{transform:translate(-3px,-3px);box-shadow:8px 8px 0 var(--ink);}
  #sa-{{ section.id }} .sa-mimg{aspect-ratio:16/10;background:var(--mint);border-bottom:2.5px solid var(--ink);overflow:hidden;}
  #sa-{{ section.id }} .sa-mimg img{width:100%;height:100%;object-fit:cover;}
  #sa-{{ section.id }} .sa-mb{padding:14px 16px 18px;}
  #sa-{{ section.id }} .sa-mt{font-family:var(--fh);font-weight:400;font-size:15px;text-transform:uppercase;line-height:1.15;}
  @media (max-width:860px){
    #sa-{{ section.id }} .sa-pgrid{grid-template-columns:repeat(2,1fr);}
    #sa-{{ section.id }} .sa-mgrid{grid-template-columns:1fr;}
    #sa-{{ section.id }} .sa-head{padding:34px 0 4px;}
  }
  @media (prefers-reduced-motion: reduce){#sa-{{ section.id }} .sa-rev{opacity:1;transform:none;}}
</style>

<section id="sa-{{ section.id }}">
  <article>
    <div class="sa-head">
      <div class="sa-wrap">
        <a class="sa-back" href="{{ blog.url | default: '/blogs/news' }}">← {{ blog.title | default: 'Back to blog' }}</a>
        {%- if article.tags.size > 0 -%}
          <div class="sa-tags sa-rev">{%- for t in article.tags limit: 4 -%}<span class="sa-tag">{{ t | remove: 'recipe_' | remove: 'dietary_' | replace: '-', ' ' }}</span>{%- endfor -%}</div>
        {%- endif -%}
        <h1 class="sa-title sa-rev">{{ article.title }}</h1>
        <div class="sa-meta sa-rev">{{ article.published_at | date: '%B %d, %Y' }}{%- if s.show_author and article.author != blank %} · by {{ article.author }}{% endif -%}</div>
      </div>
    </div>

    <div class="sa-wrap">
      <div class="sa-body sa-rev">{{ article.content }}</div>

      <div class="sa-share">
        <span class="lbl">Share</span>
        <a href="https://www.facebook.com/sharer.php?u={{ shop.url }}{{ article.url }}" target="_blank" rel="noopener" aria-label="Share on Facebook">f</a>
        <a href="https://twitter.com/intent/tweet?url={{ shop.url }}{{ article.url }}&text={{ article.title | url_encode }}" target="_blank" rel="noopener" aria-label="Share on X">X</a>
        <a href="https://pinterest.com/pin/create/button/?url={{ shop.url }}{{ article.url }}&description={{ article.title | url_encode }}" target="_blank" rel="noopener" aria-label="Share on Pinterest">P</a>
        <button type="button" class="sa-copy" data-url="{{ shop.url }}{{ article.url }}" aria-label="Copy link">⧉</button>
      </div>
    </div>
  </article>

  {%- assign shop_coll = collections[shop_handle] -%}
  {%- if shop_coll and shop_coll.products.size > 0 -%}
    <div class="sa-shop">
      <div class="sa-wide">
        <h2 class="sa-rev">{{ s.shop_heading }}</h2>
        <p class="sub sa-rev">{{ s.shop_sub }}</p>
        <div class="sa-pgrid">
          {%- for product in shop_coll.products limit: 4 -%}
            <a class="sa-pcard sa-rev" href="{{ product.url }}">
              <div class="sa-pimg">{%- if product.featured_image -%}<img src="{{ product.featured_image | image_url: width: 500 }}" alt="{{ product.title | escape }}" loading="lazy">{%- endif -%}</div>
              <div class="sa-pb">
                <span class="sa-pn">{{ product.title | remove: 'Syrup' | strip }}</span>
                {% render 'syr-vip-price', product: product %}
              </div>
            </a>
          {%- endfor -%}
        </div>
        <div class="sa-cta sa-rev"><a class="sa-btn" href="/collections/all">Shop all syrups</a></div>
      </div>
    </div>
  {%- endif -%}

  {%- assign more_count = 0 -%}
  {%- if blog.articles.size > 1 -%}
    <div class="sa-more">
      <div class="sa-wide">
        <h2 class="sa-rev">More to read</h2>
        <div class="sa-mgrid">
          {%- for a in blog.articles -%}
            {%- if a.id != article.id and more_count < 3 -%}
              {%- assign more_count = more_count | plus: 1 -%}
              <a class="sa-mcard sa-rev" href="{{ a.url }}">
                <div class="sa-mimg">{%- if a.image -%}<img src="{{ a.image | image_url: width: 600 }}" alt="{{ a.title | escape }}" loading="lazy">{%- endif -%}</div>
                <div class="sa-mb"><span class="sa-mt">{{ a.title }}</span></div>
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  {%- endif -%}
</section>

<script>
(function(){
  var root=document.getElementById('sa-{{ section.id }}');
  if(!root) return;
  if('IntersectionObserver' in window && !(window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches)){
    var io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);}});},{threshold:.08});
    root.querySelectorAll('.sa-rev').forEach(function(el){io.observe(el);});
    setTimeout(function(){root.querySelectorAll('.sa-rev:not(.in)').forEach(function(el){el.classList.add('in');});},2600);
  } else { root.querySelectorAll('.sa-rev').forEach(function(el){el.classList.add('in');}); }
  var cp=root.querySelector('.sa-copy');
  if(cp){cp.addEventListener('click',function(){var u=cp.getAttribute('data-url');if(navigator.clipboard){navigator.clipboard.writeText(u).then(function(){var o=cp.textContent;cp.textContent='✓';setTimeout(function(){cp.textContent=o;},1400);});}});}
})();
</script>

{% schema %}
{
  "name": "Article",
  "tag": "section",
  "settings": [
    { "type": "checkbox", "id": "show_author", "label": "Show author", "default": false },
    { "type": "header", "content": "Shop the flavors strip" },
    { "type": "text", "id": "shop_collection", "label": "Collection handle", "default": "best-sellers" },
    { "type": "text", "id": "shop_heading", "label": "Heading", "default": "Shop the flavors" },
    { "type": "textarea", "id": "shop_sub", "label": "Subtitle", "default": "Recreate it at home — grab the syrups behind the recipe." }
  ],
  "presets": [ { "name": "Article" } ]
}
{% endschema %}