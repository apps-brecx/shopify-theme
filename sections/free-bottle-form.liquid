{% comment %}
  Claim Your Free Bottle Form
{% endcomment %}
<div class="iced-rty-free-bottle">
  <div class="page-width free-bottle-form">
    <h2>Claim Your Free Bottle</h2>
    <p>Fill out your details below and we’ll send you a free bottle, no strings attached!</p>

    <!-- Form -->
    <form id="free-bottle-claim-form" method="post">
      <div class="form-wrapper-gt">
        <div class="name-field">
          <input type="text" name="name" id="name" placeholder="Name" required>
        </div>
        <div class="email-field">
          <input type="email" name="email" id="email" placeholder="Email" required>
        </div>
      </div>
      <button type="submit">Get My Free Bottle</button>
    </form>

    <!-- Already Claimed Message -->
    <div id="claimed-message" style="display:none;">
      <p>🎉 You have already claimed your free bottle!</p>
    </div>
  </div>
</div>

<!-- Success Popup -->
<div id="success-popup" class="modal" style="display:none;">
  <div class="modal-content">
    <span id="close-popup" class="close">&times;</span>
    <h3>Thank you for Claiming Your Free Bottle!</h3>
    <div id="persistent-add-to-cart" class="product-details" style="display:none;">
      <img src="https://syruvia.com/cdn/shop/files/iced_coffee_syrup.png?v=1727438159" alt="Iced Coffee Syrup">
      <p style="font-weight:800;font-size:20px;">Code is: ICEDCOFFEEFORU</p>
      <button onclick="addToCart()">Add to Cart</button>
    </div>
  </div>
</div>

<!-- Already Claimed Popup -->
<div id="already-claimed-popup" class="modal" style="display:none;">
  <div class="modal-content">
    <span id="close-claimed-popup" class="close">&times;</span>
    <h3>You have already claimed your free bottle!</h3>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    // Form submission event handler
    document.getElementById('free-bottle-claim-form').onsubmit = function (event) {
      event.preventDefault(); // Prevent default form submission

      const email = document.getElementById('email').value.trim();

      // Check the email using the PHP backend
      fetch('https://poojas.sg-host.com/freebottle/proxy.php', {  // Path to your PHP script
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: email })
      })
      .then(response => response.json())
      .then(data => {
        if (data.exists) {
          // If the email is found in the Shopify segment, show the message
          alert(data.message);
          document.getElementById('claimed-message').style.display = 'block';
          document.getElementById('already-claimed-popup').style.display = 'block';
        } else {
          // If the email is not found, process the claim and display success
          alert("Claim successful! You can now enjoy your free bottle.");
          document.getElementById('success-popup').style.display = 'block';
          showPersistentAddToCart();
          document.getElementById('free-bottle-claim-form').style.display = 'none';
        }
      })
      .catch(error => {
        console.error('Error:', error);
        alert('An error occurred. Please try again.');
      });

      // Clear the form fields after submission
      this.reset();
    };

    // Function to show the "Add to Cart" button
    function showPersistentAddToCart() {
      document.getElementById('persistent-add-to-cart').style.display = 'block';
    }

    // Close the success popup when the close button is clicked
    document.getElementById('close-popup').onclick = function () {
      document.getElementById('success-popup').style.display = 'none';
    };

    // Close the already claimed popup when the close button is clicked
    document.getElementById('close-claimed-popup').onclick = function () {
      document.getElementById('already-claimed-popup').style.display = 'none';
    };

    // Close the modal if clicked outside the modal content
    window.onclick = function(event) {
      if (event.target === document.getElementById('success-popup')) {
        document.getElementById('success-popup').style.display = 'none';
      }
      if (event.target === document.getElementById('already-claimed-popup')) {
        document.getElementById('already-claimed-popup').style.display = 'none';
      }
    };
  });
</script>

