{{ 'pdp-brand.css' | asset_url | stylesheet_tag }}

{%- comment -%} ===== Flavor copy (dynamic, from product title) ===== {%- endcomment -%}
{%- assign t_lc = product.title | downcase -%}
{%- assign flavor = 'fruit' -%}
{%- if t_lc contains 'mango' -%}{%- assign flavor = 'mango' -%}{%- endif -%}
{%- if t_lc contains 'strawberry' -%}{%- assign flavor = 'strawberry' -%}{%- endif -%}
{%- if t_lc contains 'peach' -%}{%- assign flavor = 'peach' -%}{%- endif -%}
{%- if t_lc contains 'passion' -%}{%- assign flavor = 'passion fruit' -%}{%- endif -%}
{%- if t_lc contains 'pomegranate' -%}{%- assign flavor = 'pomegranate' -%}{%- endif -%}
{%- if t_lc contains 'blueberry' -%}{%- assign flavor = 'blueberry' -%}{%- endif -%}

{%- if section.settings.section_bg != blank -%}
{% style %}
  #shopify-section-{{ section.id }} .pd-why { background: {{ section.settings.section_bg }} !important; }
{% endstyle %}
{%- endif -%}

<div class="pd">
  <section class="pd-why">
    <div class="pd-wrap pd-why-wrap" style="text-align:center;">
      <span class="pd-eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="pd-h2 pd-why-h2">{{ section.settings.heading_pre }}<em>{{ section.settings.heading_em }}</em>{{ section.settings.heading_post }}</h2>
      <div class="pd-why-grid pd-why-grid--spaced">
        <div class="pd-why-card pd-why-card--peach">
          <div class="pd-why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21 C 5 18, 3 11, 7 6 C 10 3, 14 3, 17 6 C 21 11, 19 18, 12 21 Z"/><path d="M10 11 a2 2 0 0 0 4 0"/></svg></div>
          <h3 class="pd-why-title">{{ section.settings.c1_title }}</h3>
          <p class="pd-why-body">{{ section.settings.c1_body | replace: '[flavor]', flavor }}</p>
        </div>
        <div class="pd-why-card pd-why-card--butter">
          <div class="pd-why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 3 v4 M12 17 v4 M3 12 h4 M17 12 h4 M5.5 5.5 l2.5 2.5 M16 16 l2.5 2.5 M5.5 18.5 l2.5 -2.5 M16 8 l2.5 -2.5"/></svg></div>
          <h3 class="pd-why-title">{{ section.settings.c2_title }}</h3>
          <p class="pd-why-body">{{ section.settings.c2_body }}</p>
        </div>
        <div class="pd-why-card pd-why-card--mint">
          <div class="pd-why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 4 H17 V20 a2 2 0 0 1 -2 2 H9 a2 2 0 0 1 -2 -2 Z"/><path d="M7 9 H17"/><circle cx="10" cy="15" r=".8" fill="#1a1a1a"/><circle cx="13" cy="17" r=".8" fill="#1a1a1a"/><circle cx="10.5" cy="18" r=".8" fill="#1a1a1a"/></svg></div>
          <h3 class="pd-why-title">{{ section.settings.c3_title }}</h3>
          <p class="pd-why-body">{{ section.settings.c3_body }}</p>
        </div>
        <div class="pd-why-card pd-why-card--sky">
          <div class="pd-why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 8 H19 V18 a3 3 0 0 1 -3 3 H8 a3 3 0 0 1 -3 -3 Z"/><path d="M19 10 h2 a2 2 0 0 1 2 2 v0 a2 2 0 0 1 -2 2 h-2"/><path d="M8 5 c 0 -2 8 -2 8 0"/></svg></div>
          <h3 class="pd-why-title">{{ section.settings.c4_title }}</h3>
          <p class="pd-why-body">{{ section.settings.c4_body }}</p>
        </div>
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "PB Why",
  "tag": "section",
  "class": "section-pb-why",
  "enabled_on": { "templates": ["product"] },
  "settings": [
    { "type": "header", "content": "Heading" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Why Syruvia Boba" },
    { "type": "text", "id": "heading_pre", "label": "Heading before emphasis", "default": "Made to " },
    { "type": "text", "id": "heading_em", "label": "Heading emphasis (italic)", "default": "pop" },
    { "type": "text", "id": "heading_post", "label": "Heading after emphasis", "default": "." },
    { "type": "header", "content": "Card 1" },
    { "type": "text", "id": "c1_title", "label": "Title", "default": "Real Fruit Flavor" },
    { "type": "text", "id": "c1_body", "label": "Body", "info": "Use [flavor] for the flavor name.", "default": "Juicy [flavor] notes in every pearl. No artificial aftertaste." },
    { "type": "header", "content": "Card 2" },
    { "type": "text", "id": "c2_title", "label": "Title", "default": "Burst Texture" },
    { "type": "text", "id": "c2_body", "label": "Body", "default": "That signature pop is the whole point. Customers love it." },
    { "type": "header", "content": "Card 3" },
    { "type": "text", "id": "c3_title", "label": "Title", "default": "Multi-Use" },
    { "type": "text", "id": "c3_body", "label": "Body", "default": "Bubble tea, smoothies, yogurt, slushies, ice cream toppings." },
    { "type": "header", "content": "Card 4" },
    { "type": "text", "id": "c4_title", "label": "Title", "default": "Café-Grade Quality" },
    { "type": "text", "id": "c4_body", "label": "Body", "default": "Commercial-grade pearls. Ready to serve, store, scoop." },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "section_bg", "label": "Section background", "info": "Leave blank to keep the theme default." }
  ],
  "presets": [{ "name": "PB Why" }]
}
{% endschema %}
