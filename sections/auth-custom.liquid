<script>
(function(){
  var root=document.querySelector('[data-sauth]'); if(!root) return;
  var views=[].slice.call(root.querySelectorAll('.auth-view'));
  function show(v){ views.forEach(function(el){ el.classList.toggle('show', el.getAttribute('data-v')===v); }); root.setAttribute('data-view',v); try{ history.replaceState(null,'', v==='create'?'{{ routes.account_register_url }}':'{{ routes.account_login_url }}'); }catch(e){} }
  // if server has recover errors/success or login errors, force the right view
  var initial=root.getAttribute('data-view');
  if(root.querySelector('[data-v="reset"] .auth-err, [data-v="reset"] .auth-ok')) initial='reset';
  else if(root.querySelector('[data-v="create"] .auth-err')) initial='create';
  else if(root.querySelector('[data-v="signin"] .auth-err')) initial='signin';
  if(location.hash==='#recover') initial='reset';
  show(initial);
  root.addEventListener('click',function(e){ var b=e.target.closest('[data-goto]'); if(b){ e.preventDefault(); show(b.getAttribute('data-goto')); return; } var sb=e.target.closest('[data-soc]'); if(sb){ e.preventDefault(); var p=sb.getAttribute('data-soc'); var v=sb.closest('.auth-view'); var sc=v?v.querySelector('.social-login-container'):document.querySelector('.social-login-container'); if(sc){ var ab=sc.querySelector('.btn-'+p)||sc.querySelector('.btn-'+p+'-plus')||sc.querySelector('[class*="'+p+'"]'); if(ab){ ab.click(); } } } });
  // password eye
  var eyeS='<svg viewBox="0 0 20 14" width="18" height="14" fill="none"><path d="M1 7s3.2-5.5 9-5.5S19 7 19 7s-3.2 5.5-9 5.5S1 7 1 7z" stroke="currentColor" stroke-width="1.6"/><circle cx="10" cy="7" r="2.4" stroke="currentColor" stroke-width="1.6"/></svg>';
  [].slice.call(root.querySelectorAll('[data-eye]')).forEach(function(btn){ btn.innerHTML=eyeS; btn.addEventListener('click',function(){ var inp=btn.parentElement.querySelector('[data-pw]'); if(inp){ inp.type=inp.type==='password'?'text':'password'; } }); });
})();
</script>

