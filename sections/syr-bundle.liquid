{%- comment -%} Build Your Bundle CTA (Skinny Mixes inspired) {%- endcomment -%}
<style id="syr-bdl-{{ section.id }}-css">
  #syr-bdl-{{ section.id }}{
    --ink:#39220f; --paper:#FFFBF4; --bg:#F4E8CE; --accent:#c58548;
    --butter:#FCE2A0; --peach:#FFD4B8;
    background:var(--paper);
    padding:60px 40px 80px;
    font-family:'Josefin Sans','Josefin',sans-serif;
  }
  #syr-bdl-{{ section.id }} .syr-bdl-card{
    max-width:1240px; margin:0 auto;
    background:linear-gradient(135deg, var(--peach) 0%, var(--butter) 100%);
    border:2px solid var(--ink); border-radius:32px;
    box-shadow:8px 8px 0 var(--ink);
    overflow:hidden;
    display:grid; grid-template-columns:1.05fr 1fr;
    align-items:stretch;
    min-height:420px;
    position:relative;
  }
  #syr-bdl-{{ section.id }} .syr-bdl-copy{
    padding:56px 56px;
    display:flex; flex-direction:column; justify-content:center;
    color:var(--ink);
  }
  #syr-bdl-{{ section.id }} .syr-bdl-eyebrow{
    display:inline-block; background:var(--ink); color:var(--butter);
    border:2px solid var(--ink); border-radius:999px;
    font-family:'Archivo Black','Archivo',sans-serif; font-weight:400;
    font-size:11px; letter-spacing:.16em; text-transform:uppercase;
    padding:7px 16px; margin-bottom:18px; width:fit-content;
    box-shadow:3px 3px 0 var(--accent);
  }
  #syr-bdl-{{ section.id }} h2{
    font-family:'Archivo Black','Archivo',sans-serif; font-weight:400;
    font-size:clamp(36px, 5.4vw, 64px); line-height:.92;
    letter-spacing:-.02em; text-transform:uppercase;
    color:var(--ink); margin:0 0 16px;
    max-width:14ch;
  }
  #syr-bdl-{{ section.id }} h2 em{
    font-family:'Caveat','Brush Script MT',cursive; font-style:italic;
    color:var(--accent); font-size:.78em; letter-spacing:0;
    text-transform:none; display:inline-block; transform:rotate(-3deg) translateY(-4px);
  }
  #syr-bdl-{{ section.id }} .syr-bdl-sub{
    font-size:17px; line-height:1.45; color:rgba(57,34,15,.78);
    margin:0 0 24px; max-width:40ch;
  }
  #syr-bdl-{{ section.id }} .syr-bdl-ticks{
    display:flex; flex-direction:column; gap:8px; margin:0 0 28px;
  }
  #syr-bdl-{{ section.id }} .syr-bdl-tick{
    display:flex; align-items:center; gap:10px;
    font-size:14.5px; color:var(--ink);
  }
  #syr-bdl-{{ section.id }} .syr-bdl-tick::before{
    content:"✔";
    display:inline-flex; align-items:center; justify-content:center;
    width:24px; height:24px; flex:0 0 auto;
    background:var(--ink); color:var(--butter);
    border-radius:50%;
    font-size:12px; font-weight:700;
  }
  #syr-bdl-{{ section.id }} .syr-bdl-btn{
    display:inline-flex; align-items:center; gap:10px;
    background:var(--ink); color:var(--paper);
    border:2px solid var(--ink); border-radius:999px;
    padding:18px 32px; width:fit-content;
    font-family:'Archivo Black','Archivo',sans-serif; font-weight:400;
    font-size:13px; letter-spacing:.14em; text-transform:uppercase;
    text-decoration:none;
    box-shadow:5px 5px 0 var(--paper);
    transition:transform .18s cubic-bezier(.4,0,.2,1), box-shadow .18s cubic-bezier(.4,0,.2,1), background .15s ease;
  }
  #syr-bdl-{{ section.id }} .syr-bdl-btn:hover{ transform:translate(-3px,-3px); box-shadow:8px 8px 0 var(--paper); background:var(--accent); }
  #syr-bdl-{{ section.id }} .syr-bdl-btn:active{ transform:scale(.97); box-shadow:3px 3px 0 var(--paper); transition-duration:.08s; }

  #syr-bdl-{{ section.id }} .syr-bdl-media{
    position:relative;
    background-size:cover; background-position:center;
    background-repeat:no-repeat;
    border-left:2px solid var(--ink);
  }
  #syr-bdl-{{ section.id }} .syr-bdl-media-fb{
    width:100%; height:100%;
    background:
      radial-gradient(80% 80% at 30% 30%, var(--butter) 0%, transparent 60%),
      radial-gradient(70% 70% at 70% 80%, var(--peach) 0%, transparent 60%),
      var(--accent);
    display:flex; align-items:center; justify-content:center;
    color:var(--paper);
    font-family:'Archivo Black','Archivo',sans-serif; font-size:60px;
  }
  /* Decorative sparkles */
  #syr-bdl-{{ section.id }} .syr-bdl-card::before,
  #syr-bdl-{{ section.id }} .syr-bdl-card::after{
    content:"✦"; position:absolute; color:var(--ink); opacity:.12; pointer-events:none;
    font-family:serif; z-index:1;
  }
  #syr-bdl-{{ section.id }} .syr-bdl-card::before{ top:18px; right:46%; font-size:60px; transform:rotate(-12deg); }
  #syr-bdl-{{ section.id }} .syr-bdl-card::after{ bottom:30px; left:48%; font-size:80px; transform:rotate(12deg); }

  @media (max-width:900px){
    #syr-bdl-{{ section.id }}{ padding:40px 14px 60px; }
    #syr-bdl-{{ section.id }} .syr-bdl-card{ grid-template-columns:1fr; box-shadow:5px 5px 0 var(--ink); border-radius:24px; min-height:auto; }
    #syr-bdl-{{ section.id }} .syr-bdl-copy{ padding:32px 24px 36px; order:2; text-align:center; align-items:center; }
    #syr-bdl-{{ section.id }} .syr-bdl-eyebrow{ margin:0 auto 14px; box-shadow:2.5px 2.5px 0 var(--accent); }
    #syr-bdl-{{ section.id }} h2{ font-size:clamp(28px, 9vw, 42px); margin:0 auto 14px; max-width:14ch; }
    #syr-bdl-{{ section.id }} .syr-bdl-sub{ font-size:14.5px; margin:0 auto 20px; }
    #syr-bdl-{{ section.id }} .syr-bdl-ticks{ align-items:flex-start; max-width:280px; margin:0 auto 22px; }
    #syr-bdl-{{ section.id }} .syr-bdl-btn{ margin:0 auto; padding:14px 24px; font-size:11.5px; }
    #syr-bdl-{{ section.id }} .syr-bdl-media{ order:1; min-height:42vw; border-left:0; border-bottom:2px solid var(--ink); }
    #syr-bdl-{{ section.id }} .syr-bdl-card::before, #syr-bdl-{{ section.id }} .syr-bdl-card::after{ display:none; }
  }
</style>

<section id="syr-bdl-{{ section.id }}">
  <div class="syr-bdl-card" data-reveal="up">
    <div class="syr-bdl-copy">
      <span class="syr-bdl-eyebrow">Save 15%</span>
      <h2>{{ section.settings.headline }}</h2>
      <p class="syr-bdl-sub">{{ section.settings.sub }}</p>
      <ul class="syr-bdl-ticks">
        <li class="syr-bdl-tick">{{ section.settings.tick_1 }}</li>
        <li class="syr-bdl-tick">{{ section.settings.tick_2 }}</li>
        <li class="syr-bdl-tick">{{ section.settings.tick_3 }}</li>
      </ul>
      <a class="syr-bdl-btn" href="{{ section.settings.cta_link | default: '/pages/build-your-bundle' }}">{{ section.settings.cta_text }} →</a>
    </div>
    <div class="syr-bdl-media" style="{% if section.settings.image %}background-image:url('{{ section.settings.image | image_url: width: 1200 }}');{% endif %}">
      {%- unless section.settings.image -%}
        <div class="syr-bdl-media-fb">🍯</div>
      {%- endunless -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bundle CTA",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "headline", "label": "Headline", "default": "Build your bundle. Save 15%." },
    { "type": "textarea", "id": "sub", "label": "Subtext", "default": "Pick any 3 syrups, get 15% off. Bigger bundle = bigger savings." },
    { "type": "text", "id": "tick_1", "label": "Tick 1", "default": "Mix and match any flavor" },
    { "type": "text", "id": "tick_2", "label": "Tick 2", "default": "Free shipping on $35+" },
    { "type": "text", "id": "tick_3", "label": "Tick 3", "default": "100% money-back guarantee" },
    { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Build your bundle" },
    { "type": "url", "id": "cta_link", "label": "CTA link" },
    { "type": "image_picker", "id": "image", "label": "Image (right side desktop / top mobile)" }
  ],
  "presets": [ { "name": "Bundle CTA" } ]
}
{% endschema %}
