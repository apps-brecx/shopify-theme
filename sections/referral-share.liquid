<script>
  document.addEventListener("DOMContentLoaded", function () {
    const copyBtn = document.querySelector(".copy-icon");
    const referralText = document.querySelector(".referral-text").innerText;

    copyBtn.addEventListener("click", () => {
      // Save original HTML content to restore later
      const originalIconHTML = copyBtn.innerHTML;

      // Copy the referral message to clipboard
      navigator.clipboard.writeText(referralText).then(() => {
        // Change icon to copied image
        copyBtn.innerHTML = '<img class="successfully-copied" src="https://cdn.shopify.com/s/files/1/0861/1106/0252/files/copied_3.png?v=1748507991" width="50px" height="50px" alt="copied_icon" />';

        // Revert back after 2 seconds
        setTimeout(() => {
          copyBtn.innerHTML = originalIconHTML;
        }, 2000);
      });
    });
  });
</script>



