{%- comment -%} Build-a-bundle companion: VIP $7.99 base in summary + case rows, tier code at checkout, and case persistence across reloads. Logged-in shows real VIP prices. Test codes only.
  v2 (sold-out guard): marks out-of-stock flavors as "Sold out" (not addable) and makes "Add case to cart" fail gracefully — a sold-out item can never wipe the case or the cart. {%- endcomment -%}

{%- comment -%} Availability map for the bundle collection: { variantId: productAvailable }. Keyed by the same variant id the builder cards expose as data-id. {%- endcomment -%}
{%- assign bb_coll = collections['syruvia-bundle'] -%}
<script type="application/json" data-bb-avail>
{
{%- if bb_coll != blank -%}
  {%- paginate bb_coll.products by 250 -%}
    {%- assign bb_first = true -%}
    {%- for product in bb_coll.products -%}
      {%- assign bb_v = product.selected_or_first_available_variant -%}
      {%- if bb_v -%}{%- unless bb_first -%},{%- endunless -%}"{{ bb_v.id }}":{{ product.available }}{%- assign bb_first = false -%}{%- endif -%}
    {%- endfor -%}
  {%- endpaginate -%}
{%- endif -%}
}
</script>

<style>
  .sbwrap .card.is-soldout{ opacity:.58 !important; }
  .sbwrap .card.is-soldout:hover{ transform:none !important; box-shadow:4px 4px 0 #39220f !important; }
  .sbwrap .card.is-soldout .thumb img{ filter:grayscale(.6); }
  .sbwrap .ribbon.bb-ribbon-soldout{ background:#8B7355 !important; color:#FFFBF4 !important; }
  .sbwrap .bb-soldout-label{ font-family:'Archivo Black','Arial Black',sans-serif !important; font-size:12px; letter-spacing:.04em; text-transform:uppercase; color:#8B7355 !important; padding:8px 4px; }
</style>

{%- comment -%} Logged-out only: "Unlock VIP pricing" strip inside the sticky summary bar. JS moves it into .summary. {%- endcomment -%}
{%- if customer == nil -%}
{%- assign bb_return_to = request.path | url_encode -%}
<style>
  /* VIP price strip — sits at the top of the sticky summary bar, logged-out shoppers only */
  html body .sbwrap .summary .bb-vipstrip{ width:100%; background:linear-gradient(180deg,#EAF4FB,#DBECF8); border-bottom:1.5px solid #39220f; }
  html body .sbwrap .bb-vipstrip-in{ max-width:1240px; margin:0 auto; padding:9px 28px; display:flex; align-items:center; justify-content:space-between; gap:16px; }
  html body .sbwrap .bb-vipstrip-msg{ display:inline-flex; align-items:center; gap:9px; min-width:0; font-family:'Josefin Sans','Josefin',sans-serif !important; font-size:14px; color:#39220f; line-height:1.2; }
  html body .sbwrap .bb-vipstrip-msg span{ min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
  html body .sbwrap .bb-vipstrip-msg strong{ font-family:'Archivo Black','Archivo Black Fallback','Arial Black',sans-serif !important; font-weight:400; color:#1F5D9C; }
  html body .sbwrap .bb-vipstrip-star{ flex:0 0 auto; width:21px; height:21px; padding:4px; background:#2F7DC4; color:#FFFBF4; border:1.5px solid #39220f; border-radius:50%; box-shadow:1.5px 1.5px 0 #39220f; }
  html body .sbwrap .bb-vipstrip-cta-wrap{ display:inline-flex; align-items:center; gap:13px; flex:0 0 auto; }
  html body .sbwrap .bb-vipstrip-cta{ display:inline-flex; align-items:center; gap:7px; font-family:'Archivo Black','Archivo Black Fallback','Arial Black',sans-serif !important; font-weight:400; font-size:11px; letter-spacing:.12em; text-transform:uppercase; text-decoration:none; color:#FFFBF4 !important; background:#2F7DC4; border:2px solid #39220f; border-radius:999px; box-shadow:2.5px 2.5px 0 #39220f; padding:8px 15px; line-height:1; transition:transform .15s ease, box-shadow .15s ease, background .15s ease; }
  html body .sbwrap .bb-vipstrip-cta:hover{ background:#1F5D9C; color:#FFFBF4 !important; transform:translate(-1.5px,-1.5px); box-shadow:4px 4px 0 #39220f; }
  html body .sbwrap .bb-vipstrip-cta svg{ flex:0 0 auto; transition:transform .2s ease; }
  html body .sbwrap .bb-vipstrip-cta:hover svg{ transform:translateX(2px); }
  html body .sbwrap .bb-vipstrip-signin{ font-family:'Archivo Black','Archivo Black Fallback','Arial Black',sans-serif !important; font-weight:400; font-size:10.5px; letter-spacing:.1em; text-transform:uppercase; color:#1F5D9C !important; text-decoration:underline; text-underline-offset:2px; white-space:nowrap; }
  html body .sbwrap .bb-vipstrip-signin:hover{ color:#39220f !important; }
  /* Taller bar now — keep the last product cards clear of it, and lift the toast above it */
  html body .sbwrap{ padding-bottom:158px !important; }
  html body .sbwrap .toast{ bottom:150px !important; }
  /* Mobile: stack the message above the CTA so they never collide */
  @media (max-width:720px){
    html body .sbwrap{ padding-bottom:176px !important; }
    html body .sbwrap .toast{ bottom:168px !important; }
    html body .sbwrap .bb-vipstrip-in{ flex-direction:column; align-items:center; text-align:center; gap:9px; padding:10px 16px; }
    html body .sbwrap .bb-vipstrip-msg{ justify-content:center; max-width:100%; font-size:12.5px; gap:7px; }
    html body .sbwrap .bb-vipstrip-msg span{ white-space:normal; overflow:visible; text-overflow:clip; }
    html body .sbwrap .bb-vipstrip-star{ width:18px; height:18px; padding:3.5px; }
    html body .sbwrap .bb-vipstrip-cta-wrap{ gap:16px; }
    html body .sbwrap .bb-vipstrip-cta{ font-size:10.5px; padding:8px 15px; letter-spacing:.09em; }
    html body .sbwrap .bb-vipstrip-signin{ display:inline; }
  }
</style>
<div id="bb-vipstrip-host" hidden>
  <div class="bb-vipstrip" data-bb-vipstrip>
    <div class="bb-vipstrip-in">
      <span class="bb-vipstrip-msg">
        <svg class="bb-vipstrip-star" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2 L14.5 8 L21 9 L16.5 13.5 L17.5 20 L12 16.5 L6.5 20 L7.5 13.5 L3 9 L9.5 8 Z"/></svg>
        <span data-bb-vipmsg>VIP members pay just <strong>$7.99</strong> a bottle</span>
      </span>
      <span class="bb-vipstrip-cta-wrap">
        <a class="bb-vipstrip-cta" href="/account/register?return_to={{ bb_return_to }}">
          Unlock VIP pricing
          <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12 h14 M13 6 l6 6 -6 6"/></svg>
        </a>
        <a class="bb-vipstrip-signin" href="/account/login?return_to={{ bb_return_to }}">Sign in</a>
      </span>
    </div>
  </div>
</div>
{%- endif -%}

<script>
(function(){
  var root=document.querySelector('.sbwrap'); if(!root) return;
  var LOGGED_IN = {% if customer %}true{% else %}false{% endif %};
  var VIPBASE=799;
  var KEY='syr_bundle_case_v1';
  var CODES={2:'BUNDLE2TEST',3:'BUNDLE3TEST',4:'BUNDLE4TEST',5:'BUNDLE5TEST',6:'BUNDLE6TEST',8:'BUNDLE8TEST',10:'BUNDLE10TEST',12:'BUNDLE12TEST'};

  /* ---- sold-out availability ---- */
  var BBAVAIL={};
  try{ var _ae=document.querySelector('[data-bb-avail]'); if(_ae){ BBAVAIL=JSON.parse(_ae.textContent||'{}'); } }catch(e){ BBAVAIL={}; }
  function bbToast(m){ var t=root.querySelector('[data-toast]'); if(!t){ return; } t.textContent=m; t.classList.add('show'); clearTimeout(t._bb); t._bb=setTimeout(function(){ t.classList.remove('show'); },2800); }
  function markSoldOutCard(card){
    if(!card || card.classList.contains('is-soldout')) return;
    card.classList.add('is-soldout'); card.classList.remove('is-selected'); card.dataset.avail='false';
    var foot=card.querySelector('.card-foot');
    if(foot){
      var ab=foot.querySelector('.add-btn,[data-add]'), st=foot.querySelector('.stepper');
      if(ab) ab.remove(); if(st) st.remove();
      if(!foot.querySelector('.bb-soldout-label')){ var s=document.createElement('span'); s.className='bb-soldout-label'; s.textContent='Sold out'; foot.appendChild(s); }
    }
    if(!card.querySelector('.bb-ribbon-soldout')){ var r=document.createElement('span'); r.className='ribbon bb-ribbon-soldout'; r.textContent='Sold out'; card.insertBefore(r, card.firstChild); }
  }
  function markSoldOutById(id){ if(id==null) return; BBAVAIL[id]=false; markSoldOutCard(root.querySelector('.card[data-id="'+id+'"]')); }
  function applySoldOut(){ cards().forEach(function(c){ var id=c.dataset.id; if(id && BBAVAIL[id]===false) markSoldOutCard(c); }); }

  function money(c){return '$'+(c/100).toFixed(2);}
  function vipUnit(reg){return Math.min(VIPBASE, reg||VIPBASE);}
  function setText(e,v){if(e&&e.textContent!==v)e.textContent=v;}
  function setDisp(e,v){if(e&&e.style.display!==v)e.style.display=v;}
  function tiers(){return [].slice.call(root.querySelectorAll('.tb-node')).map(function(n){var q=n.querySelector('.tb-q'),d=n.querySelector('.tb-d');return {q:q?parseInt(q.textContent,10):0,d:d?parseFloat(d.textContent):0};});}
  function cards(){return [].slice.call(root.querySelectorAll('.card'));}
  function cardQ(c){var qe=c.querySelector('[data-q]');return qe?parseInt(qe.textContent,10)||0:0;}
  function qty(){var n=0;cards().forEach(function(c){n+=cardQ(c);});return n;}
  function baseCents(){var b=0;cards().forEach(function(c){b+=vipUnit(parseInt(c.dataset.price,10))*cardQ(c);});return b;}
  function bestD(n){var d=0;tiers().forEach(function(t){if(n>=t.q)d=t.d;});return d;}
  function bestCode(n){var c='';tiers().forEach(function(t){if(n>=t.q&&CODES[t.q])c=CODES[t.q];});return c;}

  function patchSummary(){
    if(!LOGGED_IN) return;
    var n=qty(); if(n<1) return;
    var base=baseCents(), d=bestD(n), total=Math.round(base*(1-d/100)), sav=base-total, ready=n>=2;
    root.querySelectorAll('[data-sumnow],[data-sheetnow]').forEach(function(e){setText(e,money(ready?total:base));});
    root.querySelectorAll('[data-sumwas],[data-sheetwas]').forEach(function(e){setText(e,money(base));setDisp(e,ready?'':'none');});
    root.querySelectorAll('[data-savepill],[data-sheetsave]').forEach(function(e){setText(e,'Save '+money(sav));setDisp(e,ready?'':'none');});
  }
  function patchSheet(){
    if(!LOGGED_IN) return;
    root.querySelectorAll('.sheet-price').forEach(function(sp){
      var m=(sp.textContent||'').match(/\$[\d.]+/g); if(!m||!m.length) return;
      var unit=Math.round(parseFloat(m[0].slice(1))*100);
      var line=m[1]?Math.round(parseFloat(m[1].slice(1))*100):unit;
      var q=unit?Math.max(1,Math.round(line/unit)):1;
      var v=vipUnit(unit);
      var html=money(v)+' <em>each &middot; '+money(v*q)+'</em>';
      if(sp.innerHTML.replace(/\s+/g,' ').trim()!==html) sp.innerHTML=html;
    });
  }
  /* ---- logged-out "Unlock VIP pricing" strip in the summary bar ---- */
  function regBaseCents(){var b=0;cards().forEach(function(c){b+=(parseInt(c.dataset.price,10)||0)*cardQ(c);});return b;}
  var vipMsgEl=null, vipMsgLast='';
  function mountNudge(){
    if(LOGGED_IN) return;
    var summary=root.querySelector('.summary'), host=document.getElementById('bb-vipstrip-host');
    if(summary && host){
      var strip=host.querySelector('.bb-vipstrip');
      if(strip && !summary.querySelector('.bb-vipstrip')){ summary.insertBefore(strip, summary.firstChild); }
      if(host.parentNode) host.parentNode.removeChild(host);
    }
    if(!vipMsgEl) vipMsgEl=root.querySelector('[data-bb-vipmsg]');
  }
  function patchNudge(){
    if(LOGGED_IN) return;
    if(!vipMsgEl){ vipMsgEl=root.querySelector('[data-bb-vipmsg]'); if(!vipMsgEl) return; }
    var n=qty(), html;
    if(n<1){ html='VIP members pay just <strong>'+money(VIPBASE)+'</strong> a bottle'; }
    else{
      var d=bestD(n), regT=Math.round(regBaseCents()*(1-d/100)), vipT=Math.round(baseCents()*(1-d/100)), more=Math.max(0,regT-vipT);
      html='VIP price <strong>'+money(vipT)+'</strong>'+(more>0?(' &middot; save '+money(more)+' more'):'');
    }
    if(html!==vipMsgLast){ vipMsgEl.innerHTML=html; vipMsgLast=html; }
  }
  function patchAll(){patchSummary();patchSheet();patchNudge();}

  function saveState(){
    try{var arr=[];cards().forEach(function(c){var q=cardQ(c);if(q>0)arr.push({id:c.dataset.id,q:q});});localStorage.setItem(KEY,JSON.stringify(arr));}catch(e){}
  }
  var restoring=false;
  function restoreState(){
    var arr;try{arr=JSON.parse(localStorage.getItem(KEY)||'[]');}catch(e){arr=[];}
    if(!arr||!arr.length) return;
    restoring=true;
    arr.forEach(function(it){
      if(BBAVAIL[it.id]===false) return;
      var card=root.querySelector('.card[data-id="'+it.id+'"]'); if(!card) return;
      var add=card.querySelector('.add-btn,[data-add]'); if(!add) return;
      var have=cardQ(card);
      for(var k=have;k<it.q;k++){ add.click(); }
    });
    restoring=false;
    setTimeout(patchAll,60);
  }

  root.addEventListener('click', function(){ setTimeout(function(){patchAll();if(!restoring)saveState();},0); }, false);
  if('MutationObserver' in window){
    var mo=new MutationObserver(function(){ if(window.__bbRAF)return; window.__bbRAF=requestAnimationFrame(function(){window.__bbRAF=0;patchAll();}); });
    mo.observe(root,{childList:true,subtree:true,characterData:true});
  }

  /* ---- graceful "Add case to cart" ---- */
  function recover(payload, btn){
    var addedQty=0, failed=0, i=0;
    (function seq(){
      if(i>=payload.length){
        if(addedQty>0){
          try{localStorage.removeItem(KEY);}catch(e){}
          var code=bestCode(addedQty);
          bbFinish(code);
        } else {
          btn.disabled=false; btn.textContent='Add case to cart';
          bbToast('Those flavors just sold out \u2014 your case is saved');
        }
        return;
      }
      var it=payload[i++];
      (window.__PD_OWN_ADDS=window.__PD_OWN_ADDS||[]).push({fam:'SKIP',t:Date.now()});
      fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json','Accept':'application/json'},body:JSON.stringify({items:[{id:it.id,quantity:it.quantity}]})})
        .then(function(r){ if(r.ok){ addedQty+=it.quantity; } else { failed++; markSoldOutById(it.id); } })
        .catch(function(){ failed++; markSoldOutById(it.id); })
        .then(seq);
    })();
  }

  /* This bundle add navigates straight to /discount, so the site-wide
     managed-discount guard can't win the race to strip a stale code. Do it
     here instead: before leaving, clear any managed QTY or BUNDLE code (a
     leftover product-page QTY, or a previous case's BUNDLE) while preserving
     the customer's own coupons, then apply only THIS bundle's code and go to
     cart. The whole cleanup is awaited before navigation, so nothing races it. */
  var BB_MANAGED=/^(QTY|BUNDLE)[0-9]+(TEST)?$/i;
  function bbApplyEach(list,i){
    if(i>=list.length) return Promise.resolve();
    return fetch('/discount/'+encodeURIComponent(list[i])+'?redirect=/cart.js',{headers:{'Accept':'application/json'},credentials:'same-origin'})
      .then(function(){return bbApplyEach(list,i+1);},function(){return bbApplyEach(list,i+1);});
  }
  function bbFinish(code){
    fetch('/cart.js',{headers:{'Accept':'application/json'},credentials:'same-origin'})
      .then(function(r){return r.json();})
      .then(function(c){
        var codes=(c&&c.discount_codes)||[];
        var managed=codes.filter(function(d){return BB_MANAGED.test(String(d&&d.code||''));});
        if(!managed.length){
          window.location.href=code?('/discount/'+encodeURIComponent(code)+'?redirect=/cart'):'/cart';
          return;
        }
        var keep=codes.filter(function(d){return d&&d.code&&!BB_MANAGED.test(String(d.code));}).map(function(d){return String(d.code);});
        if(code) keep.push(code);
        var go=function(){window.location.href='/cart';};
        fetch('/cart/update.js',{method:'POST',headers:{'Content-Type':'application/json','Accept':'application/json'},credentials:'same-origin',body:JSON.stringify({discount:''})})
          .then(function(){return bbApplyEach(keep,0);})
          .then(go,go);
      })
      .catch(function(){ window.location.href=code?('/discount/'+encodeURIComponent(code)+'?redirect=/cart'):'/cart'; });
  }

  root.addEventListener('click', function(e){
    var btn=e.target.closest('[data-checkout]'); if(!btn) return;
    e.preventDefault(); e.stopImmediatePropagation();
    var payload=[];
    cards().forEach(function(card){
      var q=cardQ(card);
      if(q>0 && card.dataset.avail!=='false' && BBAVAIL[card.dataset.id]!==false && !card.classList.contains('is-soldout')){
        payload.push({id:parseInt(card.dataset.id,10),quantity:q});
      }
    });
    if(!payload.length){ bbToast('Your case is empty'); return; }
    var n=0; payload.forEach(function(p){ n+=p.quantity; });
    btn.disabled=true; btn.textContent='Adding\u2026';
    /* Append the case to the existing cart \u2014 never clear it; whatever the customer
       already had in the cart stays. Tell the managed-discount guard to skip
       this add (bbFinish below owns the code cleanup). */
    (window.__PD_OWN_ADDS=window.__PD_OWN_ADDS||[]).push({fam:'SKIP',t:Date.now()});
    fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json','Accept':'application/json'},body:JSON.stringify({items:payload})})
      .then(function(r){
        if(r.ok){
          try{localStorage.removeItem(KEY);}catch(e){}
          var code=bestCode(n);
          bbFinish(code);
          return;
        }
        /* A flavor went out of stock since load, so the batch add was rejected as a
           whole. Add the in-stock flavors one by one, flag the sold-out one(s), and
           never lose the selection. */
        recover(payload, btn);
      })
      .catch(function(){ btn.disabled=false; btn.textContent='Add case to cart'; bbToast('Network hiccup \u2014 your case is saved, try again'); });
  }, true);

  var tries=0;
  function init(){ if(!cards().length && tries<25){tries++;return setTimeout(init,150);} mountNudge(); applySoldOut(); restoreState(); setTimeout(patchAll,120); setTimeout(patchAll,600); }
  /* mark sold-out as early as possible so a fast click can't add one */
  if(document.readyState!=='loading'){ mountNudge(); applySoldOut(); setTimeout(init,200); }
  else document.addEventListener('DOMContentLoaded', function(){ mountNudge(); applySoldOut(); setTimeout(init,200); });
})();
</script>
{% schema %}
{ "name": "BB VIP Wire", "settings": [] }
{% endschema %}
