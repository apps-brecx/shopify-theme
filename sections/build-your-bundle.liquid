    { "type": "color", "id": "card_color", "label": "Card background", "default": "#FFFFFF" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#2B1B12" },
    { "type": "color", "id": "accent_color", "label": "Accent (light)", "default": "#E7B98A" },
