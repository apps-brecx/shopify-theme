  ],
  "max_blocks": 6,
  "presets": [
    { "name": "Build Your Bundle", "blocks": [
      { "type": "tier", "settings": { "min_qty": 3, "discount_pct": 10 } },
      { "type": "tier", "settings": { "min_qty": 6, "discount_pct": 20 } },
      { "type": "tier", "settings": { "min_qty": 10, "discount_pct": 30 } }
    ]}
  ]
}
