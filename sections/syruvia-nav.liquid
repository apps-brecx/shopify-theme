<script>
(function(){
  var root=document.getElementById('syrnav');if(!root||root.dataset.syrInit)return;root.dataset.syrInit='1';
  var wrap=root.querySelector('[data-megawrap]');
  var triggers=root.querySelectorAll('.syrnav-links a.has-mega');
  var panels=root.querySelectorAll('.syrnav-mega');
  function closeMega(){panels.forEach(function(p){p.classList.remove('open');});triggers.forEach(function(t){t.classList.remove('mega-on');});}
  function openMega(key){closeMega();var p=root.querySelector('.syrnav-mega[data-panel="'+key+'"]');if(p)p.classList.add('open');var t=root.querySelector('.syrnav-links a[data-mega="'+key+'"]');if(t)t.classList.add('mega-on');}
  triggers.forEach(function(t){t.addEventListener('mouseenter',function(){openMega(t.dataset.mega);});});
  if(wrap)wrap.addEventListener('mouseleave',closeMega);
  var iconCluster=root.querySelector('[data-closemega]');if(iconCluster)iconCluster.addEventListener('mouseenter',closeMega);
  root.querySelectorAll('.syrnav-subtabs').forEach(function(bar){
    var scope=bar.parentElement;
    bar.querySelectorAll('.syrnav-subtab').forEach(function(btn){
      function activate(){bar.querySelectorAll('.syrnav-subtab').forEach(function(b){b.classList.remove('active');});btn.classList.add('active');scope.querySelectorAll('.syrnav-grid').forEach(function(g){g.classList.toggle('active',g.getAttribute('data-grid')===btn.getAttribute('data-subtab'));});}
      btn.addEventListener('mouseenter',activate);btn.addEventListener('click',activate);
    });
  });
  var drawer=root.querySelector('.syrnav-drawer');var scrim=root.querySelector('.syrnav-scrim');
  function openDrawer(){drawer.classList.add('open');scrim.classList.add('open');drawer.setAttribute('aria-hidden','false');document.body.style.overflow='hidden';document.body.classList.add('overflow-hidden-mobile');document.body.classList.add('pd-menu-open');}
  function closeDrawer(){drawer.classList.remove('open');scrim.classList.remove('open');drawer.setAttribute('aria-hidden','true');document.body.style.overflow='';document.body.classList.remove('overflow-hidden-mobile');document.body.classList.remove('pd-menu-open');}
  root.querySelectorAll('[data-open-drawer]').forEach(function(b){b.addEventListener('click',openDrawer);});
  root.querySelectorAll('[data-close-drawer]').forEach(function(b){b.addEventListener('click',closeDrawer);});
  document.addEventListener('keydown',function(e){if(e.key==='Escape'&&drawer.classList.contains('open'))closeDrawer();});
  root.querySelectorAll('[data-drill]').forEach(function(btn){btn.addEventListener('click',function(){var key=btn.getAttribute('data-drill');var panel=root.querySelector('[data-drillpanel="'+key+'"]');var open=btn.classList.contains('on');root.querySelectorAll('[data-drill]').forEach(function(b){b.classList.remove('on');});root.querySelectorAll('[data-drillpanel]').forEach(function(p){p.classList.remove('open');});if(!open){btn.classList.add('on');if(panel)panel.classList.add('open');}});});
  function setH(){document.documentElement.style.setProperty('--header-height',root.offsetHeight+'px');}
  setH();window.addEventListener('resize',setH);
})();
</script>

