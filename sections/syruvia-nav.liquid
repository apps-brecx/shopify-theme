{%- comment -%} Syruvia Nav — with fallback content so images show by default {%- endcomment -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Archivo:wght@500;600;700;800&family=Josefin+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

{%- if settings.cart_type == 'drawer' -%}
  {{ 'component-cart-drawer.css' | asset_url | stylesheet_tag }}
  {{ 'component-cart.css' | asset_url | stylesheet_tag }}
  {{ 'component-totals.css' | asset_url | stylesheet_tag }}
  {{ 'component-price.css' | asset_url | stylesheet_tag }}
  {{ 'component-discounts.css' | asset_url | stylesheet_tag }}
  {{ 'component-cart-items.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'cart-drawer.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- assign acct_url = routes.account_url -%}
{%- unless customer -%}{%- assign acct_url = routes.account_login_url -%}{%- endunless -%}

{%- assign brand_logo_url = 'https://cdn.shopify.com/s/files/1/0861/1106/0252/files/syruvia_logo.png?v=1760350871' -%}
{%- if section.settings.brand_logo != blank -%}{%- assign brand_logo_url = section.settings.brand_logo | image_url: width: 400 -%}
{%- elsif settings.logo != blank -%}{%- assign brand_logo_url = settings.logo | image_url: width: 400 -%}{%- endif -%}

{%- comment -%} Detect if user added blocks for each category {%- endcomment -%}
{%- assign has_shopby = false -%}{%- assign has_featured = false -%}{%- assign has_taste = false -%}{%- assign has_deals = false -%}
{%- for block in section.blocks -%}
  {%- if block.type == 'shop_card' and block.settings.tab == 'shop_by' -%}{%- assign has_shopby = true -%}{%- endif -%}
  {%- if block.type == 'shop_card' and block.settings.tab == 'featured' -%}{%- assign has_featured = true -%}{%- endif -%}
  {%- if block.type == 'shop_card' and block.settings.tab == 'taste' -%}{%- assign has_taste = true -%}{%- endif -%}
  {%- if block.type == 'deal_link' -%}{%- assign has_deals = true -%}{%- endif -%}
{%- endfor -%}

<style>
  #syrnav{
    --bg:{{ section.settings.nav_bg | default: '#FAF3E9' }}; --ink:{{ section.settings.nav_text | default: '#1F1813' }}; --surface:#fff; --tile:#f1e9dc; --accent:{{ section.settings.nav_accent | default: '#c58548' }}; --muted:#9a8e80;
    --butter:#FCE2A0; --peach:#FFD4B8; --mint:#C5E4D4; --sky:#B8DCEB; --blush:#F5C7BE;
    --rule:2px solid var(--ink); --rule-1:1.5px solid var(--ink); --shadow-sm:3px 3px 0 var(--ink);
    --fhead:'Archivo Black',sans-serif; --fui:'Archivo',sans-serif; --fbody:'Josefin Sans',sans-serif;
    position:sticky; top:0; z-index:60; font-family:var(--fui);
    transition:transform .3s cubic-bezier(.4,0,.2,1);
  }
  #syrnav.is-hidden{ transform:translateY(-100%); }
  #syrnav *,#syrnav *::before,#syrnav *::after{box-sizing:border-box;}
  #syrnav a{text-decoration:none;color:inherit;cursor:pointer;}
  #syrnav button{font-family:inherit;cursor:pointer;}
  .syrnav-promo{background:{{ section.settings.promo_bg | default: '#1F1813' }};color:{{ section.settings.promo_color | default: '#FAF3E9' }};text-align:center;font-family:var(--fui);font-weight:700;font-size:11.5px;letter-spacing:.14em;text-transform:uppercase;padding:9px 16px;}
  .syrnav-promo b{color:{{ section.settings.promo_highlight_color | default: '#FCE2A0' }};margin-left:6px;font-weight:800;}
  .syrnav-wrap{position:relative;}
  .syrnav-bar{background:var(--bg);border-bottom:var(--rule);display:grid;grid-template-columns:1fr auto 1fr;align-items:center;height:66px;padding:0 28px;}
  .syrnav-left{justify-self:start;display:flex;align-items:center;gap:12px;}
  .syrnav-hamb{display:none;background:transparent;border:0;color:var(--ink);padding:4px;}
  .syrnav-links{display:flex;gap:20px;align-items:center;}
  .syrnav-links a{font-family:var(--fui);color:var(--ink);font-weight:700;font-size:12.5px;letter-spacing:.08em;text-transform:uppercase;opacity:.62;transition:opacity .15s,color .15s;white-space:nowrap;display:inline-flex;align-items:center;gap:5px;}
  .syrnav-links a:hover,.syrnav-links a.mega-on{opacity:1;color:var(--accent);}
  .syrnav-chev svg{width:12px;height:12px;transition:transform .2s ease;}
  .syrnav-links a.mega-on .syrnav-chev svg{transform:rotate(180deg);}
  .syrnav-brand{justify-self:center;display:inline-flex;align-items:center;height:46px;}
  .syrnav-brand img.syrnav-brand-img{display:block;height:{{ section.settings.logo_height | default: 38 }}px;width:auto;max-height:46px;max-width:200px;object-fit:contain;}
  .syrnav-icons{display:flex;gap:5px;justify-self:end;align-items:center;}
  .syrnav-ic{background:transparent;border:0;padding:8px;border-radius:50%;color:var(--ink);display:grid;place-items:center;position:relative;}
  .syrnav-ic:hover{background:color-mix(in srgb,var(--ink) 9%,transparent);}
  .syrnav-cart-n{position:absolute;top:-2px;right:-3px;background:var(--accent);color:var(--ink);font-family:var(--fhead);font-size:9.5px;min-width:17px;height:17px;border:var(--rule-1);border-radius:999px;display:grid;place-items:center;padding:0 3px;}
  .syrnav-mega{display:none;position:absolute;top:100%;left:0;right:0;z-index:55;background:var(--bg);border-bottom:var(--rule);box-shadow:0 20px 32px -20px rgba(31,24,19,.45);}
  .syrnav-mega.open{display:block;}
  .syrnav-mega-inner{max-width:1180px;margin:0 auto;padding:26px 32px 30px;}
  .syrnav-subtabs{display:flex;gap:28px;border-bottom:1.5px solid var(--ink);margin-bottom:22px;}
  .syrnav-subtab{background:transparent;border:0;padding:2px 0 12px;font-family:var(--fui);font-weight:800;font-size:12px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);position:relative;}
  .syrnav-subtab.active{color:var(--ink);}
  .syrnav-subtab.active::after{content:"";position:absolute;left:0;right:0;bottom:-1.5px;height:3px;background:var(--accent);border-radius:2px;}
  .syrnav-grid{display:none;grid-template-columns:repeat(4,1fr);gap:16px;}
  .syrnav-grid.active{display:grid;}
  .syrnav-cat{display:block;border:var(--rule);border-radius:14px;overflow:hidden;background:var(--surface);box-shadow:var(--shadow-sm);transition:transform .14s ease;}
  .syrnav-cat:hover{transform:translate(-2px,-2px);}
  .syrnav-cat-media{display:block;aspect-ratio:415/299;background:var(--tile);}
  .syrnav-cat-media img{width:100%;height:100%;object-fit:cover;display:block;}
  .syrnav-cat-lbl{display:block;font-family:var(--fui);font-weight:800;font-size:12px;letter-spacing:.05em;text-transform:uppercase;text-align:center;padding:11px 8px 12px;border-top:var(--rule);}
  .syrnav-mega-inner.deals{display:grid;grid-template-columns:1fr 340px;gap:34px;align-items:start;}
  .syrnav-deals{display:grid;grid-template-columns:1fr 1fr;gap:0 28px;}
  .syrnav-deal{display:flex;align-items:center;gap:13px;padding:14px 6px;border-bottom:1.5px solid color-mix(in srgb,#1F1813 16%,transparent);font-family:var(--fui);font-weight:700;font-size:14px;letter-spacing:.04em;text-transform:uppercase;color:var(--ink);}
  .syrnav-deal-dot{width:13px;height:13px;border-radius:5px;border:1.5px solid var(--ink);flex:0 0 auto;}
  .syrnav-promo-card{position:relative;display:block;border:var(--rule);border-radius:16px;overflow:hidden;box-shadow:var(--shadow-sm);aspect-ratio:340/210;}
  .syrnav-promo-card img{width:100%;height:100%;object-fit:cover;display:block;}
  .syrnav-promo-cap{position:absolute;left:0;right:0;bottom:0;padding:16px 18px;background:linear-gradient(transparent,rgba(31,24,19,.85));}
  .syrnav-promo-cap b{display:block;font-family:var(--fhead);font-size:24px;color:#fff;}
  .syrnav-promo-cap span{font-family:var(--fui);font-weight:600;font-size:11px;letter-spacing:.07em;text-transform:uppercase;color:var(--butter);}
  .syrnav-mega-inner.links{display:grid;grid-template-columns:1fr 340px;gap:48px;align-items:start;}
  .syrnav-cols{display:flex;gap:64px;flex-wrap:wrap;}
  .syrnav-col{display:flex;flex-direction:column;min-width:150px;}
  .syrnav-col-h{font-family:var(--fui);font-weight:800;font-size:11.5px;letter-spacing:.13em;text-transform:uppercase;color:var(--ink);margin-bottom:14px;}
  .syrnav-col-link{font-family:var(--fui);font-weight:600;font-size:14.5px;color:var(--ink);opacity:.68;padding:8px 0;}
  .syrnav-col-link:hover{opacity:1;color:var(--accent);}
  .syrnav-promo2-card{display:block;border:var(--rule);border-radius:16px;overflow:hidden;box-shadow:var(--shadow-sm);}
  .syrnav-promo2-card img{width:100%;display:block;}
  .syrnav-social{display:flex;align-items:center;gap:12px;margin-top:15px;}
  .syrnav-social a{color:var(--ink);display:grid;place-items:center;}
  .syrnav-social-h{font-family:var(--fui);font-weight:700;font-size:12px;letter-spacing:.08em;color:var(--ink);}
  .syrnav-msearch,.syrnav-scrim,.syrnav-drawer{display:none;}
  @media (max-width:980px){
    .syrnav-links{display:none;}
    .syrnav-hamb{display:grid;}
    .syrnav-bar{grid-template-columns:auto 1fr auto;padding:0 16px;height:62px;}
    .syrnav-icons .syrnav-acct,.syrnav-icons .syrnav-wish{display:none;}
    .syrnav-brand img.syrnav-brand-img{height:32px;max-width:160px;}
    .syrnav-msearch{display:none;background:var(--bg);padding:10px 16px 12px;border-bottom:var(--rule);}
    .syrnav-msearch-box{display:flex;align-items:center;gap:10px;height:44px;padding:0 15px;border:var(--rule);border-radius:26px;background:var(--surface);box-shadow:var(--shadow-sm);}
    .syrnav-msearch-box input{flex:1;border:0;outline:0;background:transparent;font-family:var(--fbody);font-size:15px;color:var(--ink);}
    .syrnav-scrim{display:block;position:fixed;inset:0;z-index:190;background:rgba(31,24,19,.42);opacity:0;pointer-events:none;transition:opacity .28s ease;}
    .syrnav-scrim.open{opacity:1;pointer-events:auto;}
    .syrnav-drawer{display:flex;flex-direction:column;position:fixed;top:0;bottom:0;left:0;z-index:200;width:84%;max-width:320px;background:var(--bg);border-right:var(--rule);box-shadow:8px 0 32px -10px rgba(31,24,19,.42);transform:translateX(-104%);transition:transform .34s cubic-bezier(.34,1.3,.5,1);overflow-y:auto;}
    .syrnav-drawer.open{transform:translateX(0);}
    .syrnav-dwr-head{display:flex;align-items:center;justify-content:space-between;height:62px;padding:0 10px 0 20px;border-bottom:var(--rule);}
    .syrnav-dwr-head .syrnav-brand{height:40px;}
    .syrnav-dwr-head .syrnav-brand img.syrnav-brand-img{height:28px;max-width:140px;}
    .syrnav-dwr-x{display:grid;place-items:center;width:42px;height:42px;border:0;background:transparent;color:var(--ink);}
    .syrnav-dwr-links{display:flex;flex-direction:column;padding:8px 14px 4px;}
    .syrnav-dwr-sec{border-bottom:var(--rule-1);}
    .syrnav-dwr-link{display:flex;align-items:center;gap:14px;padding:14px 8px;background:transparent;border:0;width:100%;font-family:var(--fhead);font-size:19px;color:var(--ink);text-align:left;}
    .syrnav-dwr-dot{width:15px;height:15px;border-radius:5px;border:1.5px solid var(--ink);flex:0 0 auto;}
    .syrnav-dwr-link .lbl{flex:1;}
    .syrnav-dwr-link.on{color:var(--accent);}
    .syrnav-dwr-link.on .syrnav-dwr-chev{transform:rotate(180deg);}
    .syrnav-dwr-drill{display:none;padding:0 8px 14px;}
    .syrnav-dwr-drill.open{display:block;}
    .syrnav-dwr-cats{display:grid;grid-template-columns:1fr 1fr;gap:9px;}
    .syrnav-dwr-cat{border:var(--rule);border-radius:12px;overflow:hidden;box-shadow:var(--shadow-sm);background:var(--surface);display:block;}
    .syrnav-dwr-cat-media{display:block;aspect-ratio:415/299;background:var(--tile);}
    .syrnav-dwr-cat-media img{display:block;width:100%;height:100%;object-fit:cover;}
    .syrnav-dwr-cat-lbl{display:block;font-family:var(--fui);font-weight:800;font-size:9.5px;letter-spacing:.04em;text-transform:uppercase;text-align:center;padding:7px 5px 8px;border-top:1.5px solid var(--ink);}
    .syrnav-dwr-deal{display:flex;align-items:center;gap:11px;padding:11px 4px;border-bottom:var(--rule-1);font-family:var(--fui);font-weight:700;font-size:13px;color:var(--ink);}
    .syrnav-dwr-deal-dot{width:11px;height:11px;border-radius:4px;border:1.5px solid var(--ink);flex:0 0 auto;}
    .syrnav-dwr-sub{margin-top:auto;padding:14px 22px 6px;display:flex;flex-direction:column;gap:15px;border-top:var(--rule-1);}
    .syrnav-dwr-subrow{display:flex;align-items:center;gap:12px;background:transparent;border:0;padding:0;font-family:var(--fui);font-weight:700;font-size:13.5px;color:var(--ink);}
    .syrnav-dwr-promo{margin:14px 16px 18px;padding:13px 15px;background:{{ section.settings.drawer_promo_bg | default: '#FCE2A0' }};border:var(--rule);border-radius:14px;box-shadow:var(--shadow-sm);}
    .syrnav-dwr-promo b{display:block;font-family:var(--fhead);font-size:14px;}
    .syrnav-dwr-promo span{display:block;font-family:var(--fbody);font-size:13px;color:#6b5d2e;}
  }
</style>

{%- liquid
  assign sIcon = '<svg viewBox="0 0 19 19" width="19" height="19" fill="none"><circle cx="8" cy="8" r="6.2" stroke="currentColor" stroke-width="1.8"/><path d="M12.8 12.8L17 17" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>'
  assign uIcon = '<svg viewBox="0 0 19 19" width="19" height="19" fill="none"><circle cx="9.5" cy="6" r="3.3" stroke="currentColor" stroke-width="1.7"/><path d="M3.5 16.5c0-3.3 2.7-5.5 6-5.5s6 2.2 6 5.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>'
  assign hIcon = '<svg viewBox="0 0 20 18" width="19" height="19" fill="none"><path d="M10 16S2 11.4 2 6.2C2 3.9 3.9 2 6.2 2 7.8 2 9.2 3 10 4.3 10.8 3 12.2 2 13.8 2 16.1 2 18 3.9 18 6.2 18 11.4 10 16 10 16z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/></svg>'
  assign bIcon = '<svg viewBox="0 0 19 20" width="19" height="19" fill="none"><path d="M4 6h11l-.8 11.5a1.5 1.5 0 01-1.5 1.4H6.3a1.5 1.5 0 01-1.5-1.4L4 6z" stroke="currentColor" stroke-width="1.7"/><path d="M6.8 6V4.8a2.7 2.7 0 015.4 0V6" stroke="currentColor" stroke-width="1.7"/></svg>'
  assign chev = '<svg viewBox="0 0 12 12" width="12" height="12"><path d="M2.5 4.5L6 8l3.5-3.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" fill="none"/></svg>'
  assign burger = '<svg viewBox="0 0 20 20" width="20" height="20"><path d="M3 6h14M3 10h14M3 14h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>'
  assign xIcon = '<svg viewBox="0 0 16 16" width="16" height="16"><path d="M3 3l10 10M13 3L3 13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>'
  assign igIcon = '<svg viewBox="0 0 22 22" width="17" height="17" fill="none"><rect x="2.5" y="2.5" width="17" height="17" rx="5" stroke="currentColor" stroke-width="1.8"/><circle cx="11" cy="11" r="4.2" stroke="currentColor" stroke-width="1.8"/><circle cx="16.2" cy="5.8" r="1.1" fill="currentColor"/></svg>'
  assign ttIcon = '<svg viewBox="0 0 22 22" width="17" height="17" fill="none"><path d="M13 3v10.5a3 3 0 11-2.4-2.94" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><path d="M13 3c.4 2.2 1.8 3.7 4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>'
  assign ytIcon = '<svg viewBox="0 0 22 22" width="17" height="17" fill="none"><rect x="2" y="5" width="18" height="12" rx="3.4" stroke="currentColor" stroke-width="1.8"/><path d="M9.4 8.4l4.4 2.6-4.4 2.6V8.4z" fill="currentColor"/></svg>'
-%}

{%- assign m1_lbl = section.settings.menu1_label | default: 'Shop' -%}{%- assign m1_url = section.settings.menu1_url | default: '/collections/all' -%}
{%- assign m2_lbl = section.settings.menu2_label | default: 'Bundle & Save' -%}{%- assign m2_url = section.settings.menu2_url | default: '/pages/build-your-bundle' -%}
{%- assign m3_lbl = section.settings.menu3_label | default: 'Sugar-Free' -%}{%- assign m3_url = section.settings.menu3_url | default: '/collections/sugar-free' -%}
{%- assign m4_lbl = section.settings.menu4_label | default: 'Deals' -%}{%- assign m4_url = section.settings.menu4_url | default: '/collections/on-sale' -%}
{%- assign m5_lbl = section.settings.menu5_label | default: 'About Us' -%}{%- assign m5_url = section.settings.menu5_url | default: '/pages/about-us' -%}
{%- assign m6_lbl = section.settings.menu6_label | default: 'More' -%}{%- assign m6_url = section.settings.menu6_url | default: '/blogs/blog-posts' -%}
{%- assign ig_url = section.settings.instagram_url | default: 'https://www.instagram.com/syruvia_official' -%}
{%- assign tt_url = section.settings.tiktok_url | default: 'https://www.tiktok.com/@syruviaofficial' -%}
{%- assign yt_url = section.settings.youtube_url | default: 'https://www.youtube.com/@Syruvia' -%}
{%- assign social_handle = section.settings.social_handle | default: '@SYRUVIAOFFICAL' -%}

<div id="syrnav" data-syrnav>
  {%- if section.settings.show_inline_promo -%}<div class="syrnav-promo">{{ section.settings.promo_text | default: '40% OFF ENTIRE SITE · USE CODE' }} <b>{{ section.settings.promo_highlight | default: 'MONDAY40' }}</b></div>{%- endif -%}
  <div class="syrnav-wrap" data-megawrap>
    <div class="syrnav-bar">
      <div class="syrnav-left">
        <button class="syrnav-hamb" aria-label="Open menu" data-open-drawer>{{ burger }}</button>
        <nav class="syrnav-links">
          <a href="{{ m1_url }}" class="has-mega" data-mega="shop">{{ m1_lbl }}<span class="syrnav-chev">{{ chev }}</span></a>
          <a href="{{ m2_url }}">{{ m2_lbl }}</a>
          <a href="{{ m3_url }}">{{ m3_lbl }}</a>
          <a href="{{ m4_url }}" class="has-mega" data-mega="deals">{{ m4_lbl }}<span class="syrnav-chev">{{ chev }}</span></a>
          <a href="{{ m5_url }}" class="has-mega" data-mega="about">{{ m5_lbl }}<span class="syrnav-chev">{{ chev }}</span></a>
          <a href="{{ m6_url }}" class="has-mega" data-mega="more">{{ m6_lbl }}<span class="syrnav-chev">{{ chev }}</span></a>
        </nav>
      </div>
      <a class="syrnav-brand" href="{{ routes.root_url }}" aria-label="{{ shop.name | escape }}"><img class="syrnav-brand-img" src="{{ brand_logo_url }}" alt="{{ shop.name | escape }}" width="200" height="60" loading="eager"></a>
      <div class="syrnav-icons" data-closemega>
        <a class="syrnav-ic" href="{{ routes.search_url }}" aria-label="Search">{{ sIcon }}</a>
        <a class="syrnav-ic syrnav-acct" href="{{ acct_url }}" aria-label="Account">{{ uIcon }}</a>
        <a class="syrnav-ic syrnav-wish" href="/pages/swym-wishlist" aria-label="Wishlist">{{ hIcon }}</a>
        <a class="syrnav-ic syrnav-cart" id="cart-icon-bubble" href="{{ routes.cart_url }}" aria-label="Cart">{{ bIcon }}<span class="syrnav-cart-n"{% if cart.item_count == 0 %} style="display:none"{% endif %}>{{ cart.item_count }}</span></a>
      </div>
    </div>

    <div class="syrnav-mega" data-panel="shop">
      <div class="syrnav-mega-inner">
        <div class="syrnav-subtabs">
          <button class="syrnav-subtab active" data-subtab="Shop By">{{ section.settings.shop_tab1 | default: 'Shop By' }}</button>
          <button class="syrnav-subtab" data-subtab="Featured">{{ section.settings.shop_tab2 | default: 'Featured' }}</button>
          <button class="syrnav-subtab" data-subtab="Browse by Taste">{{ section.settings.shop_tab3 | default: 'Browse by Taste' }}</button>
        </div>
        <div class="syrnav-grid active" data-grid="Shop By">
          {%- if has_shopby -%}
            {%- for block in section.blocks -%}{%- if block.type == 'shop_card' and block.settings.tab == 'shop_by' -%}
              <a class="syrnav-cat" href="{{ block.settings.url | default: '#' }}" {{ block.shopify_attributes }}><span class="syrnav-cat-media">{%- if block.settings.image != blank -%}<img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.label | escape }}" loading="lazy">{%- endif -%}</span><span class="syrnav-cat-lbl">{{ block.settings.label }}</span></a>
            {%- endif -%}{%- endfor -%}
          {%- else -%}
