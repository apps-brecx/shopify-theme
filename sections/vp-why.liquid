{{ 'pdp-brand.css' | asset_url | stylesheet_tag }}

{%- if section.settings.section_bg != blank -%}
{% style %}
  #shopify-section-{{ section.id }} .pd-why { background: {{ section.settings.section_bg }} !important; }
{% endstyle %}
{%- endif -%}

<div class="pd">
  <section class="pd-why">
    <div class="pd-wrap pd-why-wrap" style="text-align:center;">
      <span class="pd-eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="pd-h2 pd-why-h2">{{ section.settings.heading_pre }}<em>{{ section.settings.heading_em }}</em>{{ section.settings.heading_post }}</h2>
      <div class="pd-why-grid pd-why-grid--spaced">
        <div class="pd-why-card pd-why-card--peach">
          <div class="pd-why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="6" width="18" height="14" rx="2"/><path d="M3 10 H21"/><path d="M9 6 V3 a1 1 0 0 1 1 -1 H14 a1 1 0 0 1 1 1 V6"/></svg></div>
          <h3 class="pd-why-title">{{ section.settings.c1_title }}</h3>
          <p class="pd-why-body">{{ section.settings.c1_body }}</p>
        </div>
        <div class="pd-why-card pd-why-card--butter">
          <div class="pd-why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 L14.5 8 L21 9 L16.5 13.5 L17.5 20 L12 16.5 L6.5 20 L7.5 13.5 L3 9 L9.5 8 Z"/></svg></div>
          <h3 class="pd-why-title">{{ section.settings.c2_title }}</h3>
          <p class="pd-why-body">{{ section.settings.c2_body }}</p>
        </div>
        <div class="pd-why-card pd-why-card--mint">
          <div class="pd-why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 12 V21 H4 V12 M2 7 H22 V12 H2 Z M12 22 V7 M12 7 C 10 4, 6 4, 6 7 C 6 8, 8 8, 12 7 M12 7 C 14 4, 18 4, 18 7 C 18 8, 16 8, 12 7"/></svg></div>
          <h3 class="pd-why-title">{{ section.settings.c3_title }}</h3>
          <p class="pd-why-body">{{ section.settings.c3_body }}</p>
        </div>
        <div class="pd-why-card pd-why-card--sky">
          <div class="pd-why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12 l4 4 L19 7"/></svg></div>
          <h3 class="pd-why-title">{{ section.settings.c4_title }}</h3>
          <p class="pd-why-body">{{ section.settings.c4_body }}</p>
        </div>
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "VP Why",
  "tag": "section",
  "class": "section-vp-why",
  "enabled_on": { "templates": ["product"] },
  "settings": [
    { "type": "header", "content": "Heading" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Why this pack" },
    { "type": "text", "id": "heading_pre", "label": "Heading before emphasis", "default": "A tour of " },
    { "type": "text", "id": "heading_em", "label": "Heading emphasis (italic)", "default": "flavor" },
    { "type": "text", "id": "heading_post", "label": "Heading after emphasis", "default": "." },
    { "type": "header", "content": "Card 1" },
    { "type": "text", "id": "c1_title", "label": "Title", "default": "Bestseller Lineup" },
    { "type": "textarea", "id": "c1_body", "label": "Body", "default": "Hand-picked flavors that work together. No filler. Every bottle pulls its weight." },
    { "type": "header", "content": "Card 2" },
    { "type": "text", "id": "c2_title", "label": "Title", "default": "Save vs Singles" },
    { "type": "textarea", "id": "c2_body", "label": "Body", "default": "Bundle price built in. Always less than the same bottles one-by-one." },
    { "type": "header", "content": "Card 3" },
    { "type": "text", "id": "c3_title", "label": "Title", "default": "Gift-Ready" },
    { "type": "textarea", "id": "c3_body", "label": "Body", "default": "Presentable as-is. A great drop for a coffee lover, or split it between friends." },
    { "type": "header", "content": "Card 4" },
    { "type": "text", "id": "c4_title", "label": "Title", "default": "Café Quality" },
    { "type": "textarea", "id": "c4_body", "label": "Body", "default": "Same real-flavor Syruvia recipes inside. Pure cane sugar, no funky aftertaste." },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "section_bg", "label": "Section background", "info": "Leave blank to keep the theme default." }
  ],
  "presets": [{ "name": "VP Why" }]
}
{% endschema %}
