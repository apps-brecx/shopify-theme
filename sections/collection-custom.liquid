{%- capture icList -%}<svg viewBox="0 0 18 18" width="16" height="16" fill="none"><rect x="2" y="3" width="14" height="4" rx="1.4" stroke="currentColor" stroke-width="1.7"/><rect x="2" y="11" width="14" height="4" rx="1.4" stroke="currentColor" stroke-width="1.7"/></svg>{%- endcapture -%}
{%- capture icChev -%}<svg viewBox="0 0 12 12" width="12" height="12"><path d="M2.5 4.5L6 8l3.5-3.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>{%- endcapture -%}
{%- capture icClose -%}<svg viewBox="0 0 16 16" width="16" height="16"><path d="M3 3l10 10M13 3L3 13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>{%- endcapture -%}
