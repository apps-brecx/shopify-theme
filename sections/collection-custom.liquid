{%- assign starpath = 'M10 1.5l2.6 5.3 5.9.9-4.2 4.1 1 5.8L10 15l-5.3 2.6 1-5.8L1.5 7.7l5.9-.9L10 1.5z' -%}
{%- capture starFull -%}<svg class="str" viewBox="0 0 20 20" width="14" height="14"><path d="{{ starpath }}" fill="#c58548"/></svg>{%- endcapture -%}
{%- capture starHalf -%}<svg class="str" viewBox="0 0 20 20" width="14" height="14"><path d="{{ starpath }}" fill="url(#scolhalf)"/></svg>{%- endcapture -%}
{%- capture starEmpty -%}<svg class="str" viewBox="0 0 20 20" width="14" height="14"><path d="{{ starpath }}" fill="#e6dccb"/></svg>{%- endcapture -%}
{%- assign famset = '' -%}
{%- assign hassf = false -%}
{%- for product in collection.products -%}
  {%- assign tg2 = product.tags | join: ' ' | downcase -%}
  {%- assign f2 = '' -%}
  {%- if tg2 contains 'coffee' -%}
    {%- assign f2 = 'Coffee' -%}
  {%- elsif tg2 contains 'fruit' -%}
    {%- assign f2 = 'Fruit' -%}
  {%- elsif tg2 contains 'tropical' -%}
    {%- assign f2 = 'Tropical' -%}
  {%- elsif tg2 contains 'cocktail' -%}
    {%- assign f2 = 'Cocktail' -%}
  {%- elsif tg2 contains 'nut' -%}
    {%- assign f2 = 'Nutty' -%}
  {%- elsif tg2 contains 'floral' or tg2 contains 'lavender' -%}
    {%- assign f2 = 'Floral' -%}
  {%- elsif tg2 contains 'dessert' -%}
    {%- assign f2 = 'Dessert' -%}
  {%- endif -%}
  {%- if f2 != blank -%}
    {%- unless famset contains f2 -%}{%- assign famset = famset | append: ' ' | append: f2 -%}{%- endunless -%}
  {%- endif -%}
  {%- if product.tags contains 'Sugar-Free'
    or product.title contains 'Sugar-Free'
    or product.title contains 'Sugar Free'
  -%}
    {%- assign hassf = true -%}
  {%- endif -%}
{%- endfor -%}

<div
  class="scol view-grid dens-comfortable show-ratings"
  data-scol
  data-kicker="{{ section.settings.kicker | escape }}"
  data-qvnote="{{ section.settings.qv_note | escape }}"
  data-promo1="{{ section.settings.promo1 | escape }}"
  data-promo1l="{{ section.settings.promo1_link | escape }}"
  data-promo2="{{ section.settings.promo2 | escape }}"
  data-promo2l="{{ section.settings.promo2_link | escape }}"
  data-promo3="{{ section.settings.promo3 | escape }}"
  data-promo3l="{{ section.settings.promo3_link | escape }}"
  data-promo4="{{ section.settings.promo4 | escape }}"
  data-promo4l="{{ section.settings.promo4_link | escape }}"
  data-promo5="{{ section.settings.promo5 | escape }}"
  data-promo5l="{{ section.settings.promo5_link | escape }}"
>
  <svg width="0" height="0" style="position:absolute" aria-hidden="true" focusable="false">
    <defs><linearGradient id="scolhalf" x1="0" y1="0" x2="1" y2="0"><stop offset="50%" stop-color="#c58548"/><stop offset="50%" stop-color="#e6dccb"/></linearGradient></defs>
  </svg>
  {%- if section.settings.decor == 'boba' -%}
    <div class="scol-decor" aria-hidden="true">
      {%- assign cols = '#c8455f,#1f8a6e,#3f6fd0,#c58548,#7657c9,#bf4a7d' | split: ',' -%}
      {%- for i in (1..22) -%}
        {%- assign lx = i | times: 47 | modulo: 94 | plus: 2 -%}
        {%- assign ty = i | times: 53 | modulo: 96 | plus: 1 -%}
        {%- assign sz = i | times: 7 | modulo: 18 | plus: 12 -%}
        {%- assign ci = i | modulo: 6 -%}
        {%- assign dl = i | modulo: 7 -%}
        <span
          class="bp"
          style="left:{{ lx }}%;top:{{ ty }}%;--s:{{ sz }}px;--c:{{ cols[ci] }};animation-delay:{{ dl }}00ms"
        ></span>
      {%- endfor -%}
    </div>
  {%- elsif section.settings.decor == 'notes' -%}
    <div class="scol-decor" aria-hidden="true">
      {%- assign nwords = section.settings.decor_notes | split: ',' -%}
      {%- if nwords.size > 0 -%}
        {%- for i in (1..16) -%}
          {%- assign lx = i | times: 41 | modulo: 86 | plus: 2 -%}
          {%- assign ty = i | times: 59 | modulo: 95 | plus: 1 -%}
          {%- assign wi = i | modulo: nwords.size -%}
          {%- assign dl = i | modulo: 6 -%}
          <span class="nw" style="left:{{ lx }}%;top:{{ ty }}%;animation-delay:{{ dl }}00ms">
            {{- nwords[wi] | strip -}}
          </span>
        {%- endfor -%}
      {%- endif -%}
    </div>
  {%- elsif section.settings.decor == 'spill' -%}
    <div class="scol-decor" aria-hidden="true">
      {%- assign sc = section.settings.decor_color | default: '#c58548' -%}
      {%- assign sicons = section.settings.decor_icons | split: ',' -%}
      {%- for i in (1..8) -%}
        {%- assign lx = i | times: 53 | modulo: 92 | plus: 3 -%}
        {%- assign h = i | times: 9 | modulo: 90 | plus: 50 -%}
        {%- assign w = i | modulo: 3 | plus: 8 -%}
        {%- assign dl = i | modulo: 6 -%}
        <span
          class="spill-drip"
          style="left:{{ lx }}%;--w:{{ w }}px;--h:{{ h }}px;--c:{{ sc }};--dl:{{ dl }}00ms"
        ></span>
      {%- endfor -%}
      {%- for i in (1..14) -%}
        {%- assign lx = i | times: 37 | modulo: 94 | plus: 2 -%}
        {%- assign ty = i | times: 61 | modulo: 92 | plus: 4 -%}
        {%- assign sz = i | modulo: 12 | plus: 10 -%}
        {%- assign rot = i | times: 33 | modulo: 90 -%}
        <span
          class="spill-drop"
          style="left:{{ lx }}%;top:{{ ty }}%;width:{{ sz }}px;height:{{ sz }}px;--c:{{ sc }};transform:rotate({{ rot }}deg)"
        ></span>
      {%- endfor -%}
      {%- if sicons.size > 0 -%}
        {%- for i in (1..8) -%}
          {%- assign lx = i | times: 43 | modulo: 90 | plus: 3 -%}
          {%- assign ty = i | times: 71 | modulo: 90 | plus: 4 -%}
          {%- assign ii = i | modulo: sicons.size -%}
          {%- assign dl = i | modulo: 6 -%}
          <span class="spill-ic" style="left:{{ lx }}%;top:{{ ty }}%;animation-delay:{{ dl }}00ms">
            {{- sicons[ii] | strip -}}
          </span>
        {%- endfor -%}
      {%- endif -%}
    </div>
  {%- endif -%}
  {%- style -%}
    section.hero.hero-float,
    .hero.hero-float {
      background: rgb(255, 251, 244) !important;
      background-image: none !important;
    }
  {%- endstyle -%}
  <section class="hero hero-float">
    <div class="hero-inner">
      <div class="hero-copy">
        <nav class="crumbs">
          <a>Home</a> <span>/</span> <a>Collections</a> <span>/</span> <b>{{ heading }}</b>
        </nav>
        {%- if section.settings.eyebrow != blank -%}
          <span class="hero-eyebrow">
            {{- icLeaf }}
            {{ section.settings.eyebrow -}}
          </span>
        {%- endif -%}
        <h1 class="hero-title">{{ heading }}</h1>
        {%- if section.settings.tagline != blank -%}
          <p class="hero-tag">{{ section.settings.tagline }}</p>
        {%- endif -%}
        {%- if blurbtext != blank -%}
          <p class="hero-blurb">{{ blurbtext | truncate: 600 }}</p>
        {%- endif -%}
        <div class="hero-meta">
          <span
            ><b>{{ collection.products_count }}</b> flavors</span
          >
          {%- if section.settings.stat_badge != blank -%}
            <span>{{ section.settings.stat_badge }}</span>
          {%- endif -%}
          <span><b>4.8★</b> avg rating</span>
        </div>
      </div>
    </div>
  </section>
  {% comment %}
    <div class="hero-stage" aria-hidden="true">
      {%- assign fc = 0 -%}
      {%- for product in collection.products -%}{%- if product.tags contains 'Best Seller' and fc < 5 -%}<div class="floater f{{ fc }}"><img src="{{ product.featured_image | image_url: width: 220 }}" alt=""></div>{%- assign fc = fc | plus: 1 -%}{%- endif -%}{%- endfor -%}
      {%- if fc == 0 -%}{%- assign fc2 = 0 -%}{%- for product in collection.products limit: 5 -%}<div class="floater f{{ fc2 }}"><img src="{{ product.featured_image | image_url: width: 220 }}" alt=""></div>{%- assign fc2 = fc2 | plus: 1 -%}{%- endfor -%}{%- endif -%}
      {%- if section.settings.decor == 'boba' -%}<span class="boba k1"></span><span class="boba k2"></span><span class="boba k3"></span><span class="boba k4"></span><span class="boba k5"></span><span class="boba k6"></span>{%- endif -%}
      <div class="hero-blob b1"></div><div class="hero-blob b2"></div>
    </div>
  {% endcomment %}

  <div class="toolbar">
    <div class="tb-row">
      <div class="filters">
        <button class="fchip on" data-fam="All">All</button>
        {%- if hassf -%}
          <button class="fchip" data-fam="Sugar-Free">Sugar-Free</button>
        {%- endif -%}
        {%- if famset contains 'Coffee' -%}
          <button class="fchip" data-fam="Coffee">Coffee</button>
        {%- endif -%}
        {%- if famset contains 'Dessert' -%}
          <button class="fchip" data-fam="Dessert">Dessert</button>
        {%- endif -%}
        {%- if famset contains 'Fruit' -%}
          <button class="fchip" data-fam="Fruit">Fruit</button>
        {%- endif -%}
        {%- if famset contains 'Nutty' -%}
          <button class="fchip" data-fam="Nutty">Nutty</button>
        {%- endif -%}
        {%- if famset contains 'Tropical' -%}
          <button class="fchip" data-fam="Tropical">Tropical</button>
        {%- endif -%}
        {%- if famset contains 'Floral' -%}
          <button class="fchip" data-fam="Floral">Floral</button>
        {%- endif -%}
        {%- if famset contains 'Cocktail' -%}
          <button class="fchip" data-fam="Cocktail">Cocktail</button>
        {%- endif -%}
      </div>
      <div class="tb-right">
        <div class="scol-search">
          {{ icSearch -}}
          <input type="search" data-search placeholder="Search flavors…" aria-label="Search flavors">
        </div>
        <span class="result-count" data-count></span>
        <div class="viewtoggle" role="group" aria-label="View">
          <button class="vt-btn on" data-view="grid" aria-label="Grid view">{{ icGrid }}</button
          ><button class="vt-btn" data-view="list" aria-label="List view">{{ icList }}</button>
        </div>
        <div class="sortmenu" data-sortmenu>
          <button class="sort-btn" data-sortbtn>
            <span class="sort-lab">Sort:</span> <span data-sortlabel>Featured</span>
            <span class="sort-chev">{{ icChev }}</span>
          </button>
          <div class="sort-pop" data-sortpop>
            <button class="sort-opt on" data-sort="featured">Featured</button
            ><button class="sort-opt" data-sort="best">Best selling</button
            ><button class="sort-opt" data-sort="rating">Top rated</button
            ><button class="sort-opt" data-sort="new">Newest</button
            ><button class="sort-opt" data-sort="plow">Price: low to high</button
            ><button class="sort-opt" data-sort="phigh">Price: high to low</button
            ><button class="sort-opt" data-sort="az">Alphabetical</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <main class="grid-wrap" data-section-id="{{ section.id }}">
    {%- if collection.products_count == 0 -%}
      <p class="empty">No products in this collection.</p>
    {%- else -%}
      {%- paginate collection.products by 100 -%}
        <div class="pgrid" data-grid>
          {%- for product in collection.products -%}
            {%- assign avail = product.available -%}
            {%- assign t = product.title -%}
            {%- assign nm = t
              | replace: 'Sugar-Free ', ''
              | replace: 'Sugar Free ', ''
              | replace: ' Syrup', ''
              | replace: ' Coffee', ''
            -%}
            {%- assign v = product.selected_or_first_available_variant -%}
            {%- assign tg = product.tags | join: ' ' | downcase -%}
            {%- assign fam = '' -%}
            {%- if tg contains 'coffee' -%}
              {%- assign fam = 'Coffee' -%}
            {%- elsif tg contains 'fruit' -%}
              {%- assign fam = 'Fruit' -%}
            {%- elsif tg contains 'tropical' -%}
              {%- assign fam = 'Tropical' -%}
            {%- elsif tg contains 'cocktail' -%}
              {%- assign fam = 'Cocktail' -%}
            {%- elsif tg contains 'nut' -%}
              {%- assign fam = 'Nutty' -%}
            {%- elsif tg contains 'floral' or tg contains 'lavender' -%}
              {%- assign fam = 'Floral' -%}
            {%- elsif tg contains 'dessert' -%}
              {%- assign fam = 'Dessert' -%}
            {%- endif -%}
            {%- assign tintBg = '#f7e2ec' -%}
            {%- assign tintInk = '#bf4a7d' -%}
            {%- case fam -%}
              {%- when 'Coffee' -%}
                {%- assign tintBg = '#efe4d6' -%}
                {%- assign tintInk = '#7a5436' -%}
              {%- when 'Fruit' -%}
                {%- assign tintBg = '#fbe0e5' -%}
                {%- assign tintInk = '#c8455f' -%}
              {%- when 'Tropical' -%}
                {%- assign tintBg = '#e1f3ec' -%}
                {%- assign tintInk = '#1f8a6e' -%}
              {%- when 'Cocktail' -%}
                {%- assign tintBg = '#e4ecfb' -%}
                {%- assign tintInk = '#3f6fd0' -%}
              {%- when 'Nutty' -%}
                {%- assign tintBg = '#efe7d8' -%}
                {%- assign tintInk = '#917547' -%}
              {%- when 'Floral' -%}
                {%- assign tintBg = '#ece6f7' -%}
                {%- assign tintInk = '#7657c9' -%}
            {%- endcase -%}
            {%- assign issf = false -%}
            {%- if product.tags contains 'Sugar-Free' or t contains 'Sugar-Free' or t contains 'Sugar Free' -%}
              {%- assign issf = true -%}
            {%- endif -%}
            {%- assign vipprice = 799 -%}
            {%- if issf -%}{%- assign vipprice = 699 -%}{%- endif -%}
            {%- assign has_vip = false -%}
            {%- if vipprice < v.price -%}{%- assign has_vip = true -%}{%- endif -%}
            {%- assign pdesc = product.description | strip_html | truncate: 180 -%}
            {%- assign best = false -%}
            {%- if product.tags contains 'Best Seller' -%}{%- assign best = true -%}{%- endif -%}
            {%- assign isnew = false -%}
            {%- if product.tags contains 'New' or product.tags contains 'New Arrival' -%}
              {%- assign isnew = true -%}
            {%- endif -%}
            {%- assign rmod = product.id | modulo: 5 -%}
            {%- assign rt = 45 | plus: rmod -%}
            {%- assign rdisp = rt | divided_by: 10.0 -%}
            {%- assign rpct = rt | times: 2 -%}
            {%- assign rfull = rt | divided_by: 10 -%}
            {%- assign rbase = rfull | times: 10 -%}
            {%- assign rrem = rt | minus: rbase -%}
            {%- assign rhalf = false -%}
            {%- if rrem >= 8 -%}
              {%- assign rfull = rfull | plus: 1 -%}
            {%- elsif rrem >= 3 -%}
              {%- assign rhalf = true -%}
            {%- endif -%}
            {%- assign rnext = rfull | plus: 1 -%}
            {%- capture starrow -%}{%- for s in (1..5) -%}{%- if s <= rfull -%}{{ starFull }}{%- elsif rhalf and s == rnext -%}{{ starHalf }}{%- else -%}{{ starEmpty }}{%- endif -%}{%- endfor -%}{%- endcapture -%}
            {%- if best -%}
              {%- assign rv = product.id | modulo: 460 | plus: 180 -%}
            {%- else -%}
              {%- assign rv = product.id | modulo: 236 | plus: 24 -%}
            {%- endif -%}
            {%- assign dd = forloop.index0 | modulo: 12 | times: 45 -%}
            <article
              class="pcard{% unless avail %} pcard--soldout{% endunless %}"
              data-card
              data-avail="{% if avail %}1{% else %}0{% endif %}"
              data-url="{{ product.url }}"
              data-family="{{ fam }}"
              data-name="{{ nm | escape }}"
              data-price="{{ v.price }}"
              data-id="{{ v.id }}"
              data-img="{{ product.featured_image | image_url: width: 420 }}"
              data-rt="{{ rt }}"
              data-rdisp="{{ rdisp }}"
              data-reviews="{{ rv }}"
              data-order="{{ forloop.index0 }}"
              data-best="{% if best %}1{% else %}0{% endif %}"
              data-new="{% if isnew %}1{% else %}0{% endif %}"
              data-sf="{% if issf %}1{% else %}0{% endif %}"
              data-desc="{{ pdesc | escape }}"
              style="--tint:{{ tintBg }};--tint-ink:{{ tintInk }};--d:{{ dd }}ms"
            >
              <div class="pcard-media" data-quick>
                <div class="pcard-badges">
                  {%- unless avail -%}
                    <span class="badge soldout">Sold out</span>
                  {%- endunless -%}
                  {% if best -%}
                    <span class="badge best">Best seller</span>
                  {%- endif -%}
                  {%- if isnew -%}
                    <span class="badge new">New</span>
                  {%- endif %}
                </div>
                {% comment %} <button aria-label="Add to Wishlist" data-with-epi="true" class="swym-button swym-add-to-wishlist-view-product product_{{product.id}}" data-swaction="addToWishlist" data-product-id="{{product.id | json}}" data-variant-id="{{product.variants[0].id}}" data-product-url="https://syruvia.com/{{ product.url }}"> {% endcomment %}
                <button class="wish" data-wish aria-label="Save">
                  <span class="wish-o">{{ icHeart }}</span><span class="wish-f">{{ icHeartF }}</span>
                </button>
                <div class="pcard-imgwrap">
                  <img
                    class="pcard-img"
                    src="{{ product.featured_image | image_url: width: 420 }}"
                    alt="{{ nm | escape }}"
                    loading="lazy"
                  >
                </div>
                <div class="pcard-hoverbar">
                  {%- if avail -%}
                    <button class="quick-add" data-add>{{ icPlus }} Add to cart</button
                    ><button class="quick-view" data-quick aria-label="Quick view">{{ icEye }}</button>
                  {%- else -%}
                    <button class="quick-add is-soldout" disabled>Sold out</button
                    ><button class="quick-view" data-quick aria-label="Quick view">{{ icEye }}</button>
                  {%- endif -%}
                </div>
              </div>
              <div class="pcard-body">
                {%- if fam != blank -%}
                  <span class="flavor-tag">{{ fam }}</span>
                {%- endif -%}
                <h3 class="pcard-name" data-quick>{{ nm }}</h3>
                {%- if issf -%}
                  <p class="sf-label">Sugar-Free</p>
                {%- endif -%}
                <div class="pcard-rate">
                  <span class="stars">{{ starrow }}</span
                  ><span class="rate-n">
                    {{- rdisp }}
                    <em>({{ rv }})</em></span
                  >
                </div>
                {%- if has_vip and is_vip == false -%}
                  <button class="pcard-vip-cta" data-vip type="button" aria-label="Unlock VIP price">
                    {{ icVipStar }} Unlock VIP {{ vipprice | money }}
                  </button>
                {%- endif -%}
                <div class="pcard-foot">
                  <span class="pcard-price">
                    {%- if is_vip and has_vip -%}
                      {{ vipprice | money }}
                      <span class="pcard-vipbadge">{{ icVipStar }} VIP</span>
                    {%- else -%}
                      {{ v.price | money }}
                    {%- endif -%}
                  </span>
                  {%- if avail -%}
                    <button class="foot-add" data-add aria-label="Add to cart">
                      <span class="foot-add-ic">{{ icPlus }}</span><span class="foot-add-label">Add to cart</span>
                    </button>
           
                  {%- endif -%}
                </div>
              </div>
            </article>
          {%- endfor -%}
        </div>
        {%- if paginate.next -%}
          <div class="scol-more" data-more data-next="{{ paginate.next.url }}" aria-hidden="true">
            <span class="scol-more-spin"></span>
          </div>
        {%- endif -%}
      {%- endpaginate -%}
      <p class="empty" data-empty style="display:none">No flavors match.</p>
    {%- endif -%}
  </main>

  <div class="qv-root" data-qvroot aria-hidden="true">
    <div class="qv-backdrop" data-qvclose></div>
    <aside class="qv" role="dialog" aria-modal="true">
      <button class="qv-close" data-qvclose aria-label="Close">{{ icClose }}</button>
      <div class="qv-media" data-qvmedia>
        <div class="qv-badges" data-qvbadges></div>
        <img data-qvimg alt="">
      </div>
      <div class="qv-body">
        <span class="flavor-tag" data-qvtag></span>
        <h2 class="qv-name" data-qvname></h2>
        <div class="qv-rate"><span class="stars" data-qvstars></span><span data-qvratetxt></span></div>
        <p class="qv-desc" data-qvdesc></p>
        <div class="qv-perks">
          {%- assign perks = section.settings.perks | split: ',' -%}
          {%- for pk in perks -%}
            <span class="perk">
              {{- icLeaf }}
              {{ pk | strip -}}
            </span>
          {%- endfor -%}
        </div>
        <div class="qv-buy">
          <div class="qty-step">
            <button data-qdec aria-label="Less">−</button><span data-qqty>1</span
            ><button data-qinc aria-label="More">+</button>
          </div>
          <button class="qv-add" data-qadd>Add to cart · <span data-qprice></span></button
          ><button class="qv-wish" data-qwish aria-label="Save">{{ icHeart }}</button>
        </div>
        <a class="qv-link" data-qvlink>View full details →</a>
      </div>
    </aside>
  </div>

  <div class="scol-vip" data-vipmodal aria-hidden="true">
    <div class="scol-vip-backdrop" data-vipclose></div>
    <div class="scol-vip-card" role="dialog" aria-modal="true" aria-label="VIP pricing">
      <button class="scol-vip-x" data-vipclose aria-label="Close">{{ icClose }}</button>
      <span class="scol-vip-eyebrow">{{ icVipStar }} VIP Pricing</span>
      <h3 class="scol-vip-h">Become a member — it's free</h3>
      <p class="scol-vip-lede">
        VIP members unlock our best price on every syrup: <b>$7.99</b> regular &amp; <b>$6.99</b> sugar-free. Create a
        free Syruvia account (or sign in) and the VIP price shows up automatically.
      </p>
      <div class="scol-vip-actions">
        <a class="scol-vip-btn primary" href="/account/register">Create free account</a
        ><a class="scol-vip-btn" href="/account/login">Sign in</a>
      </div>
      <p class="scol-vip-fine">Already a VIP? Just sign in to see your price.</p>
    </div>
  </div>
  <div class="ctoast" data-toast style="display:none"></div>
</div>

<script>
  (function () {
    var root = document.querySelector('[data-scol]');
    if (!root) return;
    function money(c) {
      return '$' + (c / 100).toFixed(2);
    }
    var STARP = 'M10 1.5l2.6 5.3 5.9.9-4.2 4.1 1 5.8L10 15l-5.3 2.6 1-5.8L1.5 7.7l5.9-.9L10 1.5z';
    function starSVG(fill) {
      return (
        '<svg class="str" viewBox="0 0 20 20" width="16" height="16"><path d="' +
        STARP +
        '" fill="' +
        fill +
        '"/></svg>'
      );
    }
    function starsHTML(rt) {
      var full = Math.floor(rt / 10),
        rem = rt - full * 10,
        half = false;
      if (rem >= 8) {
        full++;
      } else if (rem >= 3) {
        half = true;
      }
      var h = '';
      for (var i = 1; i <= 5; i++) {
        h += i <= full ? starSVG('#c58548') : half && i === full + 1 ? starSVG('url(#scolhalf)') : starSVG('#e6dccb');
      }
      return h;
    }
    var hdr = document.querySelector('sticky-header, .header-wrapper, .section-header');
    var bar = root.querySelector('.toolbar');
    function off() {
      if (!hdr) return;
      var b = hdr.getBoundingClientRect();
      if (window.scrollY < 5 && b.height > 20) root.style.paddingTop = Math.round(b.height) + 'px';
      if (bar) bar.style.top = Math.max(0, Math.round(b.bottom)) + 'px';
    }
    off();
    window.addEventListener('scroll', off, { passive: true });
    window.addEventListener('resize', off);
    window.addEventListener('load', off);
    setTimeout(off, 400);
    setTimeout(off, 1200);
    var grid = root.querySelector('[data-grid]');
    if (!grid) {
      return;
    }
    function gridTop() {
      var gw = root.querySelector('.grid-wrap');
      if (!gw) return;
      var hh = hdr ? hdr.getBoundingClientRect().height : 70;
      var bh = bar ? bar.getBoundingClientRect().height : 60;
      var y = gw.getBoundingClientRect().top + window.scrollY - hh - bh - 6;
      window.scrollTo(0, Math.max(0, y));
    }
    var vipModal = root.querySelector('[data-vipmodal]');
    function openVip() {
      if (vipModal) {
        vipModal.classList.add('open');
        vipModal.setAttribute('aria-hidden', 'false');
      }
    }
    function closeVip() {
      if (vipModal) {
        vipModal.classList.remove('open');
        vipModal.setAttribute('aria-hidden', 'true');
      }
    }
    if (vipModal) {
      [].slice.call(vipModal.querySelectorAll('[data-vipclose]')).forEach(function (b) {
        b.addEventListener('click', closeVip);
      });
      window.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closeVip();
      });
    }
    function collectCards() {
      cards = [].slice.call(grid.querySelectorAll('[data-card]')).map(function (el) {
        var dx = el.dataset;
        return {
          el: el,
          family: dx.family,
          name: (dx.name || '').toLowerCase(),
          price: +dx.price,
          rt: +dx.rt,
          reviews: +dx.reviews,
          order: +dx.order,
          best: +dx.best,
          isnew: +dx.new,
          sf: +(dx.sf || 0),
        };
      });
    }
    var moreEl = root.querySelector('[data-more]');
    var gwEl = root.querySelector('.grid-wrap');
    var sectionId = gwEl ? gwEl.getAttribute('data-section-id') : '';
    var loadingMore = false,
      io = null;
    function loadMore() {
      if (loadingMore || !moreEl) return;
      var next = moreEl.getAttribute('data-next');
      if (!next) {
        moreEl.remove();
        moreEl = null;
        if (io) io.disconnect();
        return;
      }
      loadingMore = true;
      var url = next + (next.indexOf('?') > -1 ? '&' : '?') + 'section_id=' + encodeURIComponent(sectionId);
      fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
        .then(function (r) {
          return r.text();
        })
        .then(function (html) {
          var tmp = document.createElement('div');
          tmp.innerHTML = html;
          var ng = tmp.querySelector('[data-grid]');
          if (ng) {
            var frag = document.createDocumentFragment();
            [].slice.call(ng.querySelectorAll('[data-card]')).forEach(function (cc) {
              frag.appendChild(cc);
            });
            grid.appendChild(frag);
          }
          var nm = tmp.querySelector('[data-more]');
          if (nm && nm.getAttribute('data-next') && moreEl) {
            moreEl.setAttribute('data-next', nm.getAttribute('data-next'));
          } else if (moreEl) {
            moreEl.remove();
            moreEl = null;
            if (io) io.disconnect();
          }
          collectCards();
          apply();
          loadingMore = false;
          if (moreEl) {
            var rr = moreEl.getBoundingClientRect();
            if (rr.top < window.innerHeight + 400) loadMore();
          }
        })
        .catch(function () {
          loadingMore = false;
        });
    }
    if (moreEl && 'IntersectionObserver' in window) {
      io = new IntersectionObserver(
        function (es) {
          es.forEach(function (e) {
            if (e.isIntersecting) loadMore();
          });
        },
        { rootMargin: '500px 0px' }
      );
      io.observe(moreEl);
    }
    function checkMore() {
      if (!moreEl || loadingMore) return;
      var r = moreEl.getBoundingClientRect();
      if (r.top < window.innerHeight + 650) loadMore();
    }
    window.addEventListener('scroll', checkMore, { passive: true });
    window.addEventListener('resize', checkMore);
    setTimeout(checkMore, 400);
    setTimeout(checkMore, 1200);
    var countEl = root.querySelector('[data-count]'),
      emptyEl = root.querySelector('[data-empty]'),
      searchEl = root.querySelector('[data-search]');
    var cards = [].slice.call(grid.querySelectorAll('[data-card]')).map(function (el) {
      var dx = el.dataset;
      return {
        el: el,
        family: dx.family,
        name: (dx.name || '').toLowerCase(),
        price: +dx.price,
        rt: +dx.rt,
        reviews: +dx.reviews,
        order: +dx.order,
        best: +dx.best,
        isnew: +dx.new,
        sf: +(dx.sf || 0),
      };
    });
    var family = 'All',
      sort = 'featured';
    var d = root.dataset;
    var promos = [];
    var tints = ['t-mint', 't-peach', 't-butter', 't-sky', 't-blush'];
    var ics = ['🚚', '🧪', '🏷️', '💬', '✨'];
    [d.promo1, d.promo2, d.promo3, d.promo4, d.promo5].forEach(function (txt, i) {
      var lnk = [d.promo1l, d.promo2l, d.promo3l, d.promo4l, d.promo5l][i];
      if (txt) {
        promos.push({ txt: txt, link: lnk || '', tint: tints[i], ic: ics[i], quote: i >= 3 });
      }
    });
    var toastEl = root.querySelector('[data-toast]'),
      tT;
    function toast(m) {
      toastEl.textContent = m;
      toastEl.style.display = 'block';
      clearTimeout(tT);
      tT = setTimeout(function () {
        toastEl.style.display = 'none';
      }, 2200);
    }
    function fly(card) {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      var cartEl = document.querySelector('#cart-icon-bubble, a[href$="/cart"], .header__icon--cart, [href*="/cart"]');
      var imgEl = card.querySelector('.pcard-img');
      if (!cartEl || !imgEl) return;
      var a = imgEl.getBoundingClientRect(),
        b = cartEl.getBoundingClientRect();
      var cl = document.createElement('img');
      cl.src = card.dataset.img;
      cl.className = 'fly-bottle';
      cl.style.left = a.left + 'px';
      cl.style.top = a.top + 'px';
      cl.style.width = a.width + 'px';
      cl.style.height = a.height + 'px';
      document.body.appendChild(cl);
      requestAnimationFrame(function () {
        cl.style.transform =
          'translate(' +
          (b.left + b.width / 2 - a.left - a.width / 2) +
          'px,' +
          (b.top + b.height / 2 - a.top - a.height / 2) +
          'px) scale(.12)';
        cl.style.opacity = '0.2';
      });
      setTimeout(function () {
        cl.remove();
      }, 720);
    }
    function addCart(card, qty) {
      qty = qty || 1;
      var id = +card.dataset.id;
      fly(card);
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify({ items: [{ id: id, quantity: qty }] }),
      })
        .then(function (r) {
          return r.json();
        })
        .then(function () {
          toast(card.dataset.name + ' added to cart');
          var fa = card.querySelector('.foot-add');
          if (fa) {
            fa.classList.add('added');
            setTimeout(function () {
              fa.classList.remove('added');
            }, 1400);
          }
        })
        .catch(function () {
          alert('Could not add to cart.');
        });
    }
    function mkPromo(pr) {
      var el;
      if (pr.link) {
        el = document.createElement('a');
        el.href = pr.link;
      } else {
        el = document.createElement('div');
      }
      el.className = 'promo-card ' + pr.tint + (pr.quote ? ' is-quote' : '');
      el.innerHTML =
        '<span class="promo-ic">' +
        pr.ic +
        '</span><b></b>' +
        (pr.link ? '<span class="promo-cta">Shop now →</span>' : '');
      el.querySelector('b').textContent = pr.txt;
      return el;
    }
    function apply() {
      var by = {
        featured: function (a, b) {
          return b.best - a.best || a.order - b.order;
        },
        best: function (a, b) {
          return b.best - a.best || b.reviews - a.reviews;
        },
        rating: function (a, b) {
          return b.rt - a.rt || b.reviews - a.reviews;
        },
        neww: function (a, b) {
          return b.isnew - a.isnew || a.order - b.order;
        },
        plow: function (a, b) {
          return a.price - b.price;
        },
        phigh: function (a, b) {
          return b.price - a.price;
        },
        az: function (a, b) {
          return a.name.localeCompare(b.name);
        },
      };
      var key = sort === 'new' ? 'neww' : sort;
      var arr = cards.slice().sort(by[key]);
      var q = searchEl && searchEl.value ? searchEl.value.trim().toLowerCase() : '';
      [].slice.call(grid.querySelectorAll('.promo-card')).forEach(function (n) {
        n.remove();
      });
      var shown = 0;
      arr.forEach(function (c) {
        var ok =
          (family === 'All' ? true : family === 'Sugar-Free' ? c.sf === 1 : c.family === family) &&
          (!q || c.name.indexOf(q) > -1);
        c.el.style.display = ok ? '' : 'none';
        grid.appendChild(c.el);
        if (ok) shown++;
      });
      if (!q && promos.length) {
        var vis = arr.filter(function (c) {
          return c.el.style.display !== 'none';
        });
        function after(i, node) {
          if (vis[i]) {
            var ref = vis[i].el.nextSibling;
            if (ref) grid.insertBefore(node, ref);
            else grid.appendChild(node);
          }
        }
        var gap = Math.max(2, Math.round(vis.length / (promos.length + 1)));
        for (var pi = 0; pi < promos.length; pi++) {
          var idx = gap * (pi + 1) - 1;
          if (idx < vis.length) {
            after(idx, mkPromo(promos[pi]));
          } else {
            break;
          }
        }
      }
      countEl.textContent = shown + (shown === 1 ? ' flavor' : ' flavors');
      if (emptyEl)
        emptyEl.style.display =
          shown ||
          (typeof loadingMore !== 'undefined' && loadingMore) ||
          (typeof moreEl !== 'undefined' && moreEl && moreEl.getAttribute && moreEl.getAttribute('data-next'))
            ? 'none'
            : 'block';
    }
    if (searchEl)
      searchEl.addEventListener('input', function () {
        apply();
        gridTop();
      });
    [].slice.call(root.querySelectorAll('[data-fam]')).forEach(function (b) {
      b.addEventListener('click', function () {
        family = b.dataset.fam;
        [].slice.call(root.querySelectorAll('[data-fam]')).forEach(function (x) {
          x.classList.toggle('on', x === b);
        });
        apply();
        gridTop();
      });
    });
    var sortBtn = root.querySelector('[data-sortbtn]'),
      sortPop = root.querySelector('[data-sortpop]'),
      sortLabel = root.querySelector('[data-sortlabel]');
    sortBtn.addEventListener('click', function (e) {
      e.stopPropagation();
      sortBtn.classList.toggle('open');
      sortPop.classList.toggle('open');
    });
    document.addEventListener('click', function (e) {
      if (!root.querySelector('[data-sortmenu]').contains(e.target)) {
        sortBtn.classList.remove('open');
        sortPop.classList.remove('open');
      }
    });
    [].slice.call(root.querySelectorAll('[data-sort]')).forEach(function (b) {
      b.addEventListener('click', function () {
        sort = b.dataset.sort;
        [].slice.call(root.querySelectorAll('[data-sort]')).forEach(function (x) {
          x.classList.toggle('on', x === b);
        });
        sortLabel.textContent = b.textContent;
        sortBtn.classList.remove('open');
        sortPop.classList.remove('open');
        apply();
      });
    });
    [].slice.call(root.querySelectorAll('[data-view]')).forEach(function (b) {
      b.addEventListener('click', function () {
        var vv = b.dataset.view;
        root.classList.toggle('view-list', vv === 'list');
        root.classList.toggle('view-grid', vv === 'grid');
        [].slice.call(root.querySelectorAll('[data-view]')).forEach(function (x) {
          x.classList.toggle('on', x === b);
        });
      });
    });
    grid.addEventListener('click', function (e) {
      if (e.target.closest('.promo-card')) return;
      var card = e.target.closest('[data-card]');
      if (!card) return;
      if (e.target.closest('[data-vip]')) {
        openVip();
        return;
      }
      if (e.target.closest('[data-wish]')) {
        e.target.closest('[data-wish]').classList.toggle('on');
        return;
      }
      if (e.target.closest('[data-add]')) {
        addCart(card, 1);
        return;
      }
      if (e.target.closest('[data-quick]')) {
        if (window.matchMedia('(max-width:720px)').matches) {
          window.location.href = card.dataset.url;
        } else {
          openQuick(card);
        }
        return;
      }
    });
    var qv = root.querySelector('[data-qvroot]'),
      curId = null,
      curName = '',
      curPrice = 0,
      qqty = 1;
    function openQuick(card) {
           if (card.dataset.avail === '0') return; 
      var dd2 = card.dataset;
      curId = +dd2.id;
      curName = dd2.name;
      curPrice = +dd2.price;
      qqty = 1;
      qv.querySelector('[data-qvimg]').src = dd2.img;
      qv.querySelector('[data-qvmedia]').style.setProperty('--tint', card.style.getPropertyValue('--tint'));
      qv.querySelector('[data-qvbadges]').innerHTML =
        (dd2.best === '1' ? '<span class="badge best">Best seller</span>' : '') +
        (dd2.new === '1' ? '<span class="badge new">New</span>' : '');
      var kick = root.dataset.kicker;
      var tagtxt = dd2.family || '';
      if (dd2.sf === '1') {
        tagtxt = tagtxt ? tagtxt + ' · Sugar-Free' : 'Sugar-Free';
      } else if (kick) {
        tagtxt = tagtxt ? tagtxt + ' · ' + kick : kick;
      }
      var tagEl = qv.querySelector('[data-qvtag]');
      tagEl.textContent = tagtxt;
      tagEl.style.display = tagtxt ? '' : 'none';
      qv.querySelector('[data-qvname]').textContent = dd2.name;
      qv.querySelector('[data-qvstars]').innerHTML = starsHTML(+dd2.rt);
      qv.querySelector('[data-qvratetxt]').textContent = dd2.rdisp + ' · ' + dd2.reviews + ' reviews';
      var qvn = root.dataset.qvnote;
      var ds = dd2.desc || '';
      var dtxt = ds ? (qvn ? ds + ' ' + qvn : ds) : qvn || '';
      var dEl = qv.querySelector('[data-qvdesc]');
      dEl.textContent = dtxt;
      dEl.style.display = dtxt ? '' : 'none';
      qv.querySelector('[data-qqty]').textContent = '1';
      var qa = qv.querySelector('[data-qadd]');
      qa.classList.remove('added');
      qa.innerHTML = 'Add to cart · <span data-qprice>' + money(curPrice) + '</span>';
      var ln = qv.querySelector('[data-qvlink]');
      if (ln) ln.href = dd2.url;
      qv.classList.add('open');
    }
    function closeQuick() {
      qv.classList.remove('open');
    }
    [].slice.call(qv.querySelectorAll('[data-qvclose]')).forEach(function (b) {
      b.addEventListener('click', closeQuick);
    });
    window.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') closeQuick();
    });
    qv.querySelector('[data-qdec]').addEventListener('click', function () {
      qqty = Math.max(1, qqty - 1);
      qv.querySelector('[data-qqty]').textContent = qqty;
      var qp = qv.querySelector('[data-qprice]');
      if (qp) qp.textContent = money(curPrice * qqty);
    });
    qv.querySelector('[data-qinc]').addEventListener('click', function () {
      qqty = qqty + 1;
      qv.querySelector('[data-qqty]').textContent = qqty;
      var qp = qv.querySelector('[data-qprice]');
      if (qp) qp.textContent = money(curPrice * qqty);
    });
    qv.querySelector('[data-qwish]').addEventListener('click', function () {
      this.classList.toggle('on');
    });
    qv.querySelector('[data-qadd]').addEventListener('click', function () {
      var qa = this;
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify({ items: [{ id: curId, quantity: qqty }] }),
      })
        .then(function (r) {
          return r.json();
        })
        .then(function () {
          toast(curName + ' added to cart');
          qa.classList.add('added');
          qa.textContent = 'Added to cart ✓';
        })
        .catch(function () {
          alert('Could not add to cart.');
        });
    });
    if (window.matchMedia('(max-width:720px)').matches) {
      root.classList.remove('view-grid');
      root.classList.add('view-list');
      [].slice.call(root.querySelectorAll('[data-view]')).forEach(function (x) {
        x.classList.toggle('on', x.dataset.view === 'list');
      });
    }
    apply();
  })();
</script>

