    .scol.view-list .pcard-imgwrap{ aspect-ratio:auto; height:100%; min-height:150px; }
    .scol.view-list .pcard-hoverbar{ display:none; }
    .scol.view-list .pcard-body{ flex:1; justify-content:center; padding:20px 24px; gap:7px; }
    .scol.view-list .pcard-name{ font-size:22px; }
    .scol.view-list .pcard-foot{ padding-top:12px; justify-content:flex-start; gap:18px; }
    .scol.view-list .pcard-price{ font-size:22px; }
    .scol.view-list .foot-add{ width:auto; height:44px; padding:0 20px; }
    .scol.view-list .foot-add-label{ display:inline; }
    .scol .qv-root{ position:fixed; inset:0; z-index:90; pointer-events:none; } .scol .qv-root.open{ pointer-events:auto; }
    .scol .qv-backdrop{ position:absolute; inset:0; background:rgba(40,24,10,.46); opacity:0; transition:opacity .3s; } .scol .qv-root.open .qv-backdrop{ opacity:1; }
    .scol .qv{ position:absolute; top:0; right:0; height:100%; width:460px; max-width:94vw; background:var(--bg); border-left:var(--rule); box-shadow:-16px 0 50px -28px rgba(40,24,10,.5); transform:translateX(102%); transition:transform .4s cubic-bezier(.32,1,.4,1); display:flex; flex-direction:column; overflow-y:auto; }
    .scol .qv-root.open .qv{ transform:none; }
    .scol .qv-close{ position:absolute; top:16px; right:16px; z-index:5; width:40px; height:40px; border-radius:50%; background:var(--surface); border:var(--rule); color:var(--ink); display:grid; place-items:center; }
    .scol .qv-media{ position:relative; padding:54px 40px 30px; display:grid; place-items:center; background:radial-gradient(110% 80% at 50% 10%, #fff, var(--tint, var(--shell))); border-bottom:var(--rule); }
    .scol .qv-media img{ width:62%; max-width:230px; object-fit:contain; filter:drop-shadow(0 18px 22px rgba(57,34,15,.3)); mix-blend-mode:multiply; }
    .scol .qv-badges{ position:absolute; top:18px; left:18px; display:flex; gap:6px; }
    .scol .qv-body{ padding:24px 28px 34px; display:flex; flex-direction:column; gap:11px; }
    .scol .qv-name{ font-family:var(--font-head); font-size:30px; line-height:1; text-transform:uppercase; letter-spacing:-.01em; }
    .scol .qv-rate{ display:flex; align-items:center; gap:9px; font-size:13px; color:var(--muted); font-weight:600; white-space:nowrap; }
    .scol .qv-desc{ font-size:15px; color:var(--ink-2); line-height:1.55; margin:2px 0 0; }
    .scol .qv-perks{ display:grid; grid-template-columns:1fr 1fr; gap:8px; margin:10px 0 4px; }
    .scol .perk{ display:inline-flex; align-items:center; gap:7px; font-family:'Archivo',sans-serif; font-size:13px; color:var(--sf-ink); font-weight:700; } .scol .perk svg{ color:var(--sf-ink); flex:0 0 auto; }
    .scol .qv-buy{ display:flex; align-items:center; gap:10px; margin-top:12px; }
    .scol .qty-step{ display:inline-flex; align-items:center; border:var(--rule); border-radius:999px; background:var(--surface); padding:3px; }
    .scol .qty-step button{ width:34px; height:34px; border:0; background:transparent; color:var(--ink); font-size:18px; font-weight:700; border-radius:50%; transition:background .14s; } .scol .qty-step button:hover{ background:var(--bg-2); }
    .scol .qty-step span{ min-width:26px; text-align:center; font-family:var(--font-head); }
    .scol .qv-add{ flex:1; height:52px; border:var(--rule); border-radius:999px; background:var(--ink); color:var(--bg); font-family:var(--font-head); font-size:13px; letter-spacing:.1em; text-transform:uppercase; box-shadow:var(--shadow-sm); transition:transform .14s,box-shadow .14s,background .2s,color .2s; }
    .scol .qv-add:hover{ transform:translate(-1px,-1px); box-shadow:var(--shadow-cop); background:var(--accent); color:var(--ink); } .scol .qv-add.added{ background:var(--mint); color:var(--ink); }
    .scol .qv-wish{ flex:0 0 auto; width:52px; height:52px; border-radius:50%; border:var(--rule); background:var(--surface); color:var(--ink); display:grid; place-items:center; } .scol .qv-wish.on{ color:var(--accent); background:var(--blush); }
    .scol .qv-link{ font-family:'Archivo',sans-serif; font-size:13px; font-weight:700; letter-spacing:.04em; text-transform:uppercase; color:var(--accent); margin-top:14px; align-self:flex-start; }
    .scol .ctoast{ position:fixed; left:50%; bottom:32px; transform:translateX(-50%); z-index:120; background:var(--ink); color:var(--bg); font-family:var(--font-head); font-size:13px; letter-spacing:.04em; text-transform:uppercase; padding:14px 22px; border:var(--rule); border-radius:999px; box-shadow:var(--shadow); }
    .scol .ctoast::before{ content:"✓"; color:var(--mint); margin-right:8px; }
    .scol,.scol p,.scol span,.scol a,.scol button,.scol input,.scol li{ font-family:'Josefin Sans',sans-serif !important; }
    .scol h1,.scol h2,.scol h3,.scol h4,.scol .hero-title,.scol .hero-eyebrow,.scol .pcard-name,.scol .pcard-price,.scol .qv-name,.scol .badge,.scol .flavor-tag,.scol .quick-add,.scol .qv-add,.scol .foot-add-label,.scol .promo-card b,.scol .empty,.scol .ctoast,.scol .qty-step span,.scol-decor .nw{ font-family:'Archivo Black',sans-serif !important; }
    .scol .crumbs,.scol .fchip,.scol .result-count,.scol .sort-btn,.scol .sort-lab,.scol .hero-meta>span,.scol .perk,.scol .qv-link,.scol .sf-label,.scol .rate-n,.scol .scol-search input,.scol .promo-cta{ font-family:'Archivo',sans-serif !important; }
    .scol .hero-tag,.scol .qv-desc,.scol .hero-blurb,.scol .sort-opt,.scol .promo-card.is-quote b{ font-family:'Josefin Sans',sans-serif !important; }
    @media (max-width: 980px){ .scol .hero-inner{ grid-template-columns:1fr; gap:18px; } .scol .hero-stage{ height:190px; order:-1; } }
    @media (max-width: 720px){
      .scol .hero-inner{ padding:20px 16px 18px; } .scol .hero-stage{ display:none; }
      .scol .grid-wrap,.scol .tb-row,.scol .hero-inner{ padding-left:16px; padding-right:16px; }
      .scol .tb-row{ flex-wrap:wrap; gap:10px; }
      .scol .filters{ flex-wrap:nowrap; overflow-x:auto; scrollbar-width:none; margin:0 -16px; padding:0 16px; order:3; width:100%; } .scol .filters::-webkit-scrollbar{ display:none; } .scol .fchip{ flex:0 0 auto; }
      .scol .tb-right{ order:1; width:100%; flex-wrap:wrap; justify-content:space-between; }
      .scol .scol-search{ order:2; width:100%; } .scol .scol-search input{ width:100%; }
      .scol .pgrid{ grid-template-columns:1fr 1fr; gap:12px; --col:0px; }
      .scol.view-list .pcard-media{ flex:0 0 130px; width:130px; min-height:0; } .scol.view-list .pcard-imgwrap{ min-height:118px; } .scol.view-list .pcard-name{ font-size:18px; } .scol.view-list .pcard-body{ padding:14px 14px; } .scol.view-list .pcard-foot{ padding-top:10px; }
      .scol .promo-card{ min-height:0; padding:18px 14px; }
      .scol .pcard-media{ padding:12px; } .scol .pcard-body{ padding:12px 13px 14px; }
      .scol .pcard-hoverbar{ display:none; } .scol .foot-add{ width:44px; height:44px; }
      .scol .qv{ width:100%; max-width:100%; top:auto; bottom:0; height:auto; max-height:92vh; border-left:0; border-top:var(--rule); border-radius:22px 22px 0 0; transform:translateY(102%); }
    }
    @media (max-width: 380px){ .scol.view-grid .pgrid{ grid-template-columns:1fr; } }
    @media (prefers-reduced-motion: reduce){ .scol *,.scol *::before,.scol *::after{ animation-duration:.001ms !important; transition-duration:.001ms !important; } .scol .pcard{ opacity:1 !important; transform:none !important; } }
    .scol .pcard-vip-cta{ display:inline-flex; align-items:center; gap:6px; align-self:flex-start; margin-top:2px; font-family:'Archivo',sans-serif; font-size:11.5px; font-weight:700; letter-spacing:.03em; text-transform:uppercase; color:#2F7DC4; background:#eaf2fb; border:1.5px solid #2F7DC4; border-radius:999px; padding:5px 11px; cursor:pointer; transition:transform .14s,box-shadow .14s,background .16s,color .16s; }
    .scol .pcard-vip-cta:hover{ transform:translate(-1px,-1px); box-shadow:3px 3px 0 #2F7DC4; background:#2F7DC4; color:#fff; }
    .scol .pcard-vip-cta .vipstar{ flex:0 0 auto; }
    .scol .pcard-vipbadge{ display:inline-flex; align-items:center; gap:3px; font-family:'Archivo',sans-serif !important; font-size:10px; font-weight:700; letter-spacing:.04em; text-transform:uppercase; color:#fff; background:var(--accent); border-radius:999px; padding:2px 7px; vertical-align:middle; }
    .scol .scol-vip{ position:fixed; inset:0; z-index:130; display:none; align-items:center; justify-content:center; padding:20px; }
    .scol .scol-vip.open{ display:flex; }
    .scol .scol-vip-backdrop{ position:absolute; inset:0; background:rgba(40,24,10,.5); }
    .scol .scol-vip-card{ position:relative; z-index:1; width:420px; max-width:100%; background:var(--bg); border:var(--rule); border-radius:22px; box-shadow:8px 8px 0 var(--ink); padding:30px 28px 26px; text-align:center; animation:scvipin .3s cubic-bezier(.3,1,.5,1) both; }
    @keyframes scvipin{ from{ opacity:0; transform:translateY(16px) scale(.97); } to{ opacity:1; transform:none; } }
    .scol .scol-vip-x{ position:absolute; top:14px; right:14px; width:34px; height:34px; border-radius:50%; background:var(--surface); border:var(--rule-1); color:var(--ink); display:grid; place-items:center; cursor:pointer; }
    .scol .scol-vip-eyebrow{ display:inline-flex; align-items:center; gap:6px; font-family:var(--font-head) !important; font-size:11px; letter-spacing:.14em; text-transform:uppercase; color:var(--accent); }
    .scol .scol-vip-h{ font-family:var(--font-head) !important; font-size:24px; text-transform:uppercase; margin:10px 0 8px; color:var(--ink); }
    .scol .scol-vip-lede{ font-size:15px; color:var(--ink-2); line-height:1.55; margin:0 0 18px; }
    .scol .scol-vip-lede b{ color:var(--ink); }
    .scol .scol-vip-actions{ display:flex; flex-direction:column; gap:10px; }
    .scol .scol-vip-btn{ display:inline-flex; align-items:center; justify-content:center; height:48px; border:var(--rule); border-radius:999px; font-family:var(--font-head) !important; font-size:12.5px; letter-spacing:.08em; text-transform:uppercase; background:var(--surface); color:var(--ink); cursor:pointer; transition:transform .14s,box-shadow .14s,background .2s,color .2s; }
    .scol .scol-vip-btn.primary{ background:var(--ink); color:var(--bg); box-shadow:var(--shadow-sm); }
    .scol .scol-vip-btn:hover{ transform:translate(-1px,-1px); box-shadow:var(--shadow-cop); background:var(--accent); color:var(--ink); }
    .scol .scol-vip-fine{ font-size:12.5px; color:var(--muted); margin:14px 0 0; }
    .scol .scol-more{ display:flex; justify-content:center; align-items:center; padding:26px 0 12px; min-height:44px; }
    .scol .scol-more-spin{ width:26px; height:26px; border-radius:50%; border:3px solid var(--shell); border-top-color:var(--accent); animation:scspin .7s linear infinite; }
    @keyframes scspin{ to{ transform:rotate(360deg); } }
</style>

{%- capture icHeart -%}<svg viewBox="0 0 20 18" width="16" height="16" fill="none"><path d="M10 16S2 11.4 2 6.2C2 3.9 3.9 2 6.2 2 7.8 2 9.2 3 10 4.3 10.8 3 12.2 2 13.8 2 16.1 2 18 3.9 18 6.2 18 11.4 10 16 10 16z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/></svg>{%- endcapture -%}
{%- capture icHeartF -%}<svg viewBox="0 0 20 18" width="16" height="16" fill="currentColor"><path d="M10 16S2 11.4 2 6.2C2 3.9 3.9 2 6.2 2 7.8 2 9.2 3 10 4.3 10.8 3 12.2 2 13.8 2 16.1 2 18 3.9 18 6.2 18 11.4 10 16 10 16z"/></svg>{%- endcapture -%}
{%- capture icPlus -%}<svg viewBox="0 0 14 14" width="14" height="14"><path d="M7 2v10M2 7h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>{%- endcapture -%}
{%- capture icEye -%}<svg viewBox="0 0 20 14" width="18" height="14" fill="none"><path d="M1 7s3.2-5.5 9-5.5S19 7 19 7s-3.2 5.5-9 5.5S1 7 1 7z" stroke="currentColor" stroke-width="1.6"/><circle cx="10" cy="7" r="2.4" stroke="currentColor" stroke-width="1.6"/></svg>{%- endcapture -%}
{%- capture icLeaf -%}<svg viewBox="0 0 18 18" width="15" height="15" fill="none"><path d="M15 3C7 3 3 7 3 14c5 0 12-2 12-11z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M3 15S6 9 12 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>{%- endcapture -%}
{%- capture icSearch -%}<svg viewBox="0 0 19 19" width="15" height="15" fill="none"><circle cx="8" cy="8" r="6.2" stroke="currentColor" stroke-width="1.8"/><path d="M12.8 12.8L17 17" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>{%- endcapture -%}
