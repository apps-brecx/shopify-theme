{%- comment -%} Syruvia — Collection (custom, reusable v7 + syrup spill) {%- endcomment -%}
{%- liquid
  assign heading = section.settings.heading | default: collection.title
  assign seodesc = collection.metafields.global.description_tag
  assign blurbtext = section.settings.blurb | default: seodesc | default: collection.description | strip_html
  assign is_vip = false
  if customer and customer.tags contains 'VIP'
    assign is_vip = true
  endif
-%}
<style>
    .pcard--soldout .pcard-img { filter: grayscale(.7) opacity(.7); }
  .badge.soldout { background:#e7e0d6; color:#7a6f5f; }
  .quick-add.is-soldout,
  .foot-add--soldout,
  [data-qadd].is-soldout {
    background:#e7e0d6; color:#8a7c68; cursor:not-allowed; pointer-events:none;
  }
    @import url('https://fonts.googleapis.com/css2?family=Archivo+Black&family=Archivo:wght@500;600;700;800&family=Josefin+Sans:ital,wght@0,300..700;1,300..600&display=swap');
    .scol{ --bg:#FFFBF4; --bg-2:#FFF8EE; --shell:#FBEFE0; --surface:#FFFFFF; --ink:#39220f; --ink-2:#5a4632; --muted:#8a7a68;
      --accent:#c58548; --star:#c58548; --butter:#FCE2A0; --peach:#FFD4B8; --mint:#C5E4D4; --sky:#B8DCEB; --blush:#F5C7BE;
      --rule:2px solid var(--ink); --rule-1:1.5px solid var(--ink); --shadow:4px 4px 0 var(--ink); --shadow-sm:3px 3px 0 var(--ink); --shadow-cop:4px 4px 0 var(--accent);
      --radius:18px; --font-head:'Archivo Black',sans-serif; --font-body:'Josefin Sans',sans-serif; --sf-ink:#1f6b4f; --col:234px; --gap:22px;
      background:var(--bg); color:var(--ink); font-family:var(--font-body); font-size:16px; line-height:1.5; -webkit-font-smoothing:antialiased; padding-top:107px; position:relative; }
    .scol *,.scol *::before,.scol *::after{ box-sizing:border-box; }
    .scol h1,.scol h2,.scol h3,.scol h4{ margin:0; font-weight:400; letter-spacing:-.01em; }
    .scol button{ cursor:pointer; } .scol a{ cursor:pointer; }
    .scol.dens-comfortable{ --col:234px; --gap:22px; }
    .scol-decor{ position:absolute; inset:0; overflow:hidden; pointer-events:none; z-index:0; }
    .scol-decor .bp{ position:absolute; width:var(--s); height:var(--s); border-radius:50%; background:var(--c); opacity:.5; box-shadow:inset -3px -4px 5px rgba(0,0,0,.18); animation:scfloat 7s ease-in-out infinite; }
    .scol-decor .nw{ position:absolute; font-family:'Archivo Black',sans-serif; text-transform:uppercase; color:var(--accent); opacity:.14; font-size:clamp(18px,2.4vw,34px); letter-spacing:-.01em; transform:rotate(-7deg); white-space:nowrap; animation:scfloat 9s ease-in-out infinite; }
    .scol-decor .spill-drip{ position:absolute; top:-4px; width:var(--w); height:var(--h); background:linear-gradient(180deg,var(--c),color-mix(in srgb,var(--c) 22%,transparent)); border-radius:0 0 60% 60%/0 0 100% 100%; opacity:.5; }
    .scol-decor .spill-drip::after{ content:''; position:absolute; left:50%; bottom:-7px; width:calc(var(--w) + 3px); height:calc(var(--w) + 6px); background:var(--c); border-radius:50%; opacity:.55; transform:translate(-50%,0); animation:scdripfall 3.6s ease-in infinite; animation-delay:var(--dl); }
    @keyframes scdripfall{ 0%{ transform:translate(-50%,0); opacity:.55; } 70%{ opacity:.5; } 100%{ transform:translate(-50%,80px); opacity:0; } }
    .scol-decor .spill-drop{ position:absolute; background:var(--c); border-radius:50% 50% 50% 0; opacity:.4; }
    .scol-decor .spill-ic{ position:absolute; font-size:clamp(22px,2.4vw,32px); opacity:.55; animation:scfloat 7s ease-in-out infinite; }
    .scol .hero,.scol .grid-wrap{ position:relative; z-index:1; }
    .scol .hero{ position:relative; overflow:hidden; border-bottom:var(--rule); background:radial-gradient(110% 130% at 90% -20%, var(--peach), transparent 55%), radial-gradient(80% 120% at 2% 120%, var(--mint), transparent 48%), var(--bg); }
    .scol .hero-inner{ max-width:1240px; margin:0 auto; padding:26px 28px 24px; display:grid; grid-template-columns:1.1fr .9fr; gap:30px; align-items:center; position:relative; }
    .scol .crumbs{ font-family:'Archivo',sans-serif; font-size:12px; font-weight:600; letter-spacing:.04em; text-transform:uppercase; color:var(--muted); display:flex; gap:8px; align-items:center; margin-bottom:14px; white-space:nowrap; }
    .scol .crumbs a:hover{ color:var(--ink); } .scol .crumbs b{ color:var(--ink); } .scol .crumbs span{ opacity:.5; }
    .scol .hero-eyebrow{ display:inline-flex; align-items:center; gap:7px; font-family:var(--font-head); font-size:11px; letter-spacing:.16em; text-transform:uppercase; color:var(--ink); background:var(--surface); border:var(--rule-1); padding:7px 14px; border-radius:999px; box-shadow:var(--shadow-sm); }
    .scol .hero-eyebrow svg{ color:var(--sf-ink); }
    .scol .hero-title{ font-family:var(--font-head); font-size:clamp(40px,6vw,72px); line-height:.9; text-transform:uppercase; margin:14px 0 0; letter-spacing:-.02em; }
    .scol .hero-tag{ font-family:var(--font-body); font-style:italic; font-weight:400; font-size:clamp(18px,2.2vw,25px); color:var(--accent); margin:8px 0 0; }
    .scol .hero-blurb{ font-size:16px; color:var(--ink-2); max-width:32em; margin:12px 0 0; }
    .scol .hero-meta{ display:flex; flex-wrap:wrap; align-items:center; gap:8px; margin-top:16px; }
    .scol .hero-meta>span{ font-family:'Archivo',sans-serif; font-size:11.5px; font-weight:700; letter-spacing:.03em; text-transform:uppercase; color:var(--ink); background:var(--surface); border:var(--rule-1); padding:7px 12px; border-radius:999px; white-space:nowrap; }
    .scol .hero-meta>span b{ color:var(--accent); }
    .scol .hero-stage{ position:relative; height:230px; }
    .scol .hero-blob{ position:absolute; border-radius:50%; filter:blur(40px); opacity:.5; }
    .scol .hero-blob.b1{ width:230px; height:230px; right:6%; top:0; background:var(--butter); }
    .scol .hero-blob.b2{ width:180px; height:180px; left:8%; bottom:0; background:var(--sky); }
    .scol .floater{ position:absolute; will-change:transform; filter:drop-shadow(0 14px 16px rgba(57,34,15,.28)); }
    .scol .floater img{ width:100%; height:100%; object-fit:contain; mix-blend-mode:multiply; }
    .scol .floater.f0{ width:130px; height:162px; left:32%; top:6%; z-index:4; animation:scdrift 7s ease-in-out infinite; }
    .scol .floater.f1{ width:96px; height:120px; left:6%; top:24%; z-index:3; animation:scdrift 8.4s ease-in-out infinite .4s; }
    .scol .floater.f2{ width:108px; height:136px; right:8%; top:12%; z-index:3; animation:scdrift 9s ease-in-out infinite .9s; }
    .scol .floater.f3{ width:86px; height:108px; right:22%; bottom:4%; z-index:5; animation:scdrift 7.8s ease-in-out infinite .2s; }
    .scol .floater.f4{ width:78px; height:98px; left:22%; bottom:6%; z-index:2; animation:scdrift 8.8s ease-in-out infinite .6s; }
    @keyframes scdrift{ 0%,100%{transform:translateY(0) rotate(-2deg);} 50%{transform:translateY(-14px) rotate(2deg);} }
    .scol .boba{ position:absolute; border-radius:50%; opacity:.75; z-index:6; box-shadow:inset -3px -4px 6px rgba(0,0,0,.18); animation:scfloat 6s ease-in-out infinite; }
    .scol .boba.k1{ width:26px;height:26px;left:14%;top:18%;background:#c8455f;animation-delay:0s; }
    .scol .boba.k2{ width:18px;height:18px;left:40%;top:8%;background:#1f8a6e;animation-delay:.6s; }
    .scol .boba.k3{ width:30px;height:30px;right:16%;top:22%;background:#3f6fd0;animation-delay:1.1s; }
    .scol .boba.k4{ width:20px;height:20px;left:24%;bottom:14%;background:#c58548;animation-delay:.3s; }
    .scol .boba.k5{ width:24px;height:24px;right:26%;bottom:10%;background:#7657c9;animation-delay:.9s; }
    .scol .boba.k6{ width:16px;height:16px;right:40%;top:48%;background:#bf4a7d;animation-delay:1.4s; }
    @keyframes scfloat{ 0%,100%{transform:translateY(0);} 50%{transform:translateY(-18px);} }
    .scol .toolbar{ position:sticky; top:107px; z-index:5; background:var(--bg); border-bottom:var(--rule); }
    .scol .tb-row{ max-width:1240px; margin:0 auto; padding:12px 28px; display:flex; align-items:center; justify-content:space-between; gap:14px; }
    .scol .filters{ display:flex; gap:8px; flex-wrap:wrap; }
    .scol .fchip{ font-family:'Archivo',sans-serif; border:var(--rule-1); background:var(--surface); color:var(--ink); font-weight:700; font-size:12px; letter-spacing:.05em; text-transform:uppercase; padding:8px 14px; border-radius:999px; transition:transform .12s,box-shadow .12s,background .15s; }
    .scol .fchip:hover{ transform:translate(-1px,-1px); box-shadow:var(--shadow-sm); }
    .scol .fchip.on{ background:var(--ink); color:var(--bg); }
    .scol .tb-right{ display:flex; align-items:center; gap:12px; flex:0 0 auto; }
    .scol .result-count{ font-family:'Archivo',sans-serif; font-size:12px; font-weight:700; letter-spacing:.03em; text-transform:uppercase; color:var(--muted); white-space:nowrap; }
    .scol .scol-search{ position:relative; display:flex; align-items:center; }
    .scol .scol-search svg{ position:absolute; left:11px; width:15px; height:15px; stroke:var(--muted); pointer-events:none; }
    .scol .scol-search input{ font-family:'Archivo',sans-serif; border:var(--rule-1); background:var(--surface); color:var(--ink); font-size:12.5px; padding:9px 12px 9px 32px; border-radius:999px; width:150px; outline:none; -webkit-appearance:none; }
    .scol .scol-search input:focus{ box-shadow:var(--shadow-sm); }
    .scol .viewtoggle{ display:inline-flex; border:var(--rule-1); border-radius:999px; background:var(--surface); padding:3px; gap:2px; }
    .scol .vt-btn{ width:34px; height:32px; border:0; background:transparent; color:var(--ink); border-radius:999px; display:grid; place-items:center; transition:background .15s; }
    .scol .vt-btn.on{ background:var(--ink); color:var(--bg); }
    .scol .sortmenu{ position:relative; }
    .scol .sort-btn{ display:inline-flex; align-items:center; gap:7px; background:var(--surface); border:var(--rule-1); color:var(--ink); font-family:'Archivo',sans-serif; font-weight:700; font-size:12.5px; letter-spacing:.02em; padding:9px 14px; border-radius:999px; white-space:nowrap; transition:transform .12s,box-shadow .12s; }
    .scol .sort-btn:hover{ transform:translate(-1px,-1px); box-shadow:var(--shadow-sm); }
    .scol .sort-lab{ color:var(--muted); font-weight:600; text-transform:uppercase; letter-spacing:.08em; font-size:11px; }
    .scol .sort-chev{ display:inline-flex; transition:transform .2s; color:var(--ink); }
    .scol .sort-btn.open .sort-chev{ transform:rotate(180deg); }
    .scol .sort-pop{ position:absolute; right:0; top:calc(100% + 8px); background:var(--surface); border:var(--rule); border-radius:14px; box-shadow:var(--shadow); padding:6px; min-width:216px; z-index:50; opacity:0; transform:translateY(-6px); pointer-events:none; transition:all .16s cubic-bezier(.3,1,.5,1); transform-origin:top right; }
    .scol .sort-pop.open{ opacity:1; transform:translateY(0); pointer-events:auto; }
    .scol .sort-opt{ display:block; width:100%; text-align:left; background:transparent; border:0; color:var(--ink); font-family:var(--font-body); font-size:14px; font-weight:600; padding:9px 12px; border-radius:9px; transition:background .12s; }
    .scol .sort-opt:hover{ background:var(--bg-2); } .scol .sort-opt.on{ background:var(--mint); }
    .scol .stars{ display:inline-flex; align-items:center; gap:2px; line-height:0; flex:0 0 auto; vertical-align:middle; }
    .scol .stars .str{ display:block; }
    .scol .qv-rate .stars .str{ width:16px; height:16px; }
    .scol .grid-wrap{ max-width:1240px; margin:0 auto; padding:26px 28px 10px; }
    .scol .pgrid{ display:grid; grid-template-columns:repeat(auto-fill,minmax(var(--col),1fr)); gap:var(--gap); }
    .scol .pcard{ position:relative; background:var(--surface); border:var(--rule); border-radius:var(--radius); display:flex; flex-direction:column; overflow:hidden; box-shadow:var(--shadow); transition:transform .2s cubic-bezier(.3,1,.5,1),box-shadow .2s ease; }
    @media (prefers-reduced-motion: no-preference){ .scol .pcard{ animation:sccardIn .5s cubic-bezier(.3,1,.5,1) both; animation-delay:var(--d); } }
    @keyframes sccardIn{ from{ opacity:0; transform:translateY(14px); } to{ opacity:1; transform:translateY(0); } }
    .scol .pcard:hover{ transform:translate(-3px,-3px); box-shadow:7px 7px 0 var(--ink); }
    .scol .pcard-media{ position:relative; cursor:pointer; padding:16px; background:radial-gradient(120% 95% at 50% 8%, #fff, var(--bg-2)); border-bottom:var(--rule); transition:background .35s ease; }
    .scol .pcard:hover .pcard-media{ background:radial-gradient(120% 100% at 50% 0%, #fff, var(--tint, var(--shell))); }
    .scol .pcard-imgwrap{ aspect-ratio:1/1.02; display:grid; place-items:center; }
    .scol .pcard-img{ width:100%; height:100%; object-fit:contain; mix-blend-mode:multiply; transition:transform .4s cubic-bezier(.3,1,.5,1); }
    .scol .pcard:hover .pcard-img{ transform:scale(1.07) rotate(-1.5deg); }
    .scol .pcard-badges{ position:absolute; top:12px; left:12px; z-index:3; display:flex; flex-direction:column; gap:5px; align-items:flex-start; }
    .scol .badge{ font-family:var(--font-head); font-size:9.5px; letter-spacing:.08em; text-transform:uppercase; padding:5px 9px; border-radius:999px; border:var(--rule-1); white-space:nowrap; }
    .scol .badge.best{ background:var(--ink); color:var(--bg); } .scol .badge.new{ background:var(--accent); color:var(--ink); }
    .scol .wish{ position:absolute; top:11px; right:11px; z-index:3; width:34px; height:34px; border-radius:50%; background:var(--surface); border:var(--rule-1); color:var(--ink); display:grid; place-items:center; transition:transform .15s,box-shadow .15s,color .15s; }
    .scol .wish:hover{ transform:translate(-1px,-1px); box-shadow:var(--shadow-sm); color:var(--accent); }
    .scol .wish.on{ color:var(--accent); background:var(--blush); }
    .scol .wish svg{ width:16px; height:16px; }
    .scol .wish-f{ display:none; } .scol .wish.on .wish-f{ display:block; } .scol .wish.on .wish-o{ display:none; }
    .scol .pcard-hoverbar{ position:absolute; left:12px; right:12px; bottom:12px; z-index:3; display:flex; gap:8px; opacity:0; transform:translateY(12px); transition:all .25s cubic-bezier(.3,1,.5,1); }
    .scol .pcard:hover .pcard-hoverbar{ opacity:1; transform:none; }
    .scol .quick-add{ flex:1; display:inline-flex; align-items:center; justify-content:center; gap:6px; height:42px; background:var(--ink); color:var(--bg); border:var(--rule-1); border-radius:999px; font-family:var(--font-head); font-size:11.5px; letter-spacing:.1em; text-transform:uppercase; transition:background .18s,color .18s; }
    .scol .quick-add:hover{ background:var(--accent); color:var(--ink); } .scol .quick-add svg{ width:13px; height:13px; }
    .scol .quick-view{ flex:0 0 auto; width:42px; height:42px; border-radius:50%; background:var(--surface); border:var(--rule-1); color:var(--ink); display:grid; place-items:center; transition:background .18s,color .18s; }
    .scol .quick-view:hover{ background:var(--accent); color:var(--ink); }
    @media (hover: none){ .scol .pcard-hoverbar{ display:none; } }
    .scol .pcard-body{ padding:14px 16px 16px; display:flex; flex-direction:column; gap:6px; flex:1; }
    .scol .flavor-tag{ align-self:flex-start; font-family:var(--font-head); font-size:9.5px; letter-spacing:.08em; text-transform:uppercase; color:var(--ink); background:var(--mint); border:var(--rule-1); padding:4px 9px; border-radius:999px; white-space:nowrap; }
    .scol .pcard-name{ font-family:var(--font-head); font-size:16px; line-height:1.08; margin-top:3px; cursor:pointer; letter-spacing:-.01em; }
    .scol .pcard-name:hover{ color:var(--accent); }
    .scol .sf-label{ font-family:'Archivo',sans-serif; font-size:11px; font-weight:700; letter-spacing:.06em; text-transform:uppercase; color:var(--sf-ink); margin:0; }
    .scol .pcard-rate{ display:flex; align-items:center; gap:7px; margin-top:2px; }
    .scol:not(.show-ratings) .pcard-rate{ display:none; }
    .scol .rate-n{ font-family:'Archivo',sans-serif; font-size:12px; font-weight:700; color:var(--ink); }
    .scol .rate-n em{ font-style:normal; color:var(--muted); font-weight:600; }
    .scol .pcard-foot{ margin-top:auto; padding-top:10px; display:flex; align-items:center; justify-content:space-between; gap:8px; }
    .scol .pcard-price{ font-family:var(--font-head); font-size:19px; }
    .scol .foot-add{ display:inline-flex; align-items:center; justify-content:center; gap:8px; width:40px; height:40px; border-radius:999px; border:var(--rule); background:var(--surface); color:var(--ink); transition:transform .15s,box-shadow .15s,background .16s,color .16s; }
    .scol .foot-add:hover{ transform:translate(-1px,-1px); box-shadow:var(--shadow-sm); background:var(--accent); color:var(--ink); }
    .scol .foot-add-ic{ display:inline-flex; } .scol .foot-add-ic svg{ width:14px; height:14px; display:block; }
    .scol .foot-add-label{ display:none; font-family:var(--font-head); font-size:11.5px; letter-spacing:.1em; text-transform:uppercase; }
    .scol .foot-add.added{ background:var(--mint); }
    .scol .empty{ text-align:center; color:var(--muted); padding:60px 0; font-family:var(--font-head); text-transform:uppercase; letter-spacing:.04em; grid-column:1 / -1; }
