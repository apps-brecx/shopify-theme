{% comment %} Shared assets — loaded once here (hero is the first/primary section) {% endcomment %}
{{ 'pdp-brand.css' | asset_url | stylesheet_tag }}
{% render 'pd-fixes' %}
{% render 'pd-tweaks' %}
{% render 'pd-rv2-affordances' %}
{% render 'pd-reviews-style' %}
{% render 'pd-color-swap' %}
{% render 'pd-page-polish-v2' %}
{% render 'pd-sale-display' %}

{% style %}
  #shopify-section-{{ section.id }} {
    --pd-text: {{ section.settings.text_primary }};
    --pd-brand: {{ section.settings.text_brand }};
    --pd-bg: {{ section.settings.bg_section }};
    --pd-accent: {{ section.settings.accent_color }};
    --pd-star: {{ section.settings.star_color }};
    --pd-h1-max: {{ section.settings.h1_font_size_max }}px;
    --pd-wrap: {{ section.settings.wrap_max_width }}px;
    --pd-hero-pad-top: {{ section.settings.hero_padding_top }}px;
    --pd-hero-pad-bottom: {{ section.settings.hero_padding_bottom }}px;
    --pd-hero-bg: {{ section.settings.hero_bg }};
    --pd-cta-bg: {{ section.settings.cta_color_bg }};
    --pd-cta-text: {{ section.settings.cta_color_text }};
    --pd-bc-text: {{ section.settings.breadcrumb_text_color }};
    --pd-sale-bg: {{ section.settings.sale_badge_bg }};
    --pd-sale-text: {{ section.settings.sale_badge_text }};
    --pd-sticky-bg: {{ section.settings.sticky_bg }};
    --pd-sticky-text: {{ section.settings.sticky_text_color }};
    --peach: {{ section.settings.palette_peach }};
    --butter: {{ section.settings.palette_butter }};
    --mint: {{ section.settings.palette_mint }};
    --sky: {{ section.settings.palette_sky }};
    --blush: {{ section.settings.palette_blush }};
    --coral: {{ section.settings.palette_coral }};
    --pd-chip-text: {{ section.settings.chip_text_color }};
    --pd-rating-text: {{ section.settings.rating_text_color }};
    --pd-variant-link-text: {{ section.settings.variant_link_text_color }};
    --pd-mb-bg: {{ section.settings.mb_bg }};
    --pd-mb-text: {{ section.settings.mb_text_color }};
    --pd-mb-save-color: {{ section.settings.mb_save_color }};
    --pd-mb-flag-bg: {{ section.settings.mb_flag_bg }};
    --pd-mb-flag-text: {{ section.settings.mb_flag_text }};
    --pd-price-color: {{ section.settings.price_color }};
  }

  #shopify-section-{{ section.id }} .pd { background: var(--pd-bg) !important; color: var(--pd-text) !important; }
  #shopify-section-{{ section.id }} .pd-wrap { max-width: var(--pd-wrap) !important; }

  #shopify-section-{{ section.id }} .pd-hero {
    padding-top: var(--pd-hero-pad-top) !important;
    padding-bottom: var(--pd-hero-pad-bottom) !important;
    background: var(--pd-hero-bg) !important;
  }

  #shopify-section-{{ section.id }} .pd-h1 {
    font-size: clamp(28px, 8vw, var(--pd-h1-max)) !important;
    color: var(--pd-brand) !important;
  }

  #shopify-section-{{ section.id }} .pd-stars svg {
    fill: var(--pd-star) !important;
    stroke: var(--pd-star) !important;
  }

  #shopify-section-{{ section.id }} .pd-atc,
  #shopify-section-{{ section.id }} .pd-stickybar .pd-atc {
    background: var(--pd-cta-bg) !important;
    color: var(--pd-cta-text) !important;
  }
  #shopify-section-{{ section.id }} .pd-atc:hover { filter: brightness(0.92); }

  #shopify-section-{{ section.id }} .pd-variant-link strong { color: var(--pd-accent) !important; }
  #shopify-section-{{ section.id }} .pd-variant-link { color: var(--pd-variant-link-text) !important; }
  #shopify-section-{{ section.id }} .pd-chip { color: var(--pd-chip-text) !important; }
  #shopify-section-{{ section.id }} .pd-rating-text { color: var(--pd-rating-text) !important; }
  #shopify-section-{{ section.id }} .pd-price { color: var(--pd-price-color) !important; }
  #shopify-section-{{ section.id }} .pd-minibundle { background: var(--pd-mb-bg) !important; color: var(--pd-mb-text) !important; }
  #shopify-section-{{ section.id }} .pd-mb-headline,
  #shopify-section-{{ section.id }} .pd-mb-sub,
  #shopify-section-{{ section.id }} .pd-mb-num,
  #shopify-section-{{ section.id }} .pd-mb-label { color: var(--pd-mb-text) !important; }
  #shopify-section-{{ section.id }} .pd-mb-save { color: var(--pd-mb-save-color) !important; }
  #shopify-section-{{ section.id }} .pd-mb-flag { background: var(--pd-mb-flag-bg) !important; color: var(--pd-mb-flag-text) !important; }

  #shopify-section-{{ section.id }} .pd-breadcrumbs,
  #shopify-section-{{ section.id }} .pd-breadcrumbs a,
  #shopify-section-{{ section.id }} .pd-breadcrumbs .pd-bc-current { color: var(--pd-bc-text) !important; }

  #shopify-section-{{ section.id }} .pd-sale-badge {
    background: var(--pd-sale-bg) !important;
    color: var(--pd-sale-text) !important;
  }

  #shopify-section-{{ section.id }} .pd-stickybar { background: var(--pd-sticky-bg) !important; }
  #shopify-section-{{ section.id }} .pd-stickybar .pd-price { color: var(--pd-sticky-text) !important; }

  /* Price row alignment */
  #shopify-section-{{ section.id }} .pd .pd-price-row {
    display: flex !important; align-items: center !important; gap: 10px !important; flex-wrap: wrap !important;
  }
  #shopify-section-{{ section.id }} .pd .pd-stickybar .pd-price {
    display: inline-flex !important; align-items: center !important; gap: 8px !important; flex-wrap: wrap !important;
  }

  /* Thumbnail strip → arrow-only slider (every product image, ~4 visible; navigate with ‹ ›, no scrollbar) */
  #shopify-section-{{ section.id }} .pd-hero-media { min-width: 0; }
  #shopify-section-{{ section.id }} .pd-thumbs-wrap { margin-top: 14px; display: flex; align-items: center; gap: 8px; }
  html body #shopify-section-{{ section.id }} .pd .pd-thumbs { margin-top: 0 !important; display: flex !important; grid-template-columns: none !important; gap: 10px !important; flex: 1 1 auto; min-width: 0; overflow: hidden; scroll-behavior: smooth; scroll-snap-type: x mandatory; }
  html body #shopify-section-{{ section.id }} .pd .pd-thumb { flex: 0 0 calc((100% - 30px) / 4) !important; scroll-snap-align: start; }
  #shopify-section-{{ section.id }} .pd-thumbs-nav { flex: 0 0 auto; width: 30px; height: 30px; border-radius: 50%; border: 2px solid var(--pd-brand); background: #FFFBF4; color: var(--pd-brand); cursor: pointer; display: flex; align-items: center; justify-content: center; font-family: 'Archivo', sans-serif; font-size: 18px; line-height: 1; box-shadow: 2px 2px 0 var(--pd-brand); transition: transform .12s ease, box-shadow .12s ease, opacity .12s ease; padding: 0; }
  #shopify-section-{{ section.id }} .pd-thumbs-nav:hover { transform: translate(-1px,-1px); box-shadow: 3px 3px 0 var(--pd-brand); }
  #shopify-section-{{ section.id }} .pd-thumbs-nav:disabled { cursor: default; box-shadow: none; transform: none; }
  @media (max-width: 760px) { #shopify-section-{{ section.id }} .pd-thumbs-wrap { display: none !important; } }

  /* Mobile-only slider */
  #shopify-section-{{ section.id }} .pd-slider-mobile { display: none; }
  #shopify-section-{{ section.id }} .pd-slider-dots { display: none; }
  @media (max-width: 760px) {
    #shopify-section-{{ section.id }} .pd-hero-frame { display: none !important; }
    #shopify-section-{{ section.id }} .pd-thumbs { display: none !important; }
    #shopify-section-{{ section.id }} .pd-slider-mobile {
      display: block !important; position: relative; background: var(--pd-bg) !important;
      border: 2px solid var(--pd-brand) !important; border-radius: 20px; padding: 0;
      box-shadow: 4px 4px 0 var(--pd-brand) !important; overflow: hidden; max-width: 340px; margin: 0 auto;
    }
    #shopify-section-{{ section.id }} .pd-slides {
      display: flex; overflow-x: auto; scroll-snap-type: x mandatory; scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch; scrollbar-width: none; width: 100%; position: relative; z-index: 0;
    }
    #shopify-section-{{ section.id }} .pd-slides::-webkit-scrollbar { display: none; }
    #shopify-section-{{ section.id }} .pd-slide { flex: 0 0 100%; scroll-snap-align: start; min-width: 100%; }
    #shopify-section-{{ section.id }} .pd-slide img { width: 100%; height: auto; display: block; aspect-ratio: 1/1; object-fit: cover; }
    #shopify-section-{{ section.id }} .pd-slider-dots { display: flex !important; justify-content: center; gap: 5px; margin-top: 10px; }
  }
{% endstyle %}

{%- assign hero_img = product.featured_media.preview_image -%}
{%- assign hero_src = hero_img | image_url: width: 1400 -%}

<link rel="preload" as="image" href="{{ hero_src }}" imagesrcset="{{ hero_img | image_url: width: 600 }} 600w, {{ hero_img | image_url: width: 1000 }} 1000w, {{ hero_img | image_url: width: 1400 }} 1400w" imagesizes="(max-width: 980px) 100vw, 600px" fetchpriority="high">

{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign compare_at = current_variant.compare_at_price -%}
{%- assign price = current_variant.price -%}

{%- assign is_sf = false -%}
{%- assign t_lc = product.title | downcase -%}
{%- if t_lc contains 'sugar-free' or t_lc contains 'sugar free' -%}{%- assign is_sf = true -%}{%- endif -%}

{%- assign is_vip = false -%}
{%- if customer and customer.tags contains 'VIP' -%}{%- assign is_vip = true -%}{%- endif -%}

{%- assign display_price = price -%}
{%- if is_vip and price > 799 -%}{%- assign display_price = 799 -%}{%- endif -%}

{%- assign has_sale = false -%}
{%- if compare_at and compare_at > price -%}{%- assign has_sale = true -%}{%- endif -%}
{%- assign sale_pct = 0 -%}
{%- if has_sale -%}
  {%- assign sale_diff = compare_at | minus: price -%}
  {%- assign sale_pct = sale_diff | times: 100 | divided_by: compare_at -%}
{%- endif -%}

{%- comment -%} Counterpart: regular products store it in custom.sugar_free, sugar-free products in custom.regular. {%- endcomment -%}
{%- if is_sf -%}{%- assign counterpart = product.metafields.custom.regular.value -%}{%- else -%}{%- assign counterpart = product.metafields.custom.sugar_free.value -%}{%- endif -%}
{%- if counterpart == blank -%}{%- assign counterpart = product.metafields.custom.sugar_free.value | default: product.metafields.custom.regular.value -%}{%- endif -%}
{%- assign review_count = product.metafields.reviews.rating_count.value | default: 0 -%}

<div class="pd" data-product-id="{{ product.id }}" data-base-price="{{ display_price }}">

  {%- if section.settings.show_breadcrumbs -%}
    <nav class="pd-breadcrumbs" aria-label="Breadcrumb">
      <div class="pd-wrap">
        <ol>
          <li><a href="/">{{ section.settings.breadcrumb_home }}</a></li>
          <li class="pd-bc-sep" aria-hidden="true">/</li>
          <li><a href="/collections/all">{{ section.settings.breadcrumb_category }}</a></li>
          <li class="pd-bc-sep" aria-hidden="true">/</li>
          <li class="pd-bc-current">{{ product.title }}</li>
        </ol>
      </div>
    </nav>
  {%- endif -%}

  <section class="pd-hero">
    <div class="pd-wrap">
      <div class="pd-hero-grid">

        <div class="pd-hero-media">
          <div class="pd-hero-frame">
            <img id="pdHeroImg" src="{{ hero_src }}" alt="{{ product.title | escape }}" width="1200" height="1200" fetchpriority="high">
          </div>
          {%- if product.images.size > 1 -%}
            <div class="pd-thumbs-wrap">
              {%- if product.images.size > 4 -%}<button type="button" class="pd-thumbs-nav pd-thumbs-prev" aria-label="Previous thumbnails">‹</button>{%- endif -%}
              <div class="pd-thumbs">
                {%- for img in product.images -%}
                  <button type="button" class="pd-thumb{% if forloop.first %} is-active{% endif %}" data-src="{{ img | image_url: width: 1400 }}" aria-label="View image {{ forloop.index }}"><img src="{{ img | image_url: width: 200 }}" alt="" width="200" height="200" loading="lazy"></button>
                {%- endfor -%}
              </div>
              {%- if product.images.size > 4 -%}<button type="button" class="pd-thumbs-nav pd-thumbs-next" aria-label="Next thumbnails">›</button>{%- endif -%}
            </div>
          {%- endif -%}

          <div class="pd-slider-mobile">
            <div class="pd-slides" id="pdSlides">
              {%- for img in product.images -%}
                <div class="pd-slide" data-idx="{{ forloop.index0 }}">
                  <img src="{{ img | image_url: width: 1000 }}" alt="{{ product.title | escape }}" {% if forloop.first %}fetchpriority="high"{% else %}loading="lazy"{% endif %}>
                </div>
              {%- endfor -%}
            </div>
          </div>
          {%- if product.images.size > 1 -%}
            <div class="pd-slider-dots" id="pdDots">
              {%- for img in product.images -%}
                <button type="button" class="pd-dot{% if forloop.first %} is-active{% endif %}" data-idx="{{ forloop.index0 }}" aria-label="View image {{ forloop.index }}"></button>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>

        <div class="pd-hero-info">

          <a href="#reviews" class="pd-rating-row">
            <span class="pd-stars" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="{{ section.settings.star_color }}" stroke="{{ section.settings.star_color }}" stroke-width="1" stroke-linejoin="round"><path d="M12 2 L14.6 8.4 L21.5 9 L16.3 13.6 L17.9 20.4 L12 16.9 L6.1 20.4 L7.7 13.6 L2.5 9 L9.4 8.4 Z"/></svg>
              <svg viewBox="0 0 24 24" fill="{{ section.settings.star_color }}" stroke="{{ section.settings.star_color }}" stroke-width="1" stroke-linejoin="round"><path d="M12 2 L14.6 8.4 L21.5 9 L16.3 13.6 L17.9 20.4 L12 16.9 L6.1 20.4 L7.7 13.6 L2.5 9 L9.4 8.4 Z"/></svg>
              <svg viewBox="0 0 24 24" fill="{{ section.settings.star_color }}" stroke="{{ section.settings.star_color }}" stroke-width="1" stroke-linejoin="round"><path d="M12 2 L14.6 8.4 L21.5 9 L16.3 13.6 L17.9 20.4 L12 16.9 L6.1 20.4 L7.7 13.6 L2.5 9 L9.4 8.4 Z"/></svg>
              <svg viewBox="0 0 24 24" fill="{{ section.settings.star_color }}" stroke="{{ section.settings.star_color }}" stroke-width="1" stroke-linejoin="round"><path d="M12 2 L14.6 8.4 L21.5 9 L16.3 13.6 L17.9 20.4 L12 16.9 L6.1 20.4 L7.7 13.6 L2.5 9 L9.4 8.4 Z"/></svg>
              <svg viewBox="0 0 24 24" fill="{{ section.settings.star_color }}" stroke="{{ section.settings.star_color }}" stroke-width="1" stroke-linejoin="round"><path d="M12 2 L14.6 8.4 L21.5 9 L16.3 13.6 L17.9 20.4 L12 16.9 L6.1 20.4 L7.7 13.6 L2.5 9 L9.4 8.4 Z"/></svg>
            </span>
            <span class="pd-rating-text">{{ review_count }} {{ section.settings.reviews_label }}</span>
          </a>

          <h1 class="pd-h1">{{ product.title | upcase }}</h1>

          <div class="pd-chips">
            {%- if is_sf -%}
              <span class="pd-chip pd-chip--blush"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><circle cx="12" cy="12" r="9"/><path d="M5 5l14 14"/></svg>{{ section.settings.chip_sugar_sf }}</span>
            {%- else -%}
              <span class="pd-chip pd-chip--butter"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 C 7 6, 7 14, 12 22 C 17 14, 17 6, 12 2 Z M12 7 V 18"/></svg>{{ section.settings.chip_sugar_regular }}</span>
            {%- endif -%}
            <span class="pd-chip pd-chip--mint"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3 C 7 9, 5 13, 5 16 a 7 7 0 0 0 14 0 c 0 -3 -2 -7 -7 -13 Z"/></svg>{{ section.settings.chip_servings }}</span>
            <span class="pd-chip pd-chip--sky"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12 l4 4 L19 7"/></svg>{{ section.settings.chip_glutenfree }}</span>
            <span class="pd-chip pd-chip--peach"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M4 22 V 4 l 6 2 l 6 -2 l 4 2 v 14 l -4 -2 l -6 2 l -6 -2 Z"/></svg>{{ section.settings.chip_madeinusa }}</span>
          </div>

          {%- if counterpart != blank -%}
            <a href="/products/{{ counterpart.handle }}" class="pd-variant-link">
              {%- if is_sf -%}{{ section.settings.variant_link_pre_sf }} <strong>{{ section.settings.variant_link_strong_sf }}</strong>{%- else -%}{{ section.settings.variant_link_pre_regular }} <strong>{{ section.settings.variant_link_strong_regular }}</strong>{%- endif -%}
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12 h14 M13 6 l6 6 -6 6"/></svg>
            </a>
          {%- endif -%}

          {%- form 'product', product, id: 'pdAtcForm', class: 'pd-form' -%}
            <input type="hidden" name="id" value="{{ current_variant.id }}">
            {% render 'pd-purchase-options' %}
            <div class="pd-priceqty">
              <div class="pd-priceblock">
                <div class="pd-price-row">
                  <span class="pd-price" id="pdPriceTotal">{{ display_price | money }}</span>
                  {%- if has_sale -%}
                    <span class="pd-price-original" id="pdPriceCompareAt">{{ compare_at | money }}</span>
                    <span class="pd-sale-badge">{{ section.settings.sale_badge_prefix }} {{ sale_pct }}%</span>
                  {%- endif -%}
                  {% render 'pd-vip-pricing', variant: 'main', price: price %}
                  <span class="pd-price-was" id="pdPriceWas" style="display:none"></span>
                </div>
                <span class="pd-save-inline" id="pdSaveTag" style="display:none"></span>
              </div>
              <div class="pd-qty" aria-label="Quantity">
                <button type="button" data-qty="-1" aria-label="Decrease">−</button>
                <input type="number" name="quantity" value="1" min="1" inputmode="numeric">
                <button type="button" data-qty="1" aria-label="Increase">+</button>
              </div>
            </div>
            <button type="submit" class="pd-atc pd-atc--full" {% unless product.available %}disabled{% endunless %}>
              <svg class="pd-atc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 L4 6 V20 a2 2 0 0 0 2 2 H18 a2 2 0 0 0 2 -2 V6 L18 2 Z M4 6 H20 M16 10 a4 4 0 0 1 -8 0"/></svg>
              <span class="pd-atc-text" id="pdAtcText">{%- if product.available -%}{{ section.settings.atc_text_available }}{%- else -%}{{ section.settings.atc_text_soldout }}{%- endif -%}</span>
              {%- if product.available -%}<svg class="pd-atc-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12 H19 M13 6 l6 6 -6 6"/></svg>{%- endif -%}
            </button>
          {%- endform -%}

          {%- if section.settings.show_mini_bundle -%}
            <div class="pd-minibundle">
              <div class="pd-mb-head">
                <span class="pd-mb-headline">{{ section.settings.mb_headline }}</span>
                <span class="pd-mb-sub">{{ section.settings.mb_sub }}</span>
              </div>
              <div class="pd-mb-grid">
                <button type="button" class="pd-mb-cell" data-tier="2">
                  <span class="pd-mb-num">{{ section.settings.mb_tier2_num }}</span>
                  <span class="pd-mb-label">{{ section.settings.mb_tier2_label }}</span>
                  <span class="pd-mb-save">{{ section.settings.mb_tier2_save }}</span>
                </button>
                <button type="button" class="pd-mb-cell" data-tier="3">
                  <span class="pd-mb-flag">{{ section.settings.mb_tier3_flag }}</span>
                  <span class="pd-mb-num">{{ section.settings.mb_tier3_num }}</span>
                  <span class="pd-mb-label">{{ section.settings.mb_tier3_label }}</span>
                  <span class="pd-mb-save">{{ section.settings.mb_tier3_save }}</span>
                </button>
                <button type="button" class="pd-mb-cell" data-tier="4">
                  <span class="pd-mb-num">{{ section.settings.mb_tier4_num }}</span>
                  <span class="pd-mb-label">{{ section.settings.mb_tier4_label }}</span>
                  <span class="pd-mb-save">{{ section.settings.mb_tier4_save }}</span>
                </button>
              </div>
            </div>
          {%- endif -%}

        </div>
      </div>
    </div>
  </section>

  {%- if section.settings.show_sticky_bar -%}
    <div class="pd-stickybar" id="pdStickybar">
      <span class="pd-price">
        <span id="pdStickyPrice">{{ display_price | money }}</span>
        {%- if has_sale -%}<span class="pd-price-original">{{ compare_at | money }}</span>{%- endif -%}
        {% render 'pd-vip-pricing', variant: 'sticky', price: price %}
      </span>
      <button type="button" class="pd-atc" {% unless product.available %}disabled{% endunless %} onclick="document.getElementById('pdAtcForm').requestSubmit()">{%- if product.available -%}{{ section.settings.atc_text_available }}{%- else -%}{{ section.settings.atc_text_soldout }}{%- endif -%}</button>
    </div>
  {%- endif -%}

</div>

{% render 'pd-mb-prices' %}

<script>
window.PD_BASE_CENTS = {{ display_price }};
window.PD_COMPARE_AT_CENTS = {{ compare_at | default: 0 }};
window.PD_HAS_SALE = {% if has_sale %}true{% else %}false{% endif %};
window.PD_TIERS = [1, 0.95, 0.90, 0.85];
(function(){
  var currentBaseCents = window.PD_BASE_CENTS;
  var compareAtCents = window.PD_COMPARE_AT_CENTS;
  var hasSale = window.PD_HAS_SALE;
  const tiers = window.PD_TIERS;
  const fmt = (c)=>{const d=c/100; return '$' + d.toFixed(2);};
  function updatePrice(qty){
    qty = Math.max(1, parseInt(qty)||1);
    const tierIdx = Math.min(qty-1, tiers.length-1);
    const discount = tiers[tierIdx];
    const totalCents = Math.round(currentBaseCents * qty * discount);
    const origCents = currentBaseCents * qty;
    const compareCents = compareAtCents * qty;
    const priceEl = document.getElementById('pdPriceTotal');
    const wasEl = document.getElementById('pdPriceWas');
    const saveEl = document.getElementById('pdSaveTag');
    const stickyPriceEl = document.getElementById('pdStickyPrice');
    const compareEl = document.getElementById('pdPriceCompareAt');
    if (priceEl) priceEl.textContent = fmt(totalCents);
    if (stickyPriceEl) stickyPriceEl.textContent = fmt(totalCents);
    if (hasSale && compareEl) compareEl.textContent = fmt(compareCents);
    document.querySelectorAll('.pd-stickybar .pd-price-original').forEach(function(el){ el.textContent = fmt(compareCents); });
    if (qty > 1) {
      if (wasEl){wasEl.textContent = fmt(origCents); wasEl.style.display='inline';}
      if (saveEl){saveEl.textContent = 'Save '+Math.round((1-discount)*100)+'%'; saveEl.style.display='inline-block';}
    } else {
      if (wasEl) wasEl.style.display='none';
      if (saveEl) saveEl.style.display='none';
    }
    document.querySelectorAll('.pd-mb-cell').forEach(c=>{
      const t = parseInt(c.dataset.tier)||1;
      const match = (qty === t) || (qty >= 4 && t === 4);
      if (match) c.setAttribute('data-active',''); else c.removeAttribute('data-active');
    });
  }
  function getCurrentQty(){
    const inp = document.querySelector('.pd-qty input');
    return inp ? Math.max(1, parseInt(inp.value)||1) : 1;
  }
  document.querySelectorAll('.pd-qty [data-qty]').forEach(b=>{
    b.addEventListener('click', ()=>{
      const inp = b.parentElement.querySelector('input');
      const v = Math.max(1, (parseInt(inp.value)||1) + parseInt(b.dataset.qty));
      inp.value = v;
      updatePrice(v);
    });
  });
  document.querySelectorAll('.pd-qty input').forEach(inp=>{
    inp.addEventListener('change', ()=>updatePrice(parseInt(inp.value)||1));
    inp.addEventListener('input', ()=>updatePrice(parseInt(inp.value)||1));
  });
  document.querySelectorAll('.pd-mb-cell').forEach(c=>{
    c.addEventListener('click', ()=>{
      const tier = parseInt(c.dataset.tier)||1;
      const qtyInp = document.querySelector('.pd-qty input');
      if (qtyInp) {qtyInp.value = tier; updatePrice(tier);}
    });
  });
  window.addEventListener('pd:purchase-option-changed', function(e){
    var newBase = e.detail && e.detail.price ? e.detail.price : window.PD_BASE_CENTS;
    currentBaseCents = newBase;
    updatePrice(getCurrentQty());
  });
  const heroImg = document.getElementById('pdHeroImg');
  document.querySelectorAll('.pd-thumb').forEach(t=>{
    t.addEventListener('click', ()=>{document.querySelectorAll('.pd-thumb').forEach(x=>x.classList.remove('is-active'));t.classList.add('is-active');if (heroImg && t.dataset.src) heroImg.src = t.dataset.src;});
  });
  /* Desktop thumbnail slider — arrow controls */
  (function(){
    var strip = document.querySelector('.pd-thumbs');
    var prev = document.querySelector('.pd-thumbs-prev');
    var next = document.querySelector('.pd-thumbs-next');
    if (!strip || !prev || !next) return;
    function upd(){ var max = strip.scrollWidth - strip.clientWidth - 2; prev.disabled = strip.scrollLeft <= 2; next.disabled = strip.scrollLeft >= max; }
    function step(){ return Math.max(strip.clientWidth * 0.8, 120); }
    prev.addEventListener('click', function(){ strip.scrollBy({left: -step(), behavior: 'smooth'}); });
    next.addEventListener('click', function(){ strip.scrollBy({left: step(), behavior: 'smooth'}); });
    strip.addEventListener('scroll', upd, {passive: true});
    window.addEventListener('resize', upd);
    upd();
  })();
  const slides = document.getElementById('pdSlides');
  const dots = document.querySelectorAll('.pd-dot');
  if (slides && dots.length){
    let scrollTimer;
    slides.addEventListener('scroll', ()=>{
      clearTimeout(scrollTimer);
      scrollTimer = setTimeout(()=>{
        const idx = Math.round(slides.scrollLeft / slides.clientWidth);
        dots.forEach((d, i) => d.classList.toggle('is-active', i === idx));
      }, 50);
    });
    dots.forEach((d, i)=>d.addEventListener('click', ()=>{
      slides.scrollTo({left: i * slides.clientWidth, behavior: 'smooth'});
    }));
  }
  const mainAtc = document.querySelector('.pd-atc--full');
  const stickyBar = document.getElementById('pdStickybar');
  if (mainAtc && stickyBar && 'IntersectionObserver' in window){
    const io = new IntersectionObserver((entries)=>{
      entries.forEach(e=>{ if (e.isIntersecting){ stickyBar.classList.add('is-hidden'); } else { stickyBar.classList.remove('is-hidden'); } });
    }, {threshold: 0.15});
    io.observe(mainAtc);
  }
  const dotsContainer = document.getElementById('pdDots');
  if (dotsContainer) {
    let raf;
    function updateDotProminence(){
      const r = dotsContainer.getBoundingClientRect();
      if (r.top > 60 && r.top < 380) {
        dotsContainer.classList.add('is-prominent');
      } else {
        dotsContainer.classList.remove('is-prominent');
      }
    }
    window.addEventListener('scroll', ()=>{cancelAnimationFrame(raf); raf = requestAnimationFrame(updateDotProminence);}, {passive: true});
    updateDotProminence();
  }
})();
</script>

