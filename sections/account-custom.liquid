    border-radius: 6px;
    cursor: pointer;
    font-weight: 500;
  }
  .favorite-card__btn--primary {
    background: #1a1a1a;
    color: white;
    border-color: #1a1a1a;
  }
  .favorite-card__remove {
    position: absolute;
    top: 8px;
    right: 8px;
    background: rgba(255,255,255,0.9);
    border: 0;
    border-radius: 50%;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-size: 16px;
    line-height: 1;
    z-index: 2;
  }
</style>
<script>
(function() {
  const grid = document.getElementById('favorites-grid');
  const loading = document.querySelector('.favorites-loading');
  const empty = document.querySelector('.favorites-empty');

  if (!grid) return;

  function moneyFormat(cents) {
    return '$' + (cents / 100).toFixed(2);
  }

  function renderCard(item) {
    const productUrl = '/products/' + item.du.split('/products/')[1].split('?')[0];
    const imgUrl = item.iu ? (item.iu.startsWith('http') ? item.iu : 'https:' + item.iu) : '';
    const price = item.pr ? moneyFormat(item.pr * 100) : '';

    return `
      <div class="favorite-card" data-empi="${item.empi}" data-epi="${item.epi}">
        <button class="favorite-card__remove" data-remove aria-label="Remove from favorites">×</button>
        <a href="${productUrl}" class="favorite-card__image">
          ${imgUrl ? `<img src="${imgUrl}" alt="${item.dt}" loading="lazy">` : ''}
        </a>
        <div class="favorite-card__body">
          <h3 class="favorite-card__title">${item.dt}</h3>
          ${price ? `<p class="favorite-card__price">${price}</p>` : ''}
          <div class="favorite-card__actions">
            <button class="favorite-card__btn favorite-card__btn--primary" data-add-to-cart data-variant="${item.epi}">
              Add to cart
            </button>
          </div>
        </div>
      </div>
    `;
  }

  function render(items) {
    loading.style.display = 'none';

    if (!items || items.length === 0) {
      empty.style.display = 'block';
      grid.style.display = 'none';
      return;
    }

    empty.style.display = 'none';
    grid.style.display = 'grid';
    grid.innerHTML = items.map(renderCard).join('');

    // Bind remove buttons
    grid.querySelectorAll('[data-remove]').forEach(btn => {
      btn.addEventListener('click', handleRemove);
    });

    // Bind add-to-cart buttons
    grid.querySelectorAll('[data-add-to-cart]').forEach(btn => {
      btn.addEventListener('click', handleAddToCart);
    });
  }

  function handleRemove(e) {
    const card = e.target.closest('.favorite-card');
    const empi = parseInt(card.dataset.empi);
    const epi = parseInt(card.dataset.epi);

    if (!window._swat) return;

    _swat.removeFromWishList({
      empi: empi,
      epi: epi,
      du: window.location.origin + '/products/' + card.querySelector('.favorite-card__image').href.split('/products/')[1]
    }, function(response) {
      card.style.opacity = '0';
      setTimeout(loadWishlist, 200);
    });
  }

  async function handleAddToCart(e) {
    const variantId = e.target.dataset.variant;
    const btn = e.target;
    const originalText = btn.textContent;
    btn.textContent = 'Adding...';
    btn.disabled = true;

    try {
      const res = await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: [{ id: variantId, quantity: 1 }] })
      });
      if (!res.ok) throw new Error('Cart add failed');
      btn.textContent = '✓ Added';
      // Try to open cart drawer if theme supports it
      if (window.theme && window.theme.cart && window.theme.cart.open) {
        window.theme.cart.open();
      }
    } catch (err) {
      btn.textContent = 'Try again';
    }

    setTimeout(() => {
      btn.textContent = originalText;
      btn.disabled = false;
    }, 2000);
  }

  function loadWishlist() {
    if (!window._swat) {
      // Swym not loaded yet — wait
      setTimeout(loadWishlist, 300);
      return;
    }

    _swat.fetch(function(items) {
      render(items || []);
    });
  }

  // Wait for Swym to be ready
  if (window.SwymCallbacks) {
    window.SwymCallbacks.push(function(swat) {
      loadWishlist();
    });
  } else {
    window.SwymCallbacks = [function(swat) {
      loadWishlist();
    }];
  }

  // Fallback if callbacks don't fire
  setTimeout(loadWishlist, 2000);
})();
</script>
