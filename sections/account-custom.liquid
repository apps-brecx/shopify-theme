{%- comment -%} Syruvia — Account dashboard (logged in). Scoped .sdash. Wired to customer object. VIP from metafields (vip.*). v2: editable profile + valid password form type. {%- endcomment -%}
{%- liquid
  assign is_vip = false
  if customer.tags contains 'VIP'
    assign is_vip = true
  endif
  assign vpoints = customer.metafields.vip.points.value | default: 0
  assign vtier = customer.metafields.vip.tier.value | default: 'Member'
  assign vnext = customer.metafields.vip.next_tier.value | default: 'next tier'
  assign vtonext = customer.metafields.vip.points_to_next.value | default: 0
  assign vsaved = customer.metafields.vip.lifetime_saved.value | default: 0
  assign goalpts = vpoints | plus: vtonext
  assign trackpct = 0
  if goalpts > 0
    assign trackpct = vpoints | times: 100 | divided_by: goalpts
  endif
  assign fname = customer.first_name | default: 'there'
-%}
<style>
  @import url('https://fonts.googleapis.com/css2?family=Archivo+Black&family=Archivo:wght@500;600;700;800&family=Josefin+Sans:ital,wght@0,300..700;1,300..600&display=swap');
