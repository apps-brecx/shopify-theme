            <div class="vperk"><span class="pic">{{ icTruck }}</span><span class="pt"><b style="font-family:var(--font-head);font-weight:400">Free shipping</b> perks &amp; early flavor drops</span></div>
            <div class="vperk"><span class="pic">{{ icGift }}</span><span class="pt">Climb tiers from <b style="font-family:var(--font-head);font-weight:400">Taster to Legend</b></span></div>
          </div>
          <div class="card card-pad" style="display:flex;gap:12px;flex-wrap:wrap;align-items:center"><a class="btn-vip" href="/apps/vip/rewards">{{ icSpark }} Open the rewards hub</a><span style="font-size:13px;color:var(--muted)">The full program — points, daily games, redemptions &amp; referrals — lives on your VIP Rewards page.</span></div>
        </div>

        <div class="dpanel" data-panel="subscriptions">
          <div class="sect-head"><div><h2>Subscriptions</h2><p>Auto-refills, delivered on your schedule.</p></div></div>
          <div class="card"><div class="empty-state"><div class="eg">{{ icRefresh }}</div><h3>No active subscriptions</h3><p>Set up an auto-refill on any product to never run out. (Connects to your subscriptions app.)</p><a class="btn-ink" href="{{ routes.all_products_collection_url | default: '/collections/all' }}">Browse flavors {{ icArrow }}</a></div></div>
        </div>

        <div class="dpanel" data-panel="addresses">
          <div class="sect-head"><div><h2>Addresses</h2><p>Where we ship your orders.</p></div></div>
          <div class="addr-grid">
            {%- for address in customer.addresses -%}
              <div class="addr{% if address == customer.default_address %} default{% endif %}">
                <div class="addr-top"><span class="addr-label">{{ address.company | default: 'Address' }}</span>{% if address == customer.default_address %}<span class="addr-default-pill">Default</span>{% endif %}</div>
                <div class="addr-name">{{ address.first_name }} {{ address.last_name }}</div>
                <div class="addr-lines">{{ address.address1 }}{% if address.address2 != blank %}<div>{{ address.address2 }}</div>{% endif %}<div>{{ address.city }}{% if address.province != blank %}, {{ address.province }}{% endif %} {{ address.zip }}</div><div>{{ address.country }}</div></div>
                {% if address.phone != blank %}<div class="addr-phone">{{ address.phone }}</div>{% endif %}
                <div class="addr-acts"><a href="{{ routes.account_addresses_url }}">Edit</a><a class="danger" href="{{ routes.account_addresses_url }}">Manage</a></div>
              </div>
            {%- endfor -%}
            <a class="addr-add" href="{{ routes.account_addresses_url }}"><span class="plus">+</span>Add address</a>
          </div>
        </div>

        <div class="dpanel" data-panel="settings">
          <div class="sect-head"><div><h2>Settings</h2><p>Your details, password and notifications.</p></div></div>
          <div class="set-grid">
            <div class="card set-block">
              <h3>Profile</h3><div class="desc">The name &amp; email on your account. Update and click Save.</div>
              {%- form 'customer' -%}
                {%- if form.posted_successfully? -%}<div style="background:var(--mint);border:var(--rule-1);border-radius:12px;padding:10px 14px;font-size:13px;color:var(--sf-ink);margin-bottom:14px">{{ icCheck }} Profile updated.</div>{%- endif -%}
                {%- if form.errors -%}<div style="background:var(--vip-soft);border:1.5px solid var(--vip-ink);border-radius:12px;padding:10px 14px;font-size:13px;color:var(--vip-ink);margin-bottom:14px">{{ form.errors | default_errors }}</div>{%- endif -%}
                <div class="set-row2"><div class="field"><label>First name</label><input type="text" name="customer[first_name]" value="{{ customer.first_name | escape }}"></div><div class="field"><label>Last name</label><input type="text" name="customer[last_name]" value="{{ customer.last_name | escape }}"></div></div>
                <div class="field"><label>Email address</label><input type="email" name="customer[email]" value="{{ customer.email }}"></div>
                <div class="set-actions"><button class="btn-ink" type="submit">Save changes {{ icArrow }}</button></div>
              {%- endform -%}
            </div>
            <div class="card set-block">
              <h3>Password</h3><div class="desc">We'll email you a secure link to set a new password.</div>
              {%- form 'recover_customer_password' -%}
                {%- if form.posted_successfully? -%}<div style="background:var(--mint);border:var(--rule-1);border-radius:12px;padding:10px 14px;font-size:13px;color:var(--sf-ink);margin-bottom:12px">{{ icCheck }} Reset link sent to your email.</div>{%- endif -%}
                <input type="hidden" name="email" value="{{ customer.email }}">
                <div class="set-actions"><button class="btn-ink" type="submit" style="height:48px">Send password reset email</button></div>
              {%- endform -%}
            </div>
            <div class="card set-block">
              <h3>Notifications</h3><div class="desc">Pick what lands in your inbox.</div>
              <div class="toggle-line"><div><div class="nm">New flavor drops</div><div class="ds">Be first to know when we launch a flavor</div></div><button class="sw on" data-sw role="switch" aria-checked="true"><span class="knob"></span></button></div>
              <div class="toggle-line"><div><div class="nm">Back-in-stock alerts</div><div class="ds">Email me when a sold-out favorite returns</div></div><button class="sw on" data-sw role="switch" aria-checked="true"><span class="knob"></span></button></div>
              <div class="toggle-line"><div><div class="nm">Rewards &amp; VIP news</div><div class="ds">Points milestones and member-only events</div></div><button class="sw on" data-sw role="switch" aria-checked="true"><span class="knob"></span></button></div>
            </div>
            <div class="card set-block" style="border-color:var(--vip);box-shadow:var(--shadow-vip)">
              <h3 style="color:var(--vip-ink)">Danger zone</h3><div class="desc">Closing your account also ends your free VIP membership.</div>
              <div class="set-actions"><a class="btn-ghost" style="color:var(--vip-ink);border-color:var(--vip)" href="/pages/contact-us">Close account</a></div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
  <div class="toast" data-toast></div>
</div>

<script>
(function(){
  var root=document.querySelector('[data-sdash]'); if(!root) return;
  var toastEl=root.querySelector('[data-toast]'), tT;
  function toast(m){ if(!toastEl)return; toastEl.textContent=m; toastEl.classList.add('show'); clearTimeout(tT); tT=setTimeout(function(){toastEl.classList.remove('show');},2200); }
  var navs=[].slice.call(root.querySelectorAll('[data-nav]')), panels=[].slice.call(root.querySelectorAll('[data-panel]'));
  function go(id){ navs.forEach(function(b){ if(b.hasAttribute('data-nav')&&b.classList.contains('dnav-item')) b.classList.toggle('on', b.getAttribute('data-nav')===id); }); panels.forEach(function(p){ p.classList.toggle('show', p.getAttribute('data-panel')===id); }); try{ history.replaceState(null,'','#'+id); }catch(e){} window.scrollTo({top:0,behavior:'smooth'}); }
  root.addEventListener('click',function(e){ var b=e.target.closest('[data-nav]'); if(b){ e.preventDefault(); go(b.getAttribute('data-nav')); } });
  if(location.hash){ var h=location.hash.slice(1); if(panels.some(function(p){return p.getAttribute('data-panel')===h;})) go(h); }
  [].slice.call(root.querySelectorAll('[data-sw]')).forEach(function(sw){ sw.addEventListener('click',function(){ var on=sw.classList.toggle('on'); sw.setAttribute('aria-checked', on?'true':'false'); }); });
  root.addEventListener('click',function(e){ var b=e.target.closest('[data-reorder]'); if(!b)return; var id=b.getAttribute('data-reorder'); b.disabled=true; fetch('/account/orders/'+id+'.js').then(function(r){return r.ok?r.json():Promise.reject();}).then(function(o){ var items=(o.line_items||[]).filter(function(l){return l.product_exists!==false && l.variant_id;}).map(function(l){return {id:l.variant_id, quantity:l.quantity};}); if(!items.length){ throw 0; } return fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({items:items})}); }).then(function(){ toast('Items added to cart'); setTimeout(function(){window.location.href='/cart';},700); }).catch(function(){ b.disabled=false; toast('Could not reorder — some items may be unavailable'); }); });
})();
</script>

{% schema %}
{ "name": "Account (Custom)", "settings": [], "presets": [{ "name": "Account (Custom)" }] }
{% endschema %}
