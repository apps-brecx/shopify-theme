{{ 'pdp-brand.css' | asset_url | stylesheet_tag }}

{%- comment -%} ===== Flavor color theming + copy (dynamic, from product title) ===== {%- endcomment -%}
{%- assign t_lc = product.title | downcase -%}
{%- assign is_sf = false -%}
{%- if t_lc contains 'sugar-free' or t_lc contains 'sugar free' -%}{%- assign is_sf = true -%}{%- endif -%}
{%- assign si_main = '#FFD4B8' -%}
{%- assign si_accent = '#FCE2A0' -%}
{%- assign si_glow = '#FFD4B8' -%}
{%- assign si_glow2 = '#B8DCEB' -%}
{%- assign si_band = '#FCE2A0' -%}
{%- assign flavor_name = 'snow cone' -%}
{%- if t_lc contains 'blue raspberry' -%}
  {%- assign si_main = '#B8DCEB' -%}{%- assign si_accent = '#5BA3D0' -%}{%- assign si_glow = '#B8DCEB' -%}{%- assign si_glow2 = '#E0F2FA' -%}{%- assign si_band = '#B8DCEB' -%}{%- assign flavor_name = 'blue raspberry' -%}
{%- elsif t_lc contains 'blue cotton candy' -%}
  {%- assign si_main = '#A8D8F0' -%}{%- assign si_accent = '#F5C7BE' -%}{%- assign si_glow = '#A8D8F0' -%}{%- assign si_glow2 = '#FFD4E5' -%}{%- assign si_band = '#A8D8F0' -%}{%- assign flavor_name = 'cotton candy' -%}
{%- elsif t_lc contains 'cherry' -%}
  {%- assign si_main = '#F5C7BE' -%}{%- assign si_accent = '#D14B3F' -%}{%- assign si_glow = '#F5C7BE' -%}{%- assign si_glow2 = '#FFE8E5' -%}{%- assign si_band = '#F5C7BE' -%}{%- assign flavor_name = 'cherry' -%}
{%- elsif t_lc contains 'grape' -%}
  {%- assign si_main = '#D4B8E0' -%}{%- assign si_accent = '#6B3F8C' -%}{%- assign si_glow = '#D4B8E0' -%}{%- assign si_glow2 = '#E8D5F0' -%}{%- assign si_band = '#D4B8E0' -%}{%- assign flavor_name = 'grape' -%}
{%- elsif t_lc contains 'pina colada' -%}
  {%- assign si_main = '#FCE2A0' -%}{%- assign si_accent = '#C5E4D4' -%}{%- assign si_glow = '#FCE2A0' -%}{%- assign si_glow2 = '#C5E4D4' -%}{%- assign si_band = '#FCE2A0' -%}{%- assign flavor_name = 'piña colada' -%}
{%- elsif t_lc contains 'bubble gum' -%}
  {%- assign si_main = '#FFD4E5' -%}{%- assign si_accent = '#FF8FB8' -%}{%- assign si_glow = '#FFD4E5' -%}{%- assign si_glow2 = '#FFE8F0' -%}{%- assign si_band = '#FFD4E5' -%}{%- assign flavor_name = 'bubble gum' -%}
{%- elsif t_lc contains 'root beer' -%}
  {%- assign si_main = '#D4A574' -%}{%- assign si_accent = '#7A4F2A' -%}{%- assign si_glow = '#E8C9A0' -%}{%- assign si_glow2 = '#FCE2A0' -%}{%- assign si_band = '#E8C9A0' -%}{%- assign flavor_name = 'root beer' -%}
{%- elsif t_lc contains 'lime' -%}
  {%- assign si_main = '#C5E4D4' -%}{%- assign si_accent = '#5A9968' -%}{%- assign si_glow = '#C5E4D4' -%}{%- assign si_glow2 = '#E5F3E0' -%}{%- assign si_band = '#C5E4D4' -%}{%- assign flavor_name = 'lime' -%}
{%- elsif t_lc contains 'orange' -%}
  {%- assign si_main = '#FFD4B8' -%}{%- assign si_accent = '#E87E2A' -%}{%- assign si_glow = '#FFD4B8' -%}{%- assign si_glow2 = '#FFE8D5' -%}{%- assign si_band = '#FFD4B8' -%}{%- assign flavor_name = 'orange' -%}
{%- elsif t_lc contains 'strawberry' -%}
  {%- assign si_main = '#F5C7BE' -%}{%- assign si_accent = '#E85541' -%}{%- assign si_glow = '#F5C7BE' -%}{%- assign si_glow2 = '#FFE0DA' -%}{%- assign si_band = '#F5C7BE' -%}{%- assign flavor_name = 'strawberry' -%}
{%- elsif t_lc contains 'fruit punch' -%}
  {%- assign si_main = '#F5C7BE' -%}{%- assign si_accent = '#E85541' -%}{%- assign si_glow = '#FFD4B8' -%}{%- assign si_glow2 = '#F5C7BE' -%}{%- assign si_band = '#F5C7BE' -%}{%- assign flavor_name = 'fruit punch' -%}
{%- endif -%}
{%- assign flavor_cap = flavor_name | capitalize -%}

{%- assign band_color = section.settings.band_color | default: si_band -%}

{% style %}
  #shopify-section-{{ section.id }} .pd-cat-recipes { background: var(--si-band-tint, {{ band_color }}) !important; }
{% endstyle %}

<div class="pd">
  <section class="pd-cat-recipes">
    <div class="pd-wrap" style="text-align:center;">
      <span class="pd-eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="pd-h2" style="margin:14px auto 14px;">{{ section.settings.heading_pre }}<em>{{ section.settings.heading_em }}</em>{{ section.settings.heading_post }}</h2>
      <p class="pd-cat-recipes-sub">{{ section.settings.sub }}</p>
    </div>
    <div class="pd-cat-recipes-scroll">
      <button type="button" class="pd-cat-recipes-nav pd-cat-recipes-nav--prev" aria-label="Previous"><svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M15 6 l-6 6 6 6"/></svg></button>
      <div class="pd-cat-recipes-marquee">
        <div class="pd-cat-recipes-track">
          <div class="pd-cat-recipes-card"><span class="pd-cat-recipes-tag">{{ section.settings.c1_tag }}</span><h3 class="pd-cat-recipes-card-title">{{ section.settings.c1_title | replace: '[flavor]', flavor_cap | replace: '[flavor_lc]', flavor_name }}</h3><p class="pd-cat-recipes-card-body">{{ section.settings.c1_body | replace: '[flavor]', flavor_cap | replace: '[flavor_lc]', flavor_name }}</p></div>
          <div class="pd-cat-recipes-card"><span class="pd-cat-recipes-tag">{{ section.settings.c2_tag }}</span><h3 class="pd-cat-recipes-card-title">{{ section.settings.c2_title | replace: '[flavor]', flavor_cap | replace: '[flavor_lc]', flavor_name }}</h3><p class="pd-cat-recipes-card-body">{{ section.settings.c2_body | replace: '[flavor]', flavor_cap | replace: '[flavor_lc]', flavor_name }}</p></div>
          <div class="pd-cat-recipes-card"><span class="pd-cat-recipes-tag">{{ section.settings.c3_tag }}</span><h3 class="pd-cat-recipes-card-title">{{ section.settings.c3_title | replace: '[flavor]', flavor_cap | replace: '[flavor_lc]', flavor_name }}</h3><p class="pd-cat-recipes-card-body">{{ section.settings.c3_body | replace: '[flavor]', flavor_cap | replace: '[flavor_lc]', flavor_name }}</p></div>
          <div class="pd-cat-recipes-card"><span class="pd-cat-recipes-tag">{{ section.settings.c4_tag }}</span><h3 class="pd-cat-recipes-card-title">{{ section.settings.c4_title | replace: '[flavor]', flavor_cap | replace: '[flavor_lc]', flavor_name }}</h3><p class="pd-cat-recipes-card-body">{{ section.settings.c4_body | replace: '[flavor]', flavor_cap | replace: '[flavor_lc]', flavor_name }}</p></div>
          <div class="pd-cat-recipes-card"><span class="pd-cat-recipes-tag">{{ section.settings.c5_tag }}</span><h3 class="pd-cat-recipes-card-title">{{ section.settings.c5_title | replace: '[flavor]', flavor_cap | replace: '[flavor_lc]', flavor_name }}</h3><p class="pd-cat-recipes-card-body">{{ section.settings.c5_body | replace: '[flavor]', flavor_cap | replace: '[flavor_lc]', flavor_name }}</p></div>
          <div class="pd-cat-recipes-card"><span class="pd-cat-recipes-tag">{{ section.settings.c6_tag }}</span><h3 class="pd-cat-recipes-card-title">{{ section.settings.c6_title | replace: '[flavor]', flavor_cap | replace: '[flavor_lc]', flavor_name }}</h3><p class="pd-cat-recipes-card-body">{{ section.settings.c6_body | replace: '[flavor]', flavor_cap | replace: '[flavor_lc]', flavor_name }}</p></div>
        </div>
      </div>
      <button type="button" class="pd-cat-recipes-nav pd-cat-recipes-nav--next" aria-label="Next"><svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6 l6 6 -6 6"/></svg></button>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "SI Ways to Pour",
  "tag": "section",
  "class": "section-si-cat-recipes",
  "enabled_on": { "templates": ["product"] },
  "settings": [
    { "type": "header", "content": "Heading" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Ways to pour" },
    { "type": "text", "id": "heading_pre", "label": "Heading before emphasis", "default": "Way more than a " },
    { "type": "text", "id": "heading_em", "label": "Heading emphasis (italic)", "default": "snow cone" },
    { "type": "text", "id": "heading_post", "label": "Heading after emphasis", "default": "." },
    { "type": "text", "id": "sub", "label": "Sub-text", "default": "One bottle, a dozen frosty creations." },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "band_color", "label": "Section background", "info": "Leave blank to auto-match the flavor color." },
    { "type": "header", "content": "Card 1" },
    { "type": "text", "id": "c1_tag", "label": "Tag", "default": "Snow Cone" },
    { "type": "text", "id": "c1_title", "label": "Title", "info": "Use [flavor] (capitalized) or [flavor_lc] (lowercase) for the flavor name.", "default": "Classic Snow Cone" },
    { "type": "text", "id": "c1_body", "label": "Body", "info": "Use [flavor] (capitalized) or [flavor_lc] (lowercase) for the flavor name.", "default": "Fill a cup with shaved ice. Pour 2-3 oz of [flavor_lc] syrup. Sip + crunch." },
    { "type": "header", "content": "Card 2" },
    { "type": "text", "id": "c2_tag", "label": "Tag", "default": "Slushie" },
    { "type": "text", "id": "c2_title", "label": "Title", "default": "Frozen Slushie" },
    { "type": "text", "id": "c2_body", "label": "Body", "default": "Blend 2 cups crushed ice with 4 oz syrup until icy. Done in 30 seconds." },
    { "type": "header", "content": "Card 3" },
    { "type": "text", "id": "c3_tag", "label": "Tag", "default": "Ice Pop" },
    { "type": "text", "id": "c3_title", "label": "Title", "default": "Backyard Ice Pops" },
    { "type": "text", "id": "c3_body", "label": "Body", "default": "Mix syrup with water (1:3 ratio), freeze in pop molds. Summer in a stick." },
    { "type": "header", "content": "Card 4" },
    { "type": "text", "id": "c4_tag", "label": "Tag", "default": "Soda" },
    { "type": "text", "id": "c4_title", "label": "Title", "default": "Homemade Soda" },
    { "type": "text", "id": "c4_body", "label": "Body", "default": "2 oz syrup + 10 oz sparkling water over ice. Italian-soda style." },
    { "type": "header", "content": "Card 5" },
    { "type": "text", "id": "c5_tag", "label": "Tag", "default": "Cocktail" },
    { "type": "text", "id": "c5_title", "label": "Title", "info": "Use [flavor] for the capitalized flavor name.", "default": "[flavor] Spritz" },
    { "type": "text", "id": "c5_body", "label": "Body", "default": "1 oz syrup + 2 oz vodka or rum + soda + ice. Party drink in 30 seconds." },
    { "type": "header", "content": "Card 6" },
    { "type": "text", "id": "c6_tag", "label": "Tag", "default": "Shake" },
    { "type": "text", "id": "c6_title", "label": "Title", "info": "Use [flavor] for the capitalized flavor name.", "default": "[flavor] Milkshake" },
    { "type": "text", "id": "c6_body", "label": "Body", "default": "Blend 2 scoops vanilla ice cream, 1/2 cup milk, 2 oz syrup. Old-school diner vibe." }
  ],
  "presets": [{ "name": "SI Ways to Pour" }]
}
{% endschema %}
