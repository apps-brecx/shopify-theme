{{ 'pdp-brand.css' | asset_url | stylesheet_tag }}
{% render 'pd-fixes' %}
{% render 'pd-tweaks' %}
{% render 'pd-rv2-affordances' %}
{% render 'pd-reviews-style' %}
{% render 'pd-color-swap' %}
{% render 'pd-page-polish-v2' %}
{% render 'pd-sale-display' %}

{%- comment -%}
  ═══════════════════════════════════════════════════════════════
  CSS variable injection from schema settings.
  Scoped to this section so other instances/templates aren't affected.
  Loaded inline with HTML — no FOUC on first paint.
  ═══════════════════════════════════════════════════════════════
{%- endcomment -%}
{% style %}
  #shopify-section-{{ section.id }} {
    --pd-text: {{ section.settings.text_primary }};
    --pd-brand: {{ section.settings.text_brand }};
    --pd-bg: {{ section.settings.bg_section }};
    --pd-accent: {{ section.settings.accent_color }};
    --pd-star: {{ section.settings.star_color }};
    --pd-h1-max: {{ section.settings.h1_font_size_max }}px;
    --pd-h2: {{ section.settings.h2_font_size }}px;
    --pd-eyebrow-size: {{ section.settings.eyebrow_font_size }}px;
    --pd-hero-pad-top: {{ section.settings.hero_padding_top }}px;
    --pd-hero-pad-bottom: {{ section.settings.hero_padding_bottom }}px;
    --pd-sec-pad-top: {{ section.settings.section_padding_top }}px;
    --pd-sec-pad-bottom: {{ section.settings.section_padding_bottom }}px;
    --pd-wrap: {{ section.settings.wrap_max_width }}px;
    --pd-cta-bg: {{ section.settings.cta_color_bg }};
    --pd-cta-text: {{ section.settings.cta_color_text }};

    /* Per-section backgrounds & text */
    --pd-bc-text: {{ section.settings.breadcrumb_text_color }};
    --pd-hero-bg: {{ section.settings.hero_bg }};
    --pd-marquee-bg: {{ section.settings.marquee_bg }};
    --pd-marquee-text: {{ section.settings.marquee_text }};
    --pd-desc-bg: {{ section.settings.desc_bg }};
    --pd-desc-card-bg: {{ section.settings.desc_card_bg }};
    --pd-desc-text: {{ section.settings.desc_text_color }};
    --pd-why-bg: {{ section.settings.why_bg }};
    --pd-why-text: {{ section.settings.why_text_color }};
    --pd-ugc-bg: {{ section.settings.ugc_bg }};
    --pd-ugc-text: {{ section.settings.ugc_text_color }};
    --pd-sticky-bg: {{ section.settings.sticky_bg }};
    --pd-sticky-text: {{ section.settings.sticky_text_color }};
    --pd-sale-bg: {{ section.settings.sale_badge_bg }};
    --pd-sale-text: {{ section.settings.sale_badge_text }};
    --pd-eyebrow-bg: {{ section.settings.eyebrow_bg }};
    --pd-eyebrow-text: {{ section.settings.eyebrow_text_color }};

    /* Accent palette (chips, cards, emphasis) — overrides pdp-brand.css tokens */
    --peach: {{ section.settings.palette_peach }};
    --butter: {{ section.settings.palette_butter }};
    --mint: {{ section.settings.palette_mint }};
    --sky: {{ section.settings.palette_sky }};
    --blush: {{ section.settings.palette_blush }};
    --coral: {{ section.settings.palette_coral }};
  }

  /* Apply variables to page elements */
  #shopify-section-{{ section.id }} .pd {
    background: var(--pd-bg) !important;
    color: var(--pd-text) !important;
  }
  #shopify-section-{{ section.id }} .pd-wrap {
    max-width: var(--pd-wrap) !important;
  }

  /* Hero spacing */
  #shopify-section-{{ section.id }} .pd-hero {
    padding-top: var(--pd-hero-pad-top) !important;
    padding-bottom: var(--pd-hero-pad-bottom) !important;
  }

  /* Section spacing (description, why, ugc) */
  #shopify-section-{{ section.id }} .pd-description,
  #shopify-section-{{ section.id }} .pd-why,
  #shopify-section-{{ section.id }} .pd-ugc {
    padding-top: var(--pd-sec-pad-top) !important;
    padding-bottom: var(--pd-sec-pad-bottom) !important;
  }

  /* Typography */
  #shopify-section-{{ section.id }} .pd-h1 {
    font-size: clamp(28px, 8vw, var(--pd-h1-max)) !important;
    color: var(--pd-brand) !important;
  }
  #shopify-section-{{ section.id }} .pd-h2 {
    font-size: var(--pd-h2) !important;
    color: var(--pd-brand) !important;
  }
  #shopify-section-{{ section.id }} .pd-eyebrow {
    font-size: var(--pd-eyebrow-size) !important;
  }

  /* Stars */
  #shopify-section-{{ section.id }} .pd-stars svg {
    fill: var(--pd-star) !important;
    stroke: var(--pd-star) !important;
  }

  /* Add to cart button */
  #shopify-section-{{ section.id }} .pd-atc,
  #shopify-section-{{ section.id }} .pd-stickybar .pd-atc {
    background: var(--pd-cta-bg) !important;
    color: var(--pd-cta-text) !important;
  }
  #shopify-section-{{ section.id }} .pd-atc:hover {
    filter: brightness(0.92);
  }

  /* Accent color usage (Read more, links) */
  #shopify-section-{{ section.id }} .pd-blurb-more,
  #shopify-section-{{ section.id }} .pd-variant-link strong {
    color: var(--pd-accent) !important;
  }

  /* Mobile-only slider (preserved from original) */
  #shopify-section-{{ section.id }} .pd-slider-mobile { display: none; }
  #shopify-section-{{ section.id }} .pd-slider-dots { display: none; }
  @media (max-width: 760px) {
    #shopify-section-{{ section.id }} .pd-hero-frame { display: none !important; }
    #shopify-section-{{ section.id }} .pd-thumbs { display: none !important; }
    #shopify-section-{{ section.id }} .pd-slider-mobile {
      display: block !important;
      position: relative;
      background: var(--pd-bg) !important;
      border: 2px solid var(--pd-brand) !important;
      border-radius: 20px;
      padding: 0;
      box-shadow: 4px 4px 0 var(--pd-brand) !important;
      overflow: hidden;
      max-width: 340px;
      margin: 0 auto;
    }
    #shopify-section-{{ section.id }} .pd-slides {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      width: 100%;
      position: relative;
      z-index: 0;
    }
    #shopify-section-{{ section.id }} .pd-slides::-webkit-scrollbar { display: none; }
    #shopify-section-{{ section.id }} .pd-slide { flex: 0 0 100%; scroll-snap-align: start; min-width: 100%; }
    #shopify-section-{{ section.id }} .pd-slide img {
      width: 100%;
      height: auto;
      display: block;
      aspect-ratio: 1/1;
      object-fit: cover;
    }
    #shopify-section-{{ section.id }} .pd-slider-dots {
      display: flex !important;
      justify-content: center;
      gap: 5px;
      margin-top: 10px;
    }
  }

  /* Price row alignment (preserved from original) */
  #shopify-section-{{ section.id }} .pd .pd-price-row {
    display: flex !important;
    align-items: center !important;
    gap: 10px !important;
    flex-wrap: wrap !important;
  }
  #shopify-section-{{ section.id }} .pd .pd-stickybar .pd-price {
    display: inline-flex !important;
    align-items: center !important;
    gap: 8px !important;
    flex-wrap: wrap !important;
  }

  /* ── Per-section background & text overrides ─────────────────── */
  /* Breadcrumbs */
  #shopify-section-{{ section.id }} .pd-breadcrumbs,
  #shopify-section-{{ section.id }} .pd-breadcrumbs a,
  #shopify-section-{{ section.id }} .pd-breadcrumbs .pd-bc-current {
    color: var(--pd-bc-text) !important;
  }

  /* Hero */
  #shopify-section-{{ section.id }} .pd-hero {
    background: var(--pd-hero-bg) !important;
  }

  /* Marquee */
  #shopify-section-{{ section.id }} .pd-marquee {
    background: var(--pd-marquee-bg) !important;
    color: var(--pd-marquee-text) !important;
  }
  #shopify-section-{{ section.id }} .pd-marquee-track span {
    color: var(--pd-marquee-text) !important;
  }

  /* Description section */
  #shopify-section-{{ section.id }} .pd-description {
    background: var(--pd-desc-bg) !important;
  }
  #shopify-section-{{ section.id }} .pd-desc-card,
  #shopify-section-{{ section.id }} .pd-desc-card.pd-ing-card,
  #shopify-section-{{ section.id }} .pd-desc-card.pd-nf-card {
    background: var(--pd-desc-card-bg) ;
  }
  #shopify-section-{{ section.id }} .pd-desc-label,
  #shopify-section-{{ section.id }} .pd-desc-text {
    color: var(--pd-desc-text) !important;
  }

  /* Why section */
  #shopify-section-{{ section.id }} .pd-why {
    background: var(--pd-why-bg) !important;
  }
  #shopify-section-{{ section.id }} .pd-why-body {
    color: var(--pd-why-text) !important;
  }

  /* UGC section */
  #shopify-section-{{ section.id }} .pd-ugc {
    background: var(--pd-ugc-bg) !important;
    color: var(--pd-ugc-text) !important;
  }
  #shopify-section-{{ section.id }} .pd-ugc .pd-h2 {
    color: var(--pd-ugc-text) !important;
  }

  /* Sticky bar */
  #shopify-section-{{ section.id }} .pd-stickybar {
    background: var(--pd-sticky-bg) !important;
  }
  #shopify-section-{{ section.id }} .pd-stickybar .pd-price {
    color: var(--pd-sticky-text) !important;
  }

  /* Sale badge */
  #shopify-section-{{ section.id }} .pd-sale-badge {
    background: var(--pd-sale-bg) !important;
    color: var(--pd-sale-text) !important;
  }

  /* Eyebrow labels */
  #shopify-section-{{ section.id }} .pd-eyebrow {
    background: var(--pd-eyebrow-bg) !important;
    color: var(--pd-eyebrow-text) !important;
  }
{% endstyle %}

{%- assign hero_img = product.featured_media.preview_image -%}
{%- assign hero_src = hero_img | image_url: width: 1400 -%}

<link rel="preload" as="image" href="{{ hero_src }}" imagesrcset="{{ hero_img | image_url: width: 600 }} 600w, {{ hero_img | image_url: width: 1000 }} 1000w, {{ hero_img | image_url: width: 1400 }} 1400w" imagesizes="(max-width: 980px) 100vw, 600px" fetchpriority="high">

{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign compare_at = current_variant.compare_at_price -%}
{%- assign price = current_variant.price -%}

{%- assign is_sf = false -%}
{%- assign t_lc = product.title | downcase -%}
{%- if t_lc contains 'sugar-free' or t_lc contains 'sugar free' -%}{%- assign is_sf = true -%}{%- endif -%}

{%- assign is_vip = false -%}
{%- if customer and customer.tags contains 'VIP' -%}{%- assign is_vip = true -%}{%- endif -%}

{%- assign display_price = price -%}
{%- if is_vip and price > 799 -%}{%- assign display_price = 799 -%}{%- endif -%}

{%- assign has_sale = false -%}
{%- if compare_at and compare_at > price -%}{%- assign has_sale = true -%}{%- endif -%}
{%- assign sale_pct = 0 -%}
{%- if has_sale -%}
  {%- assign sale_diff = compare_at | minus: price -%}
  {%- assign sale_pct = sale_diff | times: 100 | divided_by: compare_at -%}
{%- endif -%}

{%- comment -%} Counterpart: regular products store it in custom.sugar_free, sugar-free products in custom.regular. {%- endcomment -%}
{%- if is_sf -%}{%- assign counterpart = product.metafields.custom.regular.value -%}{%- else -%}{%- assign counterpart = product.metafields.custom.sugar_free.value -%}{%- endif -%}
{%- if counterpart == blank -%}{%- assign counterpart = product.metafields.custom.sugar_free.value | default: product.metafields.custom.regular.value -%}{%- endif -%}
{%- assign ingredients_field = product.metafields.custom.additionalfield -%}
{%- assign review_count = product.metafields.reviews.rating_count.value | default: 0 -%}

<div class="pd" data-product-id="{{ product.id }}" data-base-price="{{ display_price }}">

  {%- if section.settings.show_breadcrumbs -%}
    <nav class="pd-breadcrumbs" aria-label="Breadcrumb">
      <div class="pd-wrap">
        <ol>
          <li><a href="/">{{ section.settings.breadcrumb_home }}</a></li>
          <li class="pd-bc-sep" aria-hidden="true">/</li>
          <li><a href="/collections/all">{{ section.settings.breadcrumb_category }}</a></li>
          <li class="pd-bc-sep" aria-hidden="true">/</li>
          <li class="pd-bc-current">{{ product.title }}</li>
        </ol>
      </div>
    </nav>
  {%- endif -%}

  <section class="pd-hero">
    <div class="pd-wrap">
      <div class="pd-hero-grid">

        <div class="pd-hero-media">
          <div class="pd-hero-frame">
            <img id="pdHeroImg" src="{{ hero_src }}" alt="{{ product.title | escape }}" width="1200" height="1200" fetchpriority="high">
          </div>
          {%- if product.images.size > 1 -%}
            <div class="pd-thumbs">
              {%- for img in product.images limit: 4 -%}
                <button type="button" class="pd-thumb{% if forloop.first %} is-active{% endif %}" data-src="{{ img | image_url: width: 1400 }}" aria-label="View image {{ forloop.index }}"><img src="{{ img | image_url: width: 200 }}" alt="" width="200" height="200" loading="lazy"></button>
              {%- endfor -%}
            </div>
          {%- endif -%}

          <div class="pd-slider-mobile">
            <div class="pd-slides" id="pdSlides">
              {%- for img in product.images -%}
                <div class="pd-slide" data-idx="{{ forloop.index0 }}">
                  <img src="{{ img | image_url: width: 1000 }}" alt="{{ product.title | escape }}" {% if forloop.first %}fetchpriority="high"{% else %}loading="lazy"{% endif %}>
                </div>
              {%- endfor -%}
            </div>
          </div>
          {%- if product.images.size > 1 -%}
            <div class="pd-slider-dots" id="pdDots">
              {%- for img in product.images -%}
                <button type="button" class="pd-dot{% if forloop.first %} is-active{% endif %}" data-idx="{{ forloop.index0 }}" aria-label="View image {{ forloop.index }}"></button>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>

        <div class="pd-hero-info">

          <a href="#reviews" class="pd-rating-row">
            <span class="pd-stars" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="{{ section.settings.star_color }}" stroke="{{ section.settings.star_color }}" stroke-width="1" stroke-linejoin="round"><path d="M12 2 L14.6 8.4 L21.5 9 L16.3 13.6 L17.9 20.4 L12 16.9 L6.1 20.4 L7.7 13.6 L2.5 9 L9.4 8.4 Z"/></svg>
              <svg viewBox="0 0 24 24" fill="{{ section.settings.star_color }}" stroke="{{ section.settings.star_color }}" stroke-width="1" stroke-linejoin="round"><path d="M12 2 L14.6 8.4 L21.5 9 L16.3 13.6 L17.9 20.4 L12 16.9 L6.1 20.4 L7.7 13.6 L2.5 9 L9.4 8.4 Z"/></svg>
              <svg viewBox="0 0 24 24" fill="{{ section.settings.star_color }}" stroke="{{ section.settings.star_color }}" stroke-width="1" stroke-linejoin="round"><path d="M12 2 L14.6 8.4 L21.5 9 L16.3 13.6 L17.9 20.4 L12 16.9 L6.1 20.4 L7.7 13.6 L2.5 9 L9.4 8.4 Z"/></svg>
              <svg viewBox="0 0 24 24" fill="{{ section.settings.star_color }}" stroke="{{ section.settings.star_color }}" stroke-width="1" stroke-linejoin="round"><path d="M12 2 L14.6 8.4 L21.5 9 L16.3 13.6 L17.9 20.4 L12 16.9 L6.1 20.4 L7.7 13.6 L2.5 9 L9.4 8.4 Z"/></svg>
              <svg viewBox="0 0 24 24" fill="{{ section.settings.star_color }}" stroke="{{ section.settings.star_color }}" stroke-width="1" stroke-linejoin="round"><path d="M12 2 L14.6 8.4 L21.5 9 L16.3 13.6 L17.9 20.4 L12 16.9 L6.1 20.4 L7.7 13.6 L2.5 9 L9.4 8.4 Z"/></svg>
            </span>
            <span class="pd-rating-text">{{ review_count }} reviews</span>
          </a>

          <h1 class="pd-h1">{{ product.title | upcase }}</h1>

          <div class="pd-chips">
            {%- if is_sf -%}
              <span class="pd-chip pd-chip--blush"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><circle cx="12" cy="12" r="9"/><path d="M5 5l14 14"/></svg>Sugar-Free</span>
            {%- else -%}
              <span class="pd-chip pd-chip--butter"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 C 7 6, 7 14, 12 22 C 17 14, 17 6, 12 2 Z M12 7 V 18"/></svg>Pure Cane Sugar</span>
            {%- endif -%}
            <span class="pd-chip pd-chip--mint"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3 C 7 9, 5 13, 5 16 a 7 7 0 0 0 14 0 c 0 -3 -2 -7 -7 -13 Z"/></svg>50+ Servings</span>
            <span class="pd-chip pd-chip--sky"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12 l4 4 L19 7"/></svg>Gluten-Free · Kosher</span>
            <span class="pd-chip pd-chip--peach"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M4 22 V 4 l 6 2 l 6 -2 l 4 2 v 14 l -4 -2 l -6 2 l -6 -2 Z"/></svg>Made in USA</span>
          </div>

          {%- if counterpart != blank -%}
            <a href="/products/{{ counterpart.handle }}" class="pd-variant-link">
              {%- if is_sf -%}Prefer the original? <strong>Try Regular</strong>{%- else -%}Prefer no sugar? <strong>Try Sugar-Free</strong>{%- endif -%}
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12 h14 M13 6 l6 6 -6 6"/></svg>
            </a>
          {%- endif -%}

          {%- form 'product', product, id: 'pdAtcForm', class: 'pd-form' -%}
            <input type="hidden" name="id" value="{{ current_variant.id }}">
            {% render 'pd-purchase-options' %}
            <div class="pd-priceqty">
              <div class="pd-priceblock">
                <div class="pd-price-row">
                  <span class="pd-price" id="pdPriceTotal">{{ display_price | money }}</span>
                  {%- if has_sale -%}
                    <span class="pd-price-original" id="pdPriceCompareAt">{{ compare_at | money }}</span>
                    <span class="pd-sale-badge">Save {{ sale_pct }}%</span>
                  {%- endif -%}
                  {% render 'pd-vip-pricing', variant: 'main', price: price %}
                  <span class="pd-price-was" id="pdPriceWas" style="display:none"></span>
                </div>
                <span class="pd-save-inline" id="pdSaveTag" style="display:none"></span>
              </div>
              <div class="pd-qty" aria-label="Quantity">
                <button type="button" data-qty="-1" aria-label="Decrease">−</button>
                <input type="number" name="quantity" value="1" min="1" inputmode="numeric">
                <button type="button" data-qty="1" aria-label="Increase">+</button>
              </div>
            </div>
            <button type="submit" class="pd-atc pd-atc--full" {% unless product.available %}disabled{% endunless %}>
              <svg class="pd-atc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 L4 6 V20 a2 2 0 0 0 2 2 H18 a2 2 0 0 0 2 -2 V6 L18 2 Z M4 6 H20 M16 10 a4 4 0 0 1 -8 0"/></svg>
              <span class="pd-atc-text" id="pdAtcText">{%- if product.available -%}Add to cart{%- else -%}Sold Out{%- endif -%}</span>
              {%- if product.available -%}<svg class="pd-atc-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12 H19 M13 6 l6 6 -6 6"/></svg>{%- endif -%}
            </button>
          {%- endform -%}

          {%- if section.settings.show_mini_bundle -%}
            <div class="pd-minibundle">
              <div class="pd-mb-head">
                <span class="pd-mb-headline">Add more, save more</span>
                <span class="pd-mb-sub">Tap a tier to apply</span>
              </div>
              <div class="pd-mb-grid">
                <button type="button" class="pd-mb-cell" data-tier="2">
                  <span class="pd-mb-num">2</span>
                  <span class="pd-mb-label">Bottles</span>
                  <span class="pd-mb-save">Save 5%</span>
                </button>
                <button type="button" class="pd-mb-cell" data-tier="3">
                  <span class="pd-mb-flag">Most Popular</span>
                  <span class="pd-mb-num">3</span>
                  <span class="pd-mb-label">Bottles</span>
                  <span class="pd-mb-save">Save 10%</span>
                </button>
                <button type="button" class="pd-mb-cell" data-tier="4">
                  <span class="pd-mb-num">4+</span>
                  <span class="pd-mb-label">Bottles</span>
                  <span class="pd-mb-save">Save 15%</span>
                </button>
              </div>
            </div>
          {%- endif -%}

        </div>
      </div>
    </div>
  </section>

  {%- if section.settings.show_marquee -%}
    <div class="pd-marquee" aria-hidden="true">
      <div class="pd-marquee-track">
        {%- assign marquee_lines = section.settings.marquee_items | newline_to_br | split: '<br />' -%}
        {%- for i in (1..2) -%}
          {%- for line in marquee_lines -%}
            {%- assign trimmed = line | strip -%}
            {%- if trimmed != blank -%}
              <span>{{ trimmed }}</span>
            {%- endif -%}
          {%- endfor -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- if section.settings.show_description -%}
    <section class="pd-description">
      <div class="pd-wrap">
        <div class="pd-desc-head">
          <span class="pd-eyebrow">{{ section.settings.desc_eyebrow }}</span>
          <h2 class="pd-h2" style="margin-top:14px;">{{ section.settings.desc_heading_pre }} <em>{{ section.settings.desc_heading_emphasis }}</em>.</h2>
        </div>

        <div class="pd-desc-content">
          {%- if product.description and product.description != blank and product.description contains '<li' -%}

            {%- comment -%} Server-side parse of <li> items from product.description {%- endcomment -%}
            {%- assign items_str = '' -%}
            {%- assign li_pieces = product.description | split: '<li' -%}
            {%- for piece in li_pieces -%}
              {%- unless forloop.first -%}
                {%- assign after_open = piece | split: '>' | slice: 1, 99 | join: '>' -%}
                {%- assign item_text = after_open | split: '</li>' | first | strip_html | strip -%}
                {%- if item_text != blank -%}
                  {%- assign items_str = items_str | append: item_text | append: '|##|' -%}
                {%- endif -%}
              {%- endunless -%}
            {%- endfor -%}
            {%- assign items_arr = items_str | split: '|##|' -%}
            {%- assign item_count = items_arr | size -%}

            <div class="pd-desc-card" data-transformed="1">
              {%- for item in items_arr -%}
