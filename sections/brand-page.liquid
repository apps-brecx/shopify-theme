{% render 'pd-mb-prices' %}

<script>
window.PD_BASE_CENTS = {{ display_price }};
window.PD_COMPARE_AT_CENTS = {{ compare_at | default: 0 }};
window.PD_HAS_SALE = {% if has_sale %}true{% else %}false{% endif %};
window.PD_TIERS = [1, 0.95, 0.90, 0.85];
(function(){
  var currentBaseCents = window.PD_BASE_CENTS;
  var compareAtCents = window.PD_COMPARE_AT_CENTS;
  var hasSale = window.PD_HAS_SALE;
  const tiers = window.PD_TIERS;
  const fmt = (c)=>{const d=c/100; return '$' + d.toFixed(2);};
  function updatePrice(qty){
    qty = Math.max(1, parseInt(qty)||1);
    const tierIdx = Math.min(qty-1, tiers.length-1);
    const discount = tiers[tierIdx];
    const totalCents = Math.round(currentBaseCents * qty * discount);
    const origCents = currentBaseCents * qty;
    const compareCents = compareAtCents * qty;
    const priceEl = document.getElementById('pdPriceTotal');
    const wasEl = document.getElementById('pdPriceWas');
    const saveEl = document.getElementById('pdSaveTag');
    const stickyPriceEl = document.getElementById('pdStickyPrice');
    const compareEl = document.getElementById('pdPriceCompareAt');
    if (priceEl) priceEl.textContent = fmt(totalCents);
    if (stickyPriceEl) stickyPriceEl.textContent = fmt(totalCents);
    if (hasSale && compareEl) compareEl.textContent = fmt(compareCents);
    document.querySelectorAll('.pd-stickybar .pd-price-original').forEach(function(el){ el.textContent = fmt(compareCents); });
    if (qty > 1) {
      if (wasEl){wasEl.textContent = fmt(origCents); wasEl.style.display='inline';}
      if (saveEl){saveEl.textContent = 'Save '+Math.round((1-discount)*100)+'%'; saveEl.style.display='inline-block';}
    } else {
      if (wasEl) wasEl.style.display='none';
      if (saveEl) saveEl.style.display='none';
    }
    document.querySelectorAll('.pd-mb-cell').forEach(c=>{
      const t = parseInt(c.dataset.tier)||1;
      const match = (qty === t) || (qty >= 4 && t === 4);
      if (match) c.setAttribute('data-active',''); else c.removeAttribute('data-active');
    });
  }
  function getCurrentQty(){
    const inp = document.querySelector('.pd-qty input');
    return inp ? Math.max(1, parseInt(inp.value)||1) : 1;
  }
  document.querySelectorAll('.pd-qty [data-qty]').forEach(b=>{
    b.addEventListener('click', ()=>{
      const inp = b.parentElement.querySelector('input');
      const v = Math.max(1, (parseInt(inp.value)||1) + parseInt(b.dataset.qty));
      inp.value = v;
      updatePrice(v);
    });
  });
  document.querySelectorAll('.pd-qty input').forEach(inp=>{
    inp.addEventListener('change', ()=>updatePrice(parseInt(inp.value)||1));
    inp.addEventListener('input', ()=>updatePrice(parseInt(inp.value)||1));
  });
  document.querySelectorAll('.pd-mb-cell').forEach(c=>{
    c.addEventListener('click', ()=>{
      const tier = parseInt(c.dataset.tier)||1;
      const qtyInp = document.querySelector('.pd-qty input');
      if (qtyInp) {qtyInp.value = tier; updatePrice(tier);}
    });
  });
  window.addEventListener('pd:purchase-option-changed', function(e){
    var newBase = e.detail && e.detail.price ? e.detail.price : window.PD_BASE_CENTS;
    currentBaseCents = newBase;
    updatePrice(getCurrentQty());
  });
  const heroImg = document.getElementById('pdHeroImg');
  document.querySelectorAll('.pd-thumb').forEach(t=>{
    t.addEventListener('click', ()=>{document.querySelectorAll('.pd-thumb').forEach(x=>x.classList.remove('is-active'));t.classList.add('is-active');if (heroImg && t.dataset.src) heroImg.src = t.dataset.src;});
  });
  const slides = document.getElementById('pdSlides');
  const dots = document.querySelectorAll('.pd-dot');
  if (slides && dots.length){
    let scrollTimer;
    slides.addEventListener('scroll', ()=>{
      clearTimeout(scrollTimer);
      scrollTimer = setTimeout(()=>{
        const idx = Math.round(slides.scrollLeft / slides.clientWidth);
        dots.forEach((d, i) => d.classList.toggle('is-active', i === idx));
      }, 50);
    });
    dots.forEach((d, i)=>d.addEventListener('click', ()=>{
      slides.scrollTo({left: i * slides.clientWidth, behavior: 'smooth'});
    }));
  }
  const mainAtc = document.querySelector('.pd-atc--full');
  const stickyBar = document.getElementById('pdStickybar');
  if (mainAtc && stickyBar && 'IntersectionObserver' in window){
    const io = new IntersectionObserver((entries)=>{
      entries.forEach(e=>{ if (e.isIntersecting){ stickyBar.classList.add('is-hidden'); } else { stickyBar.classList.remove('is-hidden'); } });
    }, {threshold: 0.15});
    io.observe(mainAtc);
  }
  const dotsContainer = document.getElementById('pdDots');
  if (dotsContainer) {
    let raf;
    function updateDotProminence(){
      const r = dotsContainer.getBoundingClientRect();
      if (r.top > 60 && r.top < 380) {
        dotsContainer.classList.add('is-prominent');
      } else {
        dotsContainer.classList.remove('is-prominent');
      }
    }
    window.addEventListener('scroll', ()=>{cancelAnimationFrame(raf); raf = requestAnimationFrame(updateDotProminence);}, {passive: true});
    updateDotProminence();
  }
})();
</script>

