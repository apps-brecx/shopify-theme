<section class="wholesale-platforms-section">
  <div class="page-width">

    <div class="wholesale-platforms-header">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.subheading }}</p>
    </div>

    <div class="wholesale-platforms-grid">
      {% for block in section.blocks %}
      <div class="wholesale-platform-card {% if block.settings.featured %}featured{% endif %}" {{ block.shopify_attributes }}>

        <div class="wholesale-platform-logo">
          {% if block.settings.logo != blank %}
          <img
            src="{{ block.settings.logo | image_url: width: 300 }}"
            alt="{{ block.settings.title }}"
            loading="lazy">
          {% endif %}
        </div>

        <div class="wholesale-platform-content">
          <p>{{ block.settings.description }}</p>
        </div>

        {% if block.settings.button_link != blank %}
        <a href="{{ block.settings.button_link }}" class="wholesale-platform-btn">
          {{ block.settings.button_label }}
        </a>
        {% endif %}

      </div>
      {% endfor %}
    </div>

  </div>

<style>

.wholesale-platforms-section{
  background:#FAFAFA;
  padding-top:30px;
  padding-bottom:100px;
}

/* HEADER */
.wholesale-platforms-header{
  text-align:center;
  max-width:760px;
  margin:0 auto 40px;
}

.wholesale-platforms-header h2{
  font-size:50px !important;
  color:#b8784e !important;
  font-family:"Bricolage Grotesque" !important;
  font-weight:600;
  line-height:60px;
  margin-bottom:15px;
}

.wholesale-platforms-header p{
  font-size:22px;
  color:#4a3827;
  font-family:"DM Sans", sans-serif !important;
}

/* GRID */
.wholesale-platforms-grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:25px;
  max-width:1400px;
  margin:0 auto;
  align-items:stretch;
}

/* CARD */
.wholesale-platform-card{
  background:#b8784e;
  border-radius:14px;
  padding:50px 30px;
  text-align:center;
  min-height:520px;

  display:flex;
  flex-direction:column;
  justify-content:space-between;

  transition:transform 0.35s ease, background-color 0.35s ease, box-shadow 0.35s ease;
  position:relative;

  box-shadow:0 10px 24px rgba(0,0,0,0.06);
}

/* LOGO BOX */
.wholesale-platform-logo{
  background:#ffffff;
  border-radius:8px;
  height:100px;

  display:flex;
  align-items:center;
  justify-content:center;

  margin-bottom:28px;
  padding:12px;
}

/* LOGO */
.wholesale-platform-logo img{
  max-width:130px;
  max-height:55px;
  object-fit:contain;
}

/* CONTENT */
.wholesale-platform-content{
  flex-grow:1;
  display:flex;
  align-items:center;
  justify-content:center;
}

.wholesale-platform-content p{
  color:#ffffff;
  font-size:17px;
  font-weight:400;
  line-height:35px;
  font-family:"DM Sans" !important;
  margin:0;
}

/* BUTTON */
.wholesale-platform-btn{
  display:inline-block;
  margin-top:32px;
  padding:12px 32px;
  border-radius:30px;
  border:2px solid #ffffff;
  color:#ffffff;
  text-decoration:none;
  font-family:"DM Sans" !important;
  font-size:20px;
  font-weight:500;
  background:transparent;
  transition:all 0.35s ease;
}

/* HOVER EFFECT */
.wholesale-platform-card:hover{
  background:#673F21;
  transform:scale(1.05);
  box-shadow:0 20px 40px rgba(0,0,0,0.15);
}

.wholesale-platform-card:hover .wholesale-platform-btn{
  background:#ffffff;
  color:#673F21;
  border-color:#ffffff;
}

/* TABLET */
@media(max-width:990px){

  .wholesale-platforms-grid{
    grid-template-columns:repeat(2,1fr);
  }

  .wholesale-platform-card{
    min-height:480px;
    padding:46px 26px;
  }

}

/* MOBILE */
@media(max-width:600px){

  .wholesale-platforms-grid{
    grid-template-columns:1fr;
  }

  .wholesale-platforms-header h2{
    font-size:24px !important;
    line-height:40px;
  }

  .wholesale-platforms-header p{
    font-size:18px;
  }

  .wholesale-platform-card{
    min-height:440px;
    padding:40px 22px;
  }

  .wholesale-platform-card:hover{
    transform:scale(1.02);
  }

}

</style>


{% schema %}
{
  "name": "Wholesale Platforms",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Find Syruvia on Leading Wholesale Platforms"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Whether you're looking for easy online ordering, reliable supply, or competitive pricing, you can find Syruvia on the top wholesale platforms trusted by beverage businesses nationwide"
    }
  ],
  "blocks": [
    {
      "type": "platform",
      "name": "Platform",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Platform Logo"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "shop now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        },
        {
          "type": "checkbox",
          "id": "featured",
          "label": "Highlight this card (Faire)",
          "default": false
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Wholesale Platforms",
      "blocks": [
        { "type": "platform" },
        { "type": "platform" },
        { "type": "platform" },
        { "type": "platform" }
      ]
    }
  ]
}
{% endschema %}