<!-- Full Section Code: Left Image Slider with Static Text -->

<div class="new-sec-left-img-slider {{ section.settings.custom_class }}">
  <!-- Left Side Image Slider -->
  <div class="left-image-slider">
    {% for block in section.blocks %}
      <div class="slider-item">
        <div class="slider-item-content">

          <div class="slider-image">
            <picture>
              <source
                srcset="{{ block.settings.slider_image | image_url: width: 1000 }}"
                type="image/webp"
                sizes="(max-width: 600px) 100vw, 50vw"
              >
              <img
                srcset="{{ block.settings.slider_image | image_url: width: 1000 }} 1x, {{ block.settings.slider_image | image_url: width: 2000 }} 2x"
                src="{{ block.settings.slider_image | image_url: width: 1000 }}"
                alt="{{ block.settings.slider_image.alt | escape }}"
                width="{{ block.settings.slider_image.width }}"
                height="{{ block.settings.slider_image.height }}"
                loading="lazy"
                sizes="(max-width: 600px) 100vw, (max-width: 1000px) 50vw, 33vw"
              >
            </picture>
          <a href="{{ section.settings.slider_button_link }}" class="button-link button">
          {{ section.settings.slider_button_text }}
          <span class="cst-custom-arrow">
            <img src="https://cdn.shopify.com/s/files/1/0861/1106/0252/files/arroww.png?v=1728394015" loading="lazy">
          </span>
        </a>
          </div>
        </div>
      </div>
    {% endfor %}
  </div>

  <!-- Right Side Static Text Section -->
  <div class="slider-text">
    <div class="text-content">
      <h2>{{ section.settings.slider_title }}</h2>
      <p>{{ section.settings.slider_description }}</p>
      {% if section.settings.slider_button_link %}
        <a href="{{ section.settings.slider_button_link }}" class="button-link button">
          {{ section.settings.slider_button_text }}
          <span class="cst-custom-arrow">
            <img src="https://cdn.shopify.com/s/files/1/0861/1106/0252/files/arroww.png?v=1728394015" loading="lazy">
          </span>
        </a>
      {% endif %}
      {% if section.settings.slider_sub_text %}
        <p class="slider-sub-text">{{ section.settings.slider_sub_text }}</p>
      {% endif %}
    </div>
  </div>
</div>

<!-- CSS Styles for the Section -->
<style>


