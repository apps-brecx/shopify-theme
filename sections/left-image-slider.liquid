      align-items: normal;
      height: 100%;
  }
  .left-image-slider .button span img {
      width: 58px;
      margin-left: 17px;
  }
.new-sec-left-img-slider .text-content {
text-align: center;
}

.new-sec-left-img-slider .text-content .button {
margin-top: 40px;
}
.new-sec-left-img-slider {
    width: 100%;
    display: grid;
    grid-template-columns: 45% 55%;
    align-items: center;
    height: 100%;
    margin-top: 100px;
}

    .left-image-slider .slider-text {
