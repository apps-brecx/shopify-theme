{% comment %}
Bundle Builder (One-time) — 2-column layout
- Top center: size selector (2,3,4,5,6,8,10,12)
- Left: product grid with search
- Right: “Your Current Case” summary with items, remaining count, subtotal/discount, Add to Cart → Checkout
- Only show in-stock products (variant.available == true)
{% endcomment %}

{{ 'bundle-builder.css' | asset_url | stylesheet_tag }}

<section id="bundle-builder-{{ section.id }}" class="bb-container"> 
<section id="bundle-builder-{{ section.id }}" class="bb-wrap">
  {%- assign sizes = section.settings.bundle_sizes | split: ',' -%}

  <!-- TOP: Size selector (currently commented out by you) -->
  {% comment %} 
  <div class="bb-size-toggle" data-bb-sizes>
    {% for s in sizes %}
      {% assign n = s | strip | plus: 0 %}
      <button type="button" class="bb-pill {% if forloop.first %}is-active{% endif %}" data-size="{{ n }}">
        {{ n }} items
      </button>
    {% endfor %}
  </div>
  {% endcomment %}

  <div class="bundle-builder-information">
    {% comment %} <h3 class="bundle-builder-heading">Discounts</h3> {% endcomment %}
