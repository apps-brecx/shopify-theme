<script>
(() => {
  const root = document.getElementById('bundle-builder-{{ section.id }}');
  if (!root) return;

  // ----------- CONFIG ------------
  const LOCALE   = '{{ request.locale.iso_code | default: shop.locale }}';
  const CURRENCY = '{{ cart.currency.iso_code | default: shop.currency }}';

  const DISCOUNTS = {
    2:  {{ section.settings.discount_2  | default: 0 }},
    3:  {{ section.settings.discount_3  | default: 0 }},
    4:  {{ section.settings.discount_4  | default: 0 }},
    5:  {{ section.settings.discount_5  | default: 0 }},
    6:  {{ section.settings.discount_6  | default: 0 }},
    8:  {{ section.settings.discount_8  | default: 0 }},
    10: {{ section.settings.discount_10 | default: 0 }},
    12: {{ section.settings.discount_12 | default: 0 }}
  };

  const DISCOUNT_CODES = {
    2:  "{{ section.settings.code_2  | escape }}",
    3:  "{{ section.settings.code_3  | escape }}",
    4:  "{{ section.settings.code_4  | escape }}",
    5:  "{{ section.settings.code_5  | escape }}",
    6:  "{{ section.settings.code_6  | escape }}",
    8:  "{{ section.settings.code_8  | escape }}",
    10: "{{ section.settings.code_10 | escape }}",
    12: "{{ section.settings.code_12 | escape }}"
  };

  // ---------- STATE --------------
  const state = { items: new Map() };

  // ---------- PERSISTENCE (localStorage) ----------
  const STORE_NS   = 'bb:v1'; // bump if schema changes
  const STORE_SHOP = '{{ shop.myshopify_domain | default: shop.permanent_domain }}';
  const STORE_SEC  = '{{ section.id }}';
  const STORAGE_KEY = `${STORE_NS}:${STORE_SHOP}:${STORE_SEC}`;

  function serializeState() {
    const items = [];
    state.items.forEach((v, id) => {
      items.push({
        id: String(id),
        qty: Number(v.qty) || 0,
        price: Number(v.price) || 0,
        title: v.title || '',
        img: v.img || ''
      });
    });
    return { items };
  }

  function saveState() {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(serializeState()));
    } catch (_) { /* ignore quota/private mode */ }
  }

  function clearState() {
    try { localStorage.removeItem(STORAGE_KEY); } catch (_) {}
  }

  function loadState() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return;
      const parsed = JSON.parse(raw);
      if (!parsed || !Array.isArray(parsed.items)) return;

      state.items.clear();
      for (const it of parsed.items) {
        const id = String(it.id || '');
        const qty = Math.max(0, parseInt(it.qty || 0, 10));
        if (!id || qty <= 0) continue;

        // Prefer fresh data from the DOM card if available
        const card  = root.querySelector(`.bb-card[data-variant="${CSS.escape(id)}"]`);
        const price = parseInt(card?.dataset.price || it.price || '0', 10);
        const title = card?.dataset.title || it.title || '';
        const img   = card?.dataset.img   || it.img   || '';

        state.items.set(id, { qty, price, title, img });
      }
    } catch (_) { /* ignore */ }
  }

  // Keep multiple tabs/windows in sync
  window.addEventListener('storage', (e) => {
    if (e.key !== STORAGE_KEY) return;
    loadState();
    syncCardInputs();
    renderSummary();
  });

  // ---------- HELPERS ------------
  const fmt = (cents) => {
    try { return new Intl.NumberFormat(LOCALE, { style: 'currency', currency: CURRENCY }).format(cents / 100); }
    catch (e) { return '$' + (cents / 100).toFixed(2); }
  };
  const totalQty = () => { let t = 0; state.items.forEach(v => t += v.qty); return t; };
  const subtotal = () => { let s = 0; state.items.forEach(v => s += v.qty * v.price); return s; };

  function bestTier(qty){
    const tiers = Object.keys(DISCOUNTS).map(Number).filter(Boolean).sort((a,b)=>a-b);
    let chosen = 0;
    for (const t of tiers) if (qty >= t) chosen = t;
    return chosen;
  }
  const chosenCode = () => {
    const tier = bestTier(totalQty());
    return (DISCOUNT_CODES[tier] || '').trim();
  };

  // ---------- DOM REFS -----------
  const gridCards   = root.querySelectorAll('.bb-card');
  const searchBox   = root.querySelector('[data-search]');

  // Select BOTH desktop aside and modal instances
  const caseLists   = root.querySelectorAll('[data-case-list]');
  const elsFilled   = root.querySelectorAll('[data-filled]');
  const elsSub      = root.querySelectorAll('[data-subtotal]');
  const elsDiscRow  = root.querySelectorAll('[data-discount-row]');
  const elsDiscPct  = root.querySelectorAll('[data-discount-pct]');
  const elsDiscAmt  = root.querySelectorAll('[data-discount-amount]');
  const elsTotal    = root.querySelectorAll('[data-total]');
  const btnResets   = root.querySelectorAll('[data-reset]');
  const btnAdds     = root.querySelectorAll('[data-add]');
  const discountBadges = root.querySelectorAll('[data-discount-badge]');

  // Mobile bar & modal
  const mobileBar   = root.querySelector('[data-mobile-bar]');
  const mobileLabel = root.querySelector('[data-mobile-label]');
  const asideDesktop= root.querySelector('.bb-right'); // sticky aside on desktop
  const isMobileBP  = () => window.matchMedia('(max-width: 990px)').matches;

  const modal       = document.getElementById('bb-modal');
  const overlay     = document.getElementById('bb-modal-overlay');
  const closeBtn    = document.getElementById('bb-modal-close');

  const setTextAll = (nodes, text) => nodes.forEach(n => n.textContent = text);
  const showAll    = (nodes, show) => nodes.forEach(n => { n.style.display = show ? '' : 'none'; });

  // =======================================
//  SYRUP FILTER TABS (UI ONLY)  ✅
//  - One row with 3 tabs: All / Regular / Sugar Free
//  - Only toggles active styling (no filtering logic here)
//  - Safe: does not touch any other bundle logic
// =======================================
const filtersRoot = root.querySelector('[data-bb-collections]');
const filterTabs  = filtersRoot ? filtersRoot.querySelectorAll('.bb-tab') : [];

// function initTabsUI() {
//   if (!filtersRoot) return;

//   filterTabs.forEach(btn => {
//     btn.addEventListener('click', () => {
//       // visual active state
//       filterTabs.forEach(b => { b.classList.remove('is-active'); b.setAttribute('aria-selected','false'); });
//       btn.classList.add('is-active'); btn.setAttribute('aria-selected','true');

//     });
//   });
// }

function initTabsUI() {
  if (!filtersRoot) return;

  const allGroups = root.querySelectorAll('.bb-collection-group');

  filterTabs.forEach(btn => {
    btn.addEventListener('click', () => {
      // Update tab active state
      filterTabs.forEach(b => {
        b.classList.remove('is-active');
        b.setAttribute('aria-selected', 'false');
      });
      btn.classList.add('is-active');
      btn.setAttribute('aria-selected', 'true');

      // Determine which tab was clicked
      const type = btn.dataset.sub; // "all-syrup", "regular", "sugarfree"

      // Hide all, then show the selected one
      allGroups.forEach(group => group.style.display = 'none');

     let selector = '';
        if (type === 'regular') {
          selector = '[data-collection="regual-syruvia-bundle"]';
        } else if (type === 'sugarfree') {
          selector = '[data-collection="sugar-free-syruvia-bundle"]';
        } else {
          selector = '[data-collection="syruvia-bundle"]';
        }


      const activeGroup = root.querySelector(selector);
      if (activeGroup) activeGroup.style.display = 'grid';
    });
  });
}

// =======================================




  // ---------- CORE LOGIC ---------
  function setQty(variantId, requestedQty) {
    const id = String(variantId);                         // **STRING ID**
    const qty = Math.max(0, parseInt(requestedQty || 0, 10));
    if (qty <= 0) {
      state.items.delete(id);
    } else {
      const card  = root.querySelector(`.bb-card[data-variant="${CSS.escape(id)}"]`);
      const price = parseInt(card?.dataset.price || '0', 10);
      const title = card?.dataset.title || '';
      const img   = card?.dataset.img || '';
      state.items.set(id, { qty, price, title, img });
    }
    syncCardInputs();
    renderSummary();
    saveState(); // persist after every change
  }

  // ---------- RENDER -------------
  function renderSummary() {
    const q   = totalQty();
    const s   = subtotal();
    const tier= bestTier(q);
    const pct = DISCOUNTS[tier] || 0;
    const disc= Math.round(s * pct / 100);
    const tot = s - disc;

    if (discountBadges.length) {
      if (pct > 0) {
        discountBadges.forEach(b => { b.hidden = false; b.textContent = pct + '%'; });
      } else {
        discountBadges.forEach(b => { b.hidden = true; });
      }
    }

    setTextAll(elsFilled, String(q));
    setTextAll(elsSub,    fmt(s));
    setTextAll(elsTotal,  fmt(tot));

    if (pct > 0 && disc > 0) {
      showAll(elsDiscRow, true);
      setTextAll(elsDiscPct, String(pct));
      setTextAll(elsDiscAmt, fmt(disc));
    } else {
      showAll(elsDiscRow, false);
    }

    btnAdds.forEach(b => b.disabled = (q === 0));

    caseLists.forEach(list => {
      list.innerHTML = '';
      state.items.forEach((v, id) => {
        if (!v.qty) return;
        const row = document.createElement('div');
        row.className = 'bb-row';
        row.innerHTML = `
          <div class="bb-row-left">
            <img src="${v.img}" alt="">
            <div class="bb-row-title">${v.title}</div>
          </div>
          <div class="bb-row-ctrls">
            <button type="button" class="bb-mini" data-dec aria-label="Decrease">−</button>
            <span class="bb-chip">${v.qty}</span>
            <button type="button" class="bb-mini" data-inc aria-label="Increase">+</button>
            <span class="bb-row-price">${fmt(v.price)}</span>
            <button type="button" class="bb-mini" data-remove aria-label="Remove">
              <svg class="bb-trash" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
                <path d="M3 6h18v2H3V6zm2 3h14l-1.5 12.5c-.1.8-.8 1.5-1.6 1.5H8.1c-.8 0-1.5-.7-1.6-1.5L5 9zm5 2v9h2v-9H10zm4 0v9h2v-9h-2zM9 4V2h6v2h5v2H4V4h5z"/>
              </svg>
            </button>
          </div>
        `;
        row.querySelector('[data-inc]').addEventListener('click', () => setQty(id, (state.items.get(id)?.qty || 0) + 1));
        row.querySelector('[data-dec]').addEventListener('click', () => setQty(id, (state.items.get(id)?.qty || 0) - 1));
        row.querySelector('[data-remove]').addEventListener('click', () => setQty(id, 0));
        list.appendChild(row);
      });
    });

    updateMobileBar();
  }

  function syncCardInputs() {
    gridCards.forEach(card => {
      const id = card.dataset.variant;                    // **STRING ID**
      const input = card.querySelector('.bb-qty-input');
      if (input) input.value = state.items.get(id)?.qty || 0;
    });
  }

  // ---------- MOBILE BAR ----------
  function updateMobileBar(){
    if(!mobileBar) return;
    mobileBar.hidden = !isMobileBP();
    if (mobileBar.hidden) return;

    const q = totalQty();
    if (q > 0){
      mobileBar.disabled = false;
      mobileLabel.textContent = `YOUR CURRENT BUNDLES (${q})`;
    } else {
      mobileBar.disabled = true;
      mobileLabel.textContent = 'YOUR BUNDLE IS EMPTY';
    }
  }

  // ----------- MODAL --------------
  function openModal(){
    if (!modal || !overlay) return;
    modal.hidden = false;
    overlay.hidden = false;
    requestAnimationFrame(() => {
      modal.classList.add('show');
      overlay.classList.add('show');
      document.body.classList.add('bb-lock');
    });
  }
  function closeModal(){
    if (!modal || !overlay) return;
    modal.classList.remove('show');
    overlay.classList.remove('show');
    setTimeout(() => {
      modal.hidden = true;
      overlay.hidden = true;
      document.body.classList.remove('bb-lock');
    }, 300);
  }

  mobileBar?.addEventListener('click', () => {
    if (mobileBar.disabled) return;
    if (isMobileBP()) openModal();
    else asideDesktop?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
  closeBtn?.addEventListener('click', closeModal);
  overlay?.addEventListener('click', closeModal);
  window.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
  window.addEventListener('resize', () => {
    updateMobileBar();
    if (!isMobileBP()) closeModal();
  });

  // ---------- EVENTS -------------
  gridCards.forEach(card => {
    const id = card.dataset.variant;                      // **STRING ID**
    const inc = card.querySelector('[data-incr]');
    const dec = card.querySelector('[data-decr]');
    const currentQty = () => (state.items.get(id)?.qty || 0);
    inc?.addEventListener('click', () => setQty(id, currentQty() + 1));
    dec?.addEventListener('click', () => setQty(id, currentQty() - 1));
  });

  const searchCards = () => {
    const q = (searchBox?.value || '').trim().toLowerCase();
    gridCards.forEach(card => {
      const t = (card.dataset.title || '').toLowerCase();
      card.style.display = t.includes(q) ? '' : 'none';
    });
  };
  searchBox?.addEventListener('input', searchCards);

  btnResets.forEach(btn => btn.addEventListener('click', () => {
    state.items.clear();
    discountBadges.forEach(b => { b.hidden = true; b.textContent = '0%'; });
    syncCardInputs();
    renderSummary();
    clearState(); // <-- clear saved bundle
  }));

  btnAdds.forEach(btn => btn.addEventListener('click', async () => {
    const q = totalQty();
    if (q === 0) return;

    const bundleId = 'BB-' + Date.now();
    const items = [];
    state.items.forEach((v, id) => {
      if (!v.qty) return;
      items.push({ id, quantity: v.qty, properties: { _bundle_id: bundleId } });
    });

    await fetch('/cart/clear.js', { method: 'POST', credentials: 'same-origin' });

    const res = await fetch('/cart/add.js', {
      method: 'POST',
      credentials: 'same-origin',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ items, attributes: { _bundle: bundleId, bundle_label: 'Custom Bundle', bundle_type: 'one-time' } })
    });
    if (!res.ok) { alert('Could not add bundle to cart.'); return; }

    clearState(); // <-- clear after successful add

    if (location.search.includes('discount=')) {
  const u = new URL(location.href);
  u.searchParams.delete('discount');
  history.replaceState({}, '', u.toString());
}
    const code = chosenCode();
    if (code) {
      window.location.href = '/discount/' + encodeURIComponent(code) + '?redirect=' + encodeURIComponent('/checkout');
    } else {
      window.location.href = '/checkout';
    }

    
  }));

  // ---------- FIXED MOBILE BARS (iOS/Android) ----------
  (function fixMobileFixedBars(){
    const bar = root.querySelector('.bb-mobile-bar');
    if (!bar) return;

    const setBarH = () => {
      document.documentElement.style.setProperty('--bar-h', bar.offsetHeight + 'px');
    };

    const syncVV = () => {
      let offset = 0;
      const vv = window.visualViewport;
      if (vv) {
        offset = Math.max(0, (window.innerHeight - vv.height - vv.offsetTop));
      }
      document.documentElement.style.setProperty('--vvb', offset + 'px');
    };

    setBarH();
    syncVV();

    window.addEventListener('resize', setBarH);
    window.addEventListener('orientationchange', () => { setBarH(); syncVV(); });

    if (window.visualViewport){
      visualViewport.addEventListener('resize', syncVV, { passive: true });
      visualViewport.addEventListener('scroll',  syncVV, { passive: true });
    }

    const mo = new MutationObserver(setBarH);
    mo.observe(bar, { childList: true, subtree: true, characterData: true });
  })();

  // ---------- INIT ---------------
  loadState();        // <-- hydrate from localStorage if present
  syncCardInputs();
  renderSummary();
  updateMobileBar();
  searchCards();

  // Initialize the tab UI (ADDED)
  initTabsUI();
})();
</script>




