      <div class="bb-grid" data-grid>
        {%- assign rendered = 0 -%}

        {%- for b in section.blocks -%}
        {%- assign coll = collections[b.settings.collection] -%}
        {%- if coll -%}
          <div class="bb-collection-group" 
              data-collection="{{ coll.handle }}" 
             {% if forloop.first %}style="display:grid"{% else %}style="display:none"{% endif %}>
            {% paginate coll.products by 250 %}
              {% for p in coll.products %}
                {% assign av = nil %}
                {% for vv in p.variants %}
                  {% if vv.available %}
                    {% assign av = vv %}
                    {% break %}
                  {% endif %}
                {% endfor %}
                {% if av %}
{%- assign meta_path_raw = p.metafields.custom.path | default: '' -%}
{%- assign meta_path = meta_path_raw | strip -%}
{%- assign dest = p.url | within: coll -%}

{%- if meta_path != blank -%}
  {%- if meta_path contains '://' -%}
    {%- assign dest = meta_path -%}  {# absolute URL #}
  {%- else -%}
    {%- assign first_char = meta_path | slice: 0, 1 -%}
    {%- if first_char == '/' -%}
      {%- assign dest = meta_path -%} 
    {%- else -%}
      {%- assign dest = '/' | append: meta_path -%}  
    {%- endif -%}
  {%- endif -%}
{%- endif -%}
{%- assign raw = p.metafields.custom.path -%}
{%- assign path = '' -%}
{%- if raw -%}
  {%- if raw.value -%}
    {%- assign path = raw.value | strip -%}    
  {%- else -%}
    {%- assign path = raw | strip -%}         
  {%- endif -%}
{%- endif -%}

{%- if path == '' -%}
  {%- assign path = p.handle -%}               
{%- endif -%}

{%- assign path = path | remove_first: '/' -%}  
{%- assign dest = '/products/' | append: path -%}


            <article
 class="bb-card"
  data-variant="{{ av.id }}"
  data-title="{{ p.title | escape }}"
  data-price="{{ av.price }}"
  data-img="{{ p.featured_image | img_url: '200x' }}"
  data-product-url="{{ dest }}"
>
                    {% comment %} <div class="bb-card-img">
