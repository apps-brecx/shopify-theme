<script>
(function(){
  var root=document.getElementById('cm-{{ section.id }}');
  if(!root) return;
  var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* copy code */
  root.querySelectorAll('.cm-copy').forEach(function(btn){
    btn.addEventListener('click', function(){
      var code = btn.getAttribute('data-code')||'';
      var note = btn.parentNode.querySelector('[data-copied-label]');
      function flash(msg){ if(note){ note.textContent=msg; setTimeout(function(){ note.textContent=''; }, 2200); } }
      if(navigator.clipboard && navigator.clipboard.writeText){
        navigator.clipboard.writeText(code).then(function(){ flash('Copied “'+code+'” ✓'); }).catch(function(){ flash('Code: '+code); });
      } else { flash('Code: '+code); }
    });
  });

  function countUp(el){
    if(el.__c) return; el.__c=1;
    var target=parseInt(el.getAttribute('data-count'),10)||0, suf=el.getAttribute('data-suffix')||'';
    var start=null, dur=1100;
    function step(ts){ if(!start) start=ts; var p=Math.min((ts-start)/dur,1); var e=1-Math.pow(1-p,3); el.textContent=Math.round(e*target)+suf; if(p<1) requestAnimationFrame(step); }
    requestAnimationFrame(step);
  }
  if('IntersectionObserver' in window && !reduce){
    var io=new IntersectionObserver(function(es){es.forEach(function(e){ if(e.isIntersecting){ e.target.classList.add('in'); var c=e.target.querySelector('.cm-count'); if(c) countUp(c); if(e.target.classList.contains('cm-count')) countUp(e.target); io.unobserve(e.target); } });},{threshold:.12});
    root.querySelectorAll('.cm-rev').forEach(function(el){io.observe(el);});
    root.querySelectorAll('.cm-count').forEach(function(el){io.observe(el);});
    setTimeout(function(){root.querySelectorAll('.cm-rev:not(.in)').forEach(function(el){el.classList.add('in');});},3000);
  } else {
    root.querySelectorAll('.cm-rev').forEach(function(el){el.classList.add('in');});
    root.querySelectorAll('.cm-count').forEach(function(el){ el.textContent=el.getAttribute('data-count')+(el.getAttribute('data-suffix')||''); });
  }

  var pops=[].slice.call(root.querySelectorAll('.cm-pop'));
  var track=root.querySelector('.cm-trio');
  var stage=root.querySelector('.cm-trio-sticky');
  var items=[].slice.call(root.querySelectorAll('.cm-trio-item'));
  var dots=[].slice.call(root.querySelectorAll('.cm-trio-dots span'));
  if(reduce){ pops.forEach(function(el){el.style.opacity='1';}); items.forEach(function(el){el.style.opacity='1';}); return; }
  var ticking=false;
  function update(){
    ticking=false;
    var vh=window.innerHeight||document.documentElement.clientHeight, vc=vh/2;
    for(var i=0;i<pops.length;i++){
      var el=pops[i], r=el.getBoundingClientRect();
      if(r.bottom<-160||r.top>vh+160){ continue; }
      var c=r.top+r.height/2, d=(c-vc)/vc, ad=Math.abs(d); if(ad>1) ad=1;
      var scale=1.05-ad*0.17, op=1-ad*0.55; if(op<0.2) op=0.2;
      el.style.opacity=op.toFixed(2); el.style.transform='scale('+scale.toFixed(3)+')';
    }
    if(track && stage && items.length){
      var trk=track.getBoundingClientRect();
      var span=track.offsetHeight-vh; if(span<1) span=1;
      if(trk.top>=0){ stage.style.position='absolute'; stage.style.top='0'; stage.style.bottom='auto'; }
      else if(trk.bottom<=vh){ stage.style.position='absolute'; stage.style.top='auto'; stage.style.bottom='0'; }
      else { stage.style.position='fixed'; stage.style.top='0'; stage.style.bottom='auto'; }
      var p=(-trk.top)/span; if(p<0) p=0; if(p>1) p=1;
      var n=items.length, active=Math.floor(p*n); if(active>n-1) active=n-1; if(active<0) active=0;
      for(var k=0;k<n;k++){
        var center=(k+0.5)/n;
        var dd=Math.abs(p-center)*n; var pres=1-dd; if(pres<0) pres=0;
        var ease=pres*pres*(3-2*pres);
        var sc=0.6+ease*0.45;
        var ty=(p-center)*-120;
        var it=items[k];
        it.style.opacity=ease.toFixed(3);
        it.style.transform='translate(-50%,calc(-50% + '+ty.toFixed(1)+'px)) scale('+sc.toFixed(3)+')';
        it.style.zIndex=(pres>0.5?'4':'2');
      }
      for(var j=0;j<dots.length;j++){ if(j===active){ dots[j].classList.add('on'); } else { dots[j].classList.remove('on'); } }
    }
  }
  function onScroll(){ if(!ticking){ ticking=true; requestAnimationFrame(update); } }
  window.addEventListener('scroll', onScroll, {passive:true});
  window.addEventListener('resize', onScroll);
  window.addEventListener('load', update);
  update();
})();
</script>

