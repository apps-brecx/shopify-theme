    { "type": "text", "id": "card3_name_post", "label": "Name (after product)", "default": " Cold Brew" },
    { "type": "text", "id": "card3_ing1_pre", "label": "Ingredient 1 (before product)", "default": "1 pump " },
    { "type": "text", "id": "card3_ing1_post", "label": "Ingredient 1 (after product)", "default": "" },
    { "type": "text", "id": "card3_ing2", "label": "Ingredient 2", "default": "12 oz cold brew coffee" },
    { "type": "text", "id": "card3_ing3", "label": "Ingredient 3", "default": "Splash of milk or cream" },
    { "type": "text", "id": "card3_ing4", "label": "Ingredient 4", "default": "Ice, to fill" },

    { "type": "header", "content": "Card 4" },
    { "type": "text", "id": "card4_tag", "label": "Tag", "default": "Cozy Up" },
    { "type": "text", "id": "card4_time", "label": "Time", "default": "90 sec" },
    { "type": "text", "id": "card4_name_pre", "label": "Name (before product)", "default": "" },
    { "type": "text", "id": "card4_name_post", "label": "Name (after product)", "default": " Steamer" },
    { "type": "text", "id": "card4_ing1_pre", "label": "Ingredient 1 (before product)", "default": "1 pump " },
    { "type": "text", "id": "card4_ing1_post", "label": "Ingredient 1 (after product)", "default": "" },
    { "type": "text", "id": "card4_ing2", "label": "Ingredient 2", "default": "12 oz steamed milk" },
    { "type": "text", "id": "card4_ing3", "label": "Ingredient 3", "default": "Dash of cinnamon" },
    { "type": "text", "id": "card4_ing4", "label": "Ingredient 4", "default": "Optional whipped cream" }
  ],
  "presets": [{ "name": "PD Recipes" }]
}
{% endschema %}
