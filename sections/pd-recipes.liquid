{{ 'pdp-brand.css' | asset_url | stylesheet_tag }}

{%- comment -%} Recipes v2 — featured signature + text-only quick sips carousel with scroll affordances. {%- endcomment -%}

{%- assign sig_image_ref = product.metafields.custom.product_summary_image.value -%}
{%- assign sig_recipe    = product.metafields.custom.product_summary -%}
{%- assign t_clean = product.title | replace: ' Syrup', '' | replace: ' syrup', '' -%}
{%- if t_clean == blank -%}{%- assign t_clean = product.title -%}{%- endif -%}

{%- assign sig_image_url = '' -%}
{%- if sig_image_ref.image -%}
  {%- assign sig_image_url = sig_image_ref.image | image_url: width: 1200 -%}
{%- elsif sig_image_ref.preview_image -%}
  {%- assign sig_image_url = sig_image_ref.preview_image | image_url: width: 1200 -%}
{%- elsif sig_image_ref.src -%}
  {%- assign sig_image_url = sig_image_ref.src -%}
{%- elsif sig_image_ref -%}
  {%- assign sig_image_url = sig_image_ref | image_url: width: 1200 -%}
{%- endif -%}

{%- style -%}
  #shopify-section-{{ section.id }} .pd-recipes-v2 {
    {%- if section.settings.section_bg != blank %}background: {{ section.settings.section_bg }} !important;{% endif -%}
  }
  #shopify-section-{{ section.id }} .pd-eyebrow { color: {{ section.settings.eyebrow_color }} !important; }
  #shopify-section-{{ section.id }} .pd-h2,
  #shopify-section-{{ section.id }} .pd-h3 { color: {{ section.settings.heading_color }} !important; }
  #shopify-section-{{ section.id }} .pd-rv2-lede { color: {{ section.settings.lede_color }} !important; }
  #shopify-section-{{ section.id }} .pd-rv2-feature-tag { background: {{ section.settings.feature_tag_bg }} !important; color: {{ section.settings.feature_tag_color }} !important; }
  #shopify-section-{{ section.id }} .pd-rv2-feature-time { color: {{ section.settings.feature_time_color }} !important; }
  #shopify-section-{{ section.id }} .pd-rv2-swipe-hint { color: {{ section.settings.swipe_hint_color }} !important; }
  #shopify-section-{{ section.id }} .pd-rv2-card-name { color: {{ section.settings.card_name_color }} !important; }
  #shopify-section-{{ section.id }} .pd-rv2-card-time { color: {{ section.settings.card_time_color }} !important; }
  #shopify-section-{{ section.id }} .pd-rv2-card-ings { color: {{ section.settings.card_ings_color }} !important; }
{%- endstyle -%}

<div class="pd">
  <section class="pd-recipes-v2">
    <div class="pd-wrap pd-rv2-head">
      <span class="pd-eyebrow">{{ section.settings.featured_eyebrow }}</span>
      <h2 class="pd-h2">{{ section.settings.featured_heading_pre }}<em>{{ section.settings.featured_heading_em }}</em>{{ section.settings.featured_heading_post }}</h2>
      <p class="pd-rv2-lede">{{ section.settings.featured_lede }}</p>
    </div>

    {%- if sig_image_url != '' and sig_recipe != blank -%}
      <div class="pd-wrap">
        <article class="pd-rv2-feature">
          <div class="pd-rv2-feature-img">
            <img src="{{ sig_image_url }}" alt="{{ product.title | escape }} {{ section.settings.feature_img_alt_suffix }}" loading="lazy">
            <span class="pd-rv2-feature-tag">{{ section.settings.feature_tag_label }}</span>
          </div>
          <div class="pd-rv2-feature-body">
            <div class="pd-rv2-feature-content" id="pdRv2FeatureContent">
              {{ sig_recipe | metafield_tag }}
            </div>
            <span class="pd-rv2-feature-time">{{ section.settings.feature_time_label }}</span>
          </div>
        </article>
      </div>
    {%- endif -%}

    <div class="pd-wrap pd-rv2-sub">
      <span class="pd-eyebrow">{{ section.settings.sub_eyebrow }}</span>
      <h3 class="pd-h3">{{ section.settings.sub_heading_pre }}<em>{{ section.settings.sub_heading_em }}</em>{{ section.settings.sub_heading_post }}</h3>
      <span class="pd-rv2-swipe-hint" aria-hidden="true">{{ section.settings.swipe_hint_label }}
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12 H19 M13 6 l6 6 -6 6"/></svg>
      </span>
    </div>

    <div class="pd-rv2-scroll">
      <button type="button" class="pd-rv2-nav pd-rv2-nav--prev" id="pdRecipesPrev" aria-label="{{ section.settings.prev_aria_label }}">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M15 6 l-6 6 6 6"/></svg>
      </button>
      <button type="button" class="pd-rv2-nav pd-rv2-nav--next" id="pdRecipesNext" aria-label="{{ section.settings.next_aria_label }}">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6 l6 6 -6 6"/></svg>
      </button>

      <div class="pd-rv2-marquee" id="pdRecipesMarquee">
        <div class="pd-rv2-track" id="pdRecipesTrack">

          <article class="pd-rv2-card">
            <div class="pd-rv2-card-body">
              <div class="pd-rv2-card-toprow">
                <span class="pd-rv2-card-tag pd-rv2-card-tag--peach">{{ section.settings.card1_tag }}</span>
                <span class="pd-rv2-card-time">{{ section.settings.card1_time }}</span>
              </div>
              <h4 class="pd-rv2-card-name">{{ section.settings.card1_name_pre }}{{ t_clean }}{{ section.settings.card1_name_post }}</h4>
              <ul class="pd-rv2-card-ings">
                <li>{{ section.settings.card1_ing1_pre }}{{ t_clean }}{{ section.settings.card1_ing1_post }}</li>
                <li>{{ section.settings.card1_ing2 }}</li>
                <li>{{ section.settings.card1_ing3 }}</li>
                <li>{{ section.settings.card1_ing4 }}</li>
              </ul>
            </div>
          </article>

          <article class="pd-rv2-card">
            <div class="pd-rv2-card-body">
              <div class="pd-rv2-card-toprow">
                <span class="pd-rv2-card-tag pd-rv2-card-tag--mint">{{ section.settings.card2_tag }}</span>
                <span class="pd-rv2-card-time">{{ section.settings.card2_time }}</span>
              </div>
              <h4 class="pd-rv2-card-name">{{ section.settings.card2_name_pre }}{{ t_clean }}{{ section.settings.card2_name_post }}</h4>
              <ul class="pd-rv2-card-ings">
                <li>{{ section.settings.card2_ing1_pre }}{{ t_clean }}{{ section.settings.card2_ing1_post }}</li>
                <li>{{ section.settings.card2_ing2 }}</li>
                <li>{{ section.settings.card2_ing3 }}</li>
                <li>{{ section.settings.card2_ing4 }}</li>
              </ul>
            </div>
          </article>

          <article class="pd-rv2-card">
            <div class="pd-rv2-card-body">
              <div class="pd-rv2-card-toprow">
                <span class="pd-rv2-card-tag pd-rv2-card-tag--butter">{{ section.settings.card3_tag }}</span>
                <span class="pd-rv2-card-time">{{ section.settings.card3_time }}</span>
              </div>
              <h4 class="pd-rv2-card-name">{{ section.settings.card3_name_pre }}{{ t_clean }}{{ section.settings.card3_name_post }}</h4>
              <ul class="pd-rv2-card-ings">
                <li>{{ section.settings.card3_ing1_pre }}{{ t_clean }}{{ section.settings.card3_ing1_post }}</li>
                <li>{{ section.settings.card3_ing2 }}</li>
                <li>{{ section.settings.card3_ing3 }}</li>
                <li>{{ section.settings.card3_ing4 }}</li>
              </ul>
            </div>
          </article>

          <article class="pd-rv2-card">
            <div class="pd-rv2-card-body">
              <div class="pd-rv2-card-toprow">
                <span class="pd-rv2-card-tag pd-rv2-card-tag--blush">{{ section.settings.card4_tag }}</span>
                <span class="pd-rv2-card-time">{{ section.settings.card4_time }}</span>
              </div>
              <h4 class="pd-rv2-card-name">{{ section.settings.card4_name_pre }}{{ t_clean }}{{ section.settings.card4_name_post }}</h4>
              <ul class="pd-rv2-card-ings">
                <li>{{ section.settings.card4_ing1_pre }}{{ t_clean }}{{ section.settings.card4_ing1_post }}</li>
                <li>{{ section.settings.card4_ing2 }}</li>
                <li>{{ section.settings.card4_ing3 }}</li>
                <li>{{ section.settings.card4_ing4 }}</li>
              </ul>
            </div>
          </article>

        </div>
      </div>

      <div class="pd-rv2-dots" id="pdRecipesDots" aria-hidden="true"></div>
    </div>
  </section>
</div>

<script>
(function(){
  function trim(){
    var root = document.getElementById('pdRv2FeatureContent');
    if (!root) return;
    var firstP = root.querySelector('p');
    if (firstP){
      var strong = firstP.querySelector('strong');
      if (strong){
        var name = strong.textContent;
        var h3 = document.createElement('h3');
        h3.className = 'pd-rv2-feature-name';
        h3.textContent = name;
        firstP.replaceWith(h3);
      }
    }
    var kids = Array.prototype.slice.call(root.children);
    var dropping = false;
    kids.forEach(function(el){
      if (dropping){ el.remove(); return; }
      var txt = (el.textContent || '').trim().toUpperCase();
      if (txt === 'INSTRUCTIONS' || txt.indexOf('INSTRUCTIONS') === 0){
        dropping = true; el.remove(); return;
      }
      if (el.tagName === 'OL'){ dropping = true; el.remove(); return; }
    });
    Array.prototype.slice.call(root.querySelectorAll('p')).forEach(function(p){
      var s = p.querySelector('strong');
      if (s && (s.textContent || '').trim().toUpperCase() === 'INGREDIENTS'){
        p.classList.add('pd-rv2-feature-ing-head');
      }
    });
    root.classList.add('is-trimmed');
  }

  function initRecipesCarousel(){
    var marquee = document.getElementById('pdRecipesMarquee');
    var track   = document.getElementById('pdRecipesTrack');
    var prev    = document.getElementById('pdRecipesPrev');
    var next    = document.getElementById('pdRecipesNext');
    var dots    = document.getElementById('pdRecipesDots');
    if (!marquee || !track) return;

    var cards = track.querySelectorAll('.pd-rv2-card');
    if (!cards.length) return;

    // Force initial scroll position to 0 so the first card is fully visible
    try { marquee.scrollLeft = 0; } catch(e){}

    function step(){
      var rect = cards[0].getBoundingClientRect();
      return rect.width + 18;
    }
    function scrollByCards(dir){
      marquee.scrollBy({ left: step() * dir, behavior: 'smooth' });
    }
    if (prev) prev.addEventListener('click', function(){ scrollByCards(-1); });
    if (next) next.addEventListener('click', function(){ scrollByCards(1); });

    if (dots){
      dots.innerHTML = '';
      for (var i = 0; i < cards.length; i++){
        var d = document.createElement('button');
        d.type = 'button';
        d.className = 'pd-rv2-dot';
        d.setAttribute('aria-label', 'Recipe ' + (i+1));
        d.dataset.idx = i;
        if (i === 0) d.classList.add('is-active');
        d.addEventListener('click', function(e){
          var idx = parseInt(e.currentTarget.dataset.idx, 10) || 0;
          marquee.scrollTo({ left: idx * step(), behavior: 'smooth' });
        });
        dots.appendChild(d);
      }
      function syncActive(){
        var idx = Math.round(marquee.scrollLeft / step());
        Array.prototype.forEach.call(dots.children, function(el, i){
          el.classList.toggle('is-active', i === idx);
        });
      }
      var raf = null;
      marquee.addEventListener('scroll', function(){
        if (raf) return;
        raf = requestAnimationFrame(function(){ raf = null; syncActive(); });
      }, { passive: true });
    }

    // One-time peek: nudge right, then snap reliably back to 0
    if ('IntersectionObserver' in window){
      var peeked = false;
      var io = new IntersectionObserver(function(entries){
        entries.forEach(function(e){
          if (e.isIntersecting && !peeked){
            peeked = true;
            var w = step();
            setTimeout(function(){ marquee.scrollBy({ left: w * 0.18, behavior: 'smooth' }); }, 450);
            setTimeout(function(){ marquee.scrollTo({ left: 0, behavior: 'smooth' }); }, 1100);
          }
        });
      }, { threshold: 0.35 });
      io.observe(marquee);
    }
  }

  function init(){
    trim();
    initRecipesCarousel();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

{% schema %}
{
  "name": "PD Recipes",
  "tag": "section",
  "class": "section-pd-recipes",
  "enabled_on": { "templates": ["product"] },
  "settings": [
    { "type": "header", "content": "Colors & Background" },
    { "type": "color", "id": "section_bg", "label": "Section background" },
    { "type": "color", "id": "eyebrow_color", "label": "Eyebrow color", "default": "#9a6a4f" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#2a1a12" },
    { "type": "color", "id": "lede_color", "label": "Lede text color", "default": "#6b5548" },
    { "type": "color", "id": "feature_tag_bg", "label": "Feature tag background", "default": "#2a1a12" },
    { "type": "color", "id": "feature_tag_color", "label": "Feature tag text color", "default": "#ffffff" },
    { "type": "color", "id": "feature_time_color", "label": "Feature time color", "default": "#9a6a4f" },
    { "type": "color", "id": "swipe_hint_color", "label": "Swipe hint color", "default": "#9a6a4f" },
    { "type": "color", "id": "card_name_color", "label": "Card name color", "default": "#2a1a12" },
    { "type": "color", "id": "card_time_color", "label": "Card time color", "default": "#9a6a4f" },
    { "type": "color", "id": "card_ings_color", "label": "Card ingredients color", "default": "#6b5548" },

    { "type": "header", "content": "Featured Recipe Header" },
    { "type": "text", "id": "featured_eyebrow", "label": "Eyebrow", "default": "Featured recipe" },
    { "type": "text", "id": "featured_heading_pre", "label": "Heading (before emphasis)", "default": "Pour " },
    { "type": "text", "id": "featured_heading_em", "label": "Heading (emphasized)", "default": "like this" },
    { "type": "text", "id": "featured_heading_post", "label": "Heading (after emphasis)", "default": "." },
    { "type": "textarea", "id": "featured_lede", "label": "Lede", "default": "The signature pour, plus four quick sips to mix things up." },

    { "type": "header", "content": "Featured Recipe Card" },
    { "type": "text", "id": "feature_img_alt_suffix", "label": "Image alt suffix", "default": "signature recipe" },
    { "type": "text", "id": "feature_tag_label", "label": "Feature tag", "default": "Signature recipe" },
    { "type": "text", "id": "feature_time_label", "label": "Feature time", "default": "5 min" },

    { "type": "header", "content": "Quick Sips Header" },
    { "type": "text", "id": "sub_eyebrow", "label": "Eyebrow", "default": "More ways to pour" },
    { "type": "text", "id": "sub_heading_pre", "label": "Heading (before emphasis)", "default": "Quick " },
    { "type": "text", "id": "sub_heading_em", "label": "Heading (emphasized)", "default": "sips" },
    { "type": "text", "id": "sub_heading_post", "label": "Heading (after emphasis)", "default": "." },
    { "type": "text", "id": "swipe_hint_label", "label": "Swipe hint", "default": "Swipe to explore" },
    { "type": "text", "id": "prev_aria_label", "label": "Previous button label", "default": "Previous recipe" },
    { "type": "text", "id": "next_aria_label", "label": "Next button label", "default": "Next recipe" },

    { "type": "header", "content": "Card 1" },
    { "type": "text", "id": "card1_tag", "label": "Tag", "default": "Most Popular" },
    { "type": "text", "id": "card1_time", "label": "Time", "default": "60 sec" },
    { "type": "text", "id": "card1_name_pre", "label": "Name (before product)", "default": "Iced " },
    { "type": "text", "id": "card1_name_post", "label": "Name (after product)", "default": " Latte" },
    { "type": "text", "id": "card1_ing1_pre", "label": "Ingredient 1 (before product)", "default": "1 pump " },
    { "type": "text", "id": "card1_ing1_post", "label": "Ingredient 1 (after product)", "default": "" },
    { "type": "text", "id": "card1_ing2", "label": "Ingredient 2", "default": "1 shot espresso (or 4 oz cold brew)" },
    { "type": "text", "id": "card1_ing3", "label": "Ingredient 3", "default": "8 oz cold milk of choice" },
    { "type": "text", "id": "card1_ing4", "label": "Ingredient 4", "default": "Ice, to fill" },

    { "type": "header", "content": "Card 2" },
    { "type": "text", "id": "card2_tag", "label": "Tag", "default": "Quick Sip" },
    { "type": "text", "id": "card2_time", "label": "Time", "default": "30 sec" },
    { "type": "text", "id": "card2_name_pre", "label": "Name (before product)", "default": "Sparkling " },
    { "type": "text", "id": "card2_name_post", "label": "Name (after product)", "default": " Soda" },
    { "type": "text", "id": "card2_ing1_pre", "label": "Ingredient 1 (before product)", "default": "1 pump " },
    { "type": "text", "id": "card2_ing1_post", "label": "Ingredient 1 (after product)", "default": "" },
    { "type": "text", "id": "card2_ing2", "label": "Ingredient 2", "default": "12 oz cold sparkling water" },
    { "type": "text", "id": "card2_ing3", "label": "Ingredient 3", "default": "Squeeze of lemon" },
