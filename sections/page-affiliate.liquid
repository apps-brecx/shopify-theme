{% layout 'theme' %}

<style>
  .affiliate-page {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 60px 20px;
  }

  .affiliate-hero {
    text-align: center;
    margin-bottom: 80px;
  }

  .affiliate-hero h1 {
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 700;
    color: #39220f;
    margin-bottom: 20px;
    line-height: 1.2;
  }

  .affiliate-hero p {
    font-size: 1.1rem;
    color: #666;
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.8;
  }

  .affiliate-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 40px;
    margin-bottom: 80px;
  }

  .benefit-card {
    background: #fff;
    padding: 40px;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    border: 1px solid #f0e8e0;
    text-align: center;
  }

  .benefit-icon {
    font-size: 3rem;
    margin-bottom: 20px;
    display: block;
  }

  .benefit-card h3 {
    font-size: 1.3rem;
    font-weight: 600;
    color: #39220f;
    margin-bottom: 15px;
  }

  .benefit-card p {
    font-size: 1rem;
    color: #555;
    line-height: 1.8;
    margin: 0;
  }

  .program-details {
    background: #faf8f5;
    padding: 60px 40px;
    border-radius: 8px;
    margin-bottom: 80px;
  }

  .program-details h2 {
    font-size: 2rem;
    color: #39220f;
    margin-bottom: 30px;
    font-weight: 700;
    text-align: center;
  }

  .details-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 40px;
    margin-top: 30px;
  }

  .detail-item {
    text-align: center;
  }

  .detail-item h4 {
    font-size: 1.2rem;
    color: #39220f;
    font-weight: 700;
    margin-bottom: 10px;
  }

  .detail-item p {
    font-size: 1rem;
    color: #555;
    line-height: 1.6;
    margin: 0;
  }

  .cta-section {
    background: #39220f;
    color: white;
    padding: 80px 40px;
    border-radius: 8px;
    text-align: center;
  }

  .cta-section h2 {
    font-size: 2rem;
    margin-bottom: 20px;
    font-weight: 700;
  }

  .cta-section p {
    font-size: 1.1rem;
    margin-bottom: 30px;
    line-height: 1.6;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-button {
    display: inline-block;
    background: #c58548;
    color: #39220f;
    padding: 15px 40px;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 600;
    border: none;
    cursor: pointer;
    font-size: 1rem;
  }

  .cta-button:hover {
    opacity: 0.9;
  }

  @media (max-width: 768px) {
    .affiliate-page {
      padding: 40px 20px;
    }

    .affiliate-hero {
      margin-bottom: 50px;
    }

    .affiliate-grid {
      gap: 25px;
      margin-bottom: 50px;
    }

    .benefit-card {
      padding: 30px;
    }

    .program-details {
      padding: 40px 20px;
      margin-bottom: 50px;
    }

    .program-details h2 {
      font-size: 1.5rem;
      margin-bottom: 20px;
    }

    .details-grid {
      gap: 30px;
    }

    .cta-section {
      padding: 50px 20px;
    }

    .cta-section h2 {
      font-size: 1.5rem;
    }
  }
</style>

<div class="affiliate-page">
  <!-- Hero -->
  <section class="affiliate-hero">
    <h1>Join Our Affiliate Program</h1>
    <p>Become a Syruvia partner and earn commissions by sharing the flavors you love with your community.</p>
  </section>

  <!-- Benefits -->
  <section class="affiliate-grid">
    <div class="benefit-card">
      <span class="benefit-icon">💰</span>
      <h3>Generous Commissions</h3>
      <p>Earn 15% commission on every sale referred through your unique link. Unlimited earning potential.</p>
    </div>

    <div class="benefit-card">
      <span class="benefit-icon">🛠️</span>
      <h3>Marketing Support</h3>
      <p>Get access to product images, social media templates, and promotional materials to share easily.</p>
    </div>

    <div class="benefit-card">
      <span class="benefit-icon">📊</span>
      <h3>Real-Time Tracking</h3>
      <p>Monitor your sales, clicks, and commissions in real-time with our easy-to-use partner dashboard.</p>
    </div>

    <div class="benefit-card">
      <span class="benefit-icon">👥</span>
      <h3>Dedicated Support</h3>
      <p>Our team is here to help. Get personal support to maximize your success and answer any questions.</p>
    </div>
  </section>

  <!-- Program Details -->
  <section class="program-details">
    <h2>Program Details</h2>
    <div class="details-grid">
      <div class="detail-item">
        <h4>Commission Rate</h4>
        <p>15% on all sales generated from your referral link</p>
      </div>
      <div class="detail-item">
        <h4>Cookie Duration</h4>
        <p>30-day tracking window to credit your sales</p>
      </div>
      <div class="detail-item">
        <h4>Minimum Payout</h4>
        <p>$50 minimum before you can request payment</p>
      </div>
      <div class="detail-item">
        <h4>Payment Method</h4>
        <p>Monthly payouts via direct transfer or PayPal</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <h2>Ready to Get Started?</h2>
    <p>Join hundreds of affiliates earning with Syruvia. It's free to join, takes just minutes to set up, and you can start earning right away.</p>
    <a href="#" class="cta-button">Apply Now</a>
  </section>
</div>