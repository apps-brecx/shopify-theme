<style>
  .starbucks-to-home__inner{
       background: #f7f3eb;
       padding: 40px 0;
   }
   .starbucks-to-home__heading {
     margin-bottom: 40px;
   }
   .starbucks-to-home__title{
       margin-bottom: 10px;
   }
   .starbucks-to-home__title h2{
          font-family: "Manrope", sans-serif !important;
          font-weight: 700;
       font-size: 26px;
       color: #393833;
       text-align: center;
       line-height: normal;
       margin: 0;
       line-height: 50px;
   }
   .starbucks-to-home__title h2 em{
             font-family: "Manrope", sans-serif !important;
                  font-weight: 700;
       color: #bb2a56;
       font-size: 40px;
       font-style: normal;
   }
   .starbucks-to-home__description{

       margin-bottom: 30px;
   }
   .starbucks-to-home__description p{
          font-family: "Manrope", sans-serif !important;
       margin: 0;
       font-size: 26px;
       color: #66645f;
       text-align: center;
       line-height: 30px;
   }
   .starbucks-to-home__items{
       display: flex;
       gap: 20px;
       flex-wrap: wrap;
   }
    .starbucks-to-home__item{
     text-decoration: none;
       flex: 1 0 20%;
       max-width: calc(100% / 4 - 15px );
    }
   .starbucks-to-home__item-image{
       margin-bottom: 30px;
   }
   .starbucks-to-home__item-image img{
       width: 100%;
       display: block;
       height: 100%;
       object-fit: cover;
    }
    .starbucks-to-home__item-title{
       color: #393833;
       font-size: 26px;
       text-align: center;
       margin-bottom: 10px;
       line-height: normal;
                  font-family: "Manrope", sans-serif !important;
                  font-weight: 600;
    }
    .starbucks-to-home__item-description{
       color: #66645f;
         text-align: center;
         line-height: 30px;
         font-size: 22px;
         line-height: normal;
                    font-family: "Manrope", sans-serif !important;
    }

    @media(max-width: 991px){
       .starbucks-to-home__item{
         text-decoration: none;
         flex: 1 0 40%;
         max-width: calc(100% / 2 - 10px );
     }
     .starbucks-to-home__item-image{
       margin-bottom: 10px;
     }
      .starbucks-to-home__item-title{
   
       font-size: 20px;
       margin-bottom: 5px;
       font-weight: 700;

    }
    .starbucks-to-home__item-description{
     font-size: 18px;
   
   }
    .starbucks-to-home__description p{

       font-size: 18px;

   }
   .starbucks-to-home__title h2{
     line-height: normal;
   }
    }
    @media(max-width: 750px){
      .starbucks-to-home__items{
        gap: 40px 30px;
      }
            .starbucks-to-home__item-title{

       font-size: 16px;

    }
    .starbucks-to-home__item-description{
     font-size: 16px;
   }
     .starbucks-to-home__title {
       margin-bottom: 0;
     }
          .starbucks-to-home__description p{
           line-height: normal;
         }
       .starbucks-to-home__title h2{
         font-size: 24px;
   }

   }
</style>

<div class="starbucks-to-home__inner">
  <div class="page-width">
    <div class="starbucks-to-home__heading scroll-trigger animate--slide-in">
      <div class="starbucks-to-home__title">
        {{ section.settings.title }}
      </div>
      <div class="starbucks-to-home__description">
        {{ section.settings.description }}
      </div>
    </div>

    <div class="starbucks-to-home__wrapper scroll-trigger animate--slide-in">
      <div class="starbucks-to-home__items">
        {% for block in section.blocks %}
          <a
            {% if block.settings.url != blank %}
              href="{{ block.settings.url }}"
            {% endif %}
            class="starbucks-to-home__item"
          >
            <div class="starbucks-to-home__item-image">
              {% if block.settings.image != blank %}
                {{
                  block.settings.image
                  | image_url: width: 500
                  | image_tag: loading: 'lazy', alt: block.settings.title
                }}
              {% endif %}
            </div>

            <div class="starbucks-to-home__item-title">
              {{ block.settings.title }}
            </div>

            <div class="starbucks-to-home__item-description">
              {{ block.settings.description }}
            </div>
          </a>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Starbucks To Home",
  "settings": [
    {
      "type": "richtext",
      "id": "title",
      "label": "Section Title"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Section Description"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        {
          "type": "url",
          "id": "url",
          "label": "Item Link"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Item Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Item Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Item Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Starbucks To Home",
      "blocks": [{ "type": "item" }, { "type": "item" }, { "type": "item" }]
    }
  ]
}
{% endschema %}
