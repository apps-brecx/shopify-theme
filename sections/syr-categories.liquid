{%- comment -%} Categories — picker-only (no legacy fallback), wider bottle fan, per-card bottle shadow toggle {%- endcomment -%}
{%- render 'syr-type-polish' -%}
<style id="syr-cats-{{ section.id }}-css">
  #syr-cats-{{ section.id }}{
    --ink:#39220f; --paper:#FFFBF4; --bg:#F4E8CE; --accent:#c58548;
    --butter:#FCE2A0; --peach:#FFD4B8; --mint:#C5E4D4; --sky:#B8DCEB;
    --eye-scale:.55; --eye-rot:0deg;
    background:var(--paper);
    padding:80px 0 90px;
    font-family:'Josefin Sans','Josefin',sans-serif;
    color:var(--ink);
    overflow:hidden;
  }
  #syr-cats-{{ section.id }} .syr-cats-head{ text-align:center; max-width:820px; margin:0 auto 44px; padding:0 24px; }
  #syr-cats-{{ section.id }} .syr-cats-eyebrow{
    display:inline-block; background:var(--butter); color:var(--ink);
    border:2px solid var(--ink); border-radius:999px;
    font-family:'Archivo Black','Archivo Black Fallback','Arial Black',sans-serif !important; font-weight:400;
    font-size:11px; letter-spacing:.18em; text-transform:uppercase;
    padding:7px 16px; margin-bottom:20px; box-shadow:3px 3px 0 var(--ink);
    transform-origin:center;
    transform:scale(var(--eye-scale)) rotate(var(--eye-rot));
    transition:transform .25s cubic-bezier(.16,.84,.34,1);
    will-change:transform;
  }
  #syr-cats-{{ section.id }} h2{
    font-family:'Archivo Black','Archivo Black Fallback','Arial Black',sans-serif !important; font-weight:400;
    font-size:clamp(44px, 7vw, 88px); line-height:.9;
    letter-spacing:-.025em; text-transform:uppercase;
    margin:0 0 10px;
  }
  #syr-cats-{{ section.id }} .syr-cats-sub{
    font-size:17px; color:rgba(57,34,15,.65); margin:0;
    font-family:'Archivo Black','Archivo Black Fallback','Arial Black',sans-serif !important;
    letter-spacing:.06em; text-transform:uppercase;
  }
  @media (prefers-reduced-motion: reduce){
    #syr-cats-{{ section.id }} .syr-cats-eyebrow{ transform:scale(1) rotate(0deg); transition:none; }
  }

  #syr-cats-{{ section.id }} .syr-cats-strip{
    display:flex; gap:24px;
    padding:8px max(40px, calc((100vw - 1280px) / 2)) 30px;
    overflow-x:auto; overflow-y:visible;
    scroll-snap-type:x mandatory;
    -webkit-overflow-scrolling:touch; scrollbar-width:none;
  }
  #syr-cats-{{ section.id }} .syr-cats-strip::-webkit-scrollbar{ display:none; }

  #syr-cats-{{ section.id }} .syr-cat-card{
    flex:0 0 calc((100% / 3) - 16px);
    min-width:300px; max-width:420px;
    scroll-snap-align:start;
    position:relative;
    background:var(--butter);
    border:3px solid var(--ink); border-radius:32px;
    box-shadow:8px 8px 0 var(--ink);
    aspect-ratio:4/5;
    display:flex; flex-direction:column;
    text-decoration:none; color:var(--ink);
    cursor:pointer; overflow:hidden;
    transition:transform .3s cubic-bezier(.4,0,.2,1), box-shadow .3s cubic-bezier(.4,0,.2,1);
  }
  #syr-cats-{{ section.id }} .syr-cat-card:hover{ transform:translate(-4px,-4px); box-shadow:12px 12px 0 var(--ink); }
  #syr-cats-{{ section.id }} .syr-cat-card:active{ transform:scale(.98); box-shadow:4px 4px 0 var(--ink); transition-duration:.1s; }

  #syr-cats-{{ section.id }} .syr-cat-count{
    position:absolute; top:18px; left:18px; z-index:3;
    border-radius:999px;
    box-shadow:2.5px 2.5px 0 rgba(255,251,244,.7);
    font-family:'Archivo Black','Archivo Black Fallback','Arial Black',sans-serif !important; font-weight:400;
    font-size:12px; letter-spacing:.1em; text-transform:uppercase;
    padding:7px 14px;
    display:inline-flex; align-items:center; gap:6px;
  }
  #syr-cats-{{ section.id }} .syr-cat-count strong{ font-size:16px; letter-spacing:0; }

  /* WIDER FAN — bottles spread further apart, each more visible */
  #syr-cats-{{ section.id }} .syr-cat-bottles{
    position:relative; flex:1 1 auto;
    display:flex; align-items:center; justify-content:center;
    padding:60px 16px 0;
  }
  #syr-cats-{{ section.id }} .syr-cat-bot{
    position:absolute;
    height:78%; max-height:340px;
    width:auto; object-fit:contain;
    filter:drop-shadow(4px 8px 0 rgba(57,34,15,.18));
    transition:transform .35s cubic-bezier(.4,0,.2,1);
  }
  #syr-cats-{{ section.id }} .syr-cat-card.syr-no-bot-shadow .syr-cat-bot{ filter:none !important; }

  #syr-cats-{{ section.id }} .syr-cat-bot.b-left{ transform:rotate(-12deg) translateX(-42%); z-index:1; }
  #syr-cats-{{ section.id }} .syr-cat-bot.b-center{ transform:rotate(0deg) translateY(-4%); z-index:3; }
  #syr-cats-{{ section.id }} .syr-cat-bot.b-right{ transform:rotate(12deg) translateX(42%); z-index:2; }
  #syr-cats-{{ section.id }} .syr-cat-card:hover .syr-cat-bot.b-left{ transform:rotate(-18deg) translateX(-58%) translateY(-6%); }
  #syr-cats-{{ section.id }} .syr-cat-card:hover .syr-cat-bot.b-center{ transform:rotate(0deg) translateY(-14%) scale(1.06); }
  #syr-cats-{{ section.id }} .syr-cat-card:hover .syr-cat-bot.b-right{ transform:rotate(18deg) translateX(58%) translateY(-6%); }
  #syr-cats-{{ section.id }} .syr-cat-bottles-fb{ width:60%; height:60%; background:#fff; border:2px solid var(--ink); border-radius:50% / 12%; box-shadow:6px 6px 0 var(--ink); }

  #syr-cats-{{ section.id }} .syr-cat-info{
    background:var(--paper);
    border-top:3px solid var(--ink);
    padding:18px 20px 22px;
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    gap:12px;
    text-align:center;
  }
  #syr-cats-{{ section.id }} .syr-cat-name{
    font-family:'Archivo Black','Archivo Black Fallback','Arial Black',sans-serif !important;
    font-weight:400;
    font-size:clamp(22px, 2.2vw, 30px); line-height:1;
    letter-spacing:-.005em; text-transform:uppercase;
    color:var(--ink); margin:0;
  }
  #syr-cats-{{ section.id }} .syr-cat-cta{
    display:inline-flex; align-items:center; gap:8px;
    border-radius:999px;
    font-family:'Archivo Black','Archivo Black Fallback','Arial Black',sans-serif !important;
    font-weight:400;
    font-size:12px; letter-spacing:.12em; text-transform:uppercase;
    padding:11px 22px;
    transition:transform .15s ease, box-shadow .15s ease, filter .15s ease;
    white-space:nowrap;
  }
  #syr-cats-{{ section.id }} .syr-cat-card:hover .syr-cat-cta{ transform:translate(-1px,-1px); filter:brightness(1.08); }
  #syr-cats-{{ section.id }} .syr-cat-cta svg{ width:13px; height:13px; transition:transform .15s ease; }
  #syr-cats-{{ section.id }} .syr-cat-card:hover .syr-cat-cta svg{ transform:translateX(3px); }

  #syr-cats-{{ section.id }} .syr-cats-controls{
    display:none; justify-content:flex-end; align-items:center; gap:10px;
    max-width:1280px; margin:0 auto 16px; padding:0 40px;
  }
  @media (min-width:1100px){ #syr-cats-{{ section.id }} .syr-cats-controls{ display:flex; } }
  #syr-cats-{{ section.id }} .syr-cats-arrow{
    width:48px; height:48px; border-radius:50%;
    background:var(--paper); color:var(--ink);
    border:2px solid var(--ink); box-shadow:3px 3px 0 var(--ink);
    display:flex; align-items:center; justify-content:center; cursor:pointer;
    transition:transform .15s ease, background .15s ease;
  }
  #syr-cats-{{ section.id }} .syr-cats-arrow:hover{ background:var(--butter); transform:scale(1.08); }
  #syr-cats-{{ section.id }} .syr-cats-arrow svg{ width:18px; height:18px; }

  @media (max-width:760px){
    #syr-cats-{{ section.id }}{ padding:50px 0 70px; }
    #syr-cats-{{ section.id }} .syr-cats-head{ margin-bottom:24px; }
    #syr-cats-{{ section.id }} h2{ font-size:clamp(36px, 12vw, 56px); }
    #syr-cats-{{ section.id }} .syr-cats-sub{ font-size:13.5px; }
    #syr-cats-{{ section.id }} .syr-cats-strip{ gap:16px; padding:6px 16px 24px; scroll-padding-left:16px; }
    #syr-cats-{{ section.id }} .syr-cat-card{ flex:0 0 78vw; max-width:340px; min-width:0; box-shadow:6px 6px 0 var(--ink); border-radius:26px; border-width:2px; }
    #syr-cats-{{ section.id }} .syr-cat-count{ font-size:11px; padding:6px 12px; top:14px; left:14px; box-shadow:2px 2px 0 rgba(255,251,244,.7); }
    #syr-cats-{{ section.id }} .syr-cat-count strong{ font-size:14px; }
    #syr-cats-{{ section.id }} .syr-cat-info{ padding:16px 16px 18px; gap:10px; }
    #syr-cats-{{ section.id }} .syr-cat-name{ font-size:22px; }
    #syr-cats-{{ section.id }} .syr-cat-cta{ padding:10px 18px; font-size:11px; }
  }
</style>

<section id="syr-cats-{{ section.id }}">
  <div class="syr-cats-head">
    <span class="syr-cats-eyebrow">Shop by category</span>
    <h2>{{ section.settings.headline }}</h2>
    <p class="syr-cats-sub">{{ section.settings.sub }}</p>
  </div>
  <div class="syr-cats-controls" aria-hidden="true">
    <button class="syr-cats-arrow" data-cats-prev aria-label="Previous"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M15 6l-6 6 6 6"/></svg></button>
    <button class="syr-cats-arrow" data-cats-next aria-label="Next"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg></button>
  </div>
  <div class="syr-cats-strip" id="syr-cats-strip-{{ section.id }}">
    {%- assign keys = 'c1,c2,c3,c4,c5,c6' | split: ',' -%}
    {%- assign default_bgs = '#FCE2A0,#FFD4B8,#C5E4D4,#B8DCEB,#FCE2A0,#FFD4B8' | split: ',' -%}
    {%- assign default_btn_bgs = '#39220f,#c58548,#5BA3D0,#2F7BB0,#c58548,#39220f' | split: ',' -%}
    {%- assign default_btn_colors = '#FFFBF4,#FFFBF4,#FFFBF4,#FFFBF4,#FFFBF4,#FFFBF4' | split: ',' -%}
    {%- for key in keys -%}
      {%- assign coll_k = key | append: '_coll' -%}
      {%- assign name_k = key | append: '_name' -%}
      {%- assign cta_k = key | append: '_cta' -%}
      {%- assign bg_k = key | append: '_bg' -%}
      {%- assign btn_bg_k = key | append: '_btn_bg' -%}
      {%- assign btn_color_k = key | append: '_btn_color' -%}
      {%- assign img_left_k = key | append: '_img_left' -%}
      {%- assign img_center_k = key | append: '_img_center' -%}
      {%- assign img_right_k = key | append: '_img_right' -%}
      {%- assign count_k = key | append: '_count' -%}
      {%- assign chip_show_k = key | append: '_chip_show' -%}
      {%- assign chip_text_k = key | append: '_chip_text' -%}
      {%- assign chip_suffix_k = key | append: '_chip_suffix' -%}
      {%- assign chip_bg_k = key | append: '_chip_bg' -%}
      {%- assign chip_color_k = key | append: '_chip_color' -%}
      {%- assign bot_shadow_k = key | append: '_bot_shadow' -%}
      {%- comment -%} ONLY use the collection picker. No legacy handle fallback. Card disappears if no collection picked. {%- endcomment -%}
      {%- assign coll = section.settings[coll_k] -%}
      {%- if coll == blank or coll == empty -%}{%- continue -%}{%- endif -%}
      {%- assign idx = forloop.index0 -%}
      {%- assign cat_name = section.settings[name_k] | default: coll.title -%}
      {%- assign cta_text = section.settings[cta_k] | default: 'Shop' -%}
      {%- assign bg = section.settings[bg_k] | default: default_bgs[idx] -%}
      {%- assign btn_bg = section.settings[btn_bg_k] | default: default_btn_bgs[idx] -%}
      {%- assign btn_color = section.settings[btn_color_k] | default: default_btn_colors[idx] -%}
      {%- assign img_left = section.settings[img_left_k] -%}
      {%- assign img_center = section.settings[img_center_k] -%}
      {%- assign img_right = section.settings[img_right_k] -%}
      {%- assign override_count = section.settings[count_k] -%}
      {%- assign chip_show = section.settings[chip_show_k] -%}
      {%- assign chip_text = section.settings[chip_text_k] -%}
      {%- assign chip_suffix = section.settings[chip_suffix_k] | default: 'flavors' -%}
      {%- assign chip_bg = section.settings[chip_bg_k] | default: '#39220f' -%}
      {%- assign chip_color = section.settings[chip_color_k] | default: '#FFFBF4' -%}
      {%- assign bot_shadow = section.settings[bot_shadow_k] -%}
      {%- assign live_count = coll.all_products_count -%}
      {%- if live_count == 0 or live_count == blank -%}{%- assign live_count = coll.products_count -%}{%- endif -%}
      {%- assign flavor_count = override_count | default: live_count | default: 100 -%}
      {%- assign use_manual = false -%}
      {%- if img_left != blank or img_center != blank or img_right != blank -%}{%- assign use_manual = true -%}{%- endif -%}
      <a class="syr-cat-card{% unless bot_shadow %} syr-no-bot-shadow{% endunless %}" href="{{ coll.url | default: '/collections/all' }}" style="background:{{ bg }} !important;">
        {%- if chip_show -%}
          {%- if chip_text != blank -%}
            <span class="syr-cat-count" style="background:{{ chip_bg }} !important; color:{{ chip_color }} !important; border:2px solid {{ chip_bg }} !important;">{{ chip_text }}</span>
          {%- else -%}
            <span class="syr-cat-count" style="background:{{ chip_bg }} !important; color:{{ chip_color }} !important; border:2px solid {{ chip_bg }} !important;"><strong>{{ flavor_count }}+</strong> {{ chip_suffix }}</span>
          {%- endif -%}
        {%- endif -%}
        <div class="syr-cat-bottles">
          {%- if use_manual -%}
            {%- if img_left != blank -%}<img class="syr-cat-bot b-left" src="{{ img_left | image_url: width: 540 }}" alt="{{ cat_name | escape }}" loading="lazy">{%- endif -%}
            {%- if img_center != blank -%}<img class="syr-cat-bot b-center" src="{{ img_center | image_url: width: 540 }}" alt="{{ cat_name | escape }}" loading="lazy">{%- endif -%}
            {%- if img_right != blank -%}<img class="syr-cat-bot b-right" src="{{ img_right | image_url: width: 540 }}" alt="{{ cat_name | escape }}" loading="lazy">{%- endif -%}
          {%- else -%}
            {%- assign shown = 0 -%}
            {%- assign positions = 'b-left,b-center,b-right' | split: ',' -%}
            {%- for p in coll.products limit: 3 -%}
              {%- if p.featured_media -%}
                {%- assign pos = positions[shown] -%}
                <img class="syr-cat-bot {{ pos }}" src="{{ p.featured_media | image_url: width: 540 }}" alt="{{ p.title | escape }}" loading="lazy">
                {%- assign shown = shown | plus: 1 -%}
              {%- endif -%}
            {%- endfor -%}
            {%- if shown == 0 -%}<div class="syr-cat-bottles-fb"></div>{%- endif -%}
          {%- endif -%}
        </div>
        <div class="syr-cat-info">
          <h3 class="syr-cat-name">{{ cat_name }}</h3>
          <span class="syr-cat-cta" style="background:{{ btn_bg }} !important; color:{{ btn_color }} !important; border:2px solid {{ btn_bg }} !important; box-shadow:3px 3px 0 rgba(57,34,15,.25);">
            {{ cta_text }}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </span>
        </div>
      </a>
    {%- endfor -%}
  </div>
</section>

<script>
(function(){
  var root = document.getElementById('syr-cats-{{ section.id }}');
  if (!root) return;
  var eyebrow = root.querySelector('.syr-cats-eyebrow');
  if (!eyebrow) return;
  if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches){
    root.style.setProperty('--eye-scale', '1'); root.style.setProperty('--eye-rot', '0deg');
    return;
  }
  var ticking = false;
  function update(){
    var rect = eyebrow.getBoundingClientRect();
    var vh = window.innerHeight || document.documentElement.clientHeight;
    if (vh < 1) return;
    var elementCenter = rect.top + rect.height / 2;
    var viewportCenter = vh / 2;
    var progress = (viewportCenter - elementCenter) / vh;
    if (progress < -1) progress = -1;
    if (progress > 1) progress = 1;
    var scale = 0.55 + (progress + 0.4) * 0.7;
    if (scale < 0.4) scale = 0.4;
    if (scale > 1.3) scale = 1.3;
    var rot = progress * 6;
    if (rot < -6) rot = -6;
    if (rot > 6) rot = 6;
    root.style.setProperty('--eye-scale', scale.toFixed(3));
    root.style.setProperty('--eye-rot', rot.toFixed(2) + 'deg');
    ticking = false;
  }
  function onScroll(){ if (!ticking){ ticking = true; window.requestAnimationFrame(update); } }
  window.addEventListener('scroll', onScroll, { passive:true });
  window.addEventListener('resize', onScroll);
  update();

  var strip = document.getElementById('syr-cats-strip-{{ section.id }}');
  if (!strip) return;
  var prev = root.querySelector('[data-cats-prev]');
  var next = root.querySelector('[data-cats-next]');
  function step(){ var card = strip.querySelector('.syr-cat-card'); return card ? (card.offsetWidth + 24) : 360; }
  if (prev) prev.addEventListener('click', function(){ strip.scrollBy({ left: -step(), behavior:'smooth' }); });
  if (next) next.addEventListener('click', function(){ strip.scrollBy({ left: step(), behavior:'smooth' }); });
})();
</script>

{% schema %}
{
  "name": "Categories (Syr)",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "headline", "label": "Headline", "default": "Pick your syrup" },
    { "type": "text", "id": "sub", "label": "Subtext", "default": "250+ flavors" },
    { "type": "paragraph", "content": "Each card: pick a collection. Cards with no collection picked are hidden. The chip count comes from collection's active products. Use 'count override' if Shopify's number is wrong." },

    { "type": "header", "content": "Card 1" },
    { "type": "collection", "id": "c1_coll", "label": "Pick collection (required)" },
    { "type": "text", "id": "c1_name", "label": "Card title", "default": "Coffee" },
    { "type": "text", "id": "c1_cta", "label": "Button text", "default": "Shop Coffee" },
    { "type": "checkbox", "id": "c1_bot_shadow", "label": "Show bottle drop-shadow", "default": true },
    { "type": "header", "content": "Card 1 chip badge" },
    { "type": "checkbox", "id": "c1_chip_show", "label": "Show chip badge", "default": true },
    { "type": "text", "id": "c1_chip_text", "label": "Custom chip text (e.g. 50% OFF)", "info": "If filled, shows ONLY this text. Leave blank to auto-pull count." },
    { "type": "text", "id": "c1_count", "label": "Auto: count override (number)", "info": "Force this number instead of the collection's count." },
    { "type": "text", "id": "c1_chip_suffix", "label": "Auto: word after count", "default": "flavors" },
    { "type": "color", "id": "c1_chip_bg", "label": "Chip background", "default": "#39220f" },
    { "type": "color", "id": "c1_chip_color", "label": "Chip text color", "default": "#FFFBF4" },
    { "type": "header", "content": "Card 1 bottle images" },
    { "type": "image_picker", "id": "c1_img_left", "label": "Left bottle" },
    { "type": "image_picker", "id": "c1_img_center", "label": "Center bottle" },
    { "type": "image_picker", "id": "c1_img_right", "label": "Right bottle" },
    { "type": "header", "content": "Card 1 colors" },
    { "type": "color", "id": "c1_bg", "label": "Card background", "default": "#FCE2A0" },
    { "type": "color", "id": "c1_btn_bg", "label": "Button background", "default": "#39220f" },
    { "type": "color", "id": "c1_btn_color", "label": "Button text color", "default": "#FFFBF4" },

    { "type": "header", "content": "Card 2" },
    { "type": "collection", "id": "c2_coll", "label": "Pick collection (required)" },
    { "type": "text", "id": "c2_name", "label": "Card title", "default": "Fruit" },
    { "type": "text", "id": "c2_cta", "label": "Button text", "default": "Shop Fruit" },
    { "type": "checkbox", "id": "c2_bot_shadow", "label": "Show bottle drop-shadow", "default": true },
    { "type": "header", "content": "Card 2 chip badge" },
    { "type": "checkbox", "id": "c2_chip_show", "label": "Show chip badge", "default": true },
    { "type": "text", "id": "c2_chip_text", "label": "Custom chip text (e.g. 50% OFF)", "info": "If filled, shows ONLY this text." },
    { "type": "text", "id": "c2_count", "label": "Auto: count override (number)" },
    { "type": "text", "id": "c2_chip_suffix", "label": "Auto: word after count", "default": "flavors" },
    { "type": "color", "id": "c2_chip_bg", "label": "Chip background", "default": "#39220f" },
    { "type": "color", "id": "c2_chip_color", "label": "Chip text color", "default": "#FFFBF4" },
    { "type": "header", "content": "Card 2 bottle images" },
    { "type": "image_picker", "id": "c2_img_left", "label": "Left bottle" },
    { "type": "image_picker", "id": "c2_img_center", "label": "Center bottle" },
    { "type": "image_picker", "id": "c2_img_right", "label": "Right bottle" },
    { "type": "header", "content": "Card 2 colors" },
    { "type": "color", "id": "c2_bg", "label": "Card background", "default": "#FFD4B8" },
    { "type": "color", "id": "c2_btn_bg", "label": "Button background", "default": "#c58548" },
    { "type": "color", "id": "c2_btn_color", "label": "Button text color", "default": "#FFFBF4" },

    { "type": "header", "content": "Card 3" },
    { "type": "collection", "id": "c3_coll", "label": "Pick collection (required)" },
    { "type": "text", "id": "c3_name", "label": "Card title", "default": "Sugar-Free" },
    { "type": "text", "id": "c3_cta", "label": "Button text", "default": "Shop Sugar-Free" },
    { "type": "checkbox", "id": "c3_bot_shadow", "label": "Show bottle drop-shadow", "default": true },
