{%- if customer == nil -%}
{%- assign bb_return_to = request.path | url_encode -%}
<div id="bb-vip-host">
  <div class="bb-vip-nudge">
    <span class="bb-vip-nudge-eyebrow">Syruvia VIP · Free</span>
    <h3>Sign in and <em>stack</em> your savings.</h3>
    <p class="bb-vip-nudge-body">VIP members pay a <strong>flat $7.99</strong> on every syrup. Combine it with your bundle discount and save even more on this order.</p>
    <div class="bb-vip-nudge-ctas">
      <a class="bb-vip-nudge-btn bb-vip-nudge-btn--primary" href="/account/register?return_to={{ bb_return_to }}">Create free account →</a>
      <a class="bb-vip-nudge-btn bb-vip-nudge-btn--secondary" href="/account/login?return_to={{ bb_return_to }}">Sign in</a>
    </div>
  </div>
</div>
{%- endif -%}

<script>
(function(){
  function init(){
    var root = document.querySelector('.sbwrap');
    if (!root) return;

    var host = document.getElementById('bb-vip-host');
    if (host){
      var card = host.querySelector('.bb-vip-nudge');
      var hero = root.querySelector('.hero');
      if (card && hero && !root.querySelector('.bb-vip-nudge')){
        hero.parentNode.insertBefore(card, hero.nextSibling);
        host.remove();
      }
    }

    var toolbar = root.querySelector('.toolbar');
    if (toolbar && !root.querySelector('.bb-search-row')){
      var row = document.createElement('div');
      row.className = 'bb-search-row';
      row.innerHTML =
        '<div class="bb-search-wrap">' +
          '<svg class="bb-search-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>' +
          '<input type="text" class="bb-search" placeholder="Search flavors" aria-label="Search flavors" />' +
          '<button type="button" class="bb-search-clear" aria-label="Clear search">×</button>' +
        '</div>';
      toolbar.parentNode.insertBefore(row, toolbar.nextSibling);

      var input = row.querySelector('.bb-search');
      var clearBtn = row.querySelector('.bb-search-clear');
      var cards = [].slice.call(root.querySelectorAll('[data-card]'));

      function applyFilter(){
        var q = (input.value||'').trim().toLowerCase();
        clearBtn.style.display = q ? 'inline-flex' : 'none';
        cards.forEach(function(c){
          var name = (c.dataset.name||'').toLowerCase();
          var tags = (c.dataset.tags||'').toLowerCase();
          if (!q || name.indexOf(q) > -1 || tags.indexOf(q) > -1){
            c.removeAttribute('data-search-hidden');
          } else {
            c.setAttribute('data-search-hidden', '1');
          }
        });
      }

      input.addEventListener('input', applyFilter);
      clearBtn.addEventListener('click', function(){
        input.value = '';
        applyFilter();
        input.focus();
      });
      var allChip = root.querySelector('[data-chip="all"]');
      if (allChip && !allChip.classList.contains('on')) allChip.click();
    }
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>

