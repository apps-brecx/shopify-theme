{{ 'customer.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Wrapper and background */
  .cst-custom-login-wrapper {
    position: relative;
    width: 100%;
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .cst-login-background {
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    z-index: 1;
    filter: brightness(0.65);
  }

  /* Overlay container */
  .cst-login-overlay {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 450px;
    padding: 40px;
    background: rgba(255, 255, 255, 0.95);
    border-radius: 10px;
    box-shadow: 0 5px 25px rgba(0,0,0,0.3);
    text-align: center;
  }

  /* Heading style */
  .cst-login-overlay h1 {
    font-family: Georgia, serif;
    font-weight: 500;
    font-size: 50px;
    color: #3f2305;
    margin-bottom: 20px;
    letter-spacing: 0.02em;
  }

  /* Content below heading */
  .cst-login-overlay .cst-login-content {
    margin-bottom: 25px;
    font-family: Arial, sans-serif;
    color: #333;
  }

  /* Form fields */
  .cst-login-overlay .field {
    margin-bottom: 15px;
  }

  .cst-login-overlay input {
    width: 100%;
    padding: 10px 12px;
    border-radius: 5px;
    border: 1px solid #ccc;
    font-size: 14px;
  }

  /* Submit button */
  .cst-login-button-wrapper button {
    width: 100%;
    min-height: 45px;
    padding: 0 10px;
    font-size: 16px;
    font-weight: 600;
    border-radius: 5px;
    border: none;
    background-color: #3f2305;
    color: #fff;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .cst-login-button-wrapper button:hover {
    background-color: #2d1a02;
  }

  /* Error messages */
  .form__message {
    display: flex;
    align-items: center;
    margin-top: 5px;
    color: #EB001B;
    font-size: 13px;
    text-align: left;
  }

  .form__message svg {
    margin-right: 6px;
  }
{%- endstyle -%}

<div class="cst-custom-login-wrapper section-{{ section.id }}-padding">
  <!-- Background Image -->
  <div class="cst-login-background" 
       style="background-image: url('{{ section.settings.image | img_url: '2048x2048' }}');">
  </div>

  <!-- Overlay Form -->
  <div class="cst-login-overlay">
    <!-- Heading -->
    <h1 class="cst-login-heading">{{ section.settings.heading }}</h1>

    <!-- Content -->
    <div class="cst-login-content">{{ section.settings.content }}</div>

    <!-- Register Form -->
    {% form 'create_customer', novalidate: 'novalidate' %}
      <div class="field">
        <input
          type="text"
          name="customer[first_name]"
          id="RegisterForm-FirstName"
          {% if form.first_name %} value="{{ form.first_name }}" {% endif %}
          autocomplete="given-name"
          placeholder="First Name*"
        >
      </div>

      <div class="field">
        <input
          type="text"
          name="customer[last_name]"
          id="RegisterForm-LastName"
          {% if form.last_name %} value="{{ form.last_name }}" {% endif %}
          autocomplete="family-name"
          placeholder="Last Name*"
        >
      </div>

      <div class="field">
        <input
          type="email"
          name="customer[email]"
          id="RegisterForm-email"
          {% if form.email %} value="{{ form.email }}" {% endif %}
          spellcheck="false"
          autocapitalize="off"
          autocomplete="email"
          placeholder="Email*"
        >
        {% if form.errors contains 'email' %}
          <span class="form__message">
            <svg aria-hidden="true" focusable="false" viewBox="0 0 13 13">
              <use href="#icon-error" />
            </svg>
            {{ form.errors.translated_fields.email | capitalize }}
            {{ form.errors.messages.email }}
          </span>
        {% endif %}
      </div>

      <div class="field">
        <input
          type="password"
          name="customer[password]"
          id="RegisterForm-password"
          placeholder="Password*"
        >
        {% if form.errors contains 'password' %}
          <span class="form__message">
            <svg aria-hidden="true" focusable="false" viewBox="0 0 13 13">
              <use href="#icon-error" />
            </svg>
            {{ form.errors.translated_fields.password | capitalize }}
            {{ form.errors.messages.password }}
          </span>
        {% endif %}
      </div>

      <div class="cst-login-button-wrapper">
        <button type="submit">Create Account</button>
      </div>
    {% endform %}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-register.name",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "richtext",
      "label": "Heading",
      "id": "heading"
    },
    {
      "type": "richtext",
      "label": "Content",
      "id": "content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    }
  ]
}
{% endschema %}