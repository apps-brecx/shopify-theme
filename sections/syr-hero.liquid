{%- comment -%} Hero banner slider — simple: desktop + mobile image, optional overlay button {%- endcomment -%}
<style id="syr-hero-{{ section.id }}-css">
  #syr-hero-{{ section.id }}{
    position:relative; overflow:hidden;
    font-family:'Josefin Sans','Josefin',sans-serif;
    background:#FFFBF4;
  }
  #syr-hero-{{ section.id }} .syr-banner{
    position:relative; width:100%;
    display:flex; overflow-x:auto; overflow-y:hidden;
    scroll-snap-type:x mandatory;
    -webkit-overflow-scrolling:touch; scrollbar-width:none;
  }
  #syr-hero-{{ section.id }} .syr-banner::-webkit-scrollbar{ display:none; }
  #syr-hero-{{ section.id }} .syr-slide{
    position:relative; flex:0 0 100%; width:100%;
    scroll-snap-align:start;
  }
  #syr-hero-{{ section.id }} .syr-slide-link{
    display:block; position:relative;
    text-decoration:none; color:inherit;
  }
  #syr-hero-{{ section.id }} .syr-slide-link.is-clickable{ cursor:pointer; transition:filter .25s ease; }
  #syr-hero-{{ section.id }} .syr-slide-link.is-clickable:hover{ filter:brightness(1.03); }
  #syr-hero-{{ section.id }} .syr-slide-link.is-clickable:active{ filter:brightness(.97); }

  #syr-hero-{{ section.id }} .syr-slide-img-d,
  #syr-hero-{{ section.id }} .syr-slide-img-m,
  #syr-hero-{{ section.id }} .syr-slide-vid-d,
  #syr-hero-{{ section.id }} .syr-slide-vid-m{ display:block; width:100%; height:auto; }
  #syr-hero-{{ section.id }} .syr-slide-vid-d,
  #syr-hero-{{ section.id }} .syr-slide-vid-m{ object-fit:cover; }
  #syr-hero-{{ section.id }} .syr-slide-img-m,
  #syr-hero-{{ section.id }} .syr-slide-vid-m{ display:none; }
  @media (max-width:760px){
    #syr-hero-{{ section.id }} .syr-slide-img-d,
    #syr-hero-{{ section.id }} .syr-slide-vid-d{ display:none; }
    #syr-hero-{{ section.id }} .syr-slide-img-m,
    #syr-hero-{{ section.id }} .syr-slide-vid-m{ display:block; }
  }
  #syr-hero-{{ section.id }} .syr-slide-img-fb{
    width:100%; aspect-ratio:21/9; max-height:78vh;
    background:linear-gradient(135deg, #FFD4B8 0%, #c58548 100%);
    display:flex; align-items:center; justify-content:center;
    color:#fff; font-family:'Archivo Black',sans-serif;
    font-size:18px; letter-spacing:.14em; text-transform:uppercase;
  }
  @media (max-width:760px){ #syr-hero-{{ section.id }} .syr-slide-img-fb{ aspect-ratio:4/5; } }

  /* Overlay button (3D push-button) */
  #syr-hero-{{ section.id }} .syr-slide-cta{
    position:absolute;
    left:50%; transform:translateX(-50%);
    bottom:8%;
    display:inline-flex; align-items:center; justify-content:center;
    padding:16px 42px;
    border-radius:10px;
    font-family:'Archivo Black','Archivo',sans-serif; font-weight:400;
    font-size:16px; letter-spacing:.14em; text-transform:uppercase;
    border:0; text-decoration:none; cursor:pointer;
    box-shadow:0 4px 0 rgba(0,0,0,.25), 0 6px 14px rgba(0,0,0,.15);
    transition:transform .18s cubic-bezier(.4,0,.2,1), box-shadow .18s cubic-bezier(.4,0,.2,1);
    z-index:3;
  }
  #syr-hero-{{ section.id }} .syr-slide-cta:hover{ transform:translateX(-50%) translateY(-2px); box-shadow:0 6px 0 rgba(0,0,0,.25), 0 10px 18px rgba(0,0,0,.18); }
  #syr-hero-{{ section.id }} .syr-slide-cta:active{ transform:translateX(-50%) translateY(2px); box-shadow:0 2px 0 rgba(0,0,0,.25), 0 4px 8px rgba(0,0,0,.1); transition-duration:.08s; }

  /* DOTS */
  #syr-hero-{{ section.id }} .syr-dots{
    position:absolute; left:50%; bottom:18px; transform:translateX(-50%);
    display:flex; gap:8px; z-index:10;
    background:rgba(255,255,255,.85); backdrop-filter:blur(8px);
    border:1.5px solid rgba(57,34,15,.2); border-radius:999px;
    padding:7px 11px;
  }
  #syr-hero-{{ section.id }} .syr-dot{
    width:9px; height:9px; border-radius:50%;
    background:rgba(57,34,15,.3); border:0; padding:0; cursor:pointer;
    transition:background .2s ease, width .2s ease;
  }
  #syr-hero-{{ section.id }} .syr-dot.is-active{ background:#39220f; width:24px; border-radius:5px; }

  /* Arrows (desktop) */
  #syr-hero-{{ section.id }} .syr-arrow{
    position:absolute; top:50%; transform:translateY(-50%);
    width:44px; height:44px; border-radius:50%;
    background:rgba(255,255,255,.92); color:#39220f;
    border:1.5px solid #39220f; box-shadow:3px 3px 0 #39220f;
    display:none; align-items:center; justify-content:center; cursor:pointer;
    z-index:10; transition:transform .15s ease, background .15s ease;
  }
  #syr-hero-{{ section.id }} .syr-arrow:hover{ background:#FCE2A0; transform:translateY(-50%) scale(1.08); }
  #syr-hero-{{ section.id }} .syr-arrow--prev{ left:18px; }
  #syr-hero-{{ section.id }} .syr-arrow--next{ right:18px; }
  #syr-hero-{{ section.id }} .syr-arrow svg{ width:16px; height:16px; }
  @media (min-width:901px){ #syr-hero-{{ section.id }} .syr-arrow{ display:inline-flex; } }

  @media (max-width:760px){
    #syr-hero-{{ section.id }} .syr-slide-cta{ padding:13px 34px; font-size:14px; }
    #syr-hero-{{ section.id }} .syr-dots{ bottom:12px; padding:6px 10px; }
  }
</style>

<section id="syr-hero-{{ section.id }}" aria-roledescription="carousel">
  <div class="syr-banner" id="syr-banner-{{ section.id }}">
    {%- for block in section.blocks -%}
      {%- if block.type == 'slide' -%}
        {%- assign btn_bg = block.settings.btn_bg | default: '#C8252B' -%}
        {%- assign btn_color = block.settings.btn_color | default: '#FFFFFF' -%}
        {%- assign link = block.settings.link | default: '/collections/all' -%}
        {%- assign show_button = block.settings.show_button -%}
        <div class="syr-slide" data-slide-idx="{{ forloop.index0 }}" role="group" aria-roledescription="slide">
          {%- assign alt_txt = block.settings.alt | default: block.settings.btn_text | escape -%}
          {%- assign vid_d = block.settings.video_desktop -%}
          {%- assign vid_m = block.settings.video_mobile -%}
          {%- comment -%} shared <video> attributes: autoplay bg-style, or controls when autoplay is off {%- endcomment -%}
          {%- capture vid_attrs -%}{% if block.settings.video_autoplay %}autoplay muted loop playsinline preload="metadata"{% else %}controls playsinline preload="metadata"{% endif %}{%- endcapture -%}
          {%- assign has_media = false -%}
          {%- if block.settings.image_desktop != blank or block.settings.image_mobile != blank or vid_d != blank or vid_m != blank -%}{%- assign has_media = true -%}{%- endif -%}
          {%- comment -%} posters / image fallbacks {%- endcomment -%}
          {%- assign poster_d = '' -%}
          {%- if block.settings.image_desktop != blank -%}{%- assign poster_d = block.settings.image_desktop | image_url: width: 2400 -%}{%- elsif vid_d.preview_image != blank -%}{%- assign poster_d = vid_d.preview_image | image_url: width: 2400 -%}{%- endif -%}
          {%- assign poster_m = '' -%}
          {%- if block.settings.image_mobile != blank -%}{%- assign poster_m = block.settings.image_mobile | image_url: width: 1200 -%}{%- elsif block.settings.image_desktop != blank -%}{%- assign poster_m = block.settings.image_desktop | image_url: width: 1200 -%}{%- elsif vid_m.preview_image != blank -%}{%- assign poster_m = vid_m.preview_image | image_url: width: 1200 -%}{%- elsif vid_d.preview_image != blank -%}{%- assign poster_m = vid_d.preview_image | image_url: width: 1200 -%}{%- endif -%}
          <a class="syr-slide-link {% unless show_button %}is-clickable{% endunless %}" href="{{ link }}" aria-label="{{ alt_txt }}">
            {%- comment -%} ── Desktop media: video wins, else image ── {%- endcomment -%}
            {%- if vid_d != blank -%}
              <video class="syr-slide-vid-d" {{ vid_attrs }}{% if poster_d != blank %} poster="{{ poster_d }}"{% endif %} aria-label="{{ alt_txt }}">
                {%- for src in vid_d.sources -%}<source src="{{ src.url }}" type="{{ src.mime_type }}">{%- endfor -%}
              </video>
            {%- elsif block.settings.image_desktop != blank -%}
              <img class="syr-slide-img-d" src="{{ block.settings.image_desktop | image_url: width: 2400 }}" alt="{{ alt_txt }}" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}">
            {%- endif -%}
            {%- comment -%} ── Mobile media: mobile video → mobile image → desktop video → desktop image ── {%- endcomment -%}
            {%- if vid_m != blank -%}
              <video class="syr-slide-vid-m" {{ vid_attrs }}{% if poster_m != blank %} poster="{{ poster_m }}"{% endif %} aria-label="{{ alt_txt }}">
                {%- for src in vid_m.sources -%}<source src="{{ src.url }}" type="{{ src.mime_type }}">{%- endfor -%}
              </video>
            {%- elsif block.settings.image_mobile != blank -%}
              <img class="syr-slide-img-m" src="{{ block.settings.image_mobile | image_url: width: 1200 }}" alt="{{ alt_txt }}" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}">
            {%- elsif vid_d != blank -%}
              <video class="syr-slide-vid-m" {{ vid_attrs }}{% if poster_m != blank %} poster="{{ poster_m }}"{% endif %} aria-label="{{ alt_txt }}">
                {%- for src in vid_d.sources -%}<source src="{{ src.url }}" type="{{ src.mime_type }}">{%- endfor -%}
              </video>
            {%- elsif block.settings.image_desktop != blank -%}
              <img class="syr-slide-img-m" src="{{ block.settings.image_desktop | image_url: width: 1200 }}" alt="{{ alt_txt }}" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}">
            {%- endif -%}
            {%- unless has_media -%}
              <div class="syr-slide-img-d"><div class="syr-slide-img-fb">Upload banner image</div></div>
              <div class="syr-slide-img-m"><div class="syr-slide-img-fb">Upload mobile banner</div></div>
            {%- endunless -%}
            {%- if show_button and block.settings.btn_text != blank -%}
              <span class="syr-slide-cta" style="background:{{ btn_bg }};color:{{ btn_color }};">{{ block.settings.btn_text }}</span>
            {%- endif -%}
          </a>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 -%}
    <button class="syr-arrow syr-arrow--prev" data-banner-prev aria-label="Previous slide"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M15 6l-6 6 6 6"/></svg></button>
    <button class="syr-arrow syr-arrow--next" data-banner-next aria-label="Next slide"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg></button>
    <div class="syr-dots" role="tablist">
      {%- for block in section.blocks -%}
        {%- if block.type == 'slide' -%}
          <button class="syr-dot {% if forloop.first %}is-active{% endif %}" data-banner-dot="{{ forloop.index0 }}" aria-label="Slide {{ forloop.index }}"></button>
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

<script>
(function(){
  var banner = document.getElementById('syr-banner-{{ section.id }}');
  if (!banner) return;
  var section = banner.closest('section');
  var dots = section.querySelectorAll('[data-banner-dot]');
  var slides = banner.querySelectorAll('.syr-slide');
  if (slides.length < 2) return;
  var current = 0, autoTimer = null;
  var AUTO_MS = parseInt('{{ section.settings.autoplay_s | default: 6 }}', 10) * 1000;
  function setCurrent(i){
    current = (i + slides.length) % slides.length;
    dots.forEach(function(d, di){ d.classList.toggle('is-active', di === current); });
  }
  function goTo(i){
    setCurrent(i);
    banner.scrollTo({ left: slides[current].offsetLeft, behavior:'smooth' });
  }
  function startAuto(){ if (AUTO_MS < 1000) return; stopAuto(); autoTimer = setInterval(function(){ goTo(current + 1); }, AUTO_MS); }
  function stopAuto(){ if (autoTimer){ clearInterval(autoTimer); autoTimer = null; } }
  dots.forEach(function(d){ d.addEventListener('click', function(){ goTo(parseInt(d.getAttribute('data-banner-dot'), 10)); stopAuto(); startAuto(); }); });
  var prevBtn = section.querySelector('[data-banner-prev]');
  var nextBtn = section.querySelector('[data-banner-next]');
  if (prevBtn) prevBtn.addEventListener('click', function(){ goTo(current - 1); stopAuto(); startAuto(); });
  if (nextBtn) nextBtn.addEventListener('click', function(){ goTo(current + 1); stopAuto(); startAuto(); });
  var scrollTimer = null;
  banner.addEventListener('scroll', function(){
    clearTimeout(scrollTimer);
    scrollTimer = setTimeout(function(){
      var idx = Math.round(banner.scrollLeft / banner.clientWidth);
      if (idx !== current) setCurrent(idx);
    }, 100);
  });
  banner.addEventListener('touchstart', stopAuto, { passive:true });
  banner.addEventListener('mouseenter', stopAuto);
  banner.addEventListener('mouseleave', startAuto);
  startAuto();
  document.addEventListener('visibilitychange', function(){ if (document.hidden) stopAuto(); else startAuto(); });
})();
</script>

{% schema %}
{
  "name": "Hero Banner Slider",
  "tag": "section",
  "max_blocks": 10,
  "settings": [
    { "type": "range", "id": "autoplay_s", "label": "Auto-rotate (seconds, 0 = off)", "min": 0, "max": 12, "step": 1, "default": 6 }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Banner",
      "settings": [
        { "type": "image_picker", "id": "image_desktop", "label": "Desktop image" },
        { "type": "image_picker", "id": "image_mobile", "label": "Mobile image (optional)" },
        { "type": "header", "content": "Video (optional — plays instead of the image)" },
        { "type": "video", "id": "video_desktop", "label": "Desktop video" },
        { "type": "video", "id": "video_mobile", "label": "Mobile video (optional)" },
        { "type": "checkbox", "id": "video_autoplay", "label": "Autoplay video", "default": true, "info": "On: plays automatically, muted and looping. Off: shows the poster image with play controls so visitors tap to play." },
        { "type": "paragraph", "content": "The desktop/mobile image is used as the poster and fallback — set one for the fastest load." },
        { "type": "text", "id": "alt", "label": "Image / video alt text" },
        { "type": "url", "id": "link", "label": "Link (where the slide goes)" },
        { "type": "header", "content": "Overlay button" },
        { "type": "checkbox", "id": "show_button", "label": "Show overlay button", "default": true, "info": "Turn off if your banner image already has a button. The whole image stays clickable." },
        { "type": "text", "id": "btn_text", "label": "Button text", "default": "Shop Now" },
        { "type": "color", "id": "btn_bg", "label": "Button background", "default": "#C8252B" },
        { "type": "color", "id": "btn_color", "label": "Button text color", "default": "#FFFFFF" }
      ]
    }
  ],
  "presets": [
    { "name": "Hero Banner Slider", "blocks": [ { "type": "slide" } ] }
  ]
}
{% endschema %}
