{{ 'pdp-brand.css' | asset_url | stylesheet_tag }}
{%- comment -%} ===== Flavor color theming + copy (dynamic, from product title) ===== {%- endcomment -%}
{%- assign t_lc = product.title | downcase -%}
{%- assign is_sf = false -%}
{%- if t_lc contains 'sugar-free' or t_lc contains 'sugar free' -%}{%- assign is_sf = true -%}{%- endif -%}
{%- assign si_main = '#FFD4B8' -%}
{%- assign si_accent = '#FCE2A0' -%}
{%- assign si_glow = '#FFD4B8' -%}
{%- assign si_glow2 = '#B8DCEB' -%}
{%- assign si_band = '#FCE2A0' -%}
{%- assign flavor_name = 'snow cone' -%}
{%- if t_lc contains 'blue raspberry' -%}
  {%- assign si_main = '#B8DCEB' -%}{%- assign si_accent = '#5BA3D0' -%}{%- assign si_glow = '#B8DCEB' -%}{%- assign si_glow2 = '#E0F2FA' -%}{%- assign si_band = '#B8DCEB' -%}{%- assign flavor_name = 'blue raspberry' -%}
{%- elsif t_lc contains 'blue cotton candy' -%}
  {%- assign si_main = '#A8D8F0' -%}{%- assign si_accent = '#F5C7BE' -%}{%- assign si_glow = '#A8D8F0' -%}{%- assign si_glow2 = '#FFD4E5' -%}{%- assign si_band = '#A8D8F0' -%}{%- assign flavor_name = 'cotton candy' -%}
{%- elsif t_lc contains 'cherry' -%}
  {%- assign si_main = '#F5C7BE' -%}{%- assign si_accent = '#D14B3F' -%}{%- assign si_glow = '#F5C7BE' -%}{%- assign si_glow2 = '#FFE8E5' -%}{%- assign si_band = '#F5C7BE' -%}{%- assign flavor_name = 'cherry' -%}
{%- elsif t_lc contains 'grape' -%}
  {%- assign si_main = '#D4B8E0' -%}{%- assign si_accent = '#6B3F8C' -%}{%- assign si_glow = '#D4B8E0' -%}{%- assign si_glow2 = '#E8D5F0' -%}{%- assign si_band = '#D4B8E0' -%}{%- assign flavor_name = 'grape' -%}
{%- elsif t_lc contains 'pina colada' -%}
  {%- assign si_main = '#FCE2A0' -%}{%- assign si_accent = '#C5E4D4' -%}{%- assign si_glow = '#FCE2A0' -%}{%- assign si_glow2 = '#C5E4D4' -%}{%- assign si_band = '#FCE2A0' -%}{%- assign flavor_name = 'piña colada' -%}
{%- elsif t_lc contains 'bubble gum' -%}
  {%- assign si_main = '#FFD4E5' -%}{%- assign si_accent = '#FF8FB8' -%}{%- assign si_glow = '#FFD4E5' -%}{%- assign si_glow2 = '#FFE8F0' -%}{%- assign si_band = '#FFD4E5' -%}{%- assign flavor_name = 'bubble gum' -%}
{%- elsif t_lc contains 'root beer' -%}
  {%- assign si_main = '#D4A574' -%}{%- assign si_accent = '#7A4F2A' -%}{%- assign si_glow = '#E8C9A0' -%}{%- assign si_glow2 = '#FCE2A0' -%}{%- assign si_band = '#E8C9A0' -%}{%- assign flavor_name = 'root beer' -%}
{%- elsif t_lc contains 'lime' -%}
  {%- assign si_main = '#C5E4D4' -%}{%- assign si_accent = '#5A9968' -%}{%- assign si_glow = '#C5E4D4' -%}{%- assign si_glow2 = '#E5F3E0' -%}{%- assign si_band = '#C5E4D4' -%}{%- assign flavor_name = 'lime' -%}
{%- elsif t_lc contains 'orange' -%}
  {%- assign si_main = '#FFD4B8' -%}{%- assign si_accent = '#E87E2A' -%}{%- assign si_glow = '#FFD4B8' -%}{%- assign si_glow2 = '#FFE8D5' -%}{%- assign si_band = '#FFD4B8' -%}{%- assign flavor_name = 'orange' -%}
{%- elsif t_lc contains 'strawberry' -%}
  {%- assign si_main = '#F5C7BE' -%}{%- assign si_accent = '#E85541' -%}{%- assign si_glow = '#F5C7BE' -%}{%- assign si_glow2 = '#FFE0DA' -%}{%- assign si_band = '#F5C7BE' -%}{%- assign flavor_name = 'strawberry' -%}
{%- elsif t_lc contains 'fruit punch' -%}
  {%- assign si_main = '#F5C7BE' -%}{%- assign si_accent = '#E85541' -%}{%- assign si_glow = '#FFD4B8' -%}{%- assign si_glow2 = '#F5C7BE' -%}{%- assign si_band = '#F5C7BE' -%}{%- assign flavor_name = 'fruit punch' -%}
{%- endif -%}
{%- assign flavor_cap = flavor_name | capitalize -%}

{%- if section.settings.section_bg != blank -%}
{% style %}
  #shopify-section-{{ section.id }} .pd-nutrition-wrap { background: {{ section.settings.section_bg }} !important; }
{% endstyle %}
{%- endif -%}

<div class="pd">
  <section class="pd-nutrition-wrap" aria-hidden="true">
    <div class="pd-wrap">
      <div class="pd-nutrition">
        <div class="pd-nutrition-title">{{ section.settings.title }}</div>
        <div class="pd-nut-serv">{{ section.settings.serving }}</div>
        <div class="pd-nut-rule--thick"></div>
        <div class="pd-nut-row"><strong>{{ section.settings.amount_label }}</strong></div>
        <div class="pd-nut-row" style="font-size:18px;"><strong>Calories</strong><strong>{%- if is_sf -%}{{ section.settings.calories_sf }}{%- else -%}{{ section.settings.calories_regular }}{%- endif -%}</strong></div>
        <div class="pd-nut-rule"></div>
        <div style="font-size:12px;text-align:right;">% Daily Value*</div>
        <div class="pd-nut-row"><span><strong>Total Fat</strong> {{ section.settings.fat }}</span><strong>{{ section.settings.fat_dv }}</strong></div>
        <div class="pd-nut-rule"></div>
        <div class="pd-nut-row"><span><strong>Sodium</strong> {{ section.settings.sodium }}</span><strong>{{ section.settings.sodium_dv }}</strong></div>
        <div class="pd-nut-rule"></div>
        <div class="pd-nut-row"><span><strong>Total Carbohydrate</strong> {%- if is_sf -%}{{ section.settings.carbs_sf }}{%- else -%}{{ section.settings.carbs_regular }}{%- endif -%}</span><strong>{%- if is_sf -%}{{ section.settings.carbs_dv_sf }}{%- else -%}{{ section.settings.carbs_dv_regular }}{%- endif -%}</strong></div>
        <div class="pd-nut-row" style="padding-left:14px;font-size:13px;"><span>Total Sugars {%- if is_sf -%}{{ section.settings.sugars_sf }}{%- else -%}{{ section.settings.sugars_regular }}{%- endif -%}</span><span></span></div>
        {%- unless is_sf -%}<div class="pd-nut-row" style="padding-left:14px;font-size:13px;"><span>{{ section.settings.added_sugars }}</span><strong>{{ section.settings.added_sugars_dv }}</strong></div>{%- endunless -%}
        <div class="pd-nut-rule"></div>
        <div class="pd-nut-row"><span><strong>Protein</strong> {{ section.settings.protein }}</span></div>
        <div class="pd-nut-rule--med"></div>
        <div style="font-size:11px;line-height:1.3;color:#3a3a3a;margin-top:6px;text-align:left;">{{ section.settings.footnote }}</div>
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "SI Nutrition",
  "tag": "section",
  "class": "section-si-nutrition",
  "enabled_on": { "templates": ["product"] },
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Nutrition Facts" },
    { "type": "text", "id": "serving", "label": "Serving size", "default": "Serving size 1 fl oz (30 mL)" },
    { "type": "text", "id": "amount_label", "label": "Amount-per-serving label", "default": "Amount per serving" },
    { "type": "header", "content": "Calories" },
    { "type": "text", "id": "calories_regular", "label": "Calories (regular)", "default": "80" },
    { "type": "text", "id": "calories_sf", "label": "Calories (sugar-free)", "default": "0" },
    { "type": "header", "content": "Total Fat" },
    { "type": "text", "id": "fat", "label": "Value", "default": "0g" },
    { "type": "text", "id": "fat_dv", "label": "% DV", "default": "0%" },
    { "type": "header", "content": "Sodium" },
    { "type": "text", "id": "sodium", "label": "Value", "default": "10mg" },
    { "type": "text", "id": "sodium_dv", "label": "% DV", "default": "0%" },
    { "type": "header", "content": "Total Carbohydrate" },
    { "type": "text", "id": "carbs_regular", "label": "Value (regular)", "default": "20g" },
    { "type": "text", "id": "carbs_sf", "label": "Value (sugar-free)", "default": "1g" },
    { "type": "text", "id": "carbs_dv_regular", "label": "% DV (regular)", "default": "7%" },
    { "type": "text", "id": "carbs_dv_sf", "label": "% DV (sugar-free)", "default": "0%" },
    { "type": "header", "content": "Sugars" },
    { "type": "text", "id": "sugars_regular", "label": "Total Sugars (regular)", "default": "19g" },
    { "type": "text", "id": "sugars_sf", "label": "Total Sugars (sugar-free)", "default": "0g" },
    { "type": "text", "id": "added_sugars", "label": "Added Sugars line", "default": "Incl. 19g Added Sugars" },
    { "type": "text", "id": "added_sugars_dv", "label": "Added Sugars % DV", "default": "38%" },
    { "type": "header", "content": "Protein" },
    { "type": "text", "id": "protein", "label": "Value", "default": "0g" },
    { "type": "header", "content": "Footnote & colors" },
    { "type": "text", "id": "footnote", "label": "Footnote", "default": "*% DV based on a 2,000 calorie diet." },
    { "type": "color", "id": "section_bg", "label": "Section background", "info": "Leave blank to keep the theme default." }
  ],
  "presets": [{ "name": "SI Nutrition" }]
}
{% endschema %}
