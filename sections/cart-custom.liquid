{%- capture icLock -%}<svg viewBox="0 0 16 18" width="14" height="15" fill="none"><rect x="2.5" y="7.5" width="11" height="8" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M5 7.5V5a3 3 0 016 0v2.5" stroke="currentColor" stroke-width="1.6"/></svg>{%- endcapture -%}
{%- capture icArrow -%}<svg viewBox="0 0 16 14" width="15" height="13" fill="none"><path d="M2 7h11M9 3l4 4-4 4" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"/></svg>{%- endcapture -%}
{%- capture icTrash -%}<svg viewBox="0 0 16 16" width="14" height="14" fill="none"><path d="M3 4.5h10M6.5 4V2.8h3V4M4.5 4.5l.6 9a1 1 0 001 .9h3.8a1 1 0 001-.9l.6-9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>{%- endcapture -%}
{%- capture icLeaf -%}<svg viewBox="0 0 18 18" width="15" height="15" fill="none"><path d="M15 3C7 3 3 7 3 14c5 0 12-2 12-11z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M3 15S6 9 12 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>{%- endcapture -%}
{%- capture icBag -%}<svg viewBox="0 0 18 20" width="22" height="22" fill="none"><path d="M3 6h12l-1 12.5a1 1 0 01-1 .9H5a1 1 0 01-1-.9L3 6z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M6 7V5a3 3 0 016 0v2" stroke="currentColor" stroke-width="1.6"/></svg>{%- endcapture -%}
{%- capture icClose -%}<svg viewBox="0 0 16 16" width="16" height="16"><path d="M3 3l10 10M13 3L3 13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>{%- endcapture -%}

<div class="scart" data-scart>
  <main class="cart-wrap">
    <nav class="crumbs"><a href="{{ routes.root_url }}">Home</a> <span>/</span> <b>Cart</b></nav>
    <div class="cart-head">
      <h1 class="cart-title">Your <em>cart</em></h1>
      <a class="keepshop" href="{{ routes.all_products_collection_url | default: '/collections/all' }}">{{ icArrow }} Keep shopping</a>
    </div>

    {%- if cart.item_count == 0 -%}
      <div class="empty">
        <div class="empty-glyph">{{ icBag }}</div>
        <h2>Your cart is empty</h2>
        <p>Add a flavor or two — your VIP price is waiting.</p>
        <a class="empty-cta" href="{{ routes.all_products_collection_url | default: '/collections/all' }}">Shop the flavors {{ icArrow }}</a>
      </div>
    {%- else -%}
      <span class="cart-count">{{ cart.item_count }} item{% if cart.item_count != 1 %}s{% endif %} in your cart</span>

      <div class="ship-bar">
        <div class="ship-top">
          {{ icTruck }}
          {%- if remain > 0 -%}
            <span>You're <b>{{ remain | money }}</b> away from <b>free shipping</b></span>
          {%- else -%}
            <span class="done">{{ icCheck }} You've unlocked free shipping</span>
          {%- endif -%}
        </div>
        <div class="ship-track"><div class="ship-fill" data-shipfill style="width:{{ pct }}%"></div></div>
      </div>

      <div class="cart-layout">
        <div class="cart-main">
          {%- if is_vip and real_discount > 0 -%}
            <div class="vipb active">
              <span class="vipb-seal">{{ icCheck }}</span>
              <span class="vipb-copy"><h3>VIP pricing is <span class="amt">active</span></h3><p>Your member discount is applied to every eligible bottle below.</p></span>
            </div>
          {%- elsif customer == blank and vipsave > 0 -%}
            <button class="vipb" data-vipopen type="button">
              <span class="vipb-seal">{{ icDiamondLg }}</span>
              <span class="vipb-copy"><h3>You're leaving <span class="amt">{{ vipsave | money }}</span> on the table</h3><p>VIP members pay less on every bottle — and it's free for anyone to join. Sign up to apply your price to this cart.</p></span>
              <span class="vipb-cta">{{ icDiamond }} Unlock VIP price</span>
            </button>
          {%- endif -%}

          {%- for item in cart.items -%}
            {%- assign nm = item.product.title | replace: 'Sugar-Free ','' | replace: 'Sugar Free ','' | replace: ' Syrup','' | replace: ' Coffee','' -%}
            {%- assign tg = item.product.tags | join: ' ' | downcase -%}
            {%- assign fam = '' -%}
            {%- if tg contains 'coffee' -%}{%- assign fam='Coffee' -%}{%- elsif tg contains 'fruit' -%}{%- assign fam='Fruit' -%}{%- elsif tg contains 'tropical' -%}{%- assign fam='Tropical' -%}{%- elsif tg contains 'cocktail' -%}{%- assign fam='Cocktail' -%}{%- elsif tg contains 'nut' -%}{%- assign fam='Nutty' -%}{%- elsif tg contains 'floral' or tg contains 'lavender' -%}{%- assign fam='Floral' -%}{%- elsif tg contains 'dessert' -%}{%- assign fam='Dessert' -%}{%- endif -%}
            {%- assign tint='#fbe0e5' -%}
            {%- case fam -%}{%- when 'Coffee' -%}{%- assign tint='#efe4d6' -%}{%- when 'Fruit' -%}{%- assign tint='#fbe0e5' -%}{%- when 'Tropical' -%}{%- assign tint='#e1f3ec' -%}{%- when 'Cocktail' -%}{%- assign tint='#e4ecfb' -%}{%- when 'Nutty' -%}{%- assign tint='#efe7d8' -%}{%- when 'Floral' -%}{%- assign tint='#ece6f7' -%}{%- when 'Dessert' -%}{%- assign tint='#f7e2ec' -%}{%- endcase -%}
            {%- assign vf = 799 -%}
            {%- capture line_syr_raw -%}{%- render 'syr-is-syrup', product: item.product -%}{%- endcapture -%}
            {%- assign line_syr = false -%}{%- if line_syr_raw contains '1' -%}{%- assign line_syr = true -%}{%- endif -%}
            {%- assign discounted = false -%}{%- if item.original_line_price > item.final_line_price -%}{%- assign discounted = true -%}{%- endif -%}
            <article class="line" data-line-item data-key="{{ item.key }}" data-line="{{ forloop.index }}" data-unit="{{ item.final_price }}" data-qty="{{ item.quantity }}" style="--tint:{{ tint }}">
              <a class="line-media" href="{{ item.url }}">
                {%- if item.image -%}<img class="line-img" src="{{ item.image | image_url: width: 220 }}" alt="{{ nm | escape }}" loading="lazy">{%- endif -%}
              </a>
              <div class="line-body">
                {%- if fam != blank -%}<span class="line-tag">{{ fam }}{% if item.product.title contains 'Sugar' %} · Sugar-Free{% endif %}</span>{%- endif -%}
                <a class="line-name" href="{{ item.url }}">{{ nm }}</a>
                <span class="line-sub">{{ item.final_price | money }} each{% if item.variant.title and item.variant.title != 'Default Title' %} · {{ item.variant.title }}{% endif %}</span>
                <div class="line-ctrls">
                  <div class="qty">
                    <button data-dec aria-label="Decrease" {% if item.quantity <= 1 %}disabled{% endif %}>−</button>
                    <span data-qval>{{ item.quantity }}</span>
                    <button data-inc aria-label="Increase">+</button>
                  </div>
                  <button class="line-remove" data-remove>{{ icTrash }} Remove</button>
                </div>
              </div>
              <div class="line-right">
                <div class="line-price">
                  {%- if discounted -%}<span class="was">{{ item.original_line_price | money }}</span>{%- endif -%}
                  <span data-lineprice>{{ item.final_line_price | money }}</span>
                </div>
                {%- if is_vip and discounted and line_syr -%}
                  <span class="vip-tag applied">{{ icCheck }} VIP price</span>
                {%- elsif customer == blank and line_syr and vf < item.final_price -%}
                  <button class="vip-tag" data-vipopen type="button" title="Unlock VIP pricing">{{ icDiamond }}<span class="vp">VIP {{ vf | money }}</span> ea</button>
                {%- endif -%}
              </div>
            </article>
          {%- endfor -%}
        </div>

        <aside class="summary">
          <div class="sum-h">Order summary</div>
          <div class="sum-row"><span>Subtotal</span><span class="v">{{ cart.original_total_price | money }}</span></div>
          {%- if real_discount > 0 -%}
            <div class="sum-vip applied">
              <span class="sum-vip-l">{{ icCheck }} {% if is_vip %}VIP pricing applied{% else %}Discount applied{% endif %}</span>
              <span class="sum-vip-v">−{{ real_discount | money }}</span>
            </div>
          {%- endif -%}
          <div class="sum-row"><span>Shipping</span><span class="v">{% if ship == 0 %}Free{% else %}{{ ship | money }}{% endif %}</span></div>
          <div class="sum-rule"></div>
          <div class="sum-total"><span class="lab">Total</span><span class="val">{{ grand | money }}</span></div>
          {%- if is_vip and real_discount > 0 -%}
            <div class="sum-save">You're saving {{ real_discount | money }} as a VIP</div>
          {%- elsif customer == blank and real_discount == 0 and vipsave > 0 -%}
            <button class="sum-tease" data-vipopen type="button">{{ icDiamond }} VIP members save {{ vipsave | money }} — join free →</button>
          {%- endif -%}
          <form action="{{ routes.cart_url }}" method="post" id="scart-form">
            <button type="submit" name="checkout" class="checkout">{{ icLock }} Checkout · {{ grand | money }}</button>
          </form>
          <div class="sum-note">Taxes &amp; discount codes calculated at checkout</div>
          <div class="trust">
            <span>{{ icTruck }} Ships in 1–3 days</span>
            <span>{{ icLeaf }} Kosher &amp; gluten-free</span>
            <span>{{ icLock }} Secure checkout</span>
          </div>
        </aside>
      </div>
    {%- endif -%}
  </main>

  <div class="modal-root" data-vipmodal aria-hidden="true">
    <div class="modal-bd" data-vipclose></div>
    <div class="modal" role="dialog" aria-modal="true" aria-label="Unlock VIP pricing">
      <div class="modal-top">
        <button class="modal-close" data-vipclose aria-label="Close">{{ icClose }}</button>
        <div class="modal-seal">{{ icDiamondLg }}</div>
        <h2>VIP pricing is free</h2>
        <p>Create a free account and pay the <b>member price</b> on every eligible bottle. No fee, no subscription — VIP is free for everyone.</p>
      </div>
      <div class="modal-body">
        <div class="modal-perks">
          <div class="modal-perk">{{ icDiamond }}<span><b>Member pricing</b> on every syrup, automatically</span></div>
          <div class="modal-perk">{{ icTruck }}<span>Free shipping perks &amp; early flavor drops</span></div>
          <div class="modal-perk">{{ icLeaf }}<span><b>Always free</b> to join — no fee, no subscription</span></div>
        </div>
        <a class="modal-primary" href="{{ routes.account_register_url }}">Create my free account &amp; save</a>
        <div class="modal-or">or</div>
        <div class="modal-signin">Already a member? <a href="{{ routes.account_login_url }}">Sign in</a></div>
        <div class="modal-fine">By joining you agree to Syruvia's Terms &amp; Privacy Policy.</div>
      </div>
    </div>
  </div>

  <div class="ctoast" data-toast></div>
</div>

<script>
(function(){
  var root=document.querySelector('[data-scart]'); if(!root) return;
  var toastEl=root.querySelector('[data-toast]'), tT;
  function toast(m){ if(!toastEl)return; toastEl.textContent=m; toastEl.classList.add('show'); clearTimeout(tT); tT=setTimeout(function(){toastEl.classList.remove('show');},2200); }
  var modal=root.querySelector('[data-vipmodal]');
  function openVip(){ if(modal){ modal.classList.add('open'); modal.setAttribute('aria-hidden','false'); } }
  function closeVip(){ if(modal){ modal.classList.remove('open'); modal.setAttribute('aria-hidden','true'); } }
  root.addEventListener('click',function(e){ if(e.target.closest('[data-vipopen]')){ e.preventDefault(); openVip(); } if(e.target.closest('[data-vipclose]')){ closeVip(); } });
  window.addEventListener('keydown',function(e){ if(e.key==='Escape') closeVip(); });
  var busy=false;
  function change(line, qty, lineEl, removing){
    if(busy) return; busy=true;
    fetch('/cart/change.js',{method:'POST',headers:{'Content-Type':'application/json','Accept':'application/json'},body:JSON.stringify({line:line, quantity:qty})})
      .then(function(r){return r.json();})
      .then(function(){ window.location.reload(); })
      .catch(function(){ busy=false; if(lineEl&&removing) lineEl.classList.remove('removing'); alert('Could not update the cart. Please try again.'); });
  }
  root.addEventListener('click',function(e){
    var item=e.target.closest('[data-line-item]'); if(!item) return;
    var line=+item.getAttribute('data-line'), qty=+item.getAttribute('data-qty');
    if(e.target.closest('[data-inc]')){ change(line, qty+1, item, false); }
    else if(e.target.closest('[data-dec]')){ if(qty>1) change(line, qty-1, item, false); }
    else if(e.target.closest('[data-remove]')){ item.classList.add('removing'); change(line, 0, item, true); }
  });
})();
</script>

{% schema %}
{ "name": "Cart (Custom)", "settings": [], "presets": [{ "name": "Cart (Custom)" }] }
{% endschema %}