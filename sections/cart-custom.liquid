{%- comment -%} Syruvia — Custom Cart page. Live cart + VIP teaser/modal. Scoped .scart {%- endcomment -%}
{%- liquid
  assign FREE_SHIP = 3500
  assign SHIP_COST = 495
  assign is_vip = false
  if customer and customer.tags contains 'VIP'
    assign is_vip = true
  endif
  assign vipsave = 0
  for item in cart.items
    capture _syr
      render 'syr-is-syrup', product: item.product
    endcapture
    if _syr contains '1'
      assign vf = 799
      if vf < item.final_price
        assign diff = item.final_price | minus: vf | times: item.quantity
        assign vipsave = vipsave | plus: diff
      endif
    endif
  endfor
  assign real_discount = cart.original_total_price | minus: cart.total_price
  assign payable = cart.total_price
  assign ship = SHIP_COST
  if payable >= FREE_SHIP or payable == 0
    assign ship = 0
  endif
  assign grand = payable | plus: ship
  assign remain = FREE_SHIP | minus: payable
  assign pct = payable | times: 100 | divided_by: FREE_SHIP
  if pct > 100
    assign pct = 100
  endif
-%}
<style>
