{%- comment -%} Syruvia — FAQ page (brand-styled accordion, editable Q&A blocks) {%- endcomment -%}
{%- assign brand = section.settings.brand | default: '#39220f' -%}
{%- assign accent = section.settings.accent | default: '#c58548' -%}
{%- assign cta_link = section.settings.cta_button_link | default: '/pages/contact-us' -%}
{%- assign faq_blocks = section.blocks | where: 'type', 'faq' -%}

{%- if faq_blocks.size > 0 -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- for block in faq_blocks -%}
    {
      "@type": "Question",
      "name": {{ block.settings.question | strip_html | json }},
      "acceptedAnswer": { "@type": "Answer", "text": {{ block.settings.answer | strip_html | json }} }
    }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
}
</script>
{%- endif -%}

<style>
  #syr-faq-{{ section.id }}{
    --sf-bg: {{ section.settings.bg }};
    --sf-card: {{ section.settings.card_bg }};
    --sf-brand: {{ brand }};
    --sf-accent: {{ accent }};
    --sf-icon: {{ section.settings.icon_bg }};
    --sf-eyebrow: {{ section.settings.eyebrow_bg }};
    --sf-ans: {{ section.settings.answer_color }};
    --sf-max: {{ section.settings.max_width }}px;
    --sf-pt: {{ section.settings.pad_top }}px;
    --sf-pb: {{ section.settings.pad_bottom }}px;
    background: var(--sf-bg);
    padding: var(--sf-pt) 20px var(--sf-pb);
    font-family:'Josefin Sans',sans-serif;
  }
  @import url('https://fonts.googleapis.com/css2?family=Archivo+Black&family=Archivo:wght@500;600;700&family=Josefin+Sans:ital,wght@0,300..700;1,300..600&display=swap');
  #syr-faq-{{ section.id }} *,#syr-faq-{{ section.id }} *::before,#syr-faq-{{ section.id }} *::after{ box-sizing:border-box; }

  #syr-faq-{{ section.id }} .syr-faq-head{ text-align:center; max-width:720px; margin:0 auto 34px; }
  #syr-faq-{{ section.id }} .syr-faq-eyebrow{
    display:inline-block; font-family:'Archivo Black','Archivo',sans-serif; font-weight:400;
    font-size:11px; letter-spacing:.18em; text-transform:uppercase; color:var(--sf-brand);
    background:var(--sf-eyebrow); border:1.5px solid var(--sf-brand); border-radius:999px;
    padding:7px 16px; margin:0 auto 16px; box-shadow:2px 2px 0 var(--sf-brand); line-height:1;
  }
  #syr-faq-{{ section.id }} .syr-faq-title{
    font-family:'Archivo Black','Archivo',sans-serif; font-weight:400;
    font-size:clamp(30px,5.5vw,54px); line-height:1.02; letter-spacing:-.01em;
    text-transform:uppercase; color:var(--sf-brand); margin:0 auto 12px; text-wrap:balance;
  }
  #syr-faq-{{ section.id }} .syr-faq-intro{
    font-family:'Josefin Sans',sans-serif; font-size:16px; line-height:1.55; color:var(--sf-ans);
    font-weight:500; margin:0 auto; max-width:52ch; opacity:.88;
  }

  #syr-faq-{{ section.id }} .syr-faq-wrap{ max-width:var(--sf-max); margin:0 auto; }
  #syr-faq-{{ section.id }} .syr-faq-search{
    position:relative; display:flex; align-items:center; max-width:440px; margin:0 auto 26px;
  }
  #syr-faq-{{ section.id }} .syr-faq-search svg{ position:absolute; left:16px; width:16px; height:16px; stroke:var(--sf-brand); opacity:.6; pointer-events:none; }
  #syr-faq-{{ section.id }} .syr-faq-search input{
    width:100%; font-family:'Josefin Sans',sans-serif; font-size:15px; color:var(--sf-brand);
    background:var(--sf-card); border:1.5px solid var(--sf-brand); border-radius:999px;
    padding:13px 18px 13px 42px; outline:none; box-shadow:2px 2px 0 var(--sf-brand);
    -webkit-appearance:none;
  }
  #syr-faq-{{ section.id }} .syr-faq-search input::placeholder{ color:var(--sf-brand); opacity:.5; }
  #syr-faq-{{ section.id }} .syr-faq-search input:focus{ box-shadow:3px 3px 0 var(--sf-accent); }

  #syr-faq-{{ section.id }} .syr-faq-list{ display:flex; flex-direction:column; gap:14px; list-style:none; margin:0; padding:0; }
  #syr-faq-{{ section.id }} .syr-faq-item{
    background:var(--sf-card); border:2px solid var(--sf-brand); border-radius:20px;
    box-shadow:4px 4px 0 var(--sf-brand); overflow:hidden; list-style:none;
    transition:box-shadow .25s ease, transform .25s ease;
  }
  #syr-faq-{{ section.id }} .syr-faq-item:hover{ transform:translate(-1px,-1px); box-shadow:5px 5px 0 var(--sf-brand); }
  #syr-faq-{{ section.id }} .syr-faq-item.is-open{ box-shadow:5px 5px 0 var(--sf-accent); transform:translate(-1px,-1px); }
  #syr-faq-{{ section.id }} .syr-faq-q{
    display:grid; grid-template-columns:1fr 38px; align-items:center; gap:18px;
    width:100%; padding:22px 24px; margin:0; text-align:left; cursor:pointer;
    background:transparent; border:0; font-family:'Archivo Black','Archivo',sans-serif; font-weight:400;
    font-size:16px; letter-spacing:.01em; color:var(--sf-brand); line-height:1.3;
  }
  #syr-faq-{{ section.id }} .syr-faq-q-text .syr-faq-q-lead{ color:var(--sf-accent); }
  #syr-faq-{{ section.id }} .syr-faq-icon{
    width:38px; height:38px; background:var(--sf-icon); border:2px solid var(--sf-brand); border-radius:50%;
    display:flex; align-items:center; justify-content:center; flex-shrink:0; box-shadow:2px 2px 0 var(--sf-brand);
    position:relative; transition:background .25s ease, transform .3s cubic-bezier(.34,1.56,.64,1);
  }
  #syr-faq-{{ section.id }} .syr-faq-icon::before,
  #syr-faq-{{ section.id }} .syr-faq-icon::after{ content:''; position:absolute; background:var(--sf-brand); border-radius:2px; transition:transform .3s ease, background .25s ease; }
  #syr-faq-{{ section.id }} .syr-faq-icon::before{ width:14px; height:2.4px; }
  #syr-faq-{{ section.id }} .syr-faq-icon::after{ width:2.4px; height:14px; }
  #syr-faq-{{ section.id }} .syr-faq-item.is-open .syr-faq-icon{ background:var(--sf-accent); transform:rotate(180deg); }
  #syr-faq-{{ section.id }} .syr-faq-item.is-open .syr-faq-icon::before,
  #syr-faq-{{ section.id }} .syr-faq-item.is-open .syr-faq-icon::after{ background:#FFFBF4; }
  #syr-faq-{{ section.id }} .syr-faq-item.is-open .syr-faq-icon::after{ transform:rotate(90deg); }
  #syr-faq-{{ section.id }} .syr-faq-a{ max-height:0; overflow:hidden; padding:0 24px; transition:max-height .35s ease, padding .35s ease; }
  #syr-faq-{{ section.id }} .syr-faq-item.is-open .syr-faq-a{ max-height:1200px; padding:0 24px 22px; }
  #syr-faq-{{ section.id }} .syr-faq-a-inner{
    font-family:'Josefin Sans',sans-serif; font-size:15.5px; line-height:1.65; color:var(--sf-ans);
    font-weight:500; padding-top:18px; border-top:1.5px dashed rgba(57,34,15,.2);
  }
  #syr-faq-{{ section.id }} .syr-faq-a-inner .syr-faq-a-lead{ color:#1f8a6e; font-family:'Archivo Black','Archivo',sans-serif; }
  #syr-faq-{{ section.id }} .syr-faq-a-inner p{ margin:0 0 10px; }
  #syr-faq-{{ section.id }} .syr-faq-a-inner p:last-child{ margin-bottom:0; }
  #syr-faq-{{ section.id }} .syr-faq-a-inner a{ color:var(--sf-accent); text-decoration:underline; text-underline-offset:2px; }

  #syr-faq-{{ section.id }} .syr-faq-empty{ text-align:center; padding:36px 0 8px; color:var(--sf-brand); opacity:.6; font-weight:600; }

  #syr-faq-{{ section.id }} .syr-faq-cta{
    max-width:var(--sf-max); margin:40px auto 0; text-align:center;
    background:var(--sf-card); border:2px solid var(--sf-brand); border-radius:24px;
    box-shadow:6px 6px 0 var(--sf-brand); padding:36px 28px;
  }
  #syr-faq-{{ section.id }} .syr-faq-cta-h{ font-family:'Archivo Black','Archivo',sans-serif; font-weight:400; font-size:clamp(20px,3vw,28px); text-transform:uppercase; color:var(--sf-brand); margin:0 0 8px; }
  #syr-faq-{{ section.id }} .syr-faq-cta-p{ font-family:'Josefin Sans',sans-serif; font-size:15px; color:var(--sf-ans); margin:0 0 20px; font-weight:500; }
  #syr-faq-{{ section.id }} .syr-faq-cta-btn{
    display:inline-flex; align-items:center; gap:8px; font-family:'Archivo Black','Archivo',sans-serif; font-weight:400;
    font-size:13px; letter-spacing:.1em; text-transform:uppercase; text-decoration:none;
    background:var(--sf-brand); color:#FFFBF4; border:2px solid var(--sf-brand); border-radius:999px;
    padding:14px 26px; box-shadow:4px 4px 0 var(--sf-accent); transition:transform .15s ease, box-shadow .15s ease;
  }
  #syr-faq-{{ section.id }} .syr-faq-cta-btn:hover{ transform:translate(-2px,-2px); box-shadow:6px 6px 0 var(--sf-accent); color:#FFFBF4; }

  @media (max-width:640px){
    #syr-faq-{{ section.id }}{ padding-left:16px; padding-right:16px; }
    #syr-faq-{{ section.id }} .syr-faq-q{ padding:18px 18px; font-size:14px; grid-template-columns:1fr 32px; gap:14px; }
    #syr-faq-{{ section.id }} .syr-faq-icon{ width:32px; height:32px; }
    #syr-faq-{{ section.id }} .syr-faq-a{ padding:0 18px; }
    #syr-faq-{{ section.id }} .syr-faq-item.is-open .syr-faq-a{ padding:0 18px 18px; }
    #syr-faq-{{ section.id }} .syr-faq-a-inner{ font-size:14.5px; padding-top:14px; }
    #syr-faq-{{ section.id }} .syr-faq-item{ border-radius:16px; box-shadow:3px 3px 0 var(--sf-brand); }
    #syr-faq-{{ section.id }} .syr-faq-cta{ padding:28px 20px; }
  }
</style>

<section id="syr-faq-{{ section.id }}" class="syr-faq">
  <div class="syr-faq-head">
    {%- if section.settings.eyebrow != blank -%}<span class="syr-faq-eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
    {%- if section.settings.title != blank -%}<h1 class="syr-faq-title">{{ section.settings.title }}</h1>{%- endif -%}
    {%- if section.settings.intro != blank -%}<p class="syr-faq-intro">{{ section.settings.intro }}</p>{%- endif -%}
  </div>

  <div class="syr-faq-wrap">
    {%- if section.settings.show_search -%}
      <div class="syr-faq-search">
        <svg viewBox="0 0 19 19" fill="none" aria-hidden="true"><circle cx="8" cy="8" r="6.2" stroke="currentColor" stroke-width="1.8"/><path d="M12.8 12.8L17 17" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
        <input type="search" data-faq-search placeholder="{{ section.settings.search_placeholder | escape }}" aria-label="{{ section.settings.search_placeholder | escape }}">
      </div>
    {%- endif -%}

    <ul class="syr-faq-list" data-faq-list>
      {%- for block in section.blocks -%}
        {%- if block.type == 'faq' -%}
          <li class="syr-faq-item" data-faq-item {{ block.shopify_attributes }}>
            <button type="button" class="syr-faq-q" aria-expanded="false" id="faq-q-{{ block.id }}" aria-controls="faq-a-{{ block.id }}">
              <span class="syr-faq-q-text"><span class="syr-faq-q-lead">{{ section.settings.q_prefix }}</span>{{ block.settings.question }}</span>
              <span class="syr-faq-icon" aria-hidden="true"></span>
            </button>
            <div class="syr-faq-a" id="faq-a-{{ block.id }}" role="region" aria-labelledby="faq-q-{{ block.id }}">
              <div class="syr-faq-a-inner">
                {%- if section.settings.a_prefix != blank -%}<span class="syr-faq-a-lead">{{ section.settings.a_prefix }}</span>{%- endif -%}
                {{ block.settings.answer }}
              </div>
            </div>
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>
    <p class="syr-faq-empty" data-faq-empty hidden>{{ section.settings.no_results_text }}</p>
  </div>

  {%- if section.settings.show_cta -%}
    <div class="syr-faq-cta">
      <h2 class="syr-faq-cta-h">{{ section.settings.cta_heading }}</h2>
      {%- if section.settings.cta_text != blank -%}<p class="syr-faq-cta-p">{{ section.settings.cta_text }}</p>{%- endif -%}
      <a class="syr-faq-cta-btn" href="{{ cta_link }}">
        {{ section.settings.cta_button_label }}
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12 h14 M13 6 l6 6 -6 6"/></svg>
      </a>
    </div>
  {%- endif -%}
</section>

<script>
(function(){
  var root = document.getElementById('syr-faq-{{ section.id }}');
  if (!root) return;
  var items = [].slice.call(root.querySelectorAll('[data-faq-item]'));
  items.forEach(function(item){
    var btn = item.querySelector('.syr-faq-q');
    if (!btn) return;
    btn.addEventListener('click', function(){
      var open = item.classList.toggle('is-open');
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
  });
  var search = root.querySelector('[data-faq-search]');
  var empty = root.querySelector('[data-faq-empty]');
  if (search){
    search.addEventListener('input', function(){
      var q = search.value.trim().toLowerCase();
      var shown = 0;
      items.forEach(function(item){
        var txt = (item.textContent || '').toLowerCase();
        var match = !q || txt.indexOf(q) > -1;
        item.style.display = match ? '' : 'none';
        if (match) shown++;
      });
      if (empty) empty.hidden = shown !== 0;
    });
  }
  // Deep-link: open the item referenced in the URL hash
  function openFromHash(){
    if (!location.hash || location.hash.length < 2) return;
    var item = null;
    try { var el = root.querySelector(location.hash); item = el ? el.closest('[data-faq-item]') : null; } catch (e) { item = null; }
    if (item && !item.classList.contains('is-open')){
      var btn = item.querySelector('.syr-faq-q');
      if (btn) btn.click();
      item.scrollIntoView({behavior:'smooth', block:'center'});
    }
  }
  openFromHash();
  window.addEventListener('hashchange', openFromHash);
})();
</script>

{% schema %}
{
  "name": "FAQ Page",
  "tag": "section",
  "class": "section-faq-page",
  "enabled_on": { "templates": ["page"] },
  "settings": [
    { "type": "header", "content": "Header" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Help Center" },
    { "type": "text", "id": "title", "label": "Title", "default": "Frequently Asked Questions" },
    { "type": "textarea", "id": "intro", "label": "Intro", "default": "Answers to the questions we hear most. Still stuck? Reach out — we're happy to help." },
    { "type": "header", "content": "Q & A prefixes" },
    { "type": "text", "id": "q_prefix", "label": "Question prefix", "info": "Small colored lead-in before each question. Leave blank for none.", "default": "Q: " },
    { "type": "text", "id": "a_prefix", "label": "Answer prefix", "info": "Small lead-in before each answer. Leave blank for none.", "default": "A: " },
    { "type": "header", "content": "Search" },
    { "type": "checkbox", "id": "show_search", "label": "Show search box", "default": true },
    { "type": "text", "id": "search_placeholder", "label": "Search placeholder", "default": "Search questions…" },
    { "type": "text", "id": "no_results_text", "label": "No-results message", "default": "No questions match your search." },
    { "type": "header", "content": "Contact CTA" },
    { "type": "checkbox", "id": "show_cta", "label": "Show contact CTA", "default": true },
    { "type": "text", "id": "cta_heading", "label": "CTA heading", "default": "Still have questions?" },
    { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Our team is one message away." },
    { "type": "text", "id": "cta_button_label", "label": "CTA button label", "default": "Contact us" },
    { "type": "url", "id": "cta_button_link", "label": "CTA button link" },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg", "label": "Page background", "default": "#FFFBF4" },
    { "type": "color", "id": "card_bg", "label": "Card background", "default": "#FFFFFF" },
    { "type": "color", "id": "brand", "label": "Brand color (headings, borders)", "default": "#39220f" },
    { "type": "color", "id": "accent", "label": "Accent color", "default": "#c58548" },
    { "type": "color", "id": "icon_bg", "label": "Toggle icon background", "default": "#FCE2A0" },
    { "type": "color", "id": "eyebrow_bg", "label": "Eyebrow background", "default": "#FCE2A0" },
    { "type": "color", "id": "answer_color", "label": "Answer text color", "default": "#39220f" },
    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "max_width", "label": "Content width", "min": 640, "max": 1100, "step": 20, "unit": "px", "default": 820 },
    { "type": "range", "id": "pad_top", "label": "Padding top", "min": 0, "max": 140, "step": 4, "unit": "px", "default": 72 },
    { "type": "range", "id": "pad_bottom", "label": "Padding bottom", "min": 0, "max": 140, "step": 4, "unit": "px", "default": 88 }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Your question here?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Your answer here.</p>" }
      ]
    }
  ],
  "max_blocks": 50,
  "presets": [
    {
      "name": "FAQ Page",
      "blocks": [
        { "type": "faq" },
        { "type": "faq" },
        { "type": "faq" }
      ]
    }
  ]
}
{% endschema %}
