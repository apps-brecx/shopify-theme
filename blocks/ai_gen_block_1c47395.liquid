{% doc %}
  @prompt
    create same recipe page like that
    https://www.skinnymixes.com/pages/recipes
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-recipe-grid-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-recipe-grid__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-recipe-grid__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-recipe-grid__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 16px;
    font-weight: 700;
  }

  .ai-recipe-grid__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.6;
  }

  .ai-recipe-grid__filters-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 40px;
  }

  .ai-recipe-grid__filter-btn-{{ ai_gen_id }} {
    padding: 10px 24px;
    background-color: {{ block.settings.filter_bg_color }};
    color: {{ block.settings.filter_text_color }};
    border: 2px solid {{ block.settings.filter_border_color }};
    border-radius: {{ block.settings.filter_border_radius }}px;
    cursor: pointer;
    font-size: 14px;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .ai-recipe-grid__filter-btn-{{ ai_gen_id }}:hover,
  .ai-recipe-grid__filter-btn-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.filter_active_bg_color }};
    color: {{ block.settings.filter_active_text_color }};
    border-color: {{ block.settings.filter_active_bg_color }};
  }

  .ai-recipe-grid__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-recipe-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_bg_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    display: none;
  }

  .ai-recipe-card-{{ ai_gen_id }}.visible {
    display: block;
  }

  .ai-recipe-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15);
  }

  .ai-recipe-card__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 75%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-recipe-card__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-recipe-card__image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-recipe-card__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-recipe-card__badge-{{ ai_gen_id }} {
    position: absolute;
    top: 12px;
    left: 12px;
    background-color: {{ block.settings.badge_bg_color }};
    color: {{ block.settings.badge_text_color }};
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
  }

  .ai-recipe-card__content-{{ ai_gen_id }} {
    padding: 20px;
  }

  .ai-recipe-card__title-{{ ai_gen_id }} {
    font-size: 18px;
    color: {{ block.settings.card_title_color }};
    margin: 0 0 12px;
    font-weight: 700;
    line-height: 1.3;
  }

  .ai-recipe-card__description-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.card_text_color }};
    margin: 0 0 16px;
    line-height: 1.5;
  }

  .ai-recipe-card__meta-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    margin-bottom: 16px;
    font-size: 13px;
    color: {{ block.settings.card_text_color }};
  }

  .ai-recipe-card__meta-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .ai-recipe-card__link-{{ ai_gen_id }} {
    display: inline-block;
    padding: 10px 20px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 14px;
    font-weight: 600;
    transition: background-color 0.3s ease;
  }

  .ai-recipe-card__link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-recipe-grid__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-recipe-grid__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<recipe-grid-{{ ai_gen_id }} class="ai-recipe-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-recipe-grid__container-{{ ai_gen_id }}">
    {% if block.settings.title != blank or block.settings.description != blank %}
      <div class="ai-recipe-grid__header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-recipe-grid__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.description != blank %}
          <div class="ai-recipe-grid__description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.show_filters %}
      <div class="ai-recipe-grid__filters-{{ ai_gen_id }}">
        <button class="ai-recipe-grid__filter-btn-{{ ai_gen_id }} active" data-filter="all">
          All Recipes
        </button>
        {% if block.settings.filter_1 != blank %}
          <button class="ai-recipe-grid__filter-btn-{{ ai_gen_id }}" data-filter="filter1">
            {{ block.settings.filter_1 }}
          </button>
        {% endif %}
        {% if block.settings.filter_2 != blank %}
          <button class="ai-recipe-grid__filter-btn-{{ ai_gen_id }}" data-filter="filter2">
            {{ block.settings.filter_2 }}
          </button>
        {% endif %}
        {% if block.settings.filter_3 != blank %}
          <button class="ai-recipe-grid__filter-btn-{{ ai_gen_id }}" data-filter="filter3">
            {{ block.settings.filter_3 }}
          </button>
        {% endif %}
        {% if block.settings.filter_4 != blank %}
          <button class="ai-recipe-grid__filter-btn-{{ ai_gen_id }}" data-filter="filter4">
            {{ block.settings.filter_4 }}
          </button>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-recipe-grid__grid-{{ ai_gen_id }}">
      {% for i in (1..12) %}
        {% liquid
          assign recipe_enabled_key = 'recipe_' | append: i | append: '_enabled'
          assign recipe_image_key = 'recipe_' | append: i | append: '_image'
          assign recipe_title_key = 'recipe_' | append: i | append: '_title'
          assign recipe_description_key = 'recipe_' | append: i | append: '_description'
          assign recipe_prep_time_key = 'recipe_' | append: i | append: '_prep_time'
          assign recipe_cook_time_key = 'recipe_' | append: i | append: '_cook_time'
          assign recipe_category_key = 'recipe_' | append: i | append: '_category'
          assign recipe_link_key = 'recipe_' | append: i | append: '_link'

          assign recipe_enabled = block.settings[recipe_enabled_key]
          assign recipe_image = block.settings[recipe_image_key]
          assign recipe_title = block.settings[recipe_title_key]
          assign recipe_description = block.settings[recipe_description_key]
          assign recipe_prep_time = block.settings[recipe_prep_time_key]
          assign recipe_cook_time = block.settings[recipe_cook_time_key]
          assign recipe_category = block.settings[recipe_category_key]
          assign recipe_link = block.settings[recipe_link_key]
        %}

        {% if recipe_enabled %}
          <div class="ai-recipe-card-{{ ai_gen_id }} visible" data-category="{{ recipe_category }}">
            <div class="ai-recipe-card__image-wrapper-{{ ai_gen_id }}">
              {% if recipe_image %}
                <img
                  src="{{ recipe_image | image_url: width: 600 }}"
                  alt="{{ recipe_title | escape }}"
                  class="ai-recipe-card__image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="600"
                  height="450"
                >
              {% else %}
                <div class="ai-recipe-card__image-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
              {% if recipe_category != blank and recipe_category != 'none' %}
                <div class="ai-recipe-card__badge-{{ ai_gen_id }}">
                  {% if recipe_category == 'filter1' %}
                    {{ block.settings.filter_1 }}
                  {% elsif recipe_category == 'filter2' %}
                    {{ block.settings.filter_2 }}
                  {% elsif recipe_category == 'filter3' %}
                    {{ block.settings.filter_3 }}
                  {% elsif recipe_category == 'filter4' %}
                    {{ block.settings.filter_4 }}
                  {% endif %}
                </div>
              {% endif %}
            </div>
            <div class="ai-recipe-card__content-{{ ai_gen_id }}">
              {% if recipe_title != blank %}
                <h3 class="ai-recipe-card__title-{{ ai_gen_id }}">{{ recipe_title }}</h3>
              {% endif %}
              {% if recipe_description != blank %}
                <p class="ai-recipe-card__description-{{ ai_gen_id }}">{{ recipe_description }}</p>
              {% endif %}
              {% if recipe_prep_time != blank or recipe_cook_time != blank %}
                <div class="ai-recipe-card__meta-{{ ai_gen_id }}">
                  {% if recipe_prep_time != blank %}
                    <div class="ai-recipe-card__meta-item-{{ ai_gen_id }}">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"></circle>
                        <polyline points="12 6 12 12 16 14"></polyline>
                      </svg>
                      Prep: {{ recipe_prep_time }}
                    </div>
                  {% endif %}
                  {% if recipe_cook_time != blank %}
                    <div class="ai-recipe-card__meta-item-{{ ai_gen_id }}">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"></circle>
                        <polyline points="12 6 12 12 16 14"></polyline>
                      </svg>
                      Cook: {{ recipe_cook_time }}
                    </div>
                  {% endif %}
                </div>
              {% endif %}
              {% if recipe_link != blank %}
                <a href="{{ recipe_link }}" class="ai-recipe-card__link-{{ ai_gen_id }}">
                  {{ block.settings.button_text }}
                </a>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</recipe-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class RecipeGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.filterButtons = this.querySelectorAll('.ai-recipe-grid__filter-btn-{{ ai_gen_id }}');
        this.recipeCards = this.querySelectorAll('.ai-recipe-card-{{ ai_gen_id }}');
        this.setupFilters();
      }

      setupFilters() {
        this.filterButtons.forEach(button => {
          button.addEventListener('click', () => {
            const filter = button.getAttribute('data-filter');
            
            this.filterButtons.forEach(btn => btn.classList.remove('active'));
            button.classList.add('active');
            
            this.recipeCards.forEach(card => {
              const category = card.getAttribute('data-category');
              
              if (filter === 'all' || category === filter) {
                card.classList.add('visible');
              } else {
                card.classList.remove('visible');
              }
            });
          });
        });
      }
    }

    customElements.define('recipe-grid-{{ ai_gen_id }}', RecipeGrid{{ ai_gen_id }});
  })();
</script>

