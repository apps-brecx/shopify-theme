    "custom_liquid_nUifaq": {
      "type": "custom-liquid",
      "disabled": true,
      "settings": {
        "custom_liquid": "<div class=\"cst-custom-tabs recipe-detail-btn\">\n  <div class=\"rich-text__blocks center\" style=\"margin:auto !important;\">\n    {% assign related_products_json = product.metafields.custom.you_might_enjoy_products.value %}\n    {% if related_products_json %}\n      {% assign related_products = related_products_json | parse_json %}\n\n      <div class=\"banner__top-image\">\n        <img src=\"//syruvia.com/cdn/shop/files/Blogfdzg-Page_small.png?v=1729753769\" alt=\"Top Image\">\n      </div>\n      <h2\n        class=\"rich-text__heading rte head inline-richtext hxl scroll-trigger animate--slide-in\"\n        style=\"--animation-order: 0; font-size: 50px !important;\"\n      >\n        You Might Enjoy\n      </h2>\n      <div class=\"content\">\n        <div class=\"product-grid-section slick-slider\">\n          <!-- Added slick-slider class here -->\n          {% for related_product in related_products %}\n            <div class=\"product-card {% assign colorIndex = forloop.index0 | modulo: 4 %} {% if colorIndex == 0 %}colorone{% elsif colorIndex == 1 %}colortwo{% elsif colorIndex == 2 %}colorthree{% elsif colorIndex == 3 %}colorfour{% endif %}\">\n              <!-- Product Image -->\n              <div class=\"cst-custom-product-featured-image\">\n                <a href=\"{{ related_product.url }}\">\n                  <img src=\"{{ related_product.featured_image | img_url: 'large' }}\" alt=\"{{ related_product.title }}\">\n                </a>\n              </div>\n\n              <!-- Product Content -->\n              <div class=\"cst-custom-product-content\">\n                <!-- Review Stars -->\n                <div\n                  class=\"areviews_product_item areviews_stars{{ related_product.id }}\"\n                  data-product-id=\"{{ related_product.id }}\"\n                ></div>\n\n                <!-- Product Title -->\n                <h3>{{ related_product.title }}</h3>\n                <p>{{ related_product.price | money }}</p>\n\n                <!-- Add to Cart Button -->\n                <form action=\"/cart/add\" method=\"post\" enctype=\"multipart/form-data\">\n                  <input type=\"hidden\" name=\"id\" value=\"{{ related_product.variants.first.id }}\">\n                  <button class=\"quick-add__submit button\" type=\"submit\">Add to Cart</button>\n                </form>\n              </div>\n            </div>\n          {% endfor %}\n        </div>\n      </div>\n    {% else %}\n      <div\n        class=\"related-products page-width section-{{ section.id }}-padding isolate{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}\"\n        data-url=\"{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ section.settings.products_to_show }}\"\n      >\n        {% assign product_collections = product.collections %}\n        {% if product_collections.size > 0 %}\n          <div class=\"cst-custom-tabs\">\n            <div class=\"rich-text__blocks center\" style=\"margin:auto !important;\">\n              <div class=\"banner__top-image\">\n                <img src=\"//syruvia.com/cdn/shop/files/Blogfdzg-Page_small.png?v=1729753769\" alt=\"Top Image\">\n              </div>\n              <h2\n                class=\"rich-text__heading rte head inline-richtext hxl scroll-trigger animate--slide-in\"\n                style=\"--animation-order: 0; font-size: 50px !important;\"\n              >\n                You Might Enjoy\n              </h2>\n              <div class=\"content\">\n                <div class=\"product-grid-section slick-slider\">\n                  <!-- Added slick-slider class here -->\n                  {% for recommendation in recommendations.products %}\n                    <div class=\"product-card {% assign colorIndex = forloop.index0 | modulo: 4 %} {% if colorIndex == 0 %}colorone{% elsif colorIndex == 1 %}colortwo{% elsif colorIndex == 2 %}colorthree{% elsif colorIndex == 3 %}colorfour{% endif %}\">\n                      <!-- Product Image -->\n                      <div class=\"cst-custom-product-featured-image\">\n                        <a href=\"{{ recommendation.url }}\">\n                          <img\n                            src=\"{{ recommendation.featured_image | img_url: 'large' }}\"\n                            alt=\"{{ recommendation.title }}\"\n                          >\n                        </a>\n                      </div>\n\n                      <!-- Product Content -->\n                      <div class=\"cst-custom-product-content\">\n                        <!-- Review Stars -->\n                        <div\n                          class=\"areviews_product_item areviews_stars{{ recommendation.id }}\"\n                          data-product-id=\"{{ recommendation.id }}\"\n                        ></div>\n\n                        <!-- Product Title -->\n                        <h3>{{ recommendation.title }}</h3>\n                        <p>{{ recommendation.price | money }}</p>\n\n                        <!-- Add to Cart Button -->\n                        <form action=\"/cart/add\" method=\"post\" enctype=\"multipart/form-data\">\n                          <input type=\"hidden\" name=\"id\" value=\"{{ recommendation.variants.first.id }}\">\n                          <button class=\"quick-add__submit button\" type=\"submit\">Add to Cart</button>\n                        </form>\n                      </div>\n                    </div>\n                  {% endfor %}\n                </div>\n              </div>\n            </div>\n          </div>\n        {% endif %}\n      </div>\n    {% endif %}\n  </div>\n</div>\n\n<!-- Slick Slider Styles and Scripts -->\n<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick.min.css\">\n<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick-theme.min.css\">\n<script src=\"https://code.jquery.com/jquery-3.7.1.min.js\"></script>\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick.min.js\"></script>\n\n<script>\n  $(document).ready(function() {\n    $('.slick-slider').slick({\n      centerMode: false,\n      slidesToShow: 4,\n      arrows: true,\n      responsive: [\n        {\n          breakpoint: 1300,\n          settings: {\n            slidesToShow: 3\n          }\n        },\n        {\n          breakpoint: 991,\n          settings: {\n            slidesToShow: 2\n          }\n        },\n        {\n          breakpoint: 768,\n          settings: {\n            slidesToShow: 2,\n            centerPadding: '50px'\n          }\n        },\n        {\n          breakpoint: 480,\n          settings: {\n            slidesToShow: 1,\n            centerPadding: '30px'\n          }\n        }\n      ]\n    });\n  });\n</script>",
