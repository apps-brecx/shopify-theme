      "settings": {
        "custom_liquid": "<div class=\"cst-custom-tabs recipe-detail-btn\">\n  <div class=\"rich-text__blocks center\" style=\"margin:auto !important;\">\n    {% assign related_products_json = product.metafields.custom.you_might_enjoy_products.value %}\n    {% if related_products_json %}\n      {% assign related_products = related_products_json | parse_json %}\n\n      <div class=\"banner__top-image\">\n        <img src=\"//syruvia.com/cdn/shop/files/Blogfdzg-Page_small.png?v=1729753769\" alt=\"Top Image\">\n      </div>\n      <div class=\"cst-custom-section-heading\">\n    <h2>You Might Enjoy</h2>\n  </div>\n      <div class=\"content\">\n        <div class=\"product-grid-section\">\n          {% for related_product in related_products %}\n            <div class=\"product-card \n              {% assign colorIndex = forloop.index0 | modulo: 4 %}\n              {% case colorIndex %}\n              {% when 0 %}colorone\n              {% when 1 %}colortwo\n              {% when 2 %}colorthree\n              {% when 3 %}colorfour\n              {% endcase %}\">\n              <!-- Product Image -->\n              <div class=\"cst-custom-product-featured-image\">\n                <a href=\"{{ related_product.url }}\">\n                  <img src=\"{{ related_product.featured_image | img_url: 'large' }}\" alt=\"{{ related_product.title }}\">\n                </a>\n              </div>\n\n              <!-- Product Content -->\n              <div class=\"cst-custom-product-content\">\n                <!-- Review Stars -->\n                <div class=\"areviews_product_item areviews_stars{{ related_product.id }}\" data-product-id=\"{{ related_product.id }}\"></div>\n\n                <!-- Product Title -->\n                <h3>{{ related_product.title }}</h3>\n                <p>{{ related_product.price | money }}</p>\n\n                <!-- Add to Cart Button -->\n                <form action=\"/cart/add\" method=\"post\" enctype=\"multipart/form-data\">\n                  <input type=\"hidden\" name=\"id\" value=\"{{ related_product.variants.first.id }}\">\n                  <button class=\"quick-add__submit button\" type=\"submit\">Add to Cart</button>\n                </form>\n              </div>\n            </div>\n          {% endfor %}\n        </div>\n      </div>\n    {% else %}\n      {% assign product_collections = product.collections %}\n      {% if product_collections.size > 0 %}\n        <div class=\"banner__top-image\">\n          <img src=\"//syruvia.com/cdn/shop/files/Blogfdzg-Page_small.png?v=1729753769\" alt=\"Top Image\">\n        </div>\n        <div class=\"cst-custom-section-heading \">\n    <h2>You Might Enjoy</h2>\n  </div>\n        <div class=\"content\">\n          <div class=\"product-grid-section\">\n            {% assign collection = product_collections.first %}\n            {% for related_product in collection.products limit:8 %}\n              {% if related_product.id != product.id %}\n                <div class=\"product-card \n                  {% assign colorIndex = forloop.index0 | modulo: 4 %}\n                  {% case colorIndex %}\n                  {% when 0 %}colorone\n                  {% when 1 %}colortwo\n                  {% when 2 %}colorthree\n                  {% when 3 %}colorfour\n                  {% endcase %}\">\n                  <!-- Product Image -->\n                  <div class=\"cst-custom-product-featured-image\">\n                    <a href=\"{{ related_product.url }}\">\n                      <img src=\"{{ related_product.featured_image | img_url: 'large' }}\" alt=\"{{ related_product.title }}\">\n                    </a>\n                  </div>\n\n                  <!-- Product Content -->\n                  <div class=\"cst-custom-product-content\">\n                    <!-- Review Stars -->\n                    <div class=\"areviews_product_item areviews_stars{{ related_product.id }}\" data-product-id=\"{{ related_product.id }}\"></div>\n\n                    <!-- Product Title -->\n                    <h3>{{ related_product.title }}</h3>\n                    <p>{{ related_product.price | money }}</p>\n\n                    <!-- Add to Cart Button -->\n                    <form action=\"/cart/add\" method=\"post\" enctype=\"multipart/form-data\">\n                      <input type=\"hidden\" name=\"id\" value=\"{{ related_product.variants.first.id }}\">\n                      <button class=\"quick-add__submit button\" type=\"submit\">Add to Cart</button>\n                    </form>\n                  </div>\n                </div>\n              {% endif %}\n            {% endfor %}\n          </div>\n        </div>\n      {% endif %}\n    {% endif %}\n  </div>\n</div>\n\n<!-- Add Styles and Scripts for Slick Slider -->\n<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick.min.css\">\n<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick-theme.min.css\">\n<script src=\"https://code.jquery.com/jquery-3.7.1.min.js\"></script>\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick.min.js\"></script>\n\n<script>\n  $('.product-grid-section').slick({\n    centerMode: false,\n    slidesToShow: 4,\n    responsive: [\n      {\n        breakpoint: 1300,\n        settings: {\n          arrows: true,\n          slidesToShow: 3\n        }\n      },\n      {\n        breakpoint: 991,\n        settings: {\n          arrows: true,\n          slidesToShow: 2\n        }\n      },\n      {\n        breakpoint: 768,\n        settings: {\n          arrows: true,\n          centerPadding: '100px',\n          slidesToShow: 2\n        }\n      },\n      {\n        breakpoint: 480,\n        settings: {\n          arrows: true,\n          centerPadding: '70px',\n          slidesToShow: 2\n        }\n      }\n    ]\n  });\n</script>",
        "color_scheme": "",
