{% layout 'theme' %}

{{ 'pdp-brand.css' | asset_url | stylesheet_tag }}
{% render 'pd-fixes' %}
{% render 'pd-tweaks' %}
{% render 'pd-rv2-affordances' %}
{% render 'pd-reviews-style' %}
{% render 'pd-color-swap' %}
{% render 'pd-page-polish-v2' %}
{% render 'pd-cat-styles' %}
{% render 'pd-cat-extras' %}

<style>
.pd-slider-mobile{display:none}.pd-slider-dots{display:none}
@media (max-width:760px){
  .pd-hero-frame{display:none!important}.pd-thumbs{display:none!important}
  .pd-slider-mobile{display:block!important;position:relative;background:#FFFBF4;border:2px solid #1a1a1a;border-radius:20px;padding:0;box-shadow:4px 4px 0 #1a1a1a;overflow:hidden;max-width:340px;margin:0 auto}
  .pd-slides{display:flex;overflow-x:auto;scroll-snap-type:x mandatory;scroll-behavior:smooth;-webkit-overflow-scrolling:touch;scrollbar-width:none;width:100%;position:relative;z-index:0}
  .pd-slides::-webkit-scrollbar{display:none}.pd-slide{flex:0 0 100%;scroll-snap-align:start;min-width:100%}
  .pd-slide img{width:100%;height:auto;display:block;aspect-ratio:1/1;object-fit:cover}
  .pd-slider-dots{display:flex!important;justify-content:center;gap:5px;margin-top:10px}
}
html body .pd .pd-price-row{display:flex!important;align-items:center!important;gap:10px!important;flex-wrap:wrap!important}

/* ========= Shakable Topping flavor theming ========= */
.pd-st-hero-bg{position:absolute;inset:0;z-index:0;background:radial-gradient(ellipse at 25% 20%, var(--st-glow,#FCE2A0) 0%, transparent 55%),radial-gradient(ellipse at 80% 80%, var(--st-glow2,#FFD4B8) 0%, transparent 60%);opacity:.7;pointer-events:none}
.pd-st-sprinkles{position:absolute;inset:0;z-index:0;pointer-events:none;opacity:.45}
.pd-st-sprinkle{position:absolute;width:8px;height:8px;border-radius:50%;background:var(--st-accent,#c58548)}
html body .pd .pd-st-chip{background:var(--st-main,#FCE2A0)!important}
html body .pd .pd-cat-recipes{background:var(--st-band,#FCE2A0)!important}
</style>

{%- assign hero_img = product.featured_media.preview_image -%}
{%- assign hero_src = hero_img | image_url: width: 1400 -%}
<link rel="preload" as="image" href="{{ hero_src }}" imagesrcset="{{ hero_img | image_url: width: 600 }} 600w, {{ hero_img | image_url: width: 1000 }} 1000w, {{ hero_img | image_url: width: 1400 }} 1400w" imagesizes="(max-width: 980px) 100vw, 600px" fetchpriority="high">

{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign price = current_variant.price -%}
{%- assign display_price = price -%}
{%- assign review_count = product.metafields.reviews.rating_count.value | default: 0 -%}

{%- assign t_lc = product.title | downcase -%}

{%- comment -%} ===== Flavor color theming + copy ===== {%- endcomment -%}
{%- assign st_main = '#FCE2A0' -%}
{%- assign st_accent = '#c58548' -%}
{%- assign st_glow = '#FCE2A0' -%}
{%- assign st_glow2 = '#FFD4B8' -%}
{%- assign st_band = '#FCE2A0' -%}
{%- assign flavor_name = 'topping' -%}
{%- assign flavor_short = 'topping' -%}
{%- assign sprinkle_color = '#c58548' -%}

{%- if t_lc contains 'chocolate crisp' -%}
  {%- assign st_main = '#D4A574' -%}{%- assign st_accent = '#5C3A1F' -%}{%- assign st_glow = '#E8C9A0' -%}{%- assign st_glow2 = '#D4A574' -%}{%- assign st_band = '#E8C9A0' -%}{%- assign flavor_name = 'chocolate crisp' -%}{%- assign flavor_short = 'chocolate' -%}{%- assign sprinkle_color = '#5C3A1F' -%}
{%- elsif t_lc contains 'cinnamon crisp' -%}
  {%- assign st_main = '#FFD4B8' -%}{%- assign st_accent = '#c58548' -%}{%- assign st_glow = '#FFD4B8' -%}{%- assign st_glow2 = '#FCE2A0' -%}{%- assign st_band = '#FFD4B8' -%}{%- assign flavor_name = 'cinnamon crisp' -%}{%- assign flavor_short = 'cinnamon' -%}{%- assign sprinkle_color = '#c58548' -%}
{%- elsif t_lc contains 'sweet nutmeg' or t_lc contains 'nutmeg' -%}
  {%- assign st_main = '#E8C9A0' -%}{%- assign st_accent = '#7A4F2A' -%}{%- assign st_glow = '#E8C9A0' -%}{%- assign st_glow2 = '#FFD4B8' -%}{%- assign st_band = '#E8C9A0' -%}{%- assign flavor_name = 'sweet nutmeg' -%}{%- assign flavor_short = 'nutmeg' -%}{%- assign sprinkle_color = '#7A4F2A' -%}
{%- elsif t_lc contains 'raspberry crunch' or t_lc contains 'raspberry' -%}
  {%- assign st_main = '#F5C7BE' -%}{%- assign st_accent = '#D14B3F' -%}{%- assign st_glow = '#F5C7BE' -%}{%- assign st_glow2 = '#FFD4E5' -%}{%- assign st_band = '#F5C7BE' -%}{%- assign flavor_name = 'raspberry crunch' -%}{%- assign flavor_short = 'raspberry' -%}{%- assign sprinkle_color = '#D14B3F' -%}
{%- elsif t_lc contains 'toasted coconut' or t_lc contains 'coconut' -%}
  {%- assign st_main = '#FFFBF4' -%}{%- assign st_accent = '#c58548' -%}{%- assign st_glow = '#FCE2A0' -%}{%- assign st_glow2 = '#E8C9A0' -%}{%- assign st_band = '#FCE2A0' -%}{%- assign flavor_name = 'toasted coconut' -%}{%- assign flavor_short = 'coconut' -%}{%- assign sprinkle_color = '#c58548' -%}
{%- elsif t_lc contains 'french vanilla' or t_lc contains 'vanilla' -%}
  {%- assign st_main = '#FCE2A0' -%}{%- assign st_accent = '#c58548' -%}{%- assign st_glow = '#FCE2A0' -%}{%- assign st_glow2 = '#FFD4B8' -%}{%- assign st_band = '#FCE2A0' -%}{%- assign flavor_name = 'french vanilla' -%}{%- assign flavor_short = 'vanilla' -%}{%- assign sprinkle_color = '#c58548' -%}
{%- elsif t_lc contains 'white chocolate' -%}
  {%- assign st_main = '#FFFBF4' -%}{%- assign st_accent = '#c58548' -%}{%- assign st_glow = '#FCE2A0' -%}{%- assign st_glow2 = '#FFD4B8' -%}{%- assign st_band = '#FFD4B8' -%}{%- assign flavor_name = 'white chocolate' -%}{%- assign flavor_short = 'white chocolate' -%}{%- assign sprinkle_color = '#c58548' -%}
{%- endif -%}

<style>
  :root{--st-main:{{ st_main }};--st-accent:{{ st_accent }};--st-glow:{{ st_glow }};--st-glow2:{{ st_glow2 }};--st-band:{{ st_band }};--st-chip:{{ st_main }};--st-sprinkle:{{ sprinkle_color }}}
</style>

<div class="pd" data-product-id="{{ product.id }}" data-base-price="{{ display_price }}">

  <nav class="pd-breadcrumbs" aria-label="Breadcrumb">
    <div class="pd-wrap">
      <ol>
        <li><a href="/">Home</a></li>
        <li class="pd-bc-sep" aria-hidden="true">/</li>
        <li><a href="/collections/shakable-toppings">Shakable Toppings</a></li>
        <li class="pd-bc-sep" aria-hidden="true">/</li>
        <li class="pd-bc-current">{{ product.title }}</li>
      </ol>
    </div>
  </nav>

  <section class="pd-hero" style="position:relative;overflow:hidden">
    <div class="pd-st-hero-bg" aria-hidden="true"></div>
    <div class="pd-st-sprinkles" aria-hidden="true">
      <span class="pd-st-sprinkle" style="top:12%;left:8%;background:var(--st-accent)"></span>
      <span class="pd-st-sprinkle" style="top:22%;left:18%;width:6px;height:6px;background:var(--st-main)"></span>
      <span class="pd-st-sprinkle" style="top:8%;left:74%;background:var(--st-accent);width:10px;height:10px"></span>
      <span class="pd-st-sprinkle" style="top:34%;left:88%;background:var(--st-main)"></span>
      <span class="pd-st-sprinkle" style="top:62%;left:5%;background:var(--st-accent);width:7px;height:7px"></span>
      <span class="pd-st-sprinkle" style="top:78%;left:14%;background:var(--st-main)"></span>
      <span class="pd-st-sprinkle" style="top:80%;left:82%;background:var(--st-accent);width:9px;height:9px"></span>
      <span class="pd-st-sprinkle" style="top:55%;left:92%;background:var(--st-main);width:6px;height:6px"></span>
    </div>
    <div class="pd-wrap" style="position:relative;z-index:1">
      <div class="pd-hero-grid">
        <div class="pd-hero-media">
          <div class="pd-hero-frame">
            <img id="pdHeroImg" src="{{ hero_src }}" alt="{{ product.title | escape }}" width="1200" height="1200" fetchpriority="high">
          </div>
          {%- if product.images.size > 1 -%}
            <div class="pd-thumbs">
              {%- for img in product.images limit: 4 -%}
                <button type="button" class="pd-thumb{% if forloop.first %} is-active{% endif %}" data-src="{{ img | image_url: width: 1400 }}" aria-label="View image {{ forloop.index }}"><img src="{{ img | image_url: width: 200 }}" alt="" width="200" height="200" loading="lazy"></button>
              {%- endfor -%}
            </div>
          {%- endif -%}
          <div class="pd-slider-mobile">
            <div class="pd-slides" id="pdSlides">
              {%- for img in product.images -%}
                <div class="pd-slide" data-idx="{{ forloop.index0 }}"><img src="{{ img | image_url: width: 1000 }}" alt="{{ product.title | escape }}" {% if forloop.first %}fetchpriority="high"{% else %}loading="lazy"{% endif %}></div>
              {%- endfor -%}
            </div>
          </div>
          {%- if product.images.size > 1 -%}
            <div class="pd-slider-dots" id="pdDots">
              {%- for img in product.images -%}<button type="button" class="pd-dot{% if forloop.first %} is-active{% endif %}" data-idx="{{ forloop.index0 }}" aria-label="View image {{ forloop.index }}"></button>{%- endfor -%}
            </div>
          {%- endif -%}
        </div>

        <div class="pd-hero-info">
          <a href="#reviews" class="pd-rating-row">
            <span class="pd-stars" aria-hidden="true">
              {%- for i in (1..5) -%}<svg viewBox="0 0 24 24" fill="#c58548" stroke="#c58548" stroke-width="1" stroke-linejoin="round"><path d="M12 2 L14.6 8.4 L21.5 9 L16.3 13.6 L17.9 20.4 L12 16.9 L6.1 20.4 L7.7 13.6 L2.5 9 L9.4 8.4 Z"/></svg>{%- endfor -%}
            </span>
            <span class="pd-rating-text">{{ review_count }} reviews</span>
          </a>
          <h1 class="pd-h1">{{ product.title | upcase }}</h1>

          <div class="pd-chips">
            <span class="pd-chip pd-st-chip" style="background:var(--st-main)!important"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><circle cx="9" cy="10" r="1" fill="currentColor"/><circle cx="15" cy="10" r="1" fill="currentColor"/><path d="M8 15 Q12 18 16 15"/></svg>Bold {{ flavor_short | capitalize }}</span>
            <span class="pd-chip pd-chip--butter"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6 L20 6 M5 6 L7 20 H17 L19 6 M9 6 V3 H15 V6"/></svg>Easy-Shake Lid</span>
            <span class="pd-chip pd-chip--mint"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12 l4 4 L19 7"/></svg>Kosher · Non-GMO</span>
            <span class="pd-chip pd-chip--sky"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3 H18 L17 8 H7 Z M7 8 L8 21 H16 L17 8"/></svg>Café-Ready</span>
          </div>

          {%- form 'product', product, id: 'pdAtcForm', class: 'pd-form' -%}
            <input type="hidden" name="id" value="{{ current_variant.id }}">
            <div class="pd-priceqty">
              <div class="pd-priceblock">
                <div class="pd-price-row">
                  <span class="pd-price" id="pdPriceTotal">{{ display_price | money }}</span>
                  <span class="pd-price-was" id="pdPriceWas" style="display:none"></span>
                </div>
                <span class="pd-save-inline" id="pdSaveTag" style="display:none"></span>
              </div>
              <div class="pd-qty" aria-label="Quantity">
                <button type="button" data-qty="-1" aria-label="Decrease">−</button>
                <input type="number" name="quantity" value="1" min="1" inputmode="numeric">
                <button type="button" data-qty="1" aria-label="Increase">+</button>
              </div>
            </div>
            <button type="submit" class="pd-atc pd-atc--full" {% unless product.available %}disabled{% endunless %}>
              <svg class="pd-atc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 L4 6 V20 a2 2 0 0 0 2 2 H18 a2 2 0 0 0 2 -2 V6 L18 2 Z M4 6 H20 M16 10 a4 4 0 0 1 -8 0"/></svg>
              <span class="pd-atc-text" id="pdAtcText">{%- if product.available -%}Add to cart{%- else -%}Sold Out{%- endif -%}</span>
              {%- if product.available -%}<svg class="pd-atc-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12 H19 M13 6 l6 6 -6 6"/></svg>{%- endif -%}
            </button>
          {%- endform -%}

          <div class="pd-minibundle">
            <div class="pd-mb-head">
              <span class="pd-mb-headline">Shake on the savings</span>
              <span class="pd-mb-sub">More jars, more sprinkle</span>
            </div>
            <div class="pd-mb-grid">
              <button type="button" class="pd-mb-cell" data-tier="2"><span class="pd-mb-num">2</span><span class="pd-mb-label">Jars</span><span class="pd-mb-save">Save 5%</span></button>
              <button type="button" class="pd-mb-cell" data-tier="3"><span class="pd-mb-flag">Most Popular</span><span class="pd-mb-num">3</span><span class="pd-mb-label">Jars</span><span class="pd-mb-save">Save 10%</span></button>
              <button type="button" class="pd-mb-cell" data-tier="4"><span class="pd-mb-num">4+</span><span class="pd-mb-label">Jars</span><span class="pd-mb-save">Save 15%</span></button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="pd-marquee" aria-hidden="true">
    <div class="pd-marquee-track">
      {%- for i in (1..2) -%}<span>Bold {{ flavor_short | capitalize }}</span><span>Lattes · Cappuccinos</span><span>Hot Cocoa</span><span>Whipped Cream Tops</span><span>Kosher · Non-GMO</span><span>Café-Ready</span>{%- endfor -%}
    </div>
  </div>

  <section class="pd-description">
    <div class="pd-wrap">
      <div class="pd-desc-head">
        <span class="pd-eyebrow">About this topping</span>
        <h2 class="pd-h2" style="margin-top:14px;">A finishing <em>flourish</em>.</h2>
      </div>
      <div class="pd-desc-content">
        {%- if product.description and product.description != blank -%}
          {{ product.description }}
        {%- else -%}
          <ul>
            <li>Bold {{ flavor_short | capitalize }}: Bright, fragrant flavor that hits the second the lid pops.</li>
            <li>Shake-and-Done: No grinder, no measuring. Easy-shake lid does the work.</li>
            <li>Built for Lattes &amp; More: Whipped cream tops, cocoas, oatmeal, ice cream, baked goods.</li>
            <li>Kitchen-Ready: Kosher, non-GMO, long shelf life. Tuck it next to your coffee setup.</li>
          </ul>
        {%- endif -%}
      </div>
    </div>
  </section>

  <section class="pd-standards" aria-hidden="true">
    <div class="pd-wrap">
      <div class="pd-ingredients">
        <span class="pd-ingredients-label">Ingredients</span>
        <div>Sugar, Natural &amp; Artificial Flavor, {{ flavor_short | capitalize }} Bits, Anti-Caking Agent. Kosher certified.</div>
      </div>
    </div>
  </section>

  <section class="pd-nutrition-wrap" aria-hidden="true">
    <div class="pd-wrap">
      <div class="pd-nutrition">
        <div class="pd-nutrition-title">Nutrition Facts</div>
        <div class="pd-nut-serv">Serving size 1 tsp (4 g)</div>
        <div class="pd-nut-rule--thick"></div>
        <div class="pd-nut-row"><strong>Amount per serving</strong></div>
        <div class="pd-nut-row" style="font-size:18px;"><strong>Calories</strong><strong>15</strong></div>
        <div class="pd-nut-rule"></div>
        <div style="font-size:12px;text-align:right;">% Daily Value*</div>
        <div class="pd-nut-row"><span><strong>Total Fat</strong> 0g</span><strong>0%</strong></div>
        <div class="pd-nut-rule"></div>
        <div class="pd-nut-row"><span><strong>Sodium</strong> 0mg</span><strong>0%</strong></div>
        <div class="pd-nut-rule"></div>
        <div class="pd-nut-row"><span><strong>Total Carbohydrate</strong> 4g</span><strong>1%</strong></div>
        <div class="pd-nut-row" style="padding-left:14px;font-size:13px;"><span>Total Sugars 4g</span><span></span></div>
        <div class="pd-nut-row" style="padding-left:14px;font-size:13px;"><span>Incl. 4g Added Sugars</span><strong>8%</strong></div>
        <div class="pd-nut-rule"></div>
        <div class="pd-nut-row"><span><strong>Protein</strong> 0g</span></div>
        <div class="pd-nut-rule--med"></div>
        <div style="font-size:11px;line-height:1.3;color:#3a3a3a;margin-top:6px;text-align:left;">*% DV based on a 2,000 calorie diet.</div>
      </div>
    </div>
  </section>

  <section class="pd-why">
    <div class="pd-wrap pd-why-wrap" style="text-align:center;">
      <span class="pd-eyebrow">Why Syruvia Toppings</span>
      <h2 class="pd-h2 pd-why-h2">A barista <em>finish</em>.</h2>
      <div class="pd-why-grid pd-why-grid--spaced">
        <div class="pd-why-card pd-why-card--peach">
          <div class="pd-why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="#39220f" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><circle cx="9" cy="10" r="1" fill="#39220f"/><circle cx="15" cy="10" r="1" fill="#39220f"/><path d="M8 15 Q12 18 16 15"/></svg></div>
          <h3 class="pd-why-title">Bold Aroma</h3>
          <p class="pd-why-body">Fragrant {{ flavor_short }} hits the second you twist the lid.</p>
        </div>
        <div class="pd-why-card pd-why-card--butter">
          <div class="pd-why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="#39220f" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6 L20 6 M5 6 L7 20 H17 L19 6"/></svg></div>
          <h3 class="pd-why-title">Easy-Shake Lid</h3>
          <p class="pd-why-body">Twist, sprinkle, twist back. Just like the cafés use it.</p>
        </div>
        <div class="pd-why-card pd-why-card--mint">
          <div class="pd-why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="#39220f" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3 L20 6 V12 C20 16.5 16.4 20.5 12 22 C7.6 20.5 4 16.5 4 12 V6 L12 3 Z"/><path d="M8.5 12 L11 14.5 L15.5 9.5"/></svg></div>
          <h3 class="pd-why-title">Kosher &amp; Non-GMO</h3>
          <p class="pd-why-body">Premium ingredients. Kosher certified, long shelf life.</p>
        </div>
        <div class="pd-why-card pd-why-card--sky">
          <div class="pd-why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="#39220f" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3 H18 L17 8 H7 Z M7 8 L8 21 H16 L17 8"/></svg></div>
          <h3 class="pd-why-title">Pantry Pretty</h3>
          <p class="pd-why-body">Clean jar that looks at home next to your coffee bar.</p>
        </div>
      </div>
    </div>
  </section>

  {% render 'pd-reels-section' %}

  <section class="pd-recipes-v2">
    <div class="pd-wrap pd-rv2-head">
      <span class="pd-eyebrow">Featured pour</span>
      <h2 class="pd-h2">The classic <em>{{ flavor_short }}</em> latte.</h2>
      <p class="pd-rv2-lede">Café-style finish in 60 seconds, right at home.</p>
    </div>
    <div class="pd-wrap">
      <article class="pd-rv2-feature">
        <div class="pd-rv2-feature-img">
          <img src="{{ product.featured_image | image_url: width: 1200 }}" alt="{{ product.title | escape }} latte" loading="lazy">
          <span class="pd-rv2-feature-tag">Signature shake</span>
        </div>
        <div class="pd-rv2-feature-body">
          <div class="pd-rv2-feature-content is-trimmed">
            <h3 class="pd-rv2-feature-name">Classic {{ flavor_short | capitalize }} Latte</h3>
            <p class="pd-rv2-feature-ing-head"><strong>INGREDIENTS</strong></p>
            <ul>
              <li>1 double shot espresso (or 4 oz strong coffee)</li>
              <li>6 – 8 oz steamed milk, topped with light foam</li>
              <li>2 – 3 generous shakes of Syruvia {{ flavor_short }} topping over the foam</li>
            </ul>
          </div>
          <span class="pd-rv2-feature-time">2 min</span>
        </div>
      </article>
    </div>
  </section>

  <section class="pd-cat-recipes">
    <div class="pd-wrap" style="text-align:center;">
      <span class="pd-eyebrow">Ways to shake</span>
      <h2 class="pd-h2" style="margin:14px auto 14px;">Way more than a <em>latte top</em>.</h2>
      <p class="pd-cat-recipes-sub">One jar, a dozen finishing touches.</p>
    </div>
    <div class="pd-cat-recipes-scroll">
      <button type="button" class="pd-cat-recipes-nav pd-cat-recipes-nav--prev" aria-label="Previous"><svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M15 6 l-6 6 6 6"/></svg></button>
      <div class="pd-cat-recipes-marquee">
        <div class="pd-cat-recipes-track">
          <div class="pd-cat-recipes-card"><span class="pd-cat-recipes-tag">Coffee</span><h3 class="pd-cat-recipes-card-title">Latte Topper</h3><p class="pd-cat-recipes-card-body">2-3 shakes over the foam. Instant café-style finish.</p></div>
          <div class="pd-cat-recipes-card"><span class="pd-cat-recipes-tag">Cocoa</span><h3 class="pd-cat-recipes-card-title">Hot Chocolate Crown</h3><p class="pd-cat-recipes-card-body">Whipped cream + a heavy shake of {{ flavor_short }}. Cozy upgrade.</p></div>
          <div class="pd-cat-recipes-card"><span class="pd-cat-recipes-tag">Dessert</span><h3 class="pd-cat-recipes-card-title">Ice Cream Sprinkle</h3><p class="pd-cat-recipes-card-body">Shake over vanilla, chocolate, or coffee ice cream for instant texture.</p></div>
