{% layout 'theme' %}

{{ 'pdp-brand.css' | asset_url | stylesheet_tag }}
{% render 'pd-fixes' %}
{% render 'pd-tweaks' %}
{% render 'pd-rv2-affordances' %}
{% render 'pd-reviews-style' %}
{% render 'pd-color-swap' %}
{% render 'pd-page-polish-v2' %}
{% render 'pd-cat-styles' %}
{% render 'pd-cat-extras' %}

<style>
.pd-slider-mobile{display:none}.pd-slider-dots{display:none}
@media (max-width:760px){
  .pd-hero-frame{display:none!important}.pd-thumbs{display:none!important}
  .pd-slider-mobile{display:block!important;position:relative;background:#FFFBF4;border:2px solid #1a1a1a;border-radius:20px;padding:0;box-shadow:4px 4px 0 #1a1a1a;overflow:hidden;max-width:340px;margin:0 auto}
  .pd-slides{display:flex;overflow-x:auto;scroll-snap-type:x mandatory;scroll-behavior:smooth;-webkit-overflow-scrolling:touch;scrollbar-width:none;width:100%;position:relative;z-index:0}
  .pd-slides::-webkit-scrollbar{display:none}.pd-slide{flex:0 0 100%;scroll-snap-align:start;min-width:100%}
  .pd-slide img{width:100%;height:auto;display:block;aspect-ratio:1/1;object-fit:cover}
  .pd-slider-dots{display:flex!important;justify-content:center;gap:5px;margin-top:10px}
}
html body .pd .pd-price-row{display:flex!important;align-items:center!important;gap:10px!important;flex-wrap:wrap!important}
</style>

{%- assign hero_img = product.featured_media.preview_image -%}
{%- assign hero_src = hero_img | image_url: width: 1400 -%}
<link rel="preload" as="image" href="{{ hero_src }}" imagesrcset="{{ hero_img | image_url: width: 600 }} 600w, {{ hero_img | image_url: width: 1000 }} 1000w, {{ hero_img | image_url: width: 1400 }} 1400w" imagesizes="(max-width: 980px) 100vw, 600px" fetchpriority="high">

{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign price = current_variant.price -%}
{%- assign display_price = price -%}
{%- assign review_count = product.metafields.reviews.rating_count.value | default: 0 -%}

{%- assign t_lc = product.title | downcase -%}
{%- assign flavor = 'fruit' -%}
{%- if t_lc contains 'mango' -%}{%- assign flavor = 'mango' -%}{%- endif -%}
{%- if t_lc contains 'strawberry' -%}{%- assign flavor = 'strawberry' -%}{%- endif -%}
{%- if t_lc contains 'peach' -%}{%- assign flavor = 'peach' -%}{%- endif -%}
{%- if t_lc contains 'passion' -%}{%- assign flavor = 'passion fruit' -%}{%- endif -%}
{%- if t_lc contains 'pomegranate' -%}{%- assign flavor = 'pomegranate' -%}{%- endif -%}
{%- if t_lc contains 'blueberry' -%}{%- assign flavor = 'blueberry' -%}{%- endif -%}

{%- assign current_size = '2lb' -%}
{%- if t_lc contains '1 lb' -%}{%- assign current_size = '1lb' -%}{%- endif -%}
{%- if t_lc contains '7 lb' -%}{%- assign current_size = '7lb' -%}{%- endif -%}
{%- assign handle_stem = product.handle -%}
{%- if current_size == '1lb' -%}{%- assign handle_stem = product.handle | remove_first: '1-lb-' -%}{%- endif -%}
{%- if current_size == '7lb' -%}{%- assign handle_stem = product.handle | remove_first: '7-lb-' -%}{%- endif -%}

<div class="pd" data-product-id="{{ product.id }}" data-base-price="{{ display_price }}">

  <nav class="pd-breadcrumbs" aria-label="Breadcrumb">
    <div class="pd-wrap">
      <ol>
        <li><a href="/">Home</a></li>
        <li class="pd-bc-sep" aria-hidden="true">/</li>
        <li><a href="/collections/popping-boba">Popping Boba</a></li>
        <li class="pd-bc-sep" aria-hidden="true">/</li>
        <li class="pd-bc-current">{{ product.title }}</li>
      </ol>
    </div>
  </nav>

  <section class="pd-hero">
    <div class="pd-wrap">
      <div class="pd-hero-grid">
        <div class="pd-hero-media">
          <div class="pd-hero-frame">
            <img id="pdHeroImg" src="{{ hero_src }}" alt="{{ product.title | escape }}" width="1200" height="1200" fetchpriority="high">
          </div>
          {%- if product.images.size > 1 -%}
            <div class="pd-thumbs">
              {%- for img in product.images limit: 4 -%}
                <button type="button" class="pd-thumb{% if forloop.first %} is-active{% endif %}" data-src="{{ img | image_url: width: 1400 }}" aria-label="View image {{ forloop.index }}"><img src="{{ img | image_url: width: 200 }}" alt="" width="200" height="200" loading="lazy"></button>
              {%- endfor -%}
            </div>
          {%- endif -%}
          <div class="pd-slider-mobile">
            <div class="pd-slides" id="pdSlides">
              {%- for img in product.images -%}
                <div class="pd-slide" data-idx="{{ forloop.index0 }}"><img src="{{ img | image_url: width: 1000 }}" alt="{{ product.title | escape }}" {% if forloop.first %}fetchpriority="high"{% else %}loading="lazy"{% endif %}></div>
              {%- endfor -%}
            </div>
          </div>
          {%- if product.images.size > 1 -%}
            <div class="pd-slider-dots" id="pdDots">
              {%- for img in product.images -%}<button type="button" class="pd-dot{% if forloop.first %} is-active{% endif %}" data-idx="{{ forloop.index0 }}" aria-label="View image {{ forloop.index }}"></button>{%- endfor -%}
            </div>
          {%- endif -%}
        </div>

        <div class="pd-hero-info">
          <a href="#reviews" class="pd-rating-row">
            <span class="pd-stars" aria-hidden="true">
              {%- for i in (1..5) -%}<svg viewBox="0 0 24 24" fill="#FF6B5C" stroke="#FF6B5C" stroke-width="1" stroke-linejoin="round"><path d="M12 2 L14.6 8.4 L21.5 9 L16.3 13.6 L17.9 20.4 L12 16.9 L6.1 20.4 L7.7 13.6 L2.5 9 L9.4 8.4 Z"/></svg>{%- endfor -%}
            </span>
            <span class="pd-rating-text">{{ review_count }} reviews</span>
          </a>
          <h1 class="pd-h1">{{ product.title | upcase }}</h1>

          <div class="pd-chips">
            <span class="pd-chip pd-chip--peach"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21 C 5 18, 3 11, 7 6 C 10 3, 14 3, 17 6 C 21 11, 19 18, 12 21 Z"/><path d="M9 12 a3 3 0 0 0 6 0"/></svg>Real Fruit Flavor</span>
            <span class="pd-chip pd-chip--butter"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2 v3 M12 19 v3 M2 12 h3 M19 12 h3 M5 5 l2 2 M17 17 l2 2 M5 19 l2 -2 M17 7 l2 -2"/></svg>Burst-in-Mouth</span>
            <span class="pd-chip pd-chip--mint"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 4 H17 V20 a2 2 0 0 1 -2 2 H9 a2 2 0 0 1 -2 -2 Z"/><path d="M7 8 H17 M11 12 H13 M11 16 H13"/></svg>Bubble Tea Ready</span>
            <span class="pd-chip pd-chip--sky"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12 l4 4 L19 7"/></svg>Gluten-Free</span>
          </div>

          <div class="pd-size-picker" role="group" aria-label="Choose container size">
            <span class="pd-size-picker-label">Choose size</span>
            {%- if current_size == '1lb' -%}
              <a href="#" class="pd-size-btn is-active" aria-current="true">1 LB</a>
            {%- else -%}
              <a href="/products/1-lb-{{ handle_stem }}" class="pd-size-btn">1 LB</a>
            {%- endif -%}
            {%- if current_size == '2lb' -%}
              <a href="#" class="pd-size-btn is-active" aria-current="true">2 LB</a>
            {%- else -%}
              <a href="/products/{{ handle_stem }}" class="pd-size-btn">2 LB</a>
            {%- endif -%}
            {%- if current_size == '7lb' -%}
              <a href="#" class="pd-size-btn is-active" aria-current="true">7 LB</a>
            {%- else -%}
              <a href="/products/7-lb-{{ handle_stem }}" class="pd-size-btn">7 LB</a>
            {%- endif -%}
          </div>

          {%- form 'product', product, id: 'pdAtcForm', class: 'pd-form' -%}
            <input type="hidden" name="id" value="{{ current_variant.id }}">
            <div class="pd-priceqty">
              <div class="pd-priceblock">
                <div class="pd-price-row">
                  <span class="pd-price" id="pdPriceTotal">{{ display_price | money }}</span>
                  <span class="pd-price-was" id="pdPriceWas" style="display:none"></span>
                </div>
                <span class="pd-save-inline" id="pdSaveTag" style="display:none"></span>
              </div>
              <div class="pd-qty" aria-label="Quantity">
                <button type="button" data-qty="-1" aria-label="Decrease">−</button>
                <input type="number" name="quantity" value="1" min="1" inputmode="numeric">
                <button type="button" data-qty="1" aria-label="Increase">+</button>
              </div>
            </div>
            <button type="submit" class="pd-atc pd-atc--full" {% unless product.available %}disabled{% endunless %}>
              <svg class="pd-atc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 L4 6 V20 a2 2 0 0 0 2 2 H18 a2 2 0 0 0 2 -2 V6 L18 2 Z M4 6 H20 M16 10 a4 4 0 0 1 -8 0"/></svg>
              <span class="pd-atc-text" id="pdAtcText">{%- if product.available -%}Add to cart{%- else -%}Sold Out{%- endif -%}</span>
              {%- if product.available -%}<svg class="pd-atc-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12 H19 M13 6 l6 6 -6 6"/></svg>{%- endif -%}
            </button>
          {%- endform -%}

          <div class="pd-minibundle">
            <div class="pd-mb-head">
              <span class="pd-mb-headline">Stock the bar, save more</span>
              <span class="pd-mb-sub">Mix flavors and sizes</span>
            </div>
            <div class="pd-mb-grid">
              <button type="button" class="pd-mb-cell" data-tier="2"><span class="pd-mb-num">2</span><span class="pd-mb-label">Containers</span><span class="pd-mb-save">Save 5%</span></button>
              <button type="button" class="pd-mb-cell" data-tier="3"><span class="pd-mb-flag">Most Popular</span><span class="pd-mb-num">3</span><span class="pd-mb-label">Containers</span><span class="pd-mb-save">Save 10%</span></button>
              <button type="button" class="pd-mb-cell" data-tier="4"><span class="pd-mb-num">4+</span><span class="pd-mb-label">Containers</span><span class="pd-mb-save">Save 15%</span></button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="pd-marquee" aria-hidden="true">
    <div class="pd-marquee-track">
      {%- for i in (1..2) -%}<span>Real Fruit Flavor</span><span>Burst Texture</span><span>Bubble Tea Ready</span><span>Vegan-Friendly</span><span>Gluten-Free</span><span>Made for café quality</span>{%- endfor -%}
    </div>
  </div>

  <section class="pd-description">
    <div class="pd-wrap">
      <div class="pd-desc-head">
        <span class="pd-eyebrow">About these pearls</span>
        <h2 class="pd-h2" style="margin-top:14px;">Bursts of <em>joy</em> in every sip.</h2>
      </div>
      <div class="pd-desc-content">
        <ul>
          <li>Real Fruit Flavor: Juicy {{ flavor }} bursts in every pearl, made with real fruit notes — no artificial aftertaste.</li>
          <li>Burst Texture: That signature pop-in-your-mouth experience is the whole point. Customers love it.</li>
          <li>Multi-Use: Bubble tea, smoothies, yogurt parfaits, slushies, ice cream sundaes, lemonades, mocktails.</li>
          <li>Café-Grade Quality: Commercial-grade pearls, ready to serve right out of the pouch. No prep, no cooking.</li>
          <li>Shelf-Stable: Sealed pouches keep at room temp until opened, then refrigerate for up to 2 weeks.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="pd-standards" aria-hidden="true">
    <div class="pd-wrap">
      <div class="pd-ingredients">
        <span class="pd-ingredients-label">Ingredients</span>
        <div>Water, Sugar, {{ flavor | capitalize }} Juice, Sodium Alginate, Calcium Lactate, Natural Flavor, Citric Acid, Potassium Sorbate (preservative).</div>
      </div>
    </div>
  </section>
  

  <section class="pd-nutrition-wrap" aria-hidden="true">
    <div class="pd-wrap">
      <div class="pd-nutrition">
        <div class="pd-nutrition-title">Nutrition Facts</div>
        <div class="pd-nut-serv">Serving size 1 oz (28 g)</div>
        <div class="pd-nut-rule--thick"></div>
        <div class="pd-nut-row"><strong>Amount per serving</strong></div>
        <div class="pd-nut-row" style="font-size:18px;"><strong>Calories</strong><strong>30</strong></div>
        <div class="pd-nut-rule"></div>
        <div style="font-size:12px;text-align:right;">% Daily Value*</div>
        <div class="pd-nut-row"><span><strong>Total Fat</strong> 0g</span><strong>0%</strong></div>
        <div class="pd-nut-rule"></div>
        <div class="pd-nut-row"><span><strong>Sodium</strong> 15mg</span><strong>1%</strong></div>
        <div class="pd-nut-rule"></div>
        <div class="pd-nut-row"><span><strong>Total Carbohydrate</strong> 8g</span><strong>3%</strong></div>
        <div class="pd-nut-row" style="padding-left:14px;font-size:13px;"><span>Total Sugars 7g</span><span></span></div>
        <div class="pd-nut-row" style="padding-left:14px;font-size:13px;"><span>Incl. 6g Added Sugars</span><strong>12%</strong></div>
        <div class="pd-nut-rule"></div>
        <div class="pd-nut-row"><span><strong>Protein</strong> 0g</span></div>
        <div class="pd-nut-rule--med"></div>
        <div style="font-size:11px;line-height:1.3;color:#3a3a3a;margin-top:6px;text-align:left;">*% DV based on a 2,000 calorie diet.</div>
      </div>
    </div>
  </section>

  <section class="pd-why">
    <div class="pd-wrap pd-why-wrap" style="text-align:center;">
      <span class="pd-eyebrow">Why Syruvia Boba</span>
      <h2 class="pd-h2 pd-why-h2">Made to <em>pop</em>.</h2>
      <div class="pd-why-grid pd-why-grid--spaced">
        <div class="pd-why-card pd-why-card--peach">
          <div class="pd-why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21 C 5 18, 3 11, 7 6 C 10 3, 14 3, 17 6 C 21 11, 19 18, 12 21 Z"/><path d="M10 11 a2 2 0 0 0 4 0"/></svg></div>
          <h3 class="pd-why-title">Real Fruit Flavor</h3>
          <p class="pd-why-body">Juicy {{ flavor }} notes in every pearl. No artificial aftertaste.</p>
        </div>
        <div class="pd-why-card pd-why-card--butter">
          <div class="pd-why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 3 v4 M12 17 v4 M3 12 h4 M17 12 h4 M5.5 5.5 l2.5 2.5 M16 16 l2.5 2.5 M5.5 18.5 l2.5 -2.5 M16 8 l2.5 -2.5"/></svg></div>
          <h3 class="pd-why-title">Burst Texture</h3>
          <p class="pd-why-body">That signature pop is the whole point. Customers love it.</p>
        </div>
        <div class="pd-why-card pd-why-card--mint">
          <div class="pd-why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 4 H17 V20 a2 2 0 0 1 -2 2 H9 a2 2 0 0 1 -2 -2 Z"/><path d="M7 9 H17"/><circle cx="10" cy="15" r=".8" fill="#1a1a1a"/><circle cx="13" cy="17" r=".8" fill="#1a1a1a"/><circle cx="10.5" cy="18" r=".8" fill="#1a1a1a"/></svg></div>
          <h3 class="pd-why-title">Multi-Use</h3>
          <p class="pd-why-body">Bubble tea, smoothies, yogurt, slushies, ice cream toppings.</p>
        </div>
        <div class="pd-why-card pd-why-card--sky">
          <div class="pd-why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 8 H19 V18 a3 3 0 0 1 -3 3 H8 a3 3 0 0 1 -3 -3 Z"/><path d="M19 10 h2 a2 2 0 0 1 2 2 v0 a2 2 0 0 1 -2 2 h-2"/><path d="M8 5 c 0 -2 8 -2 8 0"/></svg></div>
          <h3 class="pd-why-title">Café-Grade Quality</h3>
          <p class="pd-why-body">Commercial-grade pearls. Ready to serve, store, scoop.</p>
        </div>
      </div>
    </div>
  </section>

  {% render 'pd-reels-section' %}

  <section class="pd-recipes-v2">
    <div class="pd-wrap pd-rv2-head">
      <span class="pd-eyebrow">Featured recipe</span>
      <h2 class="pd-h2">Pour <em>like this</em>.</h2>
      <p class="pd-rv2-lede">The signature pour for Syruvia {{ flavor }} popping boba.</p>
    </div>
    <div class="pd-wrap">
      <article class="pd-rv2-feature">
        <div class="pd-rv2-feature-img">
          <img src="{{ product.featured_image | image_url: width: 1200 }}" alt="{{ product.title | escape }} signature recipe" loading="lazy">
          <span class="pd-rv2-feature-tag">Signature recipe</span>
        </div>
        <div class="pd-rv2-feature-body">
          <div class="pd-rv2-feature-content is-trimmed">
            <h3 class="pd-rv2-feature-name">{{ flavor | capitalize }} Bubble Milk Tea</h3>
            <p class="pd-rv2-feature-ing-head"><strong>INGREDIENTS</strong></p>
            <ul>
              <li>8 oz strong black tea, cooled</li>
              <li>2–3 tbsp Syruvia {{ flavor }} popping boba</li>
              <li>¼ cup milk (dairy, oat, or coconut)</li>
              <li>Ice, to fill</li>
            </ul>
          </div>
          <span class="pd-rv2-feature-time">5 min</span>
        </div>
      </article>
    </div>
  </section>

  <section class="pd-cat-recipes">
    <div class="pd-wrap" style="text-align:center;">
      <span class="pd-eyebrow">Ways to use</span>
      <h2 class="pd-h2" style="margin:14px auto 14px;">Pop them <em>everywhere</em>.</h2>
      <p class="pd-cat-recipes-sub">From bubble tea to brunch bowls, these pearls upgrade every cup, scoop, or spoon.</p>
    </div>
    <div class="pd-cat-recipes-scroll">
      <button type="button" class="pd-cat-recipes-nav pd-cat-recipes-nav--prev" aria-label="Previous"><svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M15 6 l-6 6 6 6"/></svg></button>
      <div class="pd-cat-recipes-marquee">
        <div class="pd-cat-recipes-track">
          <div class="pd-cat-recipes-card"><span class="pd-cat-recipes-tag">Smoothie Bowl</span><h3 class="pd-cat-recipes-card-title">Tropical Boba Bowl</h3><p class="pd-cat-recipes-card-body">Blend frozen fruit + yogurt, scoop into a bowl, crown with a generous spoon of pearls.</p></div>
          <div class="pd-cat-recipes-card"><span class="pd-cat-recipes-tag">Frozen Yogurt</span><h3 class="pd-cat-recipes-card-title">Fro-Yo Topping</h3><p class="pd-cat-recipes-card-body">A tablespoon over vanilla or fruit fro-yo — textural surprise in every spoonful.</p></div>
          <div class="pd-cat-recipes-card"><span class="pd-cat-recipes-tag">Ice Cream</span><h3 class="pd-cat-recipes-card-title">Boba Sundae</h3><p class="pd-cat-recipes-card-body">Two scoops of vanilla, a drizzle of syrup, a heap of pearls. Done.</p></div>
          <div class="pd-cat-recipes-card"><span class="pd-cat-recipes-tag">Lemonade</span><h3 class="pd-cat-recipes-card-title">{{ flavor | capitalize }} Lemonade Pop</h3><p class="pd-cat-recipes-card-body">Sparkling lemonade, ice, a spoonful of pearls. Bright + bursty.</p></div>
          <div class="pd-cat-recipes-card"><span class="pd-cat-recipes-tag">Cocktail</span><h3 class="pd-cat-recipes-card-title">Boba Spritz</h3><p class="pd-cat-recipes-card-body">Prosecco + soda + pearls for a brunch-ready, photo-worthy drink.</p></div>
          <div class="pd-cat-recipes-card"><span class="pd-cat-recipes-tag">Mocktail</span><h3 class="pd-cat-recipes-card-title">{{ flavor | capitalize }} Fizz</h3><p class="pd-cat-recipes-card-body">Soda water, a splash of fruit juice, pearls. Bright, kid-friendly fun.</p></div>
        </div>
      </div>
      <button type="button" class="pd-cat-recipes-nav pd-cat-recipes-nav--next" aria-label="Next"><svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6 l6 6 -6 6"/></svg></button>
    </div>
  </section>

  {% render 'pd-reviews-v2' %}
  {% render 'pd-write-review' %}
  {% render 'pd-recommended' %}

  <section class="pd-faq" id="pdFaq">
    <div class="pd-wrap pd-faq-head">
      <span class="pd-eyebrow">FAQ</span>
      <h2 class="pd-h2">Before you <em>scoop</em>.</h2>
      <p class="pd-faq-lede">Everything you need to know about working with popping boba.</p>
    </div>
    {%- assign faqs = 'How much boba per drink?|About 2 tablespoons (30 g) per 16 oz drink is the sweet spot. Adjust to taste — some customers want a single spoonful, some want the whole cup studded.;;How long does an open container last?|Once opened, transfer to an airtight container and refrigerate. Best within 2 weeks for peak burst texture.;;Do they need cooking?|No. These are ready-to-serve. Drain, scoop, and top your drink straight from the pouch.;;What can I make with them?|Bubble tea, smoothies, yogurt parfaits, slushies, ice cream sundaes, lemonades, cocktails, mocktails, fruit bowls. Anywhere you want texture + flavor.;;Are they vegan, gluten-free, kosher?|Yes — all Syruvia popping boba is vegan, gluten-free, and OU kosher certified.;;How fast do you ship?|Orders ship in 1 business day from our New Jersey warehouse. Flat-rate $5.99 shipping, free over $34. Most arrive in 3-5 business days.;;What if I do not love it?|We back every container with a 30-day taste guarantee. If it is not your thing, email us and we will make it right.' | split: ';;' -%}
    <ul class="pd-faq-list">
      {%- for faq in faqs -%}
        {%- assign parts = faq | split: '|' -%}
        <li class="pd-faq-item">
          <button type="button" class="pd-faq-q" aria-expanded="false">
            <span class="pd-faq-q-text">{{ parts[0] }}</span>
            <span class="pd-faq-icon" aria-hidden="true"></span>
          </button>
          <div class="pd-faq-a"><div class="pd-faq-a-inner">{{ parts[1] }}</div></div>
        </li>
      {%- endfor -%}
    </ul>
  </section>

  {% render 'pd-vip-section' %}

  <div class="pd-stickybar" id="pdStickybar">
    <span class="pd-price"><span id="pdStickyPrice">{{ display_price | money }}</span></span>
    <button type="button" class="pd-atc" {% unless product.available %}disabled{% endunless %} onclick="document.getElementById('pdAtcForm').requestSubmit()">{%- if product.available -%}Add to cart{%- else -%}Sold Out{%- endif -%}</button>
  </div>
</div>

{% render 'pd-mb-prices' %}

<script>
window.PD_BASE_CENTS = {{ display_price }};
window.PD_TIERS = [1, 0.95, 0.90, 0.85];
(function(){
  var currentBaseCents = window.PD_BASE_CENTS;
  const tiers = window.PD_TIERS;
  const fmt = (c)=>{const d=c/100; return '$' + d.toFixed(2);};
  function updatePrice(qty){
    qty = Math.max(1, parseInt(qty)||1);
    const tierIdx = Math.min(qty-1, tiers.length-1);
    const discount = tiers[tierIdx];
    const totalCents = Math.round(currentBaseCents * qty * discount);
    const origCents = currentBaseCents * qty;
    const priceEl = document.getElementById('pdPriceTotal');
    const wasEl = document.getElementById('pdPriceWas');
    const saveEl = document.getElementById('pdSaveTag');
    const stickyPriceEl = document.getElementById('pdStickyPrice');
    if (priceEl) priceEl.textContent = fmt(totalCents);
    if (stickyPriceEl) stickyPriceEl.textContent = fmt(totalCents);
    if (qty > 1) { if (wasEl){wasEl.textContent = fmt(origCents); wasEl.style.display='inline';} if (saveEl){saveEl.textContent = 'Save '+Math.round((1-discount)*100)+'%'; saveEl.style.display='inline-block';} }
    else { if (wasEl) wasEl.style.display='none'; if (saveEl) saveEl.style.display='none'; }
    document.querySelectorAll('.pd-mb-cell').forEach(c=>{ const t = parseInt(c.dataset.tier)||1; const match = (qty === t) || (qty >= 4 && t === 4); if (match) c.setAttribute('data-active',''); else c.removeAttribute('data-active'); });
  }
  document.querySelectorAll('.pd-qty [data-qty]').forEach(b=>{b.addEventListener('click',()=>{const inp=b.parentElement.querySelector('input'); const v=Math.max(1,(parseInt(inp.value)||1)+parseInt(b.dataset.qty)); inp.value=v; updatePrice(v);});});
  document.querySelectorAll('.pd-qty input').forEach(inp=>{inp.addEventListener('change',()=>updatePrice(parseInt(inp.value)||1)); inp.addEventListener('input',()=>updatePrice(parseInt(inp.value)||1));});
  document.querySelectorAll('.pd-mb-cell').forEach(c=>{c.addEventListener('click',()=>{const tier=parseInt(c.dataset.tier)||1; const qtyInp=document.querySelector('.pd-qty input'); if(qtyInp){qtyInp.value=tier; updatePrice(tier);}});});
  const heroImg=document.getElementById('pdHeroImg');
  document.querySelectorAll('.pd-thumb').forEach(t=>{t.addEventListener('click',()=>{document.querySelectorAll('.pd-thumb').forEach(x=>x.classList.remove('is-active'));t.classList.add('is-active');if(heroImg&&t.dataset.src)heroImg.src=t.dataset.src;});});
  const slides=document.getElementById('pdSlides'); const dots=document.querySelectorAll('.pd-dot');
  if(slides&&dots.length){let st; slides.addEventListener('scroll',()=>{clearTimeout(st);st=setTimeout(()=>{const idx=Math.round(slides.scrollLeft/slides.clientWidth);dots.forEach((d,i)=>d.classList.toggle('is-active',i===idx));},50);}); dots.forEach((d,i)=>d.addEventListener('click',()=>{slides.scrollTo({left:i*slides.clientWidth,behavior:'smooth'});}));}
  const mainAtc=document.querySelector('.pd-atc--full'); const stickyBar=document.getElementById('pdStickybar');
  if(mainAtc&&stickyBar&&'IntersectionObserver' in window){const io=new IntersectionObserver((entries)=>{entries.forEach(e=>{if(e.isIntersecting)stickyBar.classList.add('is-hidden');else stickyBar.classList.remove('is-hidden');});},{threshold:0.15}); io.observe(mainAtc);}
})();
</script>
