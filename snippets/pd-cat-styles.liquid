{%- comment -%} Shared CSS for FAQ + category-specific recipes carousel. {%- endcomment -%}
<style>
/* FAQ */
html body .pd .pd-faq{padding:96px 0!important;background:#FFFBF4!important;border-top:2px solid #39220f!important;border-bottom:2px solid #39220f!important;display:block!important}
@media (max-width:760px){html body .pd .pd-faq{padding:64px 0!important}}
html body .pd .pd-faq-head{text-align:center!important;max-width:680px!important;margin:0 auto 48px!important}
html body .pd .pd-faq-head .pd-eyebrow{--faq-s:0.85;display:inline-block!important;margin:0 auto 18px!important;font-size:calc(11px * var(--faq-s))!important;padding:calc(7px * var(--faq-s)) calc(16px * var(--faq-s))!important;will-change:font-size,padding!important}
html body .pd .pd-faq-head .pd-h2{margin:0 auto 12px!important;text-align:center!important}
html body .pd .pd-faq-lede{font-family:'Josefin Sans',sans-serif!important;font-size:15.5px!important;line-height:1.55!important;color:#3a3a3a!important;font-weight:500!important;margin:0 auto!important;max-width:42ch!important}
@media (max-width:760px){html body .pd .pd-faq-head{margin-bottom:32px!important;padding:0 18px!important}html body .pd .pd-faq-lede{font-size:14px!important}}
html body .pd .pd-faq-list{display:flex!important;flex-direction:column!important;gap:14px!important;max-width:760px!important;margin:0 auto!important;padding:0 18px!important;list-style:none!important}
html body .pd .pd-faq-list li{list-style:none!important}
html body .pd .pd-faq-list li::marker{content:''!important}
html body .pd .pd-faq-item{background:#FFFFFF!important;border:2px solid #39220f!important;border-radius:20px!important;box-shadow:4px 4px 0 #39220f!important;padding:0!important;list-style:none!important;overflow:hidden!important;transition:background .25s ease, box-shadow .25s ease, transform .25s ease!important}
html body .pd .pd-faq-item:hover{transform:translate(-1px,-1px)!important;box-shadow:5px 5px 0 #39220f!important}
html body .pd .pd-faq-item.is-open{background:#FFF8EE!important;box-shadow:5px 5px 0 #c58548!important;transform:translate(-1px,-1px)!important}
html body .pd .pd-faq-q{display:grid!important;grid-template-columns:1fr 38px!important;align-items:center!important;gap:18px!important;padding:22px 24px!important;cursor:pointer!important;user-select:none!important;font-family:'Archivo Black','Archivo',sans-serif!important;font-weight:400!important;font-size:16px!important;letter-spacing:.02em!important;color:#39220f!important;line-height:1.3!important;background:transparent!important;border:0!important;margin:0!important;text-align:left!important;width:100%!important}
html body .pd .pd-faq-icon{width:38px!important;height:38px!important;background:#FCE2A0!important;border:2px solid #39220f!important;border-radius:50%!important;display:flex!important;align-items:center!important;justify-content:center!important;flex-shrink:0!important;box-shadow:2px 2px 0 #39220f!important;transition:background .25s ease, transform .3s cubic-bezier(.34,1.56,.64,1), box-shadow .25s ease!important;position:relative!important}
html body .pd .pd-faq-icon::before,html body .pd .pd-faq-icon::after{content:''!important;position:absolute!important;background:#39220f!important;border-radius:2px!important;transition:transform .3s ease!important}
html body .pd .pd-faq-icon::before{width:14px!important;height:2.4px!important}
html body .pd .pd-faq-icon::after{width:2.4px!important;height:14px!important}
html body .pd .pd-faq-item.is-open .pd-faq-icon{background:#c58548!important;transform:rotate(180deg)!important}
html body .pd .pd-faq-item.is-open .pd-faq-icon::before,html body .pd .pd-faq-item.is-open .pd-faq-icon::after{background:#FFFBF4!important}
html body .pd .pd-faq-item.is-open .pd-faq-icon::after{transform:rotate(90deg)!important}
html body .pd .pd-faq-a{max-height:0!important;overflow:hidden!important;transition:max-height .35s ease, padding .35s ease!important;padding:0 24px!important}
html body .pd .pd-faq-item.is-open .pd-faq-a{max-height:600px!important;padding:0 24px 22px!important}
html body .pd .pd-faq-a-inner{font-family:'Josefin Sans',sans-serif!important;font-size:15px!important;line-height:1.65!important;color:#39220f!important;font-weight:500!important;padding-top:18px!important;border-top:1.5px dashed rgba(57,34,15,.18)!important}
@media (max-width:760px){
  html body .pd .pd-faq-list{gap:10px!important}
  html body .pd .pd-faq-q{padding:18px 18px!important;font-size:13.5px!important;letter-spacing:.01em!important;grid-template-columns:1fr 32px!important;gap:14px!important}
  html body .pd .pd-faq-icon{width:32px!important;height:32px!important;box-shadow:2px 2px 0 #39220f!important}
  html body .pd .pd-faq-icon::before{width:12px!important}
  html body .pd .pd-faq-icon::after{height:12px!important}
  html body .pd .pd-faq-a{padding:0 18px!important}
  html body .pd .pd-faq-item.is-open .pd-faq-a{padding:0 18px 18px!important}
  html body .pd .pd-faq-a-inner{font-size:14px!important;padding-top:14px!important}
  html body .pd .pd-faq-item{border-radius:16px!important;box-shadow:3px 3px 0 #39220f!important}
  html body .pd .pd-faq-item.is-open{box-shadow:4px 4px 0 #c58548!important}
}

/* Category recipes carousel — use unique class .pd-cat-recipes to avoid syrup pd-recipes conflicts */
html body .pd .pd-cat-recipes{padding:96px 0 80px!important;background:#FFFFFF!important;border-top:2px solid #39220f!important;display:block!important}
@media (max-width:760px){html body .pd .pd-cat-recipes{padding:64px 0 56px!important}}
html body .pd .pd-cat-recipes .pd-eyebrow{--catrec-s:0.85;display:inline-block!important;margin:0 auto 18px!important;font-size:calc(11px * var(--catrec-s))!important;padding:calc(7px * var(--catrec-s)) calc(16px * var(--catrec-s))!important;will-change:font-size,padding!important}
html body .pd .pd-cat-recipes .pd-h2{margin:0 auto 12px!important}
html body .pd .pd-cat-recipes-sub{font-family:'Josefin Sans',sans-serif!important;font-size:15px!important;color:#3a3a3a!important;font-weight:500!important;max-width:42ch!important;margin:0 auto 32px!important;line-height:1.5!important}
html body .pd .pd-cat-recipes-scroll{position:relative!important}
html body .pd .pd-cat-recipes-marquee{display:block!important;width:100%!important;overflow-x:auto!important;scroll-snap-type:x mandatory!important;-webkit-overflow-scrolling:touch!important;scrollbar-width:none!important}
html body .pd .pd-cat-recipes-marquee::-webkit-scrollbar{display:none!important}
html body .pd .pd-cat-recipes-track{display:flex!important;gap:20px!important;padding:8px 32px 24px!important}
html body .pd .pd-cat-recipes-card{flex:0 0 300px!important;max-width:300px!important;scroll-snap-align:start!important;background:#FFFBF4!important;border:2px solid #39220f!important;border-radius:22px!important;box-shadow:5px 5px 0 #39220f!important;padding:22px 24px 24px!important;display:flex!important;flex-direction:column!important;gap:8px!important;transition:transform .25s ease, box-shadow .25s ease!important;text-align:left!important}
html body .pd .pd-cat-recipes-card:hover{transform:translate(-2px,-2px)!important;box-shadow:7px 7px 0 #39220f!important}
html body .pd .pd-cat-recipes-tag{display:inline-block!important;background:#FCE2A0!important;border:1.5px solid #39220f!important;border-radius:999px!important;padding:5px 12px!important;font-family:'Archivo Black','Archivo',sans-serif!important;font-weight:400!important;font-size:10px!important;letter-spacing:.16em!important;text-transform:uppercase!important;color:#39220f!important;align-self:flex-start!important;line-height:1!important;box-shadow:1.5px 1.5px 0 #39220f!important}
html body .pd .pd-cat-recipes-card-title{font-family:'Archivo Black','Archivo',sans-serif!important;font-weight:400!important;font-size:17px!important;color:#39220f!important;margin:6px 0 6px!important;line-height:1.15!important;letter-spacing:-.005em!important;text-transform:uppercase!important}
html body .pd .pd-cat-recipes-card-body{font-family:'Josefin Sans',sans-serif!important;font-size:14px!important;line-height:1.5!important;color:#39220f!important;font-weight:500!important;margin:0!important}
html body .pd .pd-cat-recipes-nav{position:absolute!important;top:50%!important;transform:translateY(-50%)!important;width:48px!important;height:48px!important;border-radius:50%!important;background:#FFFBF4!important;border:2px solid #39220f!important;display:flex!important;align-items:center!important;justify-content:center!important;color:#39220f!important;cursor:pointer!important;z-index:5!important;box-shadow:3px 3px 0 #39220f!important;padding:0!important}
html body .pd .pd-cat-recipes-nav:hover{background:#FCE2A0!important}
html body .pd .pd-cat-recipes-nav--prev{left:12px!important}
html body .pd .pd-cat-recipes-nav--next{right:12px!important}
@media (max-width:980px){html body .pd .pd-cat-recipes-nav{display:none!important}}
</style>

<script>
(function(){
  function init(){
    document.querySelectorAll('.pd-faq-item').forEach(function(item){
      var btn = item.querySelector('.pd-faq-q');
      if (!btn || btn.dataset.faqBound) return;
      btn.dataset.faqBound = '1';
      btn.addEventListener('click', function(e){
        e.preventDefault();
        var isOpen = item.classList.toggle('is-open');
        btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      });
    });
    /* FAQ scroll-grow eyebrow */
    var faqSection = document.querySelector('.pd-faq');
    var faqBadge = faqSection && faqSection.querySelector('.pd-eyebrow');
    if (faqBadge && !faqBadge.dataset.eyebrowBound){
      faqBadge.dataset.eyebrowBound = '1';
      var minS = 0.85, maxS = 1.45, raf = null;
      function update(){
        raf = null;
        var vh = window.innerHeight || document.documentElement.clientHeight;
        var r = faqSection.getBoundingClientRect();
        var denom = (vh - vh * 0.20) || 1;
        var p = (vh - r.top) / denom;
        if (p < 0) p = 0; if (p > 1) p = 1;
        var ease = p * p * (3 - 2 * p);
        faqBadge.style.setProperty('--faq-s', (minS + (maxS - minS) * ease).toFixed(3));
      }
      function onScroll(){ if (raf) return; raf = requestAnimationFrame(update); }
      window.addEventListener('scroll', onScroll, {passive:true});
      window.addEventListener('resize', onScroll, {passive:true});
      update();
    }
    /* Category recipes carousel nav */
    var track = document.querySelector('.pd-cat-recipes-marquee');
    var prev  = document.querySelector('.pd-cat-recipes-nav--prev');
    var next  = document.querySelector('.pd-cat-recipes-nav--next');
    if (track && prev && next){
      var step = function(){var c = track.querySelector('.pd-cat-recipes-card'); return c ? c.offsetWidth + 20 : 300;};
      prev.addEventListener('click', function(){track.scrollBy({left: -step(), behavior: 'smooth'});});
      next.addEventListener('click', function(){track.scrollBy({left: step(), behavior: 'smooth'});});
    }
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>
