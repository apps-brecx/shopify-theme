{%- comment -%} Late-loading overrides: legacy subscription hide + sticky bar + scroll-reveal. {%- endcomment -%}
<style>
/* ===== Hide legacy subscription widgets ===== */
html body .appstle_subscription_wrapper,
html body .appstle-subscription-widget,
html body .appstle_product_subscription_wrapper,
html body .appstle_select_radio_box,
html body [data-appstle-subscription],
html body [data-appstle-id],
html body .shopify-subscription-purchase-option,
html body subscription-info,
html body .rc-widget,
html body .rc-subscription-options,
html body .recharge-subscription,
html body .recharge-widget,
html body .bold-subscription,
html body .bold-options,
html body .rebuy-widget,
html body [class*="appstle"]:not(.pd-po):not(.pd-po *){display:none!important;visibility:hidden!important}

/* ===== Sticky bar — hard offset shadow matching other branded cards ===== */
html body .pd .pd-stickybar{border:2px solid #39220f!important;background:#FFFBF4!important;box-shadow:5px 5px 0 #39220f!important;padding:14px 18px!important;display:flex!important;align-items:center!important;justify-content:space-between!important;gap:12px!important;border-radius:18px!important}
html body .pd .pd-stickybar .pd-price{font-family:'Archivo Black','Archivo',sans-serif!important;font-weight:400!important;letter-spacing:-.01em!important;color:#39220f!important;display:inline-flex!important;align-items:center!important;gap:10px!important;line-height:1!important;flex-wrap:nowrap!important;margin:0!important}
html body .pd .pd-stickybar #pdStickyPrice{font-family:'Archivo Black','Archivo',sans-serif!important;font-weight:400!important;font-size:22px!important;letter-spacing:-.01em!important;color:#39220f!important;line-height:1!important}
html body .pd .pd-stickybar .pd-atc{font-family:'Archivo Black','Archivo',sans-serif!important;font-weight:400!important;font-size:13px!important;letter-spacing:.14em!important;text-transform:uppercase!important;color:#FFFBF4!important;background:#39220f!important;border:2px solid #39220f!important;border-radius:999px!important;padding:12px 22px!important;box-shadow:3px 3px 0 #c58548!important;cursor:pointer!important;transition:transform .15s ease, box-shadow .15s ease!important;flex-shrink:0!important}
html body .pd .pd-stickybar .pd-atc:hover{transform:translate(-1px,-1px)!important;box-shadow:4px 4px 0 #c58548!important;color:#FFFBF4!important}
@media (max-width:760px){
  html body .pd .pd-stickybar{position:fixed!important;bottom:18px!important;left:12px!important;right:12px!important;width:auto!important;border-radius:20px!important;padding:12px 14px!important;padding-bottom:calc(12px + env(safe-area-inset-bottom, 0px))!important;box-shadow:4px 4px 0 #39220f!important;border:2px solid #39220f!important}
  html body .pd .pd-stickybar #pdStickyPrice{font-size:18px!important}
  html body .pd .pd-stickybar .pd-atc{font-size:11.5px!important;padding:11px 18px!important;box-shadow:2.5px 2.5px 0 #c58548!important}
}

/* ===== Scroll reveal ===== */
html body .pd .pd-reveal:not(.is-revealed){opacity:0!important;transform:translateY(36px)!important;transition:opacity .65s cubic-bezier(.25,.46,.45,.94), transform .65s cubic-bezier(.25,.46,.45,.94)!important;will-change:opacity, transform!important}
html body .pd .pd-reveal.is-revealed{opacity:1!important;transform:translateY(0)!important;transition:opacity .65s cubic-bezier(.25,.46,.45,.94), transform .65s cubic-bezier(.25,.46,.45,.94)!important}
@media (prefers-reduced-motion: reduce){
  html body .pd .pd-reveal{opacity:1!important;transform:none!important;transition:none!important}
  html body .pd .pd-reveal:not(.is-revealed){opacity:1!important;transform:none!important}
}
</style>

<script>
(function(){
  function init(){
    var sels = ['.pd-description', '.pd-mm-section', '.pd-why', '.pd-reels', '.pd-recipes', '.pd-recipes-v2', '.pd-reviews-v2', '.pd-faq', '.pd-recs', '.pd-vip-section', '.pd-cta'];
    var sections = [];
    sels.forEach(function(sel){
      document.querySelectorAll(sel).forEach(function(el){
        el.classList.add('pd-reveal');
        sections.push(el);
      });
    });
    if (!sections.length) return;

    if (!('IntersectionObserver' in window)){
      sections.forEach(function(s){ s.classList.add('is-revealed'); });
      return;
    }

    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if (e.isIntersecting){
          e.target.classList.add('is-revealed');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.10, rootMargin: '0px 0px -6% 0px' });
    sections.forEach(function(s){ io.observe(s); });

    setTimeout(function(){ sections.forEach(function(s){ s.classList.add('is-revealed'); }); }, 8000);
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>
