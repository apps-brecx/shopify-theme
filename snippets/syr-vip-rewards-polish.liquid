<script>
(function(){
  function init(){
    var root = document.querySelector('.vipp');
    if (!root) return;
    root.querySelectorAll('[style*="gradient"]').forEach(function(el){
      el.style.background = ''; el.style.backgroundImage = '';
    });
    var wheel = root.querySelector('.spin-card .wheel');
    if (wheel){
      var labels = wheel.querySelectorAll('.wheel-label');
      function getWheelAngle(){
        var m = getComputedStyle(wheel).transform;
        if (m === 'none') return 0;
        var match = m.match(/matrix\(([^)]+)\)/);
        if (!match) return 0;
        var v = match[1].split(',').map(parseFloat);
        return Math.atan2(v[1], v[0]) * 180 / Math.PI;
      }
      function counterRotate(){
        var angle = getWheelAngle();
        labels.forEach(function(l){
          var inner = l.querySelector('.vipp-label-text');
          if (!inner){
            inner = document.createElement('span');
            inner.className = 'vipp-label-text';
            inner.style.display = 'inline-block';
            inner.textContent = l.textContent;
            l.textContent = '';
            l.appendChild(inner);
          }
          inner.style.transform = 'rotate(' + (-angle) + 'deg)';
        });
      }
      counterRotate();
      var ticking = false;
      function loop(){
        counterRotate();
        if (ticking) requestAnimationFrame(loop);
      }
      wheel.addEventListener('transitionstart', function(){ ticking = true; loop(); });
      wheel.addEventListener('transitionend', function(){ counterRotate(); ticking = false; });
      try { var mo = new MutationObserver(function(){ counterRotate(); }); mo.observe(wheel, { attributes:true, attributeFilter:['style','class'] }); } catch(e){}
    }
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>
