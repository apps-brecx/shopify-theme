<script>
(function(){
  function isMobile(){ return window.innerWidth <= 760; }
  function forceListView(){
    if (!isMobile()) return;
    var scol = document.querySelector('.scol');
    if (!scol) return;
    if (scol.classList.contains('view-list')) {
      var listBtn = document.querySelector('.viewtoggle [data-view="list"]');
      var gridBtn = document.querySelector('.viewtoggle [data-view="grid"]');
      if (listBtn) listBtn.classList.add('on');
      if (gridBtn) gridBtn.classList.remove('on');
      return;
    }
    if (scol.dataset.viewSwitched === '1') return;
    var listBtn = document.querySelector('.viewtoggle [data-view="list"]');
    if (listBtn) { try { listBtn.click(); } catch(err){ scol.classList.remove('view-grid'); scol.classList.add('view-list'); } }
    else { scol.classList.remove('view-grid'); scol.classList.add('view-list'); }
  }
  function bindToggleMemory(){
    document.querySelectorAll('.viewtoggle [data-view]').forEach(function(btn){
      btn.addEventListener('click', function(){
        var scol = document.querySelector('.scol');
        if (scol) scol.dataset.viewSwitched = '1';
      });
    });
  }
  forceListView();
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', function(){ forceListView(); bindToggleMemory(); });
  window.addEventListener('load', forceListView);
  [50, 200, 600, 1500].forEach(function(ms){ setTimeout(forceListView, ms); });

  function wrapSticky(){
    var scol = document.querySelector('.scol');
    if (!scol) return;
    if (scol.querySelector('.pd-sticky-wrap')) return;
    var toolbar = scol.querySelector('.toolbar');
    if (!toolbar) return;
    var parent = toolbar.parentNode;
    var toMove = [];
    var sib = toolbar.previousElementSibling;
    var hops = 0;
    while (sib && hops < 3){
      var tag = sib.tagName;
      if (tag === 'SCRIPT' || tag === 'STYLE' || tag === 'HR') break;
      if (sib.classList.contains('hero-float') || sib.classList.contains('hero')) break;
      if (sib.id && /shopify-section|cart|footer/i.test(sib.id)) break;
      toMove.unshift(sib);
      sib = sib.previousElementSibling;
      hops++;
    }
    var wrap = document.createElement('div');
    wrap.className = 'pd-sticky-wrap';
    var firstNode = toMove[0] || toolbar;
    parent.insertBefore(wrap, firstNode);
    toMove.forEach(function(el){ wrap.appendChild(el); });
    wrap.appendChild(toolbar);
    var stuckObserver = new IntersectionObserver(function(entries){
      entries.forEach(function(entry){
        if (entry.intersectionRatio < 1) wrap.classList.add('is-stuck');
        else wrap.classList.remove('is-stuck');
      });
    }, {threshold:[1], rootMargin:'-1px 0px 0px 0px'});
    var sentinel = document.createElement('div');
    sentinel.style.cssText = 'position:relative;height:1px;';
    wrap.parentNode.insertBefore(sentinel, wrap);
    stuckObserver.observe(sentinel);
  }

  function installInlineWish(card){
    if (card.dataset.wishMoved === '1') return;
    var name = card.querySelector('.pcard-name');
    if (!name) return;
    var origWish = card.querySelector('.wish');
    if (!origWish) return;
    var wrap = document.createElement('div');
    wrap.className = 'pcard-name-wrap';
    name.parentNode.insertBefore(wrap, name);
    wrap.appendChild(name);
    var btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'pcard-wish-inline';
    btn.setAttribute('aria-label', 'Add to wishlist');    
    btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>';
    btn.addEventListener('click', function(e){
      e.preventDefault(); e.stopPropagation();
      try { origWish.click(); } catch(err){}
      btn.classList.toggle('is-liked');
    });
    card.appendChild(btn);
    card.dataset.wishMoved = '1';
  }
  function reserveSfSpace(card){
    if (card.dataset.sfReserved === '1') return;
    var body = card.querySelector('.pcard-body');
    if (!body) return;
    var existing = body.querySelector('.sf-label');
    if (!existing){
      var ph = document.createElement('p');
      ph.className = 'sf-label sf-placeholder';
      ph.textContent = 'SUGAR-FREE';
      body.insertBefore(ph, body.firstChild);
    }
    card.dataset.sfReserved = '1';
  }
  function rebuildAtc(card){
    if (card.dataset.atcRebuilt === '1') return;
    var atc = card.querySelector('.atc, .pcard-atc, .atc-btn, [class*="add-to-cart"], button[name="add"]');
    if (!atc) return;
    var svg = atc.querySelector('svg');
    var svgClone = svg ? svg.cloneNode(true) : null;
    while (atc.firstChild) atc.removeChild(atc.firstChild);
    if (svgClone) atc.appendChild(svgClone);
    var span = document.createElement('span');
    span.className = 'pd-atc-text';
    span.style.cssText = 'white-space:nowrap !important; word-break:keep-all !important; display:inline-block !important; line-height:1 !important;';
    span.textContent = 'Add to cart';
    atc.appendChild(span);
    card.dataset.atcRebuilt = '1';
  }
  function processAll(){
    document.querySelectorAll('.pcard').forEach(function(card){ installInlineWish(card); reserveSfSpace(card); rebuildAtc(card); });
  }
  function setupBlurbExpand(){
    var blurb = document.querySelector('.hero.hero-float .hero-blurb');
    if (!blurb || blurb.dataset.pdBlurb === '1') return;
    blurb.classList.add('pd-clamp');
    setTimeout(function(){
      if (blurb.scrollHeight > blurb.clientHeight + 4){
        var moreBtn = document.createElement('button');
        moreBtn.className = 'pd-blurb-more';
        moreBtn.type = 'button';
        moreBtn.textContent = 'Read more';
        blurb.parentNode.insertBefore(moreBtn, blurb.nextSibling);
        function toggle(){
          var expanded = blurb.classList.toggle('pd-expanded');
          moreBtn.textContent = expanded ? 'Show less' : 'Read more';
        }
        moreBtn.addEventListener('click', toggle);
        blurb.addEventListener('click', toggle);
      }
    }, 80);
    blurb.dataset.pdBlurb = '1';
  }
  function init(){
    wrapSticky(); processAll(); setupBlurbExpand();
    var grid = document.querySelector('.scol-grid, .scol [class*="grid"]');
    if (grid && 'MutationObserver' in window){
      new MutationObserver(function(){ processAll(); }).observe(grid, {childList:true, subtree:true});
    }
    function tagSugarFree(){
      document.querySelectorAll('.scol .toolbar .filters .fchip').forEach(function(c){
        var t = (c.textContent || '').trim().toLowerCase();
        if (t === 'sugar-free' || t === 'sugar free') c.classList.add('is-sugarfree');
      });
    }
    tagSugarFree();
    var filtersWrap = document.querySelector('.scol .toolbar .filters');
    if (filtersWrap && 'MutationObserver' in window){
      new MutationObserver(tagSugarFree).observe(filtersWrap, {childList:true, subtree:true});
    }
    var bottomNav = document.querySelector('nav.sticky-default-nav');
    if (!bottomNav) return;
    var revealed = false; var THRESHOLD = 50;
    function check(){
      if (revealed) return;
      var y = window.scrollY || window.pageYOffset || 0;
      if (y > THRESHOLD){
        if (bottomNav) bottomNav.classList.add('is-revealed');
        revealed = true;
        window.removeEventListener('scroll', check);
      }
    }
    window.addEventListener('scroll', check, {passive:true});
    check();
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>
{%- endif -%}
