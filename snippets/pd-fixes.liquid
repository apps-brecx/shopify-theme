<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Archivo:wght@500;700;800;900&display=swap">
{% render 'pd-trust-fix' %}
<style>
/* ===== Hide conflicting theme widgets ===== */
.swym-button-bar,.swym-add-to-wishlist-view-product,swym-button,.swym-product-button,.swym-wishlist-cta,[class*="swym-add-to-wishlist"]{display:none!important}
.sticky-top,.sticky-add-to-cart,.product-sticky,#sticky-product-bar,#sticky-cart{display:none!important}

/* ===== Overflow fix ===== */
.pd,.pd-section,.pd-faq,.pd-cta,.pd-recipe,.pd-recipes,.pd-stamps,.pd-standards,.pd-why,.pd-ugc,.pd-reviews,.pd-bundle,.pd-hero,.pd-nutrition-wrap{overflow:visible!important;overflow-x:visible!important;overflow-y:visible!important}

/* ===== Hero info layout ===== */
.pd .pd-hero-info{display:flex!important;flex-direction:column!important;gap:14px!important}
.pd .pd-form{display:flex!important;flex-direction:column!important;gap:12px!important;width:100%!important}

/* ===== Title ===== */
.pd .pd-h1{font-family:'Archivo Black','Archivo',-apple-system,sans-serif!important;font-weight:400!important;font-size:clamp(34px,5.5vw,64px)!important;line-height:.95!important;letter-spacing:-.01em!important;text-transform:uppercase!important;margin:4px 0 0!important;text-wrap:balance!important;overflow-wrap:break-word!important;word-break:normal!important;color:#1a1a1a!important}
.pd .pd-h2{font-family:'Archivo Black','Archivo',sans-serif!important;font-weight:400!important;font-size:clamp(28px,4.2vw,50px)!important;line-height:.95!important;letter-spacing:-.005em!important;text-transform:uppercase!important;margin:0 0 16px!important;text-wrap:balance!important}
.pd .pd-h3{font-family:'Archivo Black','Archivo',sans-serif!important;font-weight:400!important;font-size:clamp(20px,2.4vw,28px)!important;line-height:1.02!important;text-transform:uppercase!important;letter-spacing:-.005em!important}
.pd .pd-h2 em,.pd .pd-h3 em{font-family:'Josefin Sans',serif!important;font-weight:300!important;font-style:italic!important;text-transform:none!important;letter-spacing:0!important;color:#FF6B5C!important;display:inline-block!important}

.pd .pd-eyebrow{font-family:'Archivo Black','Archivo',sans-serif!important;font-weight:400!important;font-size:11px!important;letter-spacing:.2em!important;text-transform:uppercase!important;display:inline-block!important;padding:7px 16px!important;border:1.5px solid #1a1a1a!important;border-radius:999px!important;background:#FFFBF4!important;color:#1a1a1a!important;line-height:1.2!important}

/* ===== Tagline ===== */
.pd .pd-tagline{font-family:'Josefin Sans',-apple-system,sans-serif!important;font-style:italic!important;font-weight:400!important;font-size:clamp(15px,1.6vw,18px)!important;line-height:1.4!important;color:#3a3a3a!important;margin:0 0 4px!important;max-width:42ch!important}

/* ===== Rating row ===== */
.pd .pd-rating-row{display:inline-flex!important;align-items:center!important;gap:10px!important;text-decoration:none!important;color:#1a1a1a!important;padding:7px 14px!important;border:1.5px solid #1a1a1a!important;border-radius:999px!important;background:#FFFBF4!important;width:auto!important}
.pd .pd-rating-row:hover{background:#FCE2A0!important}
.pd .pd-stars{display:inline-flex!important;align-items:center!important;gap:2px!important}
.pd .pd-stars svg{width:14px!important;height:14px!important}
.pd .pd-rating-text{font-family:'Josefin Sans',sans-serif!important;font-size:13px!important;color:#1a1a1a!important;font-weight:600!important}
.pd .jdgm-prev-badge[data-average-rating]{display:inline-flex!important}
.pd .jdgm-prev-badge__text{font-family:'Josefin Sans',sans-serif!important;font-size:13px!important;color:#1a1a1a!important;font-weight:600!important;text-decoration:none!important}
.pd .jdgm-prev-badge .jdgm-prev-badge__stars{display:none!important}

/* ===== Chips with icons ===== */
.pd .pd-chips{display:grid!important;grid-template-columns:1fr 1fr!important;gap:8px!important;margin:6px 0 2px!important;width:100%!important;max-width:380px!important}
.pd .pd-chip{font-family:'Archivo Black','Archivo',sans-serif!important;font-weight:400!important;font-size:10.5px!important;letter-spacing:.14em!important;text-transform:uppercase!important;padding:9px 12px!important;border:1.5px solid #1a1a1a!important;border-radius:999px!important;background:#FFFBF4!important;color:#1a1a1a!important;line-height:1.1!important;text-align:center!important;display:flex!important;align-items:center!important;justify-content:center!important;gap:6px!important;white-space:nowrap!important;overflow:hidden!important}
.pd .pd-chip svg{width:13px!important;height:13px!important;flex-shrink:0!important}
.pd .pd-chip--butter{background:#FCE2A0!important}
.pd .pd-chip--peach{background:#FFD4B8!important}
.pd .pd-chip--mint{background:#C5E4D4!important}
.pd .pd-chip--sky{background:#B8DCEB!important}
.pd .pd-chip--blush{background:#F5C7BE!important}

/* ===== Variant link ===== */
.pd .pd-variant-link{display:inline-flex!important;align-items:center!important;gap:8px!important;text-decoration:none!important;font-family:'Josefin Sans',sans-serif!important;font-weight:400!important;font-size:13.5px!important;color:#3a3a3a!important;padding:4px 0!important;line-height:1.2!important;border:0!important;background:transparent!important;transition:color .12s ease,gap .12s ease}
.pd .pd-variant-link strong{font-weight:700!important;color:#FF6B5C!important;text-decoration:underline!important;text-decoration-thickness:2px!important;text-underline-offset:3px!important;text-decoration-color:rgba(255,107,92,.4)!important}
.pd .pd-variant-link:hover{color:#1a1a1a!important;gap:10px!important}
.pd .pd-variant-link:hover strong{text-decoration-color:#FF6B5C!important}
.pd .pd-variant-link svg{flex-shrink:0!important;color:#FF6B5C!important}

/* ===== Price + Qty ===== */
.pd .pd-priceqty{display:flex!important;align-items:center!important;justify-content:space-between!important;gap:14px!important;width:100%!important;padding:14px 18px!important;border:2px solid #1a1a1a!important;border-radius:24px!important;background:#FFFBF4!important;box-shadow:4px 4px 0 #1a1a1a!important}
.pd .pd-priceblock{display:flex!important;flex-direction:column!important;align-items:flex-start!important;gap:2px!important;line-height:1!important}
.pd .pd-price{font-family:'Archivo Black','Archivo',sans-serif!important;font-weight:400!important;font-size:clamp(28px,3vw,38px)!important;line-height:1!important;color:#1a1a1a!important}
.pd .pd-price-was{font-family:'Josefin Sans',sans-serif!important;font-size:14px!important;color:#3a3a3a!important;text-decoration:line-through!important;text-decoration-thickness:2px!important;text-decoration-color:#FF6B5C!important;line-height:1!important}
.pd .pd-qty{display:inline-flex!important;align-items:center!important;border:1.5px solid #1a1a1a!important;border-radius:999px!important;background:#FFF8EE!important;overflow:hidden!important;flex-shrink:0!important}
.pd .pd-qty button{width:40px!important;height:48px!important;font-size:20px!important;background:transparent!important;border:0!important;cursor:pointer!important;color:#1a1a1a!important;font-family:'Archivo Black',sans-serif!important;padding:0!important;transition:background .1s ease}
.pd .pd-qty button:hover{background:#FCE2A0!important}
.pd .pd-qty input{width:42px!important;height:48px!important;border:0!important;text-align:center!important;background:transparent!important;font-family:'Archivo Black',sans-serif!important;font-size:17px!important;color:#1a1a1a!important;-moz-appearance:textfield!important}
.pd .pd-qty input::-webkit-outer-spin-button,.pd .pd-qty input::-webkit-inner-spin-button{-webkit-appearance:none!important;margin:0!important}

/* ===== ATC ===== */
.pd .pd-atc,.pd .pd-atc--full{font-family:'Archivo Black','Archivo',sans-serif!important;font-weight:400!important;font-size:17px!important;letter-spacing:.1em!important;text-transform:uppercase!important;background:#1a1a1a!important;color:#FFFBF4!important;border:2px solid #1a1a1a!important;border-radius:999px!important;height:72px!important;padding:0 28px!important;cursor:pointer!important;white-space:nowrap!important;display:flex!important;align-items:center!important;justify-content:center!important;gap:12px!important;width:100%!important;box-shadow:5px 5px 0 #1a1a1a!important;transition:transform .12s ease, box-shadow .12s ease, background .12s ease!important}
.pd .pd-atc:hover,.pd .pd-atc--full:hover{background:#FF6B5C!important;transform:translate(-2px,-2px)!important;box-shadow:7px 7px 0 #1a1a1a!important}
.pd .pd-atc:active,.pd .pd-atc--full:active{transform:translate(3px,3px)!important;box-shadow:none!important}
.pd .pd-atc[disabled],.pd .pd-atc--full[disabled]{background:#3a3a3a!important;opacity:.7!important;cursor:not-allowed!important;box-shadow:5px 5px 0 #1a1a1a!important;transform:none!important}
.pd .pd-atc-icon,.pd .pd-atc-arrow{width:22px!important;height:22px!important;flex-shrink:0!important}
.pd .pd-atc-text{flex:0 1 auto!important;text-align:center!important}

/* ===== Trust grid ===== */
.pd .pd-trustgrid{display:grid!important;grid-template-columns:repeat(3,1fr)!important;gap:0!important;width:100%!important;margin-top:4px!important;border:1.5px solid #1a1a1a!important;border-radius:18px!important;background:#FFFBF4!important;overflow:hidden!important;box-shadow:3px 3px 0 #1a1a1a!important}
.pd .pd-trustcell{display:flex!important;flex-direction:column!important;align-items:center!important;justify-content:center!important;gap:6px!important;padding:14px 8px!important;text-align:center!important;border-right:1px solid rgba(26,26,26,.15)!important}
.pd .pd-trustcell:last-child{border-right:0!important}
.pd .pd-trustcell svg{width:20px!important;height:20px!important;color:#FF6B5C!important}
.pd .pd-trustcell span{font-family:'Josefin Sans',sans-serif!important;font-size:12px!important;font-weight:600!important;color:#1a1a1a!important;line-height:1.2!important;white-space:normal!important;word-break:keep-all!important;hyphens:auto!important}

/* ===== Sticky bar auto-hide ===== */
.pd-stickybar{transition:transform .25s ease, opacity .2s ease!important}
.pd-stickybar.is-hidden{transform:translateY(120%)!important;opacity:0!important;pointer-events:none!important}
.pd-stickybar .pd-atc{height:48px!important;font-size:13px!important;box-shadow:none!important}
.pd-stickybar .pd-atc:hover{transform:none!important;box-shadow:none!important}

/* ===== Section type ===== */
.pd .pd-bundle-num{font-family:'Archivo Black','Archivo',sans-serif!important;font-weight:400!important;font-size:clamp(38px,5vw,60px)!important;line-height:1!important}
.pd .pd-bundle-label{font-family:'Archivo Black','Archivo',sans-serif!important;font-weight:400!important;font-size:11.5px!important;letter-spacing:.14em!important;text-transform:uppercase!important;color:#3a3a3a!important}
.pd .pd-bundle-price{font-family:'Archivo Black','Archivo',sans-serif!important;font-weight:400!important;font-size:clamp(15px,1.6vw,20px)!important;margin-top:12px!important;color:#1a1a1a!important}
.pd .pd-bundle-flag{font-family:'Archivo Black','Archivo',sans-serif!important;font-weight:400!important;font-size:10.5px!important;letter-spacing:.16em!important;text-transform:uppercase!important}
.pd .pd-bundle-save{font-family:'Archivo Black','Archivo',sans-serif!important;font-weight:400!important;font-size:11px!important;letter-spacing:.14em!important;text-transform:uppercase!important;color:#E85541!important}
.pd .pd-stamp{font-family:'Archivo Black','Archivo',sans-serif!important;font-weight:400!important}
.pd .pd-stamp-num{font-family:'Archivo Black','Archivo',sans-serif!important;font-weight:400!important;font-size:28px!important;line-height:1!important;color:#1a1a1a!important}
.pd .pd-stamp-cap{font-family:'Archivo Black','Archivo',sans-serif!important;font-weight:400!important;font-size:10px!important;letter-spacing:.14em!important;text-transform:uppercase!important;line-height:1.3!important;color:#3a3a3a!important;padding:0 12px!important;margin-top:2px!important}
.pd .pd-stamp-cap strong{font-family:'Archivo Black','Archivo',sans-serif!important;font-weight:400!important;font-size:13px!important;color:#1a1a1a!important;display:block!important;margin-bottom:2px!important}
.pd .pd-why-title{font-family:'Archivo Black','Archivo',sans-serif!important;font-weight:400!important;font-size:17px!important;text-transform:uppercase!important;letter-spacing:.01em!important;margin:0 0 6px!important}
.pd .pd-recipe-tag,.pd .pd-recipe-mini-foot,.pd .pd-marquee-track span,.pd .pd-cta-btn,.pd .pd-save,.pd .pd-ingredients-label,.pd .pd-ugc-tile-tag{font-family:'Archivo Black','Archivo',sans-serif!important;font-weight:400!important;text-transform:uppercase!important;letter-spacing:.14em!important}
.pd .pd-faq-q{font-family:'Archivo Black','Archivo',sans-serif!important;font-weight:400!important;text-transform:uppercase!important;letter-spacing:.005em!important;font-size:15.5px!important}
.pd .pd-recipe-mini-name{font-family:'Archivo Black','Archivo',sans-serif!important;font-weight:400!important;font-size:18px!important;text-transform:uppercase!important;line-height:1.05!important;margin:6px 0 0!important}
.pd .pd-cta-btn{font-size:14px!important;letter-spacing:.14em!important}
.pd .pd-nutrition-title{font-family:'Archivo Black','Archivo',sans-serif!important;font-weight:400!important;font-size:30px!important;line-height:1!important;text-align:left!important}
.pd .pd-ingredients{font-family:'Archivo Black','Archivo',sans-serif!important;font-weight:400!important;font-size:13px!important;letter-spacing:.06em!important;text-transform:uppercase!important;line-height:1.7!important}
.pd .pd-lead,.pd .pd-why-body,.pd .pd-recipe-mini-body,.pd .pd-faq-a,.pd .pd-standards-lede{font-family:'Josefin Sans',-apple-system,sans-serif!important;color:#1a1a1a}

/* ===== Subscribe widget ===== */
.pd .sls-purchase-options,.pd .selling-plan-allocations{font-family:'Josefin Sans',sans-serif!important;margin:14px 0 4px!important;border:1.5px solid #1a1a1a!important;border-radius:18px!important;background:#FFFBF4!important;padding:12px 14px!important;display:flex!important;flex-direction:column!important;gap:8px!important}
.pd .sls-purchase-options-label,.pd .selling-plan-group-name{font-family:'Archivo Black',sans-serif!important;font-weight:400!important;font-size:11px!important;letter-spacing:.18em!important;text-transform:uppercase!important;color:#1a1a1a!important;margin:0 0 4px!important;display:block!important}
.pd .sls-purchase-option,.pd .selling-plan-allocation{display:flex!important;align-items:center!important;justify-content:space-between!important;gap:8px!important;padding:8px 10px!important;border:1.5px solid rgba(26,26,26,.15)!important;border-radius:999px!important;background:#FFF8EE!important;cursor:pointer!important;font-size:14px!important;font-family:'Josefin Sans',sans-serif!important}
.pd .sls-purchase-option:has(input:checked),.pd .selling-plan-allocation:has(input:checked){border-color:#1a1a1a!important;background:#FCE2A0!important}
.pd .sls-purchase-option label,.pd .selling-plan-allocation label{font-family:'Archivo Black',sans-serif!important;font-weight:400!important;font-size:13px!important;letter-spacing:.06em!important;text-transform:uppercase!important;color:#1a1a1a!important;flex:1!important}
.pd [class*="sls-discount"]{background:#FF6B5C!important;color:#FFFBF4!important;font-family:'Archivo Black',sans-serif!important;font-size:10px!important;letter-spacing:.12em!important;text-transform:uppercase!important;padding:3px 8px!important;border-radius:999px!important;border:1.5px solid #1a1a1a!important;line-height:1.1!important;display:inline-block!important}

/* MOBILE */
@media (max-width:760px){
  .pd .pd-hero{padding:calc(var(--header-height,84px) + 28px) 0 36px!important}
  .pd .pd-hero-info{align-items:center!important;text-align:center!important;gap:12px!important}
  .pd .pd-h1{text-align:center!important;font-size:clamp(30px,9vw,46px)!important}
  .pd .pd-tagline{text-align:center!important;font-size:15px!important;margin:2px auto!important}
  .pd .pd-rating-row{align-self:center!important;margin:0 auto!important}
  .pd .pd-chips{display:grid!important;grid-template-columns:1fr 1fr!important;gap:8px!important;width:100%!important;max-width:380px!important;margin:4px auto!important}
  .pd .pd-chip{font-size:9.5px!important;padding:9px 6px!important;width:100%!important;text-align:center!important;white-space:nowrap!important;letter-spacing:.1em!important}
  .pd .pd-chip svg{width:12px!important;height:12px!important}
  .pd .pd-variant-link{align-self:center!important;text-align:center!important;justify-content:center!important;margin:2px auto!important;font-size:14px!important}
  .pd .pd-priceqty{padding:12px 14px!important;gap:10px!important}
  .pd .pd-price{font-size:28px!important}
  .pd .pd-price-was{font-size:13px!important}
  .pd .pd-qty button{width:36px!important;height:44px!important;font-size:18px!important}
  .pd .pd-qty input{width:38px!important;height:44px!important;font-size:16px!important}
  .pd .pd-atc,.pd .pd-atc--full{height:64px!important;font-size:15px!important;letter-spacing:.08em!important;padding:0 18px!important}
  .pd .pd-atc-icon,.pd .pd-atc-arrow{width:20px!important;height:20px!important}
  .pd .pd-trustgrid{margin-top:2px!important}
  .pd .pd-trustcell{padding:11px 4px!important}
  .pd .pd-trustcell svg{width:17px!important;height:17px!important}
  .pd .pd-trustcell span{font-size:10.5px!important;line-height:1.15!important;letter-spacing:0!important}
  .pd .pd-h2{font-size:clamp(26px,7vw,38px)!important}
  .pd .pd-bundle-num{font-size:42px!important}
  .pd .pd-bundle-card{padding:18px 12px 14px!important}
  .pd .pd-bundle-price{font-size:16px!important}
  .pd .pd-stamp{width:120px!important;height:120px!important}
  .pd .pd-stamp-num{font-size:24px!important}
  .pd .pd-nutrition{max-width:100%!important}
  .pd-stickybar{display:flex!important}
}

@media (max-width:380px){
  .pd .pd-chip{font-size:9px!important;padding:8px 4px!important;letter-spacing:.08em!important;gap:4px!important}
  .pd .pd-priceqty{padding:10px 12px!important}
  .pd .pd-price{font-size:24px!important}
  .pd .pd-atc,.pd .pd-atc--full{font-size:14px!important;letter-spacing:.06em!important}
  .pd .pd-trustcell span{font-size:9.5px!important}
}

/* TABLET */
@media (min-width:761px) and (max-width:980px){
  .pd .pd-hero{padding:calc(var(--header-height,84px) + 32px) 0 56px!important}
  .pd .pd-hero-grid{grid-template-columns:1fr!important;gap:36px!important;max-width:680px!important;margin:0 auto!important}
  .pd .pd-hero-info{align-items:center!important;text-align:center!important}
  .pd .pd-h1{text-align:center!important}
  .pd .pd-tagline{text-align:center!important;margin:2px auto!important}
  .pd .pd-chips{display:grid!important;grid-template-columns:repeat(4,1fr)!important;gap:8px!important;max-width:620px!important;margin:0 auto!important}
  .pd .pd-chip{text-align:center!important}
  .pd .pd-variant-link{justify-content:center!important}
  .pd .pd-priceqty{max-width:520px!important;margin:0 auto!important}
  .pd .pd-atc--full{max-width:520px!important;margin:0 auto!important}
  .pd .pd-trustgrid{max-width:520px!important;margin:4px auto 0!important}
  .pd .pd-bundle-grid,.pd .pd-stamp-grid,.pd .pd-why-grid,.pd .pd-ugc-grid{grid-template-columns:repeat(2,1fr)!important;gap:16px!important}
}

/* DESKTOP */
@media (min-width:981px){
  .pd .pd-wrap{padding:0 32px!important}
  .pd .pd-hero{padding:calc(var(--header-height,84px) + 24px) 0 80px!important}
  .pd .pd-hero-grid{grid-template-columns:1.05fr 1fr!important;gap:64px!important;align-items:flex-start!important}
  .pd .pd-hero-frame{position:sticky;top:24px}
  .pd .pd-hero-info{padding-top:8px!important;align-items:flex-start!important;text-align:left!important}
  .pd .pd-chips{display:grid!important;grid-template-columns:1fr 1fr!important;gap:10px!important;width:100%!important;max-width:none!important}
  .pd .pd-priceqty{width:100%!important}
  .pd .pd-section,.pd .pd-stamps,.pd .pd-standards,.pd .pd-why,.pd .pd-recipe,.pd .pd-recipes,.pd .pd-ugc,.pd .pd-reviews,.pd .pd-faq{padding:96px 0!important}
  .pd .pd-bundle{padding:80px 0!important}
  .pd .pd-bundle-grid{gap:20px!important}
  .pd .pd-bundle-card{padding:30px 22px 24px!important}
  .pd-stickybar{display:none!important}
  body{padding-bottom:0!important}
}

@media (min-width:1280px){.pd .pd-h1{font-size:68px!important}}
</style>
