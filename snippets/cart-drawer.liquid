{%- comment -%}
  Syruvia — custom add-to-cart DRAWER (mini cart).
  Desktop = 432px right-side slide-in panel; mobile (<=560px) = bottom sheet with drag handle.
  Wired to the live cart object + Cart AJAX API. Re-renders via section rendering (?sections=cart-drawer).
  Add-to-cart anywhere (incl. product pages) opens this drawer instead of going to /cart.
{%- endcomment -%}

{%- liquid
  assign FREE_SHIP = 3500
  assign SHIP_COST = 495
  assign is_vip = false
  if customer and customer.tags contains 'VIP'
    assign is_vip = true
  endif

  assign vip_savings = 0
  for item in cart.items
    assign vipunit = 799
    if item.product.tags contains 'Sugar-Free' or item.product.tags contains 'sugar-free' or item.product.tags contains 'Sugar Free' or item.product.tags contains 'sugarfree'
      assign vipunit = 699
    endif
    assign vipline = vipunit | times: item.quantity
    if item.final_line_price > vipline
      assign diff = item.final_line_price | minus: vipline
      assign vip_savings = vip_savings | plus: diff
    endif
  endfor

  assign member_saved = cart.original_total_price | minus: cart.total_price
  assign payable = cart.total_price
  assign remain = FREE_SHIP | minus: payable
  if remain < 0
    assign remain = 0
  endif
  assign pct = 0
  if payable > 0
    assign pct = payable | times: 100 | divided_by: FREE_SHIP
  endif
  if pct > 100
    assign pct = 100
  endif
  assign checkout_total = payable
  if remain > 0
    assign checkout_total = payable | plus: SHIP_COST
  endif
-%}

<style>
  #SyrCD{ --bg:#FFFBF4; --bg-2:#FFF8EE; --shell:#FBEFE0; --surface:#FFFFFF; --ink:#39220f; --ink-2:#5a4632; --muted:#8a7a68;
    --hair:color-mix(in srgb, var(--ink) 16%, transparent); --accent:#c58548; --mint:#C5E4D4; --sf-ink:#1f6b4f;
    --butter:#FCE2A0; --vip:#C53156; --vip-soft:#FBE0E5; --vip-ink:#8e1e3c;
    --rule:2px solid var(--ink); --rule-1:1.5px solid var(--ink); --shadow:4px 4px 0 var(--ink); --shadow-sm:3px 3px 0 var(--ink); --radius:18px;
    --fh:'Archivo Black',sans-serif; --fb:'Josefin Sans',sans-serif; }
  #SyrCD, #SyrCD *{ box-sizing:border-box; }
  #SyrCD{ position:fixed; inset:0; z-index:2147483000; pointer-events:none; overflow:hidden; font-family:var(--fb); color:var(--ink); }
  #SyrCD .scd-bd{ position:absolute; display:block !important; top:0; left:0; width:100%; height:100%; background:rgba(40,24,10,.46); opacity:0; transition:opacity .3s ease; }
  /* theme hides empty divs via :empty{display:none}; force-show our decorative/overlay empties */
  #SyrCD .d-ship-fill, #SyrCD .d-vip .grain{ display:block !important; }
  #SyrCD.open{ pointer-events:auto; }
  #SyrCD.open .scd-bd{ opacity:1; }
  #SyrCD .scd-panel{ position:absolute; top:0; right:0; left:auto; height:100%; width:432px; max-width:100%; background:var(--bg); border-left:var(--rule);
    box-shadow:-8px 0 0 rgba(57,34,15,.08); display:flex; flex-direction:column; transform:translateX(105%);
    transition:transform .4s cubic-bezier(.4,1,.25,1); }
  #SyrCD.open .scd-panel{ transform:none; }
  #SyrCD #SyrCD-content{ display:flex; flex-direction:column; flex:1 1 auto; min-height:0; max-height:100%; width:100%; overflow:hidden; }
  #SyrCD h2,#SyrCD h3{ font-family:var(--fh); margin:0; font-weight:400; letter-spacing:-.01em; }
  #SyrCD button{ font-family:inherit; cursor:pointer; }
  #SyrCD .scd-grip{ display:none; }
  #SyrCD .scd-head{ flex:0 0 auto; display:flex; align-items:center; gap:12px; padding:16px 18px; border-bottom:var(--rule); background:var(--surface); }
  #SyrCD .dh-ic{ width:40px; height:40px; flex:0 0 auto; border-radius:50%; border:var(--rule-1); background:var(--mint); color:var(--sf-ink); display:grid; place-items:center; }
  #SyrCD .dh-txt{ flex:1; min-width:0; }
  #SyrCD .dh-title{ font-family:var(--fh); font-size:16px; text-transform:uppercase; letter-spacing:-.01em; line-height:1; }
  #SyrCD .dh-sub{ font-size:12.5px; color:var(--muted); margin-top:3px; }
  #SyrCD .scd-close{ width:38px; height:38px; flex:0 0 auto; border-radius:50%; border:var(--rule-1); background:var(--surface); color:var(--ink); display:grid; place-items:center; transition:transform .16s; }
  #SyrCD .scd-close:hover{ transform:rotate(90deg); }
  #SyrCD .scd-body{ flex:1 1 auto; min-height:0; overflow-y:auto; overflow-x:hidden; padding:16px 18px 8px; display:flex; flex-direction:column; gap:14px; -webkit-overflow-scrolling:touch; }
  #SyrCD .scd-body > *{ flex:0 0 auto; }
  #SyrCD .added{ display:flex; align-items:center; gap:13px; border:var(--rule); border-radius:16px; background:radial-gradient(120% 140% at 0% 0%, var(--mint), transparent 62%), var(--surface); box-shadow:var(--shadow-sm); padding:12px 14px; animation:syrAddedIn .42s cubic-bezier(.3,1.3,.5,1); }
  @keyframes syrAddedIn{ from{ transform:translateY(-8px) scale(.98); } to{ transform:none; } }
  #SyrCD .added-media{ position:relative; width:60px; height:60px; flex:0 0 auto; border:var(--rule-1); border-radius:12px; background:radial-gradient(120% 95% at 50% 8%, #fff, var(--bg-2)); display:grid; place-items:center; padding:7px; }
  #SyrCD .added-media img{ width:100%; height:100%; object-fit:contain; mix-blend-mode:multiply; }
  #SyrCD .added-check{ position:absolute; top:-7px; right:-7px; width:24px; height:24px; border-radius:50%; background:var(--sf-ink); color:#fff; border:2px solid var(--bg); display:grid; place-items:center; }
  #SyrCD .added-txt{ flex:1; min-width:0; }
  #SyrCD .added-txt .lbl{ font-family:'Archivo',sans-serif; font-size:11px; font-weight:700; letter-spacing:.05em; text-transform:uppercase; color:var(--sf-ink); display:inline-flex; align-items:center; gap:5px; }
  #SyrCD .added-txt .nm{ font-family:var(--fh); font-size:15px; line-height:1.1; margin-top:2px; }
  #SyrCD .added-txt .mt{ font-size:12.5px; color:var(--muted); margin-top:2px; }
  #SyrCD .d-ship{ background:var(--surface); border:var(--rule-1); border-radius:14px; padding:12px 14px; display:flex; flex-direction:column; gap:8px; }
  #SyrCD .d-ship-top{ display:flex; align-items:center; flex-wrap:wrap; gap:4px 8px; font-size:13.5px; line-height:1.3; color:var(--ink-2); }
  #SyrCD .d-ship-top svg{ color:var(--sf-ink); flex:0 0 auto; }
  #SyrCD .d-ship-top b{ color:var(--ink); font-family:var(--fh); font-weight:400; }
  #SyrCD .d-ship-top .done{ display:inline-flex; align-items:center; gap:6px; color:var(--sf-ink); font-weight:700; }
  #SyrCD .d-ship-track{ height:9px; border-radius:999px; background:var(--bg-2); border:var(--rule-1); overflow:hidden; }
  #SyrCD .d-ship-fill{ height:100%; background:repeating-linear-gradient(45deg, var(--mint), var(--mint) 7px, #b6dcc8 7px, #b6dcc8 14px); transition:width .5s cubic-bezier(.3,1,.5,1); }
  #SyrCD .d-vip{ position:relative; overflow:hidden; border:var(--rule); border-radius:16px; box-shadow:var(--shadow-sm); padding:14px 16px; color:#fff; text-align:left; width:100%;
    background:radial-gradient(130% 130% at 100% 0%, color-mix(in srgb, var(--vip) 80%, #000 5%), var(--vip) 58%, var(--vip-ink)); }
  #SyrCD .d-vip .grain{ position:absolute; inset:0; opacity:.4; mix-blend-mode:soft-light; background-image:radial-gradient(rgba(255,255,255,.5) 1px, transparent 1.4px); background-size:11px 11px; pointer-events:none; }
  #SyrCD .d-vip-row{ position:relative; display:flex; align-items:center; gap:12px; }
  #SyrCD .d-vip .seal{ width:38px; height:38px; flex:0 0 auto; border-radius:50%; background:rgba(255,255,255,.16); border:1.5px solid rgba(255,255,255,.6); display:grid; place-items:center; }
  #SyrCD .d-vip-copy{ flex:1; min-width:0; }
  #SyrCD .d-vip-copy .h{ font-family:var(--fh); font-size:14px; line-height:1.1; text-transform:uppercase; letter-spacing:-.01em; }
  #SyrCD .d-vip-copy .h .amt{ color:var(--butter); }
  #SyrCD .d-vip-copy .s{ font-size:12.5px; color:rgba(255,255,255,.86); margin-top:3px; line-height:1.35; }
  #SyrCD .d-vip-cta{ position:relative; margin-top:12px; width:100%; height:44px; border:2px solid #fff; border-radius:999px; background:#fff; color:var(--vip-ink); font-family:var(--fh); font-size:12px; letter-spacing:.05em; text-transform:uppercase; display:inline-flex; align-items:center; justify-content:center; gap:8px; transition:transform .14s; text-decoration:none; }
  #SyrCD .d-vip-cta:hover{ transform:translateY(-1px); }
  #SyrCD .d-vip-cta svg{ color:var(--vip); }
  #SyrCD .d-vip.active{ background:radial-gradient(130% 130% at 100% 0%, var(--mint), transparent 60%), var(--surface); color:var(--ink); }
  #SyrCD .d-vip.active .d-vip-copy .s{ color:var(--ink-2); }
  #SyrCD .d-vip.active .seal{ background:var(--mint); border-color:var(--ink); color:var(--sf-ink); }
  #SyrCD .d-vip.active .d-vip-copy .h .amt{ color:var(--sf-ink); }
  #SyrCD .d-lines{ display:flex; flex-direction:column; gap:0; border:var(--rule-1); border-radius:16px; background:var(--surface); overflow:hidden; }
  #SyrCD .d-line{ display:grid; grid-template-columns:56px minmax(0,1fr) auto; gap:12px; align-items:center; padding:12px 14px; border-top:var(--rule-1); }
  #SyrCD .d-line:first-child{ border-top:0; }
  #SyrCD .d-line-media{ width:56px; height:56px; border:var(--rule-1); border-radius:11px; background:radial-gradient(120% 95% at 50% 8%, #fff, var(--bg-2)); display:grid; place-items:center; padding:6px; }
  #SyrCD .d-line-media img{ width:100%; height:100%; object-fit:contain; mix-blend-mode:multiply; }
  #SyrCD .d-line-body{ min-width:0; display:flex; flex-direction:column; gap:5px; }
  #SyrCD .d-line-name{ font-family:var(--fh); font-size:14px; line-height:1.05; }
  #SyrCD .d-line-sub{ font-size:11.5px; color:var(--muted); }
  #SyrCD .d-line-ctrls{ display:flex; align-items:center; gap:10px; margin-top:1px; }
  #SyrCD .d-qty{ display:inline-flex; align-items:center; border:var(--rule-1); border-radius:999px; padding:2px; }
  #SyrCD .d-qty button{ width:26px; height:26px; border:0; background:transparent; color:var(--ink); font-size:15px; font-weight:700; border-radius:50%; display:grid; place-items:center; transition:background .14s; }
  #SyrCD .d-qty button:hover{ background:var(--bg-2); }
  #SyrCD .d-qty button:disabled{ opacity:.3; cursor:not-allowed; }
  #SyrCD .d-qty span{ min-width:22px; text-align:center; font-family:var(--fh); font-size:13px; }
  #SyrCD .d-line-rm{ background:transparent; border:0; color:var(--muted); display:grid; place-items:center; padding:4px; border-radius:7px; transition:color .14s; }
  #SyrCD .d-line-rm:hover{ color:var(--vip); }
  #SyrCD .d-line-right{ display:flex; flex-direction:column; align-items:flex-end; gap:3px; text-align:right; }
  #SyrCD .d-line-price{ font-family:var(--fh); font-size:14px; }
  #SyrCD .d-line-price .was{ display:block; font-size:10.5px; color:var(--muted); text-decoration:line-through; font-family:'Archivo',sans-serif; font-weight:700; }
  #SyrCD .d-upsell-h{ display:flex; align-items:center; justify-content:space-between; gap:10px; margin:2px 2px -2px; }
  #SyrCD .d-upsell-h .t{ font-family:var(--fh); font-size:12px; text-transform:uppercase; letter-spacing:.03em; }
  #SyrCD .d-upsell-h .s{ font-size:11.5px; color:var(--muted); }
  #SyrCD .d-upsell{ display:flex; gap:10px; overflow-x:auto; padding:2px 2px 6px; scroll-snap-type:x mandatory; -webkit-overflow-scrolling:touch; }
  #SyrCD .up{ flex:0 0 132px; scroll-snap-align:start; border:var(--rule-1); border-radius:13px; background:var(--surface); overflow:hidden; display:flex; flex-direction:column; }
  #SyrCD .up-media{ aspect-ratio:1 / .82; background:radial-gradient(120% 95% at 50% 8%, #fff, var(--bg-2)); display:flex; align-items:center; justify-content:center; padding:10px; border-bottom:var(--rule-1); }
  #SyrCD .up-media img{ display:block; max-width:100%; max-height:100%; width:auto; height:auto; object-fit:contain; mix-blend-mode:multiply; margin:0 auto; }
  #SyrCD .up-body{ padding:9px 10px 10px; display:flex; flex-direction:column; gap:5px; flex:1; }
  #SyrCD .up-name{ font-family:var(--fh); font-size:12px; line-height:1.05; }
  #SyrCD .up-foot{ margin-top:auto; display:flex; align-items:center; justify-content:space-between; gap:6px; }
  #SyrCD .up-price{ font-family:var(--fh); font-size:12.5px; }
  #SyrCD .up-add{ width:30px; height:30px; border:var(--rule-1); border-radius:8px; background:var(--accent); color:var(--ink); display:grid; place-items:center; box-shadow:1.5px 1.5px 0 var(--ink); transition:transform .14s; }
  #SyrCD .up-add:hover{ transform:translate(-1px,-1px); }
  #SyrCD .scd-foot{ flex:0 0 auto; border-top:var(--rule); background:var(--surface); padding:14px 18px calc(14px + env(safe-area-inset-bottom)); display:flex; flex-direction:column; gap:10px; }
  #SyrCD .d-sub{ display:flex; align-items:baseline; justify-content:space-between; gap:12px; }
  #SyrCD .d-sub .l{ font-family:'Archivo',sans-serif; font-size:12px; font-weight:700; letter-spacing:.04em; text-transform:uppercase; color:var(--muted); }
  #SyrCD .d-sub .v{ font-family:var(--fh); font-size:24px; letter-spacing:-.01em; }
  #SyrCD .d-vsave{ display:flex; align-items:center; justify-content:space-between; gap:10px; font-family:'Archivo',sans-serif; font-size:12px; font-weight:700; letter-spacing:.02em; text-transform:uppercase; padding:9px 12px; border-radius:11px; border:var(--rule-1); }
  #SyrCD .d-vsave.applied{ background:var(--mint); color:var(--sf-ink); }
  #SyrCD .d-vsave.applied svg{ color:var(--sf-ink); }
  #SyrCD .d-vsave.tease{ background:var(--vip-soft); color:var(--vip-ink); cursor:pointer; text-decoration:none; }
  #SyrCD .d-vsave.tease svg{ color:var(--vip); }
  #SyrCD .d-vsave .lft{ display:inline-flex; align-items:center; gap:7px; }
  #SyrCD .scd-checkout{ height:56px; border:var(--rule); border-radius:999px; background:var(--ink); color:var(--bg); font-family:var(--fh); font-size:14px; letter-spacing:.07em; text-transform:uppercase; box-shadow:var(--shadow-sm); display:flex; align-items:center; justify-content:center; gap:9px; transition:transform .14s, box-shadow .14s, background .2s, color .2s; width:100%; }
  #SyrCD .scd-checkout:hover{ transform:translate(-2px,-2px); box-shadow:5px 5px 0 var(--accent); background:var(--accent); color:var(--ink); }
  #SyrCD .scd-viewcart{ text-align:center; font-family:'Archivo',sans-serif; font-size:12px; font-weight:700; letter-spacing:.04em; text-transform:uppercase; color:var(--ink-2); text-decoration:underline; padding:2px; display:block; }
  #SyrCD .scd-viewcart:hover{ color:var(--ink); }
  #SyrCD .scd-continue{ width:100%; height:46px; border:var(--rule-1); border-radius:999px; background:var(--surface); color:var(--ink); font-family:var(--fh); font-size:12px; letter-spacing:.05em; text-transform:uppercase; display:flex; align-items:center; justify-content:center; gap:8px; cursor:pointer; transition:background .16s, transform .14s; }
  #SyrCD .scd-continue:hover{ background:var(--bg-2); transform:translateY(-1px); }
  #SyrCD .scd-continue svg{ transform:scaleX(-1); }
  #SyrCD .d-empty{ text-align:center; padding:40px 20px; margin:auto 0; }
  #SyrCD .d-empty .g{ width:76px; height:76px; margin:0 auto 16px; border-radius:50%; border:var(--rule); background:var(--bg-2); display:grid; place-items:center; box-shadow:var(--shadow-sm); }
  #SyrCD .d-empty h3{ font-family:var(--fh); font-size:20px; text-transform:uppercase; }
  #SyrCD .d-empty p{ color:var(--ink-2); font-size:14px; margin:7px 0 18px; }
  #SyrCD .d-empty .cta{ display:inline-flex; align-items:center; gap:8px; height:48px; padding:0 22px; border:var(--rule); border-radius:999px; background:var(--accent); color:var(--ink); font-family:var(--fh); font-size:12.5px; letter-spacing:.06em; text-transform:uppercase; box-shadow:var(--shadow-sm); text-decoration:none; }
  .syr-toast{ position:fixed; left:50%; bottom:30px; transform:translateX(-50%); z-index:1100; background:#39220f; color:#FFFBF4; font-family:'Archivo Black',sans-serif; font-size:13px; letter-spacing:.03em; text-transform:uppercase; padding:13px 20px; border:2px solid #39220f; border-radius:999px; box-shadow:4px 4px 0 #39220f; animation:syrToastIn .3s cubic-bezier(.4,1.4,.5,1); }
  @keyframes syrToastIn{ from{ opacity:0; transform:translate(-50%,14px); } to{ opacity:1; transform:translate(-50%,0); } }
  @media (max-width:560px){
    #SyrCD .scd-panel{ top:auto; bottom:0; right:0; left:0; width:100%; height:auto; max-height:92vh; border-left:0; border-top:var(--rule);
      border-top-left-radius:22px; border-top-right-radius:22px; box-shadow:0 -6px 0 rgba(57,34,15,.08);
      transform:translateY(102%); transition:transform .42s cubic-bezier(.32,1.2,.4,1); }
    #SyrCD.open .scd-panel{ transform:none; }
    #SyrCD .scd-grip{ display:block; position:relative; width:100%; padding:9px 0 4px; flex:0 0 auto; background:var(--surface); border-top-left-radius:22px; border-top-right-radius:22px; touch-action:none; cursor:grab; }
    #SyrCD .scd-grip::before{ content:""; display:block; width:44px; height:5px; border-radius:999px; background:var(--hair); margin:0 auto; }
    #SyrCD .scd-head{ padding:8px 16px 14px; }
    #SyrCD .scd-body{ padding:14px 16px 6px; gap:12px; }
    #SyrCD .scd-foot{ padding:13px 16px calc(16px + env(safe-area-inset-bottom)); }
    #SyrCD .d-sub .v{ font-size:22px; }
    #SyrCD .scd-checkout{ height:54px; }
  }
  @media (prefers-reduced-motion:reduce){ #SyrCD *{ animation-duration:.001ms !important; transition-duration:.001ms !important; } }
</style>

{%- capture icon_check -%}<svg viewBox="0 0 16 16" width="14" height="14" fill="none"><path d="M3 8.5l3.2 3.3L13 4.5" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>{%- endcapture -%}
