<div id="SyrCD" aria-hidden="true">
  <div class="scd-bd" data-syr-close></div>
  <aside class="scd-panel" role="dialog" aria-modal="true" aria-label="Your cart">
    <div id="SyrCD-content">
      <div class="scd-grip" data-syr-grip></div>
      <div class="scd-head">
        <span class="dh-ic">{% if cart == empty %}{{ icon_bag }}{% else %}{{ icon_check }}{% endif %}</span>
        <div class="dh-txt">
          <div class="dh-title">{% if cart == empty %}Your cart{% else %}Added to cart{% endif %}</div>
          <div class="dh-sub">{{ cart.item_count }} item{% unless cart.item_count == 1 %}s{% endunless %} · {{ payable | money }}</div>
        </div>
        <button class="scd-close" data-syr-close aria-label="Close">{{ icon_close }}</button>
      </div>

      {%- if cart == empty -%}
        <div class="scd-body">
          <div class="d-empty">
            <div class="g">{{ icon_bag }}</div>
            <h3>Your cart is empty</h3>
            <p>Add a flavor — your VIP price is waiting.</p>
            <a class="cta" href="{{ routes.all_products_collection_url }}" data-syr-close>Keep shopping {{ icon_arrow }}</a>
          </div>
        </div>
      {%- else -%}
        <div class="scd-body">
          {%- comment -%} free-ship progress {%- endcomment -%}
          <div class="d-ship">
            <div class="d-ship-top">
              {{ icon_truck }}
              {%- if remain > 0 -%}
                <span>You're <b>{{ remain | money }}</b> from <b>free shipping</b></span>
              {%- else -%}
                <span class="done">{{ icon_check }} You've unlocked free shipping</span>
              {%- endif -%}
            </div>
            <div class="d-ship-track"><div class="d-ship-fill" style="width:{{ pct }}%"></div></div>
          </div>

          {%- comment -%} VIP teaser / active {%- endcomment -%}
          {%- if is_vip -%}
            <div class="d-vip active">
              <div class="d-vip-row">
                <span class="seal">{{ icon_check }}</span>
                <div class="d-vip-copy">
                  <div class="h">VIP pricing is <span class="amt">active</span></div>
                  <div class="s">Your member discount is applied{% if member_saved > 0 %} — you're saving {{ member_saved | money }} on this cart{% endif %}.</div>
                </div>
              </div>
            </div>
          {%- elsif vip_savings > 0 -%}
            <div class="d-vip">
              <span class="grain"></span>
              <div class="d-vip-row">
                <span class="seal">{{ icon_diamondlg }}</span>
                <div class="d-vip-copy">
                  <div class="h">Save <span class="amt">{{ vip_savings | money }}</span> with VIP</div>
                  <div class="s">Members pay less on every bottle — free to join, applied to this cart instantly.</div>
                </div>
              </div>
              <a class="d-vip-cta" href="{{ routes.account_register_url }}">{{ icon_diamond }} Unlock VIP price — it's free</a>
            </div>
          {%- endif -%}

          {%- comment -%} line items {%- endcomment -%}
          <div class="d-lines">
            {%- for item in cart.items -%}
              <div class="d-line" data-line="{{ forloop.index }}">
                <div class="d-line-media">
                  {%- if item.image -%}<img src="{{ item.image | image_url: width: 160 }}" alt="{{ item.product.title | escape }}" loading="lazy">{%- endif -%}
                </div>
                <div class="d-line-body">
                  <a class="d-line-name" href="{{ item.url }}" style="text-decoration:none;color:inherit">{{ item.product.title | escape }}</a>
                  <div class="d-line-sub">
                    {%- if item.variant.title and item.variant.title != 'Default Title' -%}{{ item.variant.title | escape }}{%- else -%}{{ item.product.type | default: 'Syrup' }}{%- endif -%}
                  </div>
                  <div class="d-line-ctrls">
                    <div class="d-qty">
                      <button data-syr-qtm aria-label="Decrease"{% if item.quantity <= 1 %} disabled{% endif %}>−</button>
                      <span data-syr-q>{{ item.quantity }}</span>
                      <button data-syr-qtp aria-label="Increase">+</button>
                    </div>
                    <button class="d-line-rm" data-syr-remove aria-label="Remove">{{ icon_trash }}</button>
                  </div>
                </div>
                <div class="d-line-right">
                  <div class="d-line-price">
                    {%- if item.original_line_price > item.final_line_price -%}
                      <span class="was">{{ item.original_line_price | money }}</span>
                    {%- endif -%}
                    {{ item.final_line_price | money }}
                  </div>
                </div>
              </div>
            {%- endfor -%}
          </div>

          {%- comment -%} upsell from the cart-drawer collection setting {%- endcomment -%}
          {%- assign upcol_obj = collections[settings.cart_drawer_collection] -%}
          {%- if upcol_obj == empty or upcol_obj.products.size < 8 -%}{%- assign upcol_obj = collections['best-sellers'] -%}{%- endif -%}
          {%- if upcol_obj == empty or upcol_obj.products.size < 8 -%}{%- assign upcol_obj = collections['trending-flavors'] -%}{%- endif -%}
          {%- if upcol_obj == empty or upcol_obj.products.size < 8 -%}{%- assign upcol_obj = collections.all -%}{%- endif -%}
          {%- if upcol_obj.products.size > 0 -%}
            {%- assign cart_pids = '' -%}
            {%- for li in cart.items -%}{%- assign cart_pids = cart_pids | append: ',' | append: li.product_id | append: ',' -%}{%- endfor -%}
            {%- assign upcount = 0 -%}
            {%- capture upsell_html -%}
              {%- comment -%} Syrup pump always shown first {%- endcomment -%}
              {%- assign pumpp = all_products['syrup-pump'] -%}
              {%- if pumpp != empty and pumpp.available -%}{%- assign pneedle = ',' | append: pumpp.id | append: ',' -%}{%- unless cart_pids contains pneedle -%}{%- assign upcount = upcount | plus: 1 -%}<div class="up"><div class="up-media">{%- if pumpp.featured_image -%}<img src="{{ pumpp.featured_image | image_url: width: 200 }}" alt="{{ pumpp.title | escape }}" loading="lazy">{%- endif -%}</div><div class="up-body"><div class="up-name">{{ pumpp.title | escape | truncate: 28 }}</div><div class="up-foot"><span class="up-price">{{ pumpp.price | money }}</span><button class="up-add" data-syr-add="{{ pumpp.selected_or_first_available_variant.id }}" aria-label="Add {{ pumpp.title | escape }}">{{ icon_plus }}</button></div></div></div>{%- endunless -%}{%- endif -%}
              {%- for product in upcol_obj.products limit: 40 -%}
                {%- assign needle = ',' | append: product.id | append: ',' -%}
                {%- unless cart_pids contains needle -%}
                  {%- if product.available and upcount < 10 and product.handle != 'syrup-pump' -%}
                    {%- assign upcount = upcount | plus: 1 -%}
                    <div class="up">
                      <div class="up-media">{%- if product.featured_image -%}<img src="{{ product.featured_image | image_url: width: 200 }}" alt="{{ product.title | escape }}" loading="lazy">{%- endif -%}</div>
                      <div class="up-body">
                        <div class="up-name">{{ product.title | escape | truncate: 28 }}</div>
                        <div class="up-foot">
                          <span class="up-price">{{ product.price | money }}</span>
                          <button class="up-add" data-syr-add="{{ product.selected_or_first_available_variant.id }}" aria-label="Add {{ product.title | escape }}">{{ icon_plus }}</button>
                        </div>
                      </div>
                    </div>
                  {%- endif -%}
                {%- endunless -%}
              {%- endfor -%}
            {%- endcapture -%}
            {%- if upcount > 0 -%}
              <div class="d-upsell-h">
                <span class="t">Add a little more</span>
                <span class="s">{% if remain > 0 %}{{ remain | money }} to free ship{% else %}Pairs great{% endif %}</span>
              </div>
              <div class="d-upsell">{{ upsell_html }}</div>
            {%- endif -%}
          {%- endif -%}
        </div>

        {%- comment -%} sticky footer {%- endcomment -%}
        <div class="scd-foot">
          {%- if is_vip -%}
            {%- if member_saved > 0 -%}
              <div class="d-vsave applied"><span class="lft">{{ icon_check }} VIP saved</span><span>{{ member_saved | money }}</span></div>
            {%- endif -%}
          {%- elsif vip_savings > 0 -%}
            <a class="d-vsave tease" href="{{ routes.account_register_url }}"><span class="lft">{{ icon_diamond }} Join free &amp; save</span><span>−{{ vip_savings | money }}</span></a>
          {%- endif -%}
          {%- if cart.cart_level_discount_applications.size > 0 -%}
            {%- for discount in cart.cart_level_discount_applications -%}
              <div class="d-vsave applied"><span class="lft">{{ icon_check }} {{ discount.title }}</span><span>−{{ discount.total_allocated_amount | money }}</span></div>
            {%- endfor -%}
          {%- endif -%}
          <div class="d-sub">
            <span class="l">Subtotal{% if is_vip %} · VIP{% endif %}</span>
            <span class="v">{{ payable | money }}</span>
          </div>
          <button class="scd-checkout" data-syr-checkout>{{ icon_lock }} Checkout · {{ checkout_total | money }}</button>
          <button type="button" class="scd-continue" data-syr-close>{{ icon_arrow }} Continue shopping</button>
          <a class="scd-viewcart" href="{{ routes.cart_url }}">View full cart</a>
        </div>
      {%- endif -%}
    </div>
  </aside>
</div>

<script>
(function(){
  if (window.__syrCDInit) return; window.__syrCDInit = true;
  var origFetch = window.fetch ? window.fetch.bind(window) : null;
  var lastAdded = null;       // {title, image, quantity, final_line_price}
  function root(){ return document.getElementById('SyrCD'); }
  function content(){ return document.getElementById('SyrCD-content'); }
  function money(c){ try{ return (window.Shopify&&Shopify.currency? '': '') + '$' + (c/100).toFixed(2); }catch(e){ return '$'+(c/100).toFixed(2); } }

  function fitViewport(r){ try{ if(window.matchMedia('(max-width:560px)').matches){ var vw=(window.visualViewport&&window.visualViewport.width)||document.documentElement.clientWidth||window.innerWidth; r.style.width=Math.round(vw)+'px'; r.style.left='0'; r.style.right='auto'; } else { r.style.width=''; r.style.left=''; r.style.right=''; } }catch(e){} }
  function open(){ var r=root(); if(!r) return; r.setAttribute('aria-hidden','false'); document.body.style.overflow='hidden'; fitViewport(r); r.classList.add('open'); }
  function close(){ var r=root(); if(!r) return; r.classList.remove('open'); r.setAttribute('aria-hidden','true'); document.body.style.overflow=''; lastAdded=null; }

  function bumpBubble(){ var b=document.getElementById('cart-icon-bubble'); if(b){ b.style.transition='transform .2s'; b.style.transform='scale(1.25)'; setTimeout(function(){ b.style.transform=''; },220); } }

  function injectHero(){
    if(!lastAdded) return;
    var body = root() && root().querySelector('.scd-body'); if(!body) return;
    if(body.querySelector('.added')) return;
    var img = lastAdded.image ? '<div class="added-media"><span class="added-check"><svg viewBox="0 0 16 16" width="14" height="14" fill="none"><path d="M3 8.5l3.2 3.3L13 4.5" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg></span><img src="'+lastAdded.image+'" alt=""></div>' : '';
    var html = '<div class="added">'+img+'<div class="added-txt"><div class="lbl"><svg viewBox="0 0 16 16" width="12" height="12" fill="none"><path d="M3 8.5l3.2 3.3L13 4.5" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"/></svg> Just added</div><div class="nm">'+(lastAdded.title||'')+'</div><div class="mt">Qty '+(lastAdded.quantity||1)+' · '+money(lastAdded.final_line_price||lastAdded.line_price||0)+'</div></div></div>';
    body.insertAdjacentHTML('afterbegin', html);
  }

  function refresh(){
    if(!origFetch) return Promise.resolve();
    return origFetch(window.Shopify && Shopify.routes && Shopify.routes.root ? Shopify.routes.root+'?sections=cart-drawer,cart-icon-bubble' : '/?sections=cart-drawer,cart-icon-bubble')
      .then(function(r){ return r.json(); })
      .then(function(j){
        if(j['cart-drawer']){
          var doc=new DOMParser().parseFromString(j['cart-drawer'],'text/html');
          var nc=doc.getElementById('SyrCD-content'); var cur=content();
          if(nc && cur){ cur.innerHTML = nc.innerHTML; }
        }
        if(j['cart-icon-bubble']){
          var b=document.getElementById('cart-icon-bubble');
          var nb=new DOMParser().parseFromString(j['cart-icon-bubble'],'text/html').getElementById('cart-icon-bubble');
          if(b && nb) b.innerHTML = nb.innerHTML;
        }
      }).catch(function(){});
  }

  function addVariant(id, qty){
    if(!origFetch) return Promise.reject();
    return origFetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json','Accept':'application/json'},body:JSON.stringify({items:[{id:id,quantity:qty||1}]})})
      .then(function(r){ return r.json(); });
  }
  function changeLine(line, qty){
    if(!origFetch) return Promise.reject();
    return origFetch('/cart/change.js',{method:'POST',headers:{'Content-Type':'application/json','Accept':'application/json'},body:JSON.stringify({line:line,quantity:qty})})
      .then(function(r){ return r.json(); });
  }

  function afterAdd(item){
    var it = (item && item.items && item.items.length) ? item.items[item.items.length-1] : item;
    if(it && (it.title || it.product_title)){
      lastAdded = { title:(it.product_title||it.title), image:it.image||it.featured_image||(it.featured_image&&it.featured_image.url), quantity:it.quantity, final_line_price:it.final_line_price, line_price:it.line_price };
    }
    /* let other scripts (e.g. pd-qty-wire quantity discounts) react to the add */
    try{ document.dispatchEvent(new CustomEvent('syr:cart:added',{detail:{item:it,quantity:(it&&it.quantity)||1}})); }catch(e){}
    return refresh().then(function(){ injectHero(); open(); bumpBubble(); });
  }

  /* ---- delegated clicks ---- */
  document.addEventListener('click', function(e){
    var r = root();
    // open from header cart icon
    var icon = e.target.closest('#cart-icon-bubble');
    var iconLink = e.target.closest('.header__icon--cart, a#cart-icon-bubble');
    if(icon || iconLink){
      var insideDrawer = r && r.contains(e.target);
      if(!insideDrawer){ e.preventDefault(); lastAdded=null; refresh().then(open); return; }
    }
    if(!r) return;
    if(e.target.closest('[data-syr-close]')){ e.preventDefault(); close(); return; }
    if(e.target.closest('[data-syr-checkout]')){ e.preventDefault(); window.location.href='/checkout'; return; }
    var addBtn = e.target.closest('[data-syr-add]');
    if(addBtn){ e.preventDefault(); var vid=addBtn.getAttribute('data-syr-add'); addBtn.disabled=true; addVariant(vid,1).then(function(it){ lastAdded=null; return refresh(); }).then(open).then(function(){ bumpBubble(); }).catch(function(){ addBtn.disabled=false; }); return; }
    var line = e.target.closest('.d-line');
    if(line){
      var idx = parseInt(line.getAttribute('data-line'),10);
      var qEl = line.querySelector('[data-syr-q]'); var q = qEl?parseInt(qEl.textContent,10):1;
      if(e.target.closest('[data-syr-qtp]')){ e.preventDefault(); changeLine(idx, q+1).then(function(){ lastAdded=null; return refresh(); }); return; }
      if(e.target.closest('[data-syr-qtm]')){ e.preventDefault(); if(q>1){ changeLine(idx, q-1).then(function(){ lastAdded=null; return refresh(); }); } return; }
      if(e.target.closest('[data-syr-remove]')){ e.preventDefault(); line.style.opacity='.4'; changeLine(idx, 0).then(function(){ lastAdded=null; return refresh(); }); return; }
    }
  }, false);

  /* ---- esc to close ---- */
  document.addEventListener('keydown', function(e){ if(e.key==='Escape'){ var r=root(); if(r&&r.classList.contains('open')) close(); } });

  /* ---- drag to dismiss (mobile bottom sheet) ---- */
  var drag={y:0,dy:0,active:false};
  function sheet(){ return root() && root().querySelector('.scd-panel'); }
  document.addEventListener('touchstart', function(e){ var g=e.target.closest('[data-syr-grip]'); if(!g) return; drag={y:e.touches[0].clientY,dy:0,active:true}; var s=sheet(); if(s) s.style.transition='none'; }, {passive:true});
  document.addEventListener('touchmove', function(e){ if(!drag.active) return; var dy=Math.max(0,e.touches[0].clientY-drag.y); drag.dy=dy; var s=sheet(); if(s) s.style.transform='translateY('+dy+'px)'; }, {passive:true});
  document.addEventListener('touchend', function(){ if(!drag.active) return; var s=sheet(); var dy=drag.dy; drag.active=false; if(s){ s.style.transition=''; s.style.transform=''; } if(dy>110) close(); });

  /* ---- intercept ADD-TO-CART form submits (e.g. product pages) so they open the drawer instead of navigating ---- */
  document.addEventListener('submit', function(e){
    var form=e.target;
    if(!form || !form.action || !/\/cart\/add(\.js)?(\?|#|$)/.test(form.action)) return;
    e.preventDefault(); e.stopImmediatePropagation();
    var fd=new FormData(form);
    var btn=form.querySelector('[type=submit], button[name=add]'); if(btn){ btn.setAttribute('aria-busy','true'); btn.classList.add('loading'); }
    origFetch('/cart/add.js',{method:'POST',headers:{'Accept':'application/json'},body:fd})
      .then(function(r){ if(!r.ok) throw new Error('add failed'); return r.json(); })
      .then(function(item){ return afterAdd(item); })
      .catch(function(){ form.submit(); })
      .then(function(){ if(btn){ btn.removeAttribute('aria-busy'); btn.classList.remove('loading'); } });
  }, true);

  /* ---- intercept JS-based adds (other scripts calling fetch('/cart/add')) ---- */
  if(window.fetch){
    var wrapped = window.fetch;
    window.fetch = function(){
      var args=arguments;
      var url = (args[0] && args[0].url) ? args[0].url : args[0];
      var isAdd = (typeof url==='string') && /\/cart\/add(\.js)?(\?|#|$)/.test(url);
      var p = wrapped.apply(this, args);
      if(isAdd){
        p.then(function(res){ try{ res.clone().json().then(function(item){ afterAdd(item); }); }catch(e){ refresh().then(open); } }).catch(function(){});
      }
      return p;
    };
  }

  /* expose a small API so other scripts can refresh / open the drawer after mutating the cart */
  window.SyrCD = { open:open, close:close, refresh:refresh };
})();
</script>
