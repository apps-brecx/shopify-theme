<script>
(function(){
  function init(){
    var configs = [
      {section: document.querySelector('.pd-description'), prop: '--desc-s', selector: '.pd-desc-head .pd-eyebrow'},
      {section: document.querySelector('.pd-why'), prop: '--why-s'},
      {section: document.getElementById('pdReels'), prop: '--reels-s'},
      {section: document.querySelector('.pd-recipes-v2'), prop: '--recipes-s', selector: '.pd-rv2-head .pd-eyebrow'}
    ];
    var items = [];
    configs.forEach(function(c){
      if (!c.section) return;
      var badge = c.section.querySelector(c.selector || '.pd-eyebrow');
      if (!badge) return;
      items.push({section: c.section, badge: badge, prop: c.prop});
    });
    if (!items.length) return;
    var minScale = 0.85;
    var maxScale = 1.45;
    var raf = null;
    function update(){
      raf = null;
      var vh = window.innerHeight || document.documentElement.clientHeight;
      var start = vh;
      var end = vh * 0.20;
      var denom = (start - end) || 1;
      items.forEach(function(item){
        var r = item.section.getBoundingClientRect();
        var p = (start - r.top) / denom;
        if (p < 0) p = 0;
        if (p > 1) p = 1;
        var ease = p * p * (3 - 2 * p);
        var scale = minScale + (maxScale - minScale) * ease;
        item.badge.style.setProperty(item.prop, scale.toFixed(3));
      });
    }
    function onScroll(){if (raf) return; raf = requestAnimationFrame(update);}
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    update();
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>
