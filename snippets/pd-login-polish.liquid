{%- comment -%} Login polish v6 — full brand styling + social login click rewire. {%- endcomment -%}
{%- if template contains 'customers' or request.page_type == 'customers/login' or request.page_type == 'customers/register' or request.path contains '/account' -%}
{%- render 'pd-social-login-fix' -%}
<style id="pd-login-polish-css">
/* ============================================================
   VARIABLE SWAP — kill the coral/red at the CSS-variable source
   ============================================================ */
html body .sauth,
html body .sauth *{
  --vip:#5BA3D0 !important; --vip-soft:#DBEEF5 !important; --vip-ink:#2F7BB0 !important; --vip-deep:#2F7BB0 !important;
  --coral:#5BA3D0 !important; --red:#5BA3D0 !important;
  --ink:#39220f !important; --paper:#FFFBF4 !important; --copper:#c58548 !important;
  --butter:#FCE2A0 !important; --peach:#FFD4B8 !important; --sky:#B8DCEB !important;
  --blue:#5BA3D0 !important; --deep-blue:#2F7BB0 !important;
  --muted:rgba(57,34,15,.55) !important; --hair:rgba(57,34,15,.18) !important;
}

/* FONT BASELINE */
html body .sauth, html body .sauth p, html body .sauth span, html body .sauth a,
html body .sauth input, html body .sauth label,
html body .sauth .auth-foot, html body .sauth .auth-fine{
  font-family:'Josefin Sans','Josefin',sans-serif !important;
}
html body .sauth h1, html body .sauth h2, html body .sauth h3,
html body .sauth [class*="title"], html body .sauth .auth-tab,
html body .sauth .auth-submit, html body .sauth button[type="submit"],
html body .sauth .btn-ink, html body .sauth .btn-vip, html body .sauth .btn-ghost,
html body .sauth .auth-or, html body .sauth .auth-aside-brand,
html body .sauth .aside-stat .big, html body .sauth .perk-row b{
  font-family:'Archivo Black','Archivo',sans-serif !important; font-weight:400 !important;
}

/* ============================================================
   CARD CONTAINER — mobile centering
   ============================================================ */
html body .sauth{ width:100% !important; max-width:100% !important; overflow-x:clip !important; }
html body .sauth .auth-stage{ width:100% !important; max-width:100% !important; }
html body .sauth .auth-formwrap{
  background:#FFFBF4 !important; background-image:none !important;
  padding:48px 32px !important; width:100% !important; max-width:100% !important;
  box-sizing:border-box !important;
  display:flex !important; align-items:center !important; justify-content:center !important;
}
html body .sauth .auth-card{
  background:#FFFFFF !important; background-image:none !important;
  border:2px solid #39220f !important; border-radius:20px !important;
  box-shadow:5px 5px 0 #39220f !important;
  padding:32px 30px 28px !important; max-width:460px !important; width:100% !important;
  margin-left:auto !important; margin-right:auto !important; box-sizing:border-box !important;
}
@media (max-width:680px){
  html body .sauth .auth-formwrap{ padding:24px 16px 28px !important; }
  html body .sauth .auth-card{ padding:24px 20px !important; box-shadow:4px 4px 0 #39220f !important; margin:0 auto !important; }
}
@media (max-width:420px){
  html body .sauth .auth-formwrap{ padding:18px 12px 24px !important; }
  html body .sauth .auth-card{ padding:22px 16px !important; }
}

/* ============================================================
   TAB TOGGLE
   ============================================================ */
html body .sauth .auth-view, html body .sauth .auth-view.show{ text-align:center !important; }
html body .sauth .auth-tabs{
  background:#FFFBF4 !important; border:1.5px solid #39220f !important;
  border-radius:999px !important; padding:5px !important;
  position:relative !important; overflow:hidden !important;
  display:inline-flex !important; align-items:stretch !important;
  gap:0 !important; margin:0 auto 22px !important;
  box-shadow:3px 3px 0 #39220f !important; vertical-align:middle !important;
}
html body .sauth .auth-tab{
  font-family:'Archivo Black','Archivo',sans-serif !important; font-weight:400 !important;
  letter-spacing:.14em !important; text-transform:uppercase !important; font-size:12.5px !important;
  padding:0 32px !important; min-width:130px !important; height:42px !important;
  border:0 !important; background:transparent !important;
  color:#39220f !important; border-radius:999px !important;
  position:relative !important; z-index:2 !important; cursor:pointer !important;
  display:inline-flex !important; align-items:center !important; justify-content:center !important;
  text-align:center !important; white-space:nowrap !important; box-sizing:border-box !important;
  line-height:1 !important; transition:color .2s ease !important;
  outline:none !important; -webkit-tap-highlight-color:transparent !important;
  vertical-align:middle !important;
}
html body .sauth .auth-tab.on, html body .sauth .auth-tab.on.vip{ color:#39220f !important; }
html body .sauth .auth-tab:not(.on):hover{ color:#c58548 !important; }
html body .sauth .auth-tabglide{
  background:#FCE2A0 !important; border:1.5px solid #39220f !important;
  border-radius:999px !important; z-index:1 !important;
  top:5px !important; bottom:5px !important; height:auto !important; box-shadow:none !important;
  transition:transform .25s cubic-bezier(.5,1.5,.5,1), width .25s ease, left .25s ease !important;
}
html body .sauth .auth-tabglide.r{ background:#FCE2A0 !important; box-shadow:none !important; }

/* HEADINGS */
html body .sauth .auth-head{ margin-bottom:20px !important; text-align:center !important; }
html body .sauth .auth-head h1, html body .sauth .auth-card h1, html body .sauth .auth-card h2{
  font-family:'Archivo Black','Archivo',sans-serif !important; font-weight:400 !important;
  font-size:28px !important; line-height:1.02 !important;
  letter-spacing:-.005em !important; text-transform:uppercase !important;
  color:#39220f !important; text-align:center !important; margin:0 !important;
}
html body .sauth .auth-head h1 em, html body .sauth .auth-card h1 em, html body .sauth .auth-card h2 em{
  font-family:'Josefin Sans',sans-serif !important; font-style:italic !important;
  font-weight:300 !important; color:#c58548 !important; text-transform:none !important;
}
html body .sauth .auth-head p{
  font-family:'Josefin Sans',sans-serif !important; font-size:14.5px !important; line-height:1.5 !important;
  color:rgba(57,34,15,.7) !important; text-align:center !important; margin:8px auto 0 !important; max-width:34ch !important;
}
html body .sauth .auth-head p b{ color:#2F7BB0 !important; font-weight:700 !important; }

/* FIELDS / INPUTS / PLACEHOLDERS */
html body .sauth .field{ margin-bottom:14px !important; text-align:left !important; }
html body .sauth .auth-card label, html body .sauth .field label{
