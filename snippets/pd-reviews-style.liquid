html body .pd .pd-rvw-pager-btn:hover:not(:disabled){background:#FCE2A0!important;transform:translate(-1px,-1px)!important;box-shadow:2px 2px 0 #1a1a1a!important}
html body .pd .pd-rvw-pager-btn:disabled{opacity:.35!important;cursor:not-allowed!important}
html body .pd .pd-rvw-pager-pages{display:inline-flex!important;align-items:center!important;gap:6px!important;flex-wrap:wrap!important;justify-content:center!important}
html body .pd .pd-rvw-pager-page{display:inline-flex!important;align-items:center!important;justify-content:center!important;min-width:42px!important;height:42px!important;padding:0 12px!important;background:#FFFFFF!important;border:1.5px solid #1a1a1a!important;border-radius:999px!important;font-family:'Archivo Black','Archivo',sans-serif!important;font-weight:400!important;font-size:13px!important;color:#1a1a1a!important;text-decoration:none!important;cursor:pointer!important;transition:transform .15s ease, background .15s ease, box-shadow .15s ease!important}
html body .pd .pd-rvw-pager-page:hover{background:#FCE2A0!important;transform:translate(-1px,-1px)!important;box-shadow:2px 2px 0 #1a1a1a!important;color:#1a1a1a!important}
html body .pd .pd-rvw-pager-page.is-current{background:#FF6B5C!important;color:#FFFBF4!important;border-color:#1a1a1a!important;box-shadow:2px 2px 0 #1a1a1a!important;cursor:default!important}
html body .pd .pd-rvw-pager-page.is-current:hover{transform:none!important;background:#FF6B5C!important;color:#FFFBF4!important}
html body .pd .pd-rvw-pager-dots{font-family:'Archivo Black','Archivo',sans-serif!important;color:#3a3a3a!important;padding:0 4px!important;font-size:14px!important;line-height:1!important}
@media (max-width:760px){
  html body .pd .pd-rvw-pager-btn,html body .pd .pd-rvw-pager-page{width:38px!important;height:38px!important;font-size:12px!important;min-width:38px!important}
  html body .pd .pd-rvw-toolbar{justify-content:center!important;margin-bottom:16px!important}
