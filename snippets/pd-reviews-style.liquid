<script>
(function(){
  var MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  var PER_PAGE = 5;
  var section, listEl, histEl, pagerEl, prevBtn, nextBtn, pagesEl, sortEl;
  var reviews = [];
  var filtered = [];
  var activeFilter = null;
  var currentPage = 1;
  var sortVal = 'date|desc';

  /* ===== Stars SVG ===== */
  function starSvg(filled, size){
    var s = size || 14;
    if (filled){
      return '<svg viewBox="0 0 24 24" width="' + s + '" height="' + s + '" fill="#FF6B5C" stroke="#FF6B5C" stroke-width="1" stroke-linejoin="round" aria-hidden="true"><path d="M12 2 L14.6 8.4 L21.5 9 L16.3 13.6 L17.9 20.4 L12 16.9 L6.1 20.4 L7.7 13.6 L2.5 9 L9.4 8.4 Z"/></svg>';
    }
    return '<svg viewBox="0 0 24 24" width="' + s + '" height="' + s + '" fill="none" stroke="#1a1a1a" stroke-width="1.5" stroke-linejoin="round" opacity=".22" aria-hidden="true"><path d="M12 2 L14.6 8.4 L21.5 9 L16.3 13.6 L17.9 20.4 L12 16.9 L6.1 20.4 L7.7 13.6 L2.5 9 L9.4 8.4 Z"/></svg>';
  }

  function starsHTML(score, size){
    var html = '';
    for (var i = 1; i <= 5; i++) html += starSvg(i <= score, size);
    return html;
  }

  function formatDate(iso){
    if (!iso) return '';
    var d = new Date(iso);
    if (isNaN(d.getTime())) return iso;
    return MONTHS[d.getMonth()] + ' ' + d.getDate() + ', ' + d.getFullYear();
  }

  function escapeHtml(s){
    if (s == null) return '';
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  /* ===== Render histogram ===== */
  function renderHistogram(){
    if (!histEl) return;
    var counts = [0, 0, 0, 0, 0, 0]; /* index 0 unused, 1–5 are ratings */
    for (var i = 0; i < reviews.length; i++){
      var r = parseInt(reviews[i].r, 10);
      if (r >= 1 && r <= 5) counts[r]++;
    }
    var total = reviews.length;
    var html = '';
    for (var s = 5; s >= 1; s--){
      var cnt = counts[s];
      var pct = total > 0 ? Math.round((cnt / total) * 100) : 0;
      var isActive = activeFilter === s;
      html += '<div class="pd-rvw-hist-row' + (isActive ? ' is-active' : '') + '" role="button" tabindex="0" data-rating="' + s + '" data-frequency="' + cnt + '" aria-pressed="' + (isActive ? 'true' : 'false') + '">' +
              '<span class="pd-rvw-hist-stars">' + starsHTML(s, 13) + '</span>' +
              '<div class="pd-rvw-hist-bar"><div class="pd-rvw-hist-bar-fill" style="width:' + pct + '%"></div></div>' +
              '<span class="pd-rvw-hist-pct">' + pct + '%</span>' +
              '<span class="pd-rvw-hist-cnt">(' + cnt + ')</span>' +
              '</div>';
    }
    histEl.innerHTML = html;
    var rows = histEl.querySelectorAll('.pd-rvw-hist-row');
    rows.forEach(function(row){
      var rating = parseInt(row.getAttribute('data-rating'), 10);
      var freq = parseInt(row.getAttribute('data-frequency'), 10);
      row.addEventListener('click', function(){ toggleFilter(rating, freq); });
      row.addEventListener('keydown', function(e){
        if (e.key === 'Enter' || e.key === ' '){
          e.preventDefault();
          toggleFilter(rating, freq);
        }
      });
    });
  }

  /* ===== Filter banner ===== */
  function clearFilterBanner(){
    var b = section.querySelector('.pd-rvw-filter-banner');
    if (b) b.remove();
  }

  function showFilterBanner(rating, total){
    clearFilterBanner();
    var label = total === 1 ? 'review' : 'reviews';
    var banner = document.createElement('div');
    banner.className = 'pd-rvw-filter-banner';
    banner.innerHTML =
      '<span class="pd-rvw-filter-banner-text">Showing ' + total + ' ' + rating + '★ ' + label + '</span>' +
      '<button type="button" class="pd-rvw-filter-clear">' +
        '<svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 L6 18 M6 6 L18 18"/></svg>' +
        'Clear filter' +
      '</button>';
    histEl.parentNode.insertBefore(banner, histEl.nextSibling);
    banner.querySelector('.pd-rvw-filter-clear').addEventListener('click', function(){ clearFilter(); });
  }

  function clearFilter(){
    activeFilter = null;
    currentPage = 1;
    clearFilterBanner();
    rebuildFiltered();
    renderHistogram();
    renderList();
    renderPager();
  }

  function toggleFilter(rating, totalForRating){
    if (activeFilter === rating){ clearFilter(); return; }
    activeFilter = rating;
    currentPage = 1;
    rebuildFiltered();
    renderHistogram();
    showFilterBanner(rating, totalForRating);
    renderList();
    renderPager();
  }

  /* ===== Sort + filter ===== */
  function rebuildFiltered(){
    var arr = reviews.slice();
    if (activeFilter){
      arr = arr.filter(function(rev){ return parseInt(rev.r, 10) === activeFilter; });
    }
    var parts = sortVal.split('|');
    var field = parts[0];
    var dir = parts[1];
    arr.sort(function(a, b){
      var av, bv;
      if (field === 'date'){
        av = new Date(a.d).getTime() || 0;
        bv = new Date(b.d).getTime() || 0;
      } else if (field === 'rating'){
        av = parseInt(a.r, 10);
        bv = parseInt(b.r, 10);
        if (av === bv){
          /* tiebreaker: newest first */
          var ad = new Date(a.d).getTime() || 0;
          var bd = new Date(b.d).getTime() || 0;
          return bd - ad;
        }
      } else { av = 0; bv = 0; }
      return dir === 'desc' ? bv - av : av - bv;
    });
    filtered = arr;
  }

  /* ===== Render list ===== */
  function renderList(){
    if (!listEl) return;
    var total = filtered.length;
    if (total === 0){
      listEl.innerHTML =
        '<div class="pd-rvw-empty">' +
          '<p class="pd-rvw-empty-title">No reviews found</p>' +
          '<p class="pd-rvw-empty-sub">Try a different filter.</p>' +
        '</div>';
      return;
    }
    var start = (currentPage - 1) * PER_PAGE;
    var end = Math.min(start + PER_PAGE, total);
    var html = '';
    for (var i = start; i < end; i++){
      var rev = filtered[i];
      var initial = (rev.n || 'A').trim().charAt(0).toUpperCase();
      html +=
        '<article class="pd-rvw-card">' +
          '<div class="pd-rvw-card-head">' +
            '<div class="pd-rvw-icon">' + escapeHtml(initial) + '</div>' +
            '<span class="pd-rvw-stars">' + starsHTML(rev.r, 16) + '</span>' +
            '<span class="pd-rvw-meta">' +
              '<span class="pd-rvw-author">' + escapeHtml(rev.n || 'Anonymous') + '</span>' +
              '<span class="pd-rvw-date">' + formatDate(rev.d) + '</span>' +
            '</span>' +
            '<span class="pd-rvw-verified">✓ Verified</span>' +
          '</div>' +
          (rev.t ? '<h3 class="pd-rvw-title">' + escapeHtml(rev.t) + '</h3>' : '') +
          '<p class="pd-rvw-body">' + escapeHtml(rev.b || '') + '</p>' +
        '</article>';
    }
    listEl.innerHTML = html;
  }

  /* ===== Pager ===== */
  function renderPager(){
    if (!pagerEl) return;
    var totalPages = Math.max(1, Math.ceil(filtered.length / PER_PAGE));
    if (totalPages <= 1){
      pagerEl.style.display = 'none';
      return;
    }
    pagerEl.style.display = '';
    pagesEl.innerHTML = '';
    var pages = [];
    var add = function(p){ if (pages.indexOf(p) === -1 && p >= 1 && p <= totalPages) pages.push(p); };
    add(1);
    add(currentPage - 1);
    add(currentPage);
    add(currentPage + 1);
    add(totalPages);
    pages.sort(function(a,b){return a - b;});
    var last = 0;
    pages.forEach(function(p){
      if (last && p - last > 1){
        var dots = document.createElement('span');
        dots.className = 'pd-rvw-pager-dots';
        dots.textContent = '…';
        pagesEl.appendChild(dots);
      }
      var el = document.createElement('button');
      el.type = 'button';
      el.className = 'pd-rvw-pager-page' + (p === currentPage ? ' is-current' : '');
      el.textContent = p;
      if (p !== currentPage){
        el.addEventListener('click', function(){ goToPage(p); });
      }
      pagesEl.appendChild(el);
      last = p;
    });
    prevBtn.disabled = currentPage <= 1;
    nextBtn.disabled = currentPage >= totalPages;
  }

  function goToPage(p){
    currentPage = p;
    renderList();
    renderPager();
    /* scroll the list into view */
    var listTop = listEl.getBoundingClientRect().top + window.scrollY - 80;
    window.scrollTo({top: listTop, behavior: 'smooth'});
  }

  function wirePager(){
    prevBtn.addEventListener('click', function(){ if (currentPage > 1) goToPage(currentPage - 1); });
    nextBtn.addEventListener('click', function(){
      var totalPages = Math.max(1, Math.ceil(filtered.length / PER_PAGE));
      if (currentPage < totalPages) goToPage(currentPage + 1);
    });
  }

  function wireSort(){
    sortEl.addEventListener('change', function(){
      sortVal = sortEl.value;
      currentPage = 1;
      rebuildFiltered();
      renderList();
      renderPager();
    });
  }

  /* ===== Scroll-grow eyebrow ===== */
  function wireEyebrow(){
    var badge = section.querySelector('.pd-rvw-head .pd-eyebrow');
    if (!badge) return;
    var minScale = 0.85;
    var maxScale = 1.45;
    var raf = null;
    function update(){
      raf = null;
      var vh = window.innerHeight || document.documentElement.clientHeight;
      var start = vh;
      var end = vh * 0.20;
      var denom = (start - end) || 1;
      var r = section.getBoundingClientRect();
      var p = (start - r.top) / denom;
      if (p < 0) p = 0;
      if (p > 1) p = 1;
      var ease = p * p * (3 - 2 * p);
      var scale = minScale + (maxScale - minScale) * ease;
      badge.style.setProperty('--reviews-s', scale.toFixed(3));
    }
    function onScroll(){if (raf) return; raf = requestAnimationFrame(update);}
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    update();
  }

  function init(){
    section = document.querySelector('.pd-reviews-v2');
    if (!section) return;
    listEl  = section.querySelector('#pdRvwList');
    histEl  = section.querySelector('#pdRvwHistogram');
    pagerEl = section.querySelector('#pdRvwPager');
    prevBtn = section.querySelector('#pdRvwPrev');
    nextBtn = section.querySelector('#pdRvwNext');
    pagesEl = section.querySelector('#pdRvwPages');
    sortEl  = section.querySelector('#pdRvwSort');

    var dataEl = section.querySelector('#pdRvwData');
    if (!dataEl){ wireEyebrow(); return; }
    try {
      reviews = JSON.parse(dataEl.textContent.trim());
    } catch(e){
      console.error('Reviews parse error', e);
      reviews = [];
    }

    rebuildFiltered();
    renderHistogram();
    renderList();
    renderPager();
    wireSort();
    wirePager();
    wireEyebrow();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>
