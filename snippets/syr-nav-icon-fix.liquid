<script>
(function(){
  var CLOSE_SVG = '<svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true"><circle cx="16" cy="16" r="13.5"/><path d="M11 11l10 10M21 11l-10 10"/></svg>';

  function init(){
    var drawer = document.querySelector('.syrnav-drawer');
    var hambs  = document.querySelectorAll('.syrnav-hamb');
    if (!drawer || !hambs.length) return;

    drawer.querySelectorAll('.syrnav-dwr-head').forEach(function(n){ n.remove(); });

    var closeBtn = document.querySelector('.syr-drawer-close');
    if (!closeBtn){
      closeBtn = document.createElement('button');
      closeBtn.type = 'button';
      closeBtn.className = 'syr-drawer-close';
      closeBtn.setAttribute('aria-label', 'Close menu');
      closeBtn.innerHTML = CLOSE_SVG;
      document.body.appendChild(closeBtn);
      closeBtn.addEventListener('click', function(e){ e.preventDefault(); e.stopPropagation(); closeDrawer(); });
    }

    function closeDrawer(){
      drawer.classList.remove('open');
      document.body.classList.remove('open-drawer');
      document.body.classList.remove('pd-menu-open');
      var scrim = document.querySelector('.syrnav-scrim');
      if (scrim) scrim.classList.remove('open');
      document.documentElement.style.overflow = '';
      document.body.style.overflow = '';
      sync();
    }

    function sync(){
      var isOpen = drawer.classList.contains('open');
      hambs.forEach(function(h){ if (isOpen) h.classList.add('is-open'); else h.classList.remove('is-open'); });
      if (isOpen) document.body.classList.add('open-drawer');
      else document.body.classList.remove('open-drawer');
      if (closeBtn){
        if (isOpen) closeBtn.classList.add('is-visible');
        else closeBtn.classList.remove('is-visible');
      }
    }

    try {
      var mo = new MutationObserver(function(){
        drawer.querySelectorAll('.syrnav-dwr-head').forEach(function(n){ n.remove(); });
        sync();
      });
      mo.observe(drawer, { attributes:true, attributeFilter:['class'], childList:true, subtree:true });
    } catch(e){}
    sync();

    hambs.forEach(function(h){
      h.addEventListener('click', function(e){
        if (drawer.classList.contains('open')){
          e.stopImmediatePropagation();
          e.preventDefault();
          closeDrawer();
        }
      }, true);
    });

    document.addEventListener('keydown', function(e){ if (e.key === 'Escape' && drawer.classList.contains('open')) closeDrawer(); });
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>

