{%- comment -%} === CRITICAL FOUC PREVENT — inject CSS into <head> immediately so the new collection design is set up before the section paints {%- endcomment -%}
<script>
(function(){
  if (document.getElementById('syr-fouc-prevent')) return;
  var s = document.createElement('style');
  s.id = 'syr-fouc-prevent';
  s.textContent = '\n'+
    'html body .scol .floater,html body .scol .hero-stage,html body .scol .hero-stage > *,html body .scol [class*="floater"],html body .floater,html body .hero-stage{display:none!important;visibility:hidden!important;opacity:0!important;width:0!important;height:0!important;pointer-events:none!important}'+
    'html body .scol .read-more,html body .scol .lede-clip,html body .scol [data-readmore],html body .scol .hero .read-more,html body .scol .hero a.read-more{display:none!important}'+
    'html body .scol .hero,html body .scol section.hero,html body .scol section.hero.hero-float,html body .scol .hero.hero-float,html body section.hero.hero-float,html body .hero.hero-float{background-image:none!important;background:rgb(255,251,244)!important}'+
    'html body .scol .lede,html body .scol .hero .lede,html body .scol .hero p{-webkit-line-clamp:none!important;max-height:none!important;display:block!important;overflow:visible!important}';
  (document.head || document.documentElement).appendChild(s);
})();
</script>

