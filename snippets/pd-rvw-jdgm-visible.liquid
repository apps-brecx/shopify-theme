html body .pd .pd-rvw-jdgm-sort select{appearance:none!important;-webkit-appearance:none!important;-moz-appearance:none!important;background:none!important;border:0!important;font-family:'Archivo Black','Archivo',sans-serif!important;font-weight:400!important;font-size:11.5px!important;letter-spacing:.08em!important;text-transform:uppercase!important;color:#39220f!important;cursor:pointer!important;padding:0!important;margin:0!important;line-height:1!important;outline:none!important;min-width:120px!important}
html body .pd .pd-rvw-jdgm-sort-chev{position:absolute!important;right:14px!important;top:50%!important;transform:translateY(-50%)!important;pointer-events:none!important;color:#39220f!important}

/* LOADING / EMPTY STATES */
html body .pd .pd-rvw-jdgm-loading{font-family:'Josefin Sans','Josefin',sans-serif!important;font-size:14px!important;color:#3a3a3a!important;text-align:center!important;padding:40px 20px!important;font-style:italic!important;font-weight:500!important}
html body .pd .pd-rvw-jdgm-empty{font-family:'Josefin Sans','Josefin',sans-serif!important;font-size:14px!important;color:#3a3a3a!important;text-align:center!important;padding:32px 20px!important;background:#FFF8EE!important;border:2px dashed rgba(57,34,15,.25)!important;border-radius:18px!important;font-weight:500!important}

@media (max-width:760px){
  html body .pd .pd-rvw-jdgm-content .jdgm-rev{padding:20px 22px!important;border-radius:18px!important;box-shadow:4px 4px 0 #39220f!important}
  html body .pd .pd-rvw-jdgm-content .jdgm-rev__title{font-size:15px!important}
  html body .pd .pd-rvw-jdgm-content .jdgm-rev__body{font-size:14px!important;line-height:1.55!important}
  html body .pd .pd-rvw-jdgm-content .jdgm-rev__icon{width:38px!important;height:38px!important;font-size:15px!important}
  html body .pd .pd-rvw-jdgm-content .jdgm-rev__author{font-size:13px!important}
  html body .pd .pd-rvw-jdgm-content .jdgm-histogram{margin-left:0!important;margin-right:0!important;padding:18px!important}
  html body .pd .pd-rvw-jdgm-content .jdgm-paginate__page{width:38px!important;height:38px!important;font-size:12px!important;min-width:38px!important}
  html body .pd .pd-rvw-jdgm-content .pd-rvw-filter-banner{margin:14px 0!important;padding:12px 16px!important}
  html body .pd .pd-rvw-jdgm-content .pd-rvw-filter-banner-text{font-size:11px!important}
  html body .pd .pd-rvw-jdgm-toolbar{margin:14px 0 10px!important;justify-content:center!important}
}
</style>

<script>
(function(){
  var SHOP = '1afd15-57.myshopify.com';
  var MAX_FILTER_PAGES = 8;
  var FILTER_PER_PAGE = 30;
  var PAGINATE_PER_PAGE = 5;
  var activeFilter = null;
  var bannerEl = null;
  var originalHTML = null;
  var productId = null;
  var contentEl = null;
  var reviewsListEl = null;
  var paginateEl = null;
  var lastPage = 1;
  var ratingCache = {};
  var paginateCache = {};

  function clearBanner(){ if (bannerEl){ bannerEl.remove(); bannerEl = null; } }

  function showBanner(rating, count, histEl){
    clearBanner();
    var label = (count === 1 ? 'review' : 'reviews');
    bannerEl = document.createElement('div');
    bannerEl.className = 'pd-rvw-filter-banner';
    bannerEl.innerHTML =
      '<span class="pd-rvw-filter-banner-text">Showing ' + count + ' ' + rating + '★ ' + label + '</span>' +
      '<button type="button" class="pd-rvw-filter-clear">' +
        '<svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 L6 18 M6 6 L18 18"/></svg>' +
        'Clear filter' +
      '</button>';
    histEl.parentNode.insertBefore(bannerEl, histEl.nextSibling);
    bannerEl.querySelector('.pd-rvw-filter-clear').addEventListener('click', function(){ clearFilter(histEl); });
  }

  function showLoading(){ if (reviewsListEl) reviewsListEl.innerHTML = '<div class="pd-rvw-jdgm-loading">Loading reviews…</div>'; }
  function showEmpty(rating){ if (reviewsListEl) reviewsListEl.innerHTML = '<div class="pd-rvw-jdgm-empty">No ' + rating + '★ reviews to show.</div>'; }

  function reformatReviews(){
    if (!reviewsListEl) return;
    var MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    reviewsListEl.querySelectorAll('.jdgm-rev').forEach(function(rev){
      /* Author initial in avatar */
      var icon = rev.querySelector('.jdgm-rev__icon');
      if (icon && !icon.textContent.trim()){
        var nameEl = rev.querySelector('.jdgm-rev__author');
        var ini = (nameEl ? nameEl.textContent.trim().charAt(0).toUpperCase() : 'A');
        icon.textContent = ini;
      }
      /* Format timestamp */
      var ts = rev.querySelector('.jdgm-rev__timestamp[data-content]');
      if (ts){
        var raw = ts.getAttribute('data-content');
        if (raw){
          var d = new Date(raw.replace(' UTC', 'Z').replace(' ', 'T'));
          if (!isNaN(d.getTime())){
            ts.classList.remove('jdgm-spinner');
            ts.textContent = MONTHS[d.getMonth()] + ' ' + d.getDate() + ', ' + d.getFullYear();
          }
        }
      }
      /* Verified badge — inject branded pill into review header */
      if (!rev.querySelector('.pd-rvw-verified-badge')){
        var header = rev.querySelector('.jdgm-rev__header');
        if (header){
          var badge = document.createElement('span');
          badge.className = 'pd-rvw-verified-badge';
          badge.innerHTML = '<svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12 l4 4 L19 7"/></svg> Verified';
          header.appendChild(badge);
        }
      }
    });
  }

  async function fetchPage(page, perPage){
    var url = new URL('https://api.judge.me/reviews/reviews_for_widget');
    url.searchParams.set('url', SHOP);
    url.searchParams.set('shop_domain', SHOP);
    url.searchParams.set('platform', 'shopify');
    url.searchParams.set('page', String(page));
    url.searchParams.set('per_page', String(perPage));
    url.searchParams.set('product_id', String(productId));
    var r = await fetch(url.toString());
    var j = await r.json();
    return j.html || '';
  }

  function updatePaginateActive(page){
    if (!paginateEl) return;
    paginateEl.querySelectorAll('.jdgm-paginate__page').forEach(function(btn){ btn.classList.remove('jdgm-curt'); });
    var numericBtns = paginateEl.querySelectorAll('.jdgm-paginate__page:not(.jdgm-paginate__next-page):not(.jdgm-paginate__last-page):not(.jdgm-paginate__prev-page):not(.jdgm-paginate__first-page)');
    numericBtns.forEach(function(btn){
      if (parseInt(btn.getAttribute('data-page'), 10) === page){ btn.classList.add('jdgm-curt'); }
    });
    var nextBtn = paginateEl.querySelector('.jdgm-paginate__next-page');
    if (nextBtn){
      var np = Math.min(page + 1, lastPage);
      nextBtn.setAttribute('data-page', String(np));
      nextBtn.style.display = page >= lastPage ? 'none' : '';
    }
  }

  async function goToPage(page){
    if (!reviewsListEl || activeFilter) return;
    page = Math.max(1, Math.min(page, lastPage));
    showLoading();
    try {
      var html;
      if (paginateCache[page]){ html = paginateCache[page]; }
      else { html = await fetchPage(page, PAGINATE_PER_PAGE); paginateCache[page] = html; }
      var tmp = document.createElement('div');
      tmp.innerHTML = html;
      var inner = tmp.querySelector('.jdgm-rev-widg__reviews');
      reviewsListEl.innerHTML = inner ? inner.innerHTML : html;
      reformatReviews();
      updatePaginateActive(page);
      var hist = contentEl.querySelector('.jdgm-histogram');
      if (hist){ var top = hist.getBoundingClientRect().top + window.scrollY - 100; window.scrollTo({top: top, behavior: 'smooth'}); }
    } catch(e){ console.error('Pagination fetch failed', e); }
  }

  function wirePagination(){
    if (!paginateEl) return;
    var lastBtn = paginateEl.querySelector('.jdgm-paginate__last-page');
    if (lastBtn) lastPage = parseInt(lastBtn.getAttribute('data-page'), 10) || 1;
    else {
      var allNum = paginateEl.querySelectorAll('.jdgm-paginate__page:not(.jdgm-paginate__next-page):not(.jdgm-paginate__last-page):not(.jdgm-paginate__prev-page):not(.jdgm-paginate__first-page)');
      var maxP = 1;
      allNum.forEach(function(btn){ var p = parseInt(btn.getAttribute('data-page'), 10); if (p > maxP) maxP = p; });
      lastPage = maxP;
    }
    if (lastPage <= 1){ paginateEl.classList.add('is-hidden'); return; }
    if (reviewsListEl) paginateCache[1] = '<div class="jdgm-rev-widg__reviews">' + reviewsListEl.innerHTML + '</div>';
    paginateEl.querySelectorAll('a.jdgm-paginate__page[data-page]').forEach(function(btn){
      btn.addEventListener('click', function(e){ e.preventDefault(); var p = parseInt(btn.getAttribute('data-page'), 10); if (p) goToPage(p); });
    });
  }

  async function gatherFiltered(rating, expectedCount){
    var matching = [];
    for (var page = 1; page <= MAX_FILTER_PAGES; page++){
      var html = await fetchPage(page, FILTER_PER_PAGE);
      var tmp = document.createElement('div');
      tmp.innerHTML = html;
      var revs = Array.prototype.slice.call(tmp.querySelectorAll('.jdgm-rev'));
      if (revs.length === 0) break;
      revs.forEach(function(rev){
        var scoreEl = rev.querySelector('.jdgm-rev__rating');
        var score = scoreEl ? parseInt(scoreEl.getAttribute('data-score'), 10) : null;
        if (score === rating) matching.push(rev.outerHTML);
      });
      if (matching.length >= expectedCount) break;
      if (revs.length < FILTER_PER_PAGE) break;
    }
    return matching;
  }

  async function applyFilter(rating, expectedCount){
    if (!reviewsListEl) return;
    activeFilter = rating;
    if (paginateEl) paginateEl.classList.add('is-hidden');
    showLoading();
    try {
      var matching;
      if (ratingCache[rating]){ matching = ratingCache[rating]; }
      else { matching = await gatherFiltered(rating, expectedCount); ratingCache[rating] = matching; }
      if (matching && matching.length > 0){ reviewsListEl.innerHTML = matching.join(''); reformatReviews(); }
      else { showEmpty(rating); }
    } catch(e){ showEmpty(rating); }
  }

  function clearFilter(histEl){
    activeFilter = null;
    clearBanner();
    if (histEl) histEl.querySelectorAll('.jdgm-histogram__row.is-active').forEach(function(row){ row.classList.remove('is-active'); });
    if (reviewsListEl && originalHTML) reviewsListEl.innerHTML = originalHTML;
    if (paginateEl && lastPage > 1) paginateEl.classList.remove('is-hidden');
    if (paginateEl && lastPage > 1) updatePaginateActive(1);
    reformatReviews();
  }

  function wireFilters(histEl){
    histEl.querySelectorAll('.jdgm-histogram__row[data-rating]').forEach(function(row){
      var rating = parseInt(row.getAttribute('data-rating'), 10);
      if (!rating || rating < 1 || rating > 5) return;
      row.addEventListener('click', function(e){
        e.preventDefault();
        var freq = parseInt(row.getAttribute('data-frequency'), 10) || 0;
        if (activeFilter === rating){ clearFilter(histEl); return; }
        histEl.querySelectorAll('.jdgm-histogram__row.is-active').forEach(function(r){ r.classList.remove('is-active'); });
        row.classList.add('is-active');
        showBanner(rating, freq, histEl);
        if (freq === 0){ showEmpty(rating); if (paginateEl) paginateEl.classList.add('is-hidden'); return; }
        applyFilter(rating, freq);
      });
    });
  }

  function buildSortToolbar(){
    var body = contentEl.querySelector('.jdgm-rev-widg__body');
    if (!body || contentEl.querySelector('.pd-rvw-jdgm-toolbar')) return;
    var toolbar = document.createElement('div');
    toolbar.className = 'pd-rvw-jdgm-toolbar';
    toolbar.innerHTML =
      '<label class="pd-rvw-jdgm-sort">' +
        '<span class="pd-rvw-jdgm-sort-label">Sort</span>' +
        '<select aria-label="Sort reviews">' +
          '<option value="date|desc">Most Recent</option>' +
          '<option value="date|asc">Oldest First</option>' +
          '<option value="rating|desc">Highest Rated</option>' +
          '<option value="rating|asc">Lowest Rated</option>' +
        '</select>' +
        '<svg class="pd-rvw-jdgm-sort-chev" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9 l6 6 6 -6"/></svg>' +
      '</label>';
    body.parentNode.insertBefore(toolbar, body);
    toolbar.querySelector('select').addEventListener('change', function(e){ applySort(e.target.value); });
  }

  function applySort(value){
    if (!reviewsListEl) return;
    var revs = Array.prototype.slice.call(reviewsListEl.querySelectorAll('.jdgm-rev'));
    var parts = value.split('|');
    var field = parts[0], dir = parts[1];
    revs.sort(function(a, b){
      var av, bv;
      if (field === 'rating'){
        av = parseInt(a.querySelector('.jdgm-rev__rating')?.getAttribute('data-score') || '0', 10);
        bv = parseInt(b.querySelector('.jdgm-rev__rating')?.getAttribute('data-score') || '0', 10);
        if (av === bv){
          var ad = new Date((a.querySelector('.jdgm-rev__timestamp')?.getAttribute('data-content') || '').replace(' UTC','Z').replace(' ','T')).getTime() || 0;
          var bd = new Date((b.querySelector('.jdgm-rev__timestamp')?.getAttribute('data-content') || '').replace(' UTC','Z').replace(' ','T')).getTime() || 0;
          return bd - ad;
        }
      } else {
        av = new Date((a.querySelector('.jdgm-rev__timestamp')?.getAttribute('data-content') || '').replace(' UTC','Z').replace(' ','T')).getTime() || 0;
        bv = new Date((b.querySelector('.jdgm-rev__timestamp')?.getAttribute('data-content') || '').replace(' UTC','Z').replace(' ','T')).getTime() || 0;
      }
      return dir === 'desc' ? bv - av : av - bv;
    });
    revs.forEach(function(r){ reviewsListEl.appendChild(r); });
  }

  function init(){
    contentEl = document.querySelector('.pd-rvw-jdgm-content');
    if (!contentEl) return;
    var section = document.querySelector('.pd-reviews-v2');
    productId = section ? section.getAttribute('data-product-id') : null;
    if (productId && productId.indexOf('/') !== -1) productId = productId.split('/').pop();
    contentEl.querySelectorAll('.jdgm-temp-hiding-style').forEach(function(s){ s.remove(); });
    var title = contentEl.querySelector('.jdgm-rev-widg__title'); if (title) title.remove();
    var summary = contentEl.querySelector('.jdgm-rev-widg__summary'); if (summary) summary.remove();
    var sortWrap = contentEl.querySelector('.jdgm-rev-widg__sort-wrapper'); if (sortWrap) sortWrap.remove();
    var writeLink = contentEl.querySelector('.jdgm-write-rev-link'); if (writeLink) writeLink.remove();
    /* Remove leftover paginate spinner wrapper */
    contentEl.querySelectorAll('.jdgm-rev-widg__paginate-spinner-wrapper').forEach(function(s){ s.remove(); });
    contentEl.querySelectorAll('.jdgm-temp-hidden').forEach(function(el){ el.classList.remove('jdgm-temp-hidden'); });
    var widg = contentEl.querySelector('.jdgm-rev-widg'); if (widg) widg.style.display = 'block';
    reviewsListEl = contentEl.querySelector('.jdgm-rev-widg__reviews');
    paginateEl = contentEl.querySelector('.jdgm-paginate');
    if (reviewsListEl) originalHTML = reviewsListEl.innerHTML;
    reformatReviews();
    var histEl = contentEl.querySelector('.jdgm-histogram');
    if (histEl) wireFilters(histEl);
    wirePagination();
    buildSortToolbar();
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else setTimeout(init, 100);
})();
</script>
