{%- comment -%}
  Mobile side-drawer brand polish v5 — hide inactive subtab grids + breathing room between cards.
{%- endcomment -%}
<style id="pd-drawer-polish">
@media (max-width:980px){
  /* SCRIM */
  html body .syrnav-scrim{
    background:rgba(57,34,15,.55) !important;
    backdrop-filter:blur(2px) !important;
    -webkit-backdrop-filter:blur(2px) !important;
  }

  /* DRAWER SHELL */
  html body .syrnav-drawer{
    background:#FFFBF4 !important;
    border-right:2px solid #39220f !important;
    box-shadow:8px 0 0 rgba(57,34,15,.06), 12px 0 32px -8px rgba(57,34,15,.32) !important;
    width:86% !important; max-width:340px !important;
    font-family:'Josefin Sans','Josefin',sans-serif !important;
    color:#39220f !important;
    flex-direction:column !important;
    overflow-y:auto !important; overflow-x:hidden !important;
    -webkit-overflow-scrolling:touch !important;
    overscroll-behavior:contain !important;
    padding-bottom:env(safe-area-inset-bottom) !important;
    transition:transform .38s cubic-bezier(.32,1.15,.4,1) !important;
  }
  html body .syrnav-drawer *{ -webkit-tap-highlight-color:transparent !important; }

  /* HEAD — centered logo */
  html body .syrnav-drawer .syrnav-dwr-head{
    position:sticky !important; top:0 !important; z-index:2 !important;
    height:68px !important; padding:0 !important;
    border-bottom:1.5px solid #39220f !important;
    background:#FFFBF4 !important;
    display:flex !important; align-items:center !important; justify-content:center !important;
  }
  html body .syrnav-drawer .syrnav-dwr-head .syrnav-brand{ margin:0 auto !important; height:42px !important; padding:0 !important; flex:0 0 auto !important; display:inline-flex !important; align-items:center !important; }
  html body .syrnav-drawer .syrnav-dwr-head .syrnav-brand img.syrnav-brand-img{ height:32px !important; max-height:42px !important; width:auto !important; max-width:160px !important; display:block !important; }
  html body .syrnav-drawer .syrnav-dwr-x{
    position:absolute !important; right:14px !important; top:50% !important; transform:translateY(-50%) !important;
    width:40px !important; height:40px !important;
    border-radius:50% !important; border:1.5px solid #39220f !important;
    background:#FFFBF4 !important; color:#39220f !important;
    display:inline-flex !important; align-items:center !important; justify-content:center !important;
    box-shadow:1.5px 1.5px 0 #39220f !important;
    transition:background .15s ease, transform .15s ease, box-shadow .15s ease !important;
  }
  html body .syrnav-drawer .syrnav-dwr-x:hover,
  html body .syrnav-drawer .syrnav-dwr-x:active{
    background:#FCE2A0 !important; transform:translateY(-50%) scale(.95) !important; box-shadow:2px 2px 0 #39220f !important;
  }
  html body .syrnav-drawer .syrnav-dwr-x svg{ width:14px !important; height:14px !important; color:#39220f !important; }

  /* NAV LINKS */
  html body .syrnav-drawer .syrnav-dwr-links{
    display:flex !important; flex-direction:column !important;
    padding:6px 12px 8px !important; gap:0 !important; flex:0 0 auto !important;
  }
  html body .syrnav-drawer .syrnav-dwr-sec{
    border-bottom:1px solid rgba(57,34,15,.12) !important;
    padding:0 !important; margin:0 !important;
  }
  html body .syrnav-drawer .syrnav-dwr-sec:last-child{ border-bottom:0 !important; }
  html body .syrnav-drawer .syrnav-dwr-link{
    display:flex !important; align-items:center !important; gap:0 !important;
    width:100% !important; padding:16px 12px !important;
    background:transparent !important; border:0 !important; text-align:left !important;
    font-family:'Archivo Black','Archivo',sans-serif !important; font-weight:400 !important;
    font-size:17px !important; letter-spacing:-.005em !important;
    color:#39220f !important; text-decoration:none !important; text-transform:none !important;
    cursor:pointer !important; border-radius:14px !important;
    transition:background .15s ease, color .15s ease, transform .12s ease !important;
    min-height:54px !important;
  }
  html body .syrnav-drawer .syrnav-dwr-link:hover{ background:rgba(252,226,160,.4) !important; }
  html body .syrnav-drawer .syrnav-dwr-link:active{ transform:scale(.985) !important; }
  html body .syrnav-drawer .syrnav-dwr-link.on,
  html body .syrnav-drawer .syrnav-dwr-link.active{ color:#c58548 !important; background:#FCE2A0 !important; }
  html body .syrnav-drawer .syrnav-dwr-link .lbl{ flex:1 1 auto !important; min-width:0 !important; color:inherit !important; }
  html body .syrnav-drawer .syrnav-dwr-link .syrnav-dwr-dot,
  html body .syrnav-drawer .syrnav-dwr-dot{ display:none !important; }
  html body .syrnav-drawer .syrnav-dwr-link .syrnav-dwr-chev{
