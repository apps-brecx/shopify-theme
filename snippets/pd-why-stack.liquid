html body .pd .pd-why-grid .pd-why-card{position:sticky!important;width:100%!important;max-width:500px!important;aspect-ratio:auto!important;height:auto!important;min-height:0!important;margin:0 auto 24px!important;padding:22px 24px 20px!important;background:#FFFFFF!important;border:2px solid #39220f!important;border-radius:22px!important;box-shadow:5px 5px 0 #39220f!important;display:flex!important;flex-direction:column!important;align-items:center!important;text-align:center!important;gap:10px!important;transition:transform .25s ease!important;justify-content:flex-start!important}
