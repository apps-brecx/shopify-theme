html body .pd .pd-why-grid{overflow:visible!important}
html body .pd .pd-description{overflow:visible!important}
html body .pd .pd-description .pd-wrap{overflow:visible!important}
html body .pd .pd-desc-content{overflow:visible!important}

/* WHY SYRUVIA — sticky stack (compact, non-square) */
html body .pd .pd-why{padding:80px 0 180px!important;background:#FFFBF4!important;border-top:2px solid #39220f!important;position:relative!important}
@media (max-width:760px){html body .pd .pd-why{padding:56px 0 140px!important}}
html body .pd .pd-why .pd-why-wrap{max-width:640px!important;margin:0 auto!important;padding:0 18px!important;text-align:center!important;position:relative!important}
