html body .pd .pd-why-grid .pd-why-card .pd-why-title{font-family:'Archivo Black','Archivo',sans-serif!important;font-weight:400!important;font-size:18px!important;letter-spacing:.005em!important;text-transform:uppercase!important;color:#39220f!important;margin:0!important;line-height:1.15!important}
html body .pd .pd-why-grid .pd-why-card .pd-why-body{font-family:'Josefin Sans',sans-serif!important;font-size:13.5px!important;line-height:1.5!important;color:#39220f!important;font-weight:500!important;margin:0!important;max-width:38ch!important}
