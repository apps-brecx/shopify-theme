html body .pd .pd-desc-content .pd-desc-card{position:sticky!important;width:100%!important;max-width:720px!important;margin:0 auto 32px!important;background:#FFF8EE!important;border:2px solid #39220f!important;border-radius:22px!important;box-shadow:6px 6px 0 #39220f!important;transition:transform .25s ease, box-shadow .25s ease, height .25s ease!important}
