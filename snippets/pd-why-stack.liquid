html body .pd .pd-why.pd-reveal:not(.is-revealed){opacity:1!important;transform:none!important}

/* ABOUT THIS SYRUP — sticky stack (unchanged) */
html body .pd .pd-description{padding:96px 0 200px!important;background:#FFFFFF!important;overflow:visible!important}
@media (max-width:760px){html body .pd .pd-description{padding:64px 0 160px!important}}
