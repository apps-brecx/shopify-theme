{%- comment -%} Standards — stamps only (ingredients moved back to its own area) {%- endcomment -%}
<section class="pd-standards-x">
  <div class="pd-wrap">

    <div class="pd-stx-head">
      <span class="pd-eyebrow">Made with standards</span>
      <h2 class="pd-h2">The fine print, <em>front &amp; center</em>.</h2>
      <p class="pd-stx-lede">No mystery flavoring. No filler. No high-fructose corn syrup. Just the marks that matter — and nothing that doesn't belong in your cup.</p>
    </div>

    <div class="pd-stx-stamps">
      <div class="pd-stx-stamp pd-stx-stamp--butter">
        <div class="pd-stx-stamp-ring">
          <svg viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 L14 9 L21 11 L14 13 L12 20 L10 13 L3 11 L10 9 Z"/></svg>
        </div>
        <div class="pd-stx-stamp-cap"><strong>Pure Cane</strong>Sugar</div>
      </div>
      <div class="pd-stx-stamp pd-stx-stamp--mint">
        <div class="pd-stx-stamp-ring">
          <svg viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M8 12 L11 15 L16 9"/></svg>
        </div>
        <div class="pd-stx-stamp-cap"><strong>Kosher</strong>Certified</div>
      </div>
      <div class="pd-stx-stamp pd-stx-stamp--sky">
        <div class="pd-stx-stamp-ring">
          <svg viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 22 V 4 l 6 2 l 6 -2 l 4 2 v 14 l -4 -2 l -6 2 l -6 -2 Z"/></svg>
        </div>
        <div class="pd-stx-stamp-cap"><strong>Made</strong>In USA</div>
      </div>
      <div class="pd-stx-stamp pd-stx-stamp--blush">
        <div class="pd-stx-stamp-ring"><span class="pd-stx-stamp-num">50+</span></div>
        <div class="pd-stx-stamp-cap"><strong>Servings</strong>Per Bottle</div>
      </div>
    </div>

  </div>
</section>
