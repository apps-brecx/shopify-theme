{%- comment -%} Forces the Syruvia logo to be truly centered on mobile regardless of left/right icon widths. {%- endcomment -%}
<style id="pd-logo-center-css">
@media (max-width:980px){
  /* The header bar needs to be positioned so the absolutely-centered logo has it as its containing block */
  html body #syrnav .syrnav-bar{ position:relative !important; }
  /* Brand becomes absolute-centered on mobile — true geometric center regardless of side icon widths */
  html body #syrnav .syrnav-bar > .syrnav-brand{
    position:absolute !important;
    left:50% !important;
    top:50% !important;
    transform:translate(-50%, -50%) !important;
    margin:0 !important;
    z-index:1 !important;
    pointer-events:auto !important;
    justify-self:auto !important;
  }
  html body #syrnav .syrnav-bar > .syrnav-brand img.syrnav-brand-img{
    height:32px !important; width:auto !important; max-width:140px !important; display:block !important;
  }
  /* Drawer logo stays where it is (in flow, not absolute) */
  html body #syrnav .syrnav-dwr-head > .syrnav-brand{
    position:static !important; transform:none !important; left:auto !important; top:auto !important;
  }
}
</style>
